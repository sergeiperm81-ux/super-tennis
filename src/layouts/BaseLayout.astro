---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  jsonLd?: Record<string, any>;
  publishedTime?: string;
}

const {
  title,
  description = 'Tennis for everyone. Players, records, gear, lifestyle — the world of tennis beyond the court.',
  ogImage = '/og/default.png',
  jsonLd,
  publishedTime,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
// Avoid duplicate SUPER.TENNIS in title tag
const cleanTitle = title.replace(/\s*[—|]\s*SUPER\.TENNIS\s*/gi, '').trim();
const fullTitle = cleanTitle === 'Home' ? 'SUPER.TENNIS — Tennis for Everyone' : `${cleanTitle} | SUPER.TENNIS`;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <!-- Google Analytics -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-Z6JY7X381V"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-Z6JY7X381V');
  </script>

  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />
  <link rel="alternate" hreflang="en" href={canonicalURL} />
  <link rel="alternate" hreflang="x-default" href={canonicalURL} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="alternate" type="application/rss+xml" title="Super Tennis News" href="/rss.xml" />

  <!-- Impact.com (Ticketmaster) verification -->
  <meta name="impact-site-verification" value="b478032f-5051-418d-83ab-9475918a70a8" />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={new URL(ogImage, Astro.site)} />
  <meta property="og:site_name" content="SUPER.TENNIS" />
  <meta property="og:locale" content="en_US" />
  {publishedTime && <meta property="article:published_time" content={publishedTime} />}

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={new URL(ogImage, Astro.site)} />

  <!-- Preconnect to external domains -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="preconnect" href="https://upload.wikimedia.org" />
  <link rel="preconnect" href="https://flagcdn.com" />
  <link rel="dns-prefetch" href="https://upload.wikimedia.org" />
  <link rel="dns-prefetch" href="https://flagcdn.com" />
  <link rel="preconnect" href="https://i.ytimg.com" />
  <link rel="dns-prefetch" href="https://www.youtube-nocookie.com" />

  <!-- Preload critical CSS for faster first paint -->
  <link rel="preload" href="/css/dynamic-content.css?v=2" as="style" />

  <!-- Fonts (display=swap for better LCP) -->
  <link rel="preload" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Oswald:wght@500;600;700&display=swap" as="style" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Oswald:wght@500;600;700&display=swap" rel="stylesheet" />

  <!-- Dynamic content styles (client-side rendered news/videos) -->
  <link rel="stylesheet" href="/css/dynamic-content.css?v=2" />
  <!-- Magazine article layout styles -->
  <link rel="stylesheet" href="/css/magazine.css?v=1" />

  {jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}

  <!-- Microsoft Clarity -->
  <script is:inline>
    (function(c,l,a,r,i,t,y){c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y)})(window,document,"clarity","script","w1th9vjy1k");
  </script>

  <!-- Skimlinks affiliate monetization -->
  <script type="text/javascript" src="https://s.skimresources.com/js/300805X1788676.skimlinks.js" is:inline></script>

  <!-- Cloudflare Web Analytics -->
  <script defer src="https://static.cloudflareinsights.com/beacon.min.js" data-cf-beacon='{"token": "58c55eb389e74cd9a957df82216424eb"}' is:inline></script>
</head>
<body>
  <Header />
  <main style={`padding-top: var(--header-height);`}>
    <slot />
  </main>
  <Footer />

  <!-- Back to top button -->
  <button class="back-to-top" id="back-to-top" aria-label="Back to top" title="Back to top">
    <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
      <path d="M10 4L4 10h4v6h4v-6h4L10 4z" fill="currentColor"/>
    </svg>
  </button>

  <!-- Flag image fallback: show country code text if flagcdn is down -->
  <script is:inline>
    document.addEventListener('error', function(e) {
      var t = e.target;
      if (t && t.tagName === 'IMG' && t.src && t.src.includes('flagcdn.com')) {
        var code = t.alt || '';
        var span = document.createElement('span');
        span.textContent = code;
        span.style.cssText = 'font-size:0.7rem;color:#6b7280;font-weight:600;';
        t.replaceWith(span);
      }
    }, true);
  </script>

  <!-- Back to top button logic -->
  <script is:inline>
    (function() {
      var btn = document.getElementById('back-to-top');
      if (!btn) return;
      window.addEventListener('scroll', function() {
        btn.classList.toggle('visible', window.scrollY > 600);
      }, { passive: true });
      btn.addEventListener('click', function() {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });
    })();
  </script>

  <!-- Open external links in new tab (affiliate, shops, etc.) -->
  <script is:inline>
    document.addEventListener('click', function(e) {
      var a = e.target.closest('a');
      if (!a || !a.href) return;
      try {
        var url = new URL(a.href);
        if (url.hostname !== location.hostname && !a.hasAttribute('target')) {
          a.setAttribute('target', '_blank');
          a.setAttribute('rel', 'noopener noreferrer');
        }
      } catch(ex) {}
    });
  </script>
</body>
</html>
