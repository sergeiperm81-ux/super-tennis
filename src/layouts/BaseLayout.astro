---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
import { ogLocale, hreflang, type Locale, type Alternate } from '../lib/i18n';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  jsonLd?: Record<string, any>;
  publishedTime?: string;
  dynamicContent?: boolean;
  ogType?: string;
  /** i18n (Phase 1): default 'en' reproduces the current English output 1:1. */
  locale?: Locale;
  /** hreflang alternates; empty → static en + x-default (current behaviour). */
  alternates?: Alternate[];
}

const {
  title,
  description = 'Tennis for everyone. Players, records, gear, lifestyle — the world of tennis beyond the court.',
  ogImage = '/og/default.png',
  jsonLd,
  publishedTime,
  dynamicContent = false,
  ogType = 'website',
  locale = 'en',
  alternates = [],
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
// locale='en' → htmlLang='en', ogLocaleValue='en_US' (identical to previous hardcoded values).
const htmlLang = hreflang(locale);
const ogLocaleValue = ogLocale(locale);

// Visible EN/ES language switcher — shown only on pages that have a translation
// (alternates has more than just self + x-default). Renders nothing otherwise.
const LANG_LABELS: Record<string, string> = { en: 'English', es: 'Español', fr: 'Français', zh: '中文' };
const switcherLangs = alternates
  .filter((a) => a.hreflang !== 'x-default')
  .map((a) => ({ code: a.hreflang === 'zh-Hans' ? 'zh' : a.hreflang, href: a.href }));
// Avoid duplicate SUPER.TENNIS in title tag
const cleanTitle = title.replace(/\s*[—|]\s*SUPER\.TENNIS\s*/gi, '').trim();
const fullTitle = cleanTitle === 'Home' ? 'SUPER.TENNIS — Tennis for Everyone' : `${cleanTitle} | SUPER.TENNIS`;

// Organization schema — on every page for AI entity recognition
const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  '@id': 'https://super.tennis/#organization',
  name: 'SUPER.TENNIS',
  url: 'https://super.tennis',
  logo: {
    '@type': 'ImageObject',
    url: 'https://super.tennis/og/default.png',
    width: 1200,
    height: 630,
  },
  sameAs: [
    'https://www.youtube.com/@SuperTennisNews',
    'https://bsky.app/profile/supertennisnews.bsky.social',
  ],
  description: 'Tennis for everyone. Players, records, gear, lifestyle — the world of tennis beyond the court.',
};

// WebSite schema with SearchAction
const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  '@id': 'https://super.tennis/#website',
  url: 'https://super.tennis',
  name: 'SUPER.TENNIS',
  description: 'Tennis for everyone. Players, records, gear, lifestyle — the world of tennis beyond the court.',
  publisher: { '@id': 'https://super.tennis/#organization' },
  potentialAction: {
    '@type': 'SearchAction',
    target: {
      '@type': 'EntryPoint',
      urlTemplate: 'https://super.tennis/search/?q={search_term_string}',
    },
    'query-input': 'required name=search_term_string',
  },
};
---

<!DOCTYPE html>
<html lang={htmlLang}>
<head>
  <!-- Google Analytics (async — non-blocking) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-Z6JY7X381V"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-Z6JY7X381V');
  </script>

  <!--
    Monetization click tracking (2026-06-12). Fires a GA4 event when a reader
    clicks an affiliate or gear-guide link so we can finally see WHICH block
    converts (player racket / shoes / Tennis Fitness / gear fallback) — until
    now a blind spot. Event delegation: one passive listener, zero extra
    requests, never calls preventDefault so navigation is untouched. block=
    comes from data-aff on the CTA; dest= from the URL.
  -->
  <script>
    document.addEventListener('click', function (e) {
      var t = e.target;
      var a = t && t.closest ? t.closest('a') : null;
      if (!a || typeof gtag !== 'function') return;
      var href = a.getAttribute('href') || '';
      var rel = a.getAttribute('rel') || '';
      var block = (a.dataset && a.dataset.aff) || '';
      var isAff = /\bsponsored\b/.test(rel) || /amazon\.|memberstennisfitness/i.test(href);
      var isGear = !!block || /^\/gear\//.test(href);
      if (!isAff && !isGear) return;
      var dest = /amazon\./i.test(href) ? 'amazon'
        : /memberstennisfitness/i.test(href) ? 'tennis_fitness'
        : /^\/gear\//.test(href) ? 'gear_guide' : 'other';
      gtag('event', isAff ? 'affiliate_click' : 'gear_click', {
        destination: dest,
        block: block || 'inline',
        link_url: href,
        page_path: location.pathname,
      });
    }, { passive: true });
  </script>

  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />
  {alternates.length > 0
    ? alternates.map((a) => (
        <link rel="alternate" hreflang={a.hreflang} href={new URL(a.href, Astro.site)} />
      ))
    : (
      <Fragment>
        <link rel="alternate" hreflang="en" href={canonicalURL} />
        <link rel="alternate" hreflang="x-default" href={canonicalURL} />
      </Fragment>
    )}
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="alternate" type="application/rss+xml" title="Super Tennis News" href="/rss.xml" />

  <!-- Impact.com (Ticketmaster) verification -->
  <meta name="impact-site-verification" value="b478032f-5051-418d-83ab-9475918a70a8" />

  <!-- Open Graph -->
  <meta property="og:type" content={ogType} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={new URL(ogImage, Astro.site)} />
  <meta property="og:site_name" content="SUPER.TENNIS" />
  <meta property="og:locale" content={ogLocaleValue} />
  {publishedTime && <meta property="article:published_time" content={publishedTime} />}

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={new URL(ogImage, Astro.site)} />

  <!-- Preconnect to external domains -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="preconnect" href="https://upload.wikimedia.org" />
  <link rel="preconnect" href="https://flagcdn.com" />
  <link rel="dns-prefetch" href="https://upload.wikimedia.org" />
  <link rel="dns-prefetch" href="https://flagcdn.com" />
  <link rel="preconnect" href="https://i.ytimg.com" />
  <link rel="dns-prefetch" href="https://www.youtube-nocookie.com" />

  <!-- Preload dynamic content CSS only on pages that need it -->
  {dynamicContent && <link rel="preload" href="/css/dynamic-content.css?v=2" as="style" />}

  <!-- Fonts: async load to avoid render-blocking (display=swap keeps text visible) -->
  <link rel="preload" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Oswald:wght@500;600;700&display=swap&subset=latin" as="style" onload="this.onload=null;this.rel='stylesheet'" />
  <noscript><link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Oswald:wght@500;600;700&display=swap&subset=latin" rel="stylesheet" /></noscript>

  <!-- Dynamic content styles (client-side rendered news/videos) -->
  {dynamicContent && <link rel="stylesheet" href="/css/dynamic-content.css?v=2" />}
  <!-- Magazine article layout styles -->
  <link rel="stylesheet" href="/css/magazine.css?v=1" />

  <!-- Organization + WebSite schema on every page (AI entity recognition) -->
  <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />

  {jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}

  <!-- Microsoft Clarity -->
  <script is:inline>
    (function(c,l,a,r,i,t,y){c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y)})(window,document,"clarity","script","w1th9vjy1k");
  </script>

  <!-- Cloudflare Web Analytics -->
  <script defer src="https://static.cloudflareinsights.com/beacon.min.js" data-cf-beacon='{"token": "58c55eb389e74cd9a957df82216424eb"}' is:inline></script>
</head>
<body>
  <Header />
  <main style={`padding-top: var(--header-height);`}>
    {switcherLangs.length > 1 && (
      <div data-pagefind-ignore style="max-width:800px;margin:0 auto;padding:14px 24px 0;display:flex;justify-content:flex-end;align-items:center;gap:8px;font-size:0.9rem;">
        <span aria-hidden="true" style="opacity:0.55;">🌐</span>
        {switcherLangs.map((l) => (
          l.code === locale
            ? <span style="color:#2d8c3c;font-weight:700;padding:5px 14px;border:1px solid #2d8c3c;border-radius:16px;background:rgba(45,140,60,0.08);">{LANG_LABELS[l.code] ?? l.code}</span>
            : <a href={l.href} hreflang={l.code} style="color:#4b5563;text-decoration:none;padding:5px 14px;border:1px solid #d1d5db;border-radius:16px;">{LANG_LABELS[l.code] ?? l.code}</a>
        ))}
      </div>
    )}
    <slot />
  </main>
  <Footer />

  <!-- Back to top button -->
  <button class="back-to-top" id="back-to-top" aria-label="Back to top" title="Back to top">
    <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
      <path d="M10 4L4 10h4v6h4v-6h4L10 4z" fill="currentColor"/>
    </svg>
  </button>

  <!-- Flag image fallback: show country code text if flagcdn is down -->
  <script is:inline>
    document.addEventListener('error', function(e) {
      var t = e.target;
      if (t && t.tagName === 'IMG' && t.src && t.src.includes('flagcdn.com')) {
        var code = t.alt || '';
        var span = document.createElement('span');
        span.textContent = code;
        span.style.cssText = 'font-size:0.7rem;color:#6b7280;font-weight:600;';
        t.replaceWith(span);
      }
    }, true);
  </script>

  <!-- Back to top button logic -->
  <script is:inline>
    (function() {
      var btn = document.getElementById('back-to-top');
      if (!btn) return;
      window.addEventListener('scroll', function() {
        btn.classList.toggle('visible', window.scrollY > 600);
      }, { passive: true });
      btn.addEventListener('click', function() {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });
    })();
  </script>

  <!-- External links: new tab + rel="sponsored" for affiliate domains -->
  <script is:inline>
    (function() {
      var affiliateDomains = ['amazon.com','tennis-warehouse.com','tennis-point.com','memberstennisfitness.com','tennisfitness.com','ebay.com','tennistopia.com','doittennis.com','holabirdsports.com','wilson.com','tennisexpress.com'];
      document.querySelectorAll('a[href]').forEach(function(a) {
        try {
          var url = new URL(a.href);
          if (url.hostname === location.hostname) return;
          a.setAttribute('target', '_blank');
          var isAffiliate = affiliateDomains.some(function(d) { return url.hostname.includes(d); });
          a.setAttribute('rel', isAffiliate ? 'sponsored noopener noreferrer' : 'noopener noreferrer');
        } catch(ex) {}
      });
    })();
  </script>

  <!-- Skimlinks affiliate monetization (async — after page render) -->
  <script async src="https://s.skimresources.com/js/300805X1788676.skimlinks.js"></script>

  <!-- Google AdSense (deferred — after page render) -->
  <script async defer src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-8691721344110584" crossorigin="anonymous"></script>
</body>
</html>
