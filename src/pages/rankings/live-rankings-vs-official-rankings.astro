        </a>
        <a href="/rankings/" class="context-card">
          <span class="context-label">Live Data</span>
          <span class="context-title">Current ATP & WTA Rankings</span>
        </a>
      </div>
    </section>

    <FaqBlock faqs={faqs} title="Live vs Official Rankings — FAQ" />
  </article>
</BaseLayout>

