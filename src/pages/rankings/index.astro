---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LiteYouTube from '../../components/LiteYouTube.astro';
import { getLatestRankings, getArticles } from '../../lib/supabase';
import { countryFlags, countryNames, getFlagUrl } from '../../lib/fallback-data';

// Fetch real data from Supabase
let atpRankings = await getLatestRankings('atp', 200);
let wtaRankings = await getLatestRankings('wta', 200);

// Determine latest ranking date
const rankingDate = atpRankings[0]?.ranking_date
  ? new Date(atpRankings[0].ranking_date).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })
  : 'Latest';
const rankingsJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'ATP Tennis Rankings',
  description: 'Current ATP and WTA tennis rankings',
  numberOfItems: atpRankings.length,
  itemListElement: atpRankings.slice(0, 10).map((r: any, i: number) => ({
    '@type': 'ListItem',
    position: r.ranking,
    name: `${r.players?.first_name} ${r.players?.last_name}`,
    url: `https://super.tennis/players/${r.players?.slug}/`,
  })),
};

// FAQ data for rankings page
const atpNo1 = atpRankings[0]?.players ? `${atpRankings[0].players.first_name} ${atpRankings[0].players.last_name}` : 'the current leader';
const wtaNo1 = wtaRankings[0]?.players ? `${wtaRankings[0].players.first_name} ${wtaRankings[0].players.last_name}` : 'the current leader';

const rankingsFaqItems = [
  {
    q: 'How are ATP rankings calculated?',
    a: 'ATP rankings are based on a points system that counts a player\'s best 19 tournament results over a rolling 52-week period. Points are awarded based on how far a player advances in each tournament, with Grand Slams and Masters 1000 events offering the most points.',
  },
  {
    q: 'How are WTA rankings calculated?',
    a: 'WTA rankings use a points system based on a player\'s best 16 tournament results over a rolling 52-week period. Grand Slams and WTA 1000 events carry the highest point values, rewarding deep runs in prestigious tournaments.',
  },
  {
    q: 'How often are tennis rankings updated?',
    a: 'Both ATP and WTA rankings are updated every Monday following the conclusion of each tournament week. Points from tournaments played exactly 52 weeks ago drop off, while new points from the most recent week are added.',
  },
  {
    q: `Who is the current world No. 1 in men's tennis?`,
    a: `As of ${rankingDate}, ${atpNo1} holds the ATP world No. 1 ranking. The No. 1 ranking is determined by accumulating the most ranking points over a 52-week period.`,
  },
  {
    q: `Who is the current world No. 1 in women's tennis?`,
    a: `As of ${rankingDate}, ${wtaNo1} holds the WTA world No. 1 ranking. The No. 1 ranking is based on the highest total of ranking points accumulated over the past 52 weeks.`,
  },
];

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: rankingsFaqItems.map(item => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.a,
    },
  })),
};

// ========== SIDEBAR DATA ==========

// News and videos are loaded client-side via dynamic-content.js

// 3. Explore articles (5 random from lifestyle + gear)
let sidebarArticles: any[] = [];
try {
  const [gearArts, lifeArts] = await Promise.all([
    getArticles({ category: 'gear', limit: 10 }),
    getArticles({ category: 'lifestyle', limit: 10 }),
  ]);
  const all = [...gearArts, ...lifeArts].filter(a => a.title);
  // Shuffle
  for (let i = all.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [all[i], all[j]] = [all[j], all[i]];
  }
  sidebarArticles = all.slice(0, 5);
} catch {}

// Article URL helper
const categoryUrl: Record<string, string> = {
  gear: '/gear/', lifestyle: '/lifestyle/',
};
function articleUrl(art: { category: string; slug: string }): string {
  return `${categoryUrl[art.category] || '/'}${art.slug}/`;
}
const sbCatColors: Record<string, string> = {
  gear: '#2196F3', lifestyle: '#E91E63',
};
const sbCatLabels: Record<string, string> = {
  gear: 'Gear', lifestyle: 'Lifestyle',
};
---

<BaseLayout
  title="ATP & WTA Rankings — Live Tennis Rankings"
  description="Current ATP and WTA tennis rankings. Updated weekly with points, country, and links to player profiles."
  ogImage="/og/rankings.png"
  jsonLd={rankingsJsonLd}
>
  <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />
  <div class="rankings-page">
    <div class="container">
      <nav class="breadcrumbs"><a href="/">Home</a> <span class="sep">/</span> <span class="current">Rankings</span></nav>
      <section class="page-hero">
        <h1>Tennis Rankings</h1>
        <p class="subtitle">Official ATP & WTA rankings as of {rankingDate}</p>
      </section>

      <!-- TWO-COLUMN LAYOUT -->
      <div class="rankings-layout">

        <!-- ========== MAIN COLUMN ========== -->
        <main class="rankings-main">

          <!-- Tour Tabs -->
          <div class="tour-tabs" id="tour-tabs">
            <button class="tab active" data-tour="atp" onclick="switchTour('atp')">
              ATP <span class="tab-badge atp">Men's</span>
            </button>
            <button class="tab" data-tour="wta" onclick="switchTour('wta')">
              WTA <span class="tab-badge wta">Women's</span>
            </button>
          </div>

          <!-- ATP Rankings Table -->
          <div class="rankings-table-wrap" id="atp-table">
            {atpRankings.length > 0 ? (
              <table class="rankings-table">
                <thead>
                  <tr>
                    <th class="col-rank">#</th>
                    <th class="col-player">Player</th>
                    <th class="col-country">Country</th>
                    <th class="col-points">Points</th>
                  </tr>
                </thead>
                <tbody>
                  {atpRankings.map((r: any) => {
                    const p = r.players;
                    const slug = p?.slug || '';
                    const cc = p?.country_code || '';
                    const flagSrc = getFlagUrl(cc, 20);
                    return (
                      <tr class={r.ranking <= 10 ? 'top-ten' : ''} data-rank={r.ranking} data-hidden={r.ranking > 50 ? 'true' : undefined}>
                        <td class="col-rank">
                          <span class="rank-num">{r.ranking}</span>
                        </td>
                        <td class="col-player">
                          <a href={`/players/${slug}/`} class="player-link">
                            {flagSrc ? (<img src={flagSrc} alt={cc} class="player-flag-img" width="20" height="15" loading="lazy" decoding="async" />) : (<span class="player-flag">{countryFlags[cc] || ''}</span>)}
                            <span class="player-name">
                              {p?.first_name} <strong>{p?.last_name?.toUpperCase()}</strong>
                            </span>
                          </a>
                        </td>
                        <td class="col-country">{cc}</td>
                        <td class="col-points">
                          <strong>{r.points?.toLocaleString()}</strong>
                        </td>
                      </tr>
                    );
                  })}
                </tbody>
              </table>
              {atpRankings.length > 50 && (
                <button class="show-more-btn" id="atp-show-more" data-tour="atp">Show More Rankings</button>
              )}
            ) : (
              <div class="empty-state">
                <p>Rankings data is loading. Please check back shortly.</p>
              </div>
            )}
          </div>

          <!-- WTA Rankings Table -->
          <div class="rankings-table-wrap" id="wta-table" style="display: none;">
            {wtaRankings.length > 0 ? (
              <table class="rankings-table">
                <thead>
                  <tr>
                    <th class="col-rank">#</th>
                    <th class="col-player">Player</th>
                    <th class="col-country">Country</th>
                    <th class="col-points">Points</th>
                  </tr>
                </thead>
                <tbody>
                  {wtaRankings.map((r: any) => {
                    const p = r.players;
                    const slug = p?.slug || '';
                    const cc = p?.country_code || '';
                    const flagSrc = getFlagUrl(cc, 20);
                    return (
                      <tr class={r.ranking <= 10 ? 'top-ten' : ''} data-rank={r.ranking} data-hidden={r.ranking > 50 ? 'true' : undefined}>
                        <td class="col-rank">
                          <span class="rank-num">{r.ranking}</span>
                        </td>
                        <td class="col-player">
                          <a href={`/players/${slug}/`} class="player-link">
                            {flagSrc ? (<img src={flagSrc} alt={cc} class="player-flag-img" width="20" height="15" loading="lazy" decoding="async" />) : (<span class="player-flag">{countryFlags[cc] || ''}</span>)}
                            <span class="player-name">
                              {p?.first_name} <strong>{p?.last_name?.toUpperCase()}</strong>
                            </span>
                          </a>
                        </td>
                        <td class="col-country">{cc}</td>
                        <td class="col-points">
                          <strong>{r.points?.toLocaleString()}</strong>
                        </td>
                      </tr>
                    );
                  })}
                </tbody>
              </table>
              {wtaRankings.length > 50 && (
                <button class="show-more-btn" id="wta-show-more" data-tour="wta">Show More Rankings</button>
              )}
            ) : (
              <div class="empty-state">
                <p>Rankings data is loading. Please check back shortly.</p>
              </div>
            )}
          </div>

        </main>

        <!-- ========== SIDEBAR ========== -->
        <aside class="sb">

          <!-- NEWS — loaded client-side -->
          <div class="sb-block" data-dynamic="sidebar-news" data-limit="3"></div>

          <!-- VIDEO — loaded client-side -->
          <div class="sb-block" data-dynamic="sidebar-videos" data-slots="0"></div>

          <!-- EXPLORE — 5 articles from lifestyle + gear -->
          {sidebarArticles.length > 0 && (
            <div class="sb-articles">
              <div class="sb-articles__header">
                <span class="sb-articles__label">Explore</span>
              </div>
              <div class="sb-articles__list">
                {sidebarArticles.map((art: any) => (
                  <a href={articleUrl(art)} class="sb-articles__item">
                    <span class="sb-articles__cat" style={`background: ${sbCatColors[art.category] || '#666'}`}>
                      {sbCatLabels[art.category] || art.category}
                    </span>
                    <span class="sb-articles__link">{art.title}</span>
                  </a>
                ))}
              </div>
            </div>
          )}

        </aside>

      </div>

      <!-- FAQ Section -->
      <section class="faq-section">
        <h2>Frequently Asked Questions</h2>
        <div class="faq-list">
          {rankingsFaqItems.map(item => (
            <details class="faq-item">
              <summary class="faq-question">{item.q}</summary>
              <p class="faq-answer">{item.a}</p>
            </details>
          ))}
        </div>
      </section>

    </div>
  </div>

  <script is:inline>
    function switchTour(tour) {
      document.getElementById('atp-table').style.display = tour === 'atp' ? '' : 'none';
      document.getElementById('wta-table').style.display = tour === 'wta' ? '' : 'none';
      document.querySelectorAll('.tour-tabs .tab').forEach(btn => {
        btn.classList.toggle('active', btn.dataset.tour === tour);
      });
    }

    // Show More Rankings — reveals next 50 rows
    var showState = { atp: 50, wta: 50 };
    document.querySelectorAll('.show-more-btn').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var tour = btn.dataset.tour;
        var table = document.getElementById(tour + '-table');
        var current = showState[tour];
        var next = current + 50;
        var rows = table.querySelectorAll('tr[data-rank]');
        rows.forEach(function(row) {
          var rank = parseInt(row.dataset.rank);
          if (rank <= next) {
            row.removeAttribute('data-hidden');
          }
        });
        showState[tour] = next;
        var totalRows = rows.length;
        if (next >= totalRows) {
          btn.style.display = 'none';
        } else {
          btn.textContent = 'Show More Rankings (' + next + ' of ' + totalRows + ')';
        }
      });
    });
  </script>
</BaseLayout>

<style>
  .rankings-page {
    padding: 0 24px 60px;
  }

  .page-hero {
    padding: 48px 0 32px;
    border-bottom: 3px solid var(--court-green);
    margin-bottom: 32px;
  }
  .page-hero h1 {
    font-family: var(--font-heading);
    font-size: 2.8rem;
    text-transform: uppercase;
    color: var(--gray-900);
    margin: 0;
  }
  .subtitle {
    color: var(--gray-600);
    font-size: 1.05rem;
    margin: 8px 0 0;
  }

  /* ===== TWO-COLUMN LAYOUT ===== */
  .rankings-layout {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 32px;
    align-items: start;
    max-width: 1200px;
    margin: 0 auto;
  }

  .rankings-main {
    min-width: 0;
  }

  /* Tour Tabs */
  .tour-tabs {
    display: flex;
    gap: 8px;
    margin-bottom: 24px;
  }
  .tab {
    padding: 10px 24px;
    font-family: var(--font-heading);
    font-size: 1rem;
    text-transform: uppercase;
    background: var(--gray-100);
    border: 2px solid var(--gray-200);
    border-radius: 8px;
    color: var(--gray-600);
    cursor: pointer;
    transition: all 0.2s;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .tab:hover {
    border-color: var(--gray-400);
    color: var(--gray-800);
  }
  .tab.active {
    background: var(--gray-900);
    border-color: var(--gray-900);
    color: white;
  }
  .tab-badge {
    font-size: 0.65rem;
    padding: 2px 8px;
    border-radius: 4px;
    font-family: var(--font-body);
    letter-spacing: 0.04em;
  }
  .tab-badge.atp { background: #003580; color: white; }
  .tab-badge.wta { background: #7b2d8e; color: white; }

  /* Rankings Table */
  .rankings-table-wrap {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    border: 1px solid var(--gray-200);
    border-radius: var(--radius);
  }
  .rankings-table {
    display: table;
    overflow: visible;
    border: none;
    border-radius: 0;
  }
  .rankings-table thead th {
    background: var(--gray-100);
    padding: 12px 16px;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--gray-500);
    font-family: var(--font-body);
    font-weight: 600;
    text-align: left;
    border-bottom: 2px solid var(--gray-200);
  }
  .rankings-table tbody tr {
    border-bottom: 1px solid var(--gray-100);
    transition: background 0.15s;
  }
  .rankings-table tbody tr:hover {
    background: var(--gray-50);
  }
  .rankings-table tbody tr.top-ten {
    background: #fffbeb;
  }
  .rankings-table tbody tr.top-ten:hover {
    background: #fff3c4;
  }

  .rankings-table td {
    padding: 10px 16px;
    font-size: 0.9rem;
  }

  .col-rank { width: 60px; text-align: center; }
  .col-country { width: 80px; text-align: center; }
  .col-points { width: 120px; text-align: right; }

  .rank-num {
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 700;
    color: var(--gray-500);
  }
  .top-ten .rank-num { color: var(--court-green); }

  .player-link {
    display: flex;
    align-items: center;
    gap: 10px;
    color: inherit;
    transition: color 0.2s;
  }
  .player-link:hover { color: var(--court-green); }

  .player-flag { font-size: 1.2rem; }
  .player-flag-img { border-radius: 1px; vertical-align: middle; }
  .player-name {
    font-size: 0.9rem;
  }
  .player-name strong {
    font-family: var(--font-heading);
    font-size: 0.85rem;
  }

  .col-points strong {
    font-family: var(--font-heading);
    font-size: 1rem;
    color: var(--gray-900);
  }
  .top-ten .col-points strong {
    color: var(--court-green);
  }

  .col-country {
    font-size: 0.8rem;
    color: var(--gray-500);
    font-weight: 500;
  }

  .empty-state {
    text-align: center;
    padding: 48px;
    color: var(--gray-500);
    font-size: 1rem;
  }

  tr[data-hidden="true"] {
    display: none;
  }

  .show-more-btn {
    display: block;
    width: 100%;
    padding: 14px;
    margin-top: 8px;
    background: var(--gray-50);
    border: 2px solid var(--gray-200);
    border-radius: var(--radius);
    font-family: var(--font-heading);
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--gray-700);
    cursor: pointer;
    transition: background 0.2s, border-color 0.2s;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }
  .show-more-btn:hover {
    background: var(--court-green, #16a34a);
    border-color: var(--court-green, #16a34a);
    color: white;
  }

  /* ===== SIDEBAR ===== */
  .sb {
    position: sticky;
    top: calc(var(--header-height) + 8px);
    display: flex;
    flex-direction: column;
    gap: 24px;
  }
  .sb-link {
    font-size: 0.72rem;
    color: var(--court-green);
    font-weight: 600;
  }
  .sb-link:hover {
    text-decoration: underline;
  }

  /* Sidebar block — generic */
  .sb-block {
    background: var(--white);
    border-radius: var(--radius);
    overflow: hidden;
    border: 1px solid var(--gray-200);
  }
  .sb-block__header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 14px 16px;
    background: var(--gray-900);
  }
  .sb-block__label {
    font-family: var(--font-heading);
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: #fff;
  }

  /* Sidebar: News */
  .sb-news {
    display: flex;
    flex-direction: column;
  }
  .sb-news__item {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 12px 14px;
    border-bottom: 1px solid var(--gray-100);
    text-decoration: none;
    transition: background 0.15s;
  }
  .sb-news__item:last-child {
    border-bottom: none;
  }
  .sb-news__item:hover {
    background: var(--gray-50);
  }
  .sb-news__meta {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .sb-news__cat {
    display: inline-block;
    padding: 2px 6px;
    border-radius: 3px;
    font-size: 0.55rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: #fff;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .sb-news__time {
    font-size: 0.7rem;
    color: var(--gray-500);
  }
  .sb-news__title {
    font-size: 0.82rem;
    font-weight: 600;
    line-height: 1.3;
    color: var(--gray-800);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .sb-news__item:hover .sb-news__title {
    color: var(--court-green);
  }

  /* Sidebar: Videos */
  .sb-videos {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding: 12px;
  }
  .sb-video__meta {
    padding: 6px 0 0;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .sb-video__cat {
    font-family: var(--font-heading);
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    font-weight: 700;
  }
  .sb-video__ch {
    font-size: 0.68rem;
    color: var(--gray-500);
  }

  /* Sidebar: Articles */
  .sb-articles {
    background: #fff;
    border-radius: var(--radius);
    overflow: hidden;
    border: 1px solid var(--gray-200);
  }
  .sb-articles__header {
    padding: 14px 16px;
    background: var(--gray-900);
  }
  .sb-articles__label {
    font-family: var(--font-heading);
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: #fff;
  }
  .sb-articles__list {
    display: flex;
    flex-direction: column;
  }
  .sb-articles__item {
    display: flex;
    align-items: flex-start;
    gap: 8px;
    padding: 10px 14px;
    border-bottom: 1px solid var(--gray-100);
    text-decoration: none;
    transition: background 0.15s;
  }
  .sb-articles__item:last-child {
    border-bottom: none;
  }
  .sb-articles__item:hover {
    background: var(--gray-50);
  }
  .sb-articles__cat {
    display: inline-block;
    padding: 2px 6px;
    border-radius: 3px;
    font-size: 0.55rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: #fff;
    white-space: nowrap;
    flex-shrink: 0;
    margin-top: 2px;
  }
  .sb-articles__link {
    font-size: 0.82rem;
    font-weight: 600;
    line-height: 1.3;
    color: var(--gray-800);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .sb-articles__item:hover .sb-articles__link {
    color: var(--court-green);
  }

  /* ===== FAQ SECTION ===== */
  .faq-section {
    max-width: 1200px;
    margin: 48px auto 0;
    padding-top: 48px;
    border-top: 1px solid var(--gray-200);
  }
  .faq-section h2 {
    font-family: var(--font-heading);
    font-size: 1.6rem;
    text-transform: uppercase;
    color: var(--gray-900);
    margin: 0 0 24px;
  }
  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .faq-item {
    border: 1px solid var(--gray-200);
    border-radius: var(--radius);
    overflow: hidden;
  }
  .faq-question {
    padding: 16px 20px;
    font-weight: 600;
    font-size: 0.95rem;
    cursor: pointer;
    list-style: none;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    background: var(--gray-50);
    transition: background 0.15s;
  }
  .faq-question::-webkit-details-marker { display: none; }
  .faq-question::after {
    content: '+';
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--gray-400);
    flex-shrink: 0;
  }
  .faq-item[open] .faq-question::after { content: '-'; }
  .faq-question:hover { background: var(--gray-100); }
  .faq-answer {
    padding: 16px 20px;
    margin: 0;
    font-size: 0.9rem;
    line-height: 1.7;
    color: var(--gray-600);
    border-top: 1px solid var(--gray-200);
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 1024px) {
    .rankings-layout {
      grid-template-columns: 1fr 280px;
