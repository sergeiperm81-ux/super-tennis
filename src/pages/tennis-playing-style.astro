---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="What's Your Tennis Playing Style? — Quiz"
  description="Answer 4 questions and find out which tennis legend plays like you. Carlos Alcaraz? Novak Djokovic? Rafael Nadal? Find out now."
  ogImage="/images/style-card-template.png"
>

<style is:global>
  .quiz-section {
    background: var(--gray-50, #f8f9fa);
    padding: 3rem 1rem 5rem;
  }
  .quiz-wrap {
    max-width: 640px;
    margin: 0 auto;
  }

  /* Header */
  .quiz-header {
    text-align: center;
    margin-bottom: 2rem;
  }
  .quiz-badge {
    background: #3aaa35;
    border-radius: 4px;
    color: #fff;
    display: inline-block;
    font-family: var(--font-heading, 'Oswald', sans-serif);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 1.5px;
    margin-bottom: 1rem;
    padding: 0.3rem 0.9rem;
    text-transform: uppercase;
  }
  .quiz-header h1 {
    font-family: var(--font-heading, 'Oswald', sans-serif);
    font-size: clamp(1.8rem, 5vw, 2.6rem);
    font-weight: 700;
    color: var(--gray-900, #212529);
    margin-bottom: 0.4rem;
    text-transform: uppercase;
    letter-spacing: 1px;
  }
  .quiz-header p {
    color: var(--gray-600, #868e96);
    font-size: 0.95rem;
  }

  /* Progress */
  .quiz-progress {
    margin-bottom: 1.5rem;
  }
  .quiz-progress-label {
    display: flex;
    justify-content: space-between;
    font-size: 0.8rem;
    color: #868e96;
    margin-bottom: 0.4rem;
  }
  .quiz-progress-bar {
    height: 6px;
    background: #dee2e6;
    border-radius: 3px;
    overflow: hidden;
  }
  .quiz-progress-fill {
    height: 100%;
    background: #3aaa35;
    border-radius: 3px;
    transition: width 0.3s ease;
  }

  /* Question */
  .quiz-question {
    background: #fff;
    border-radius: 16px;
    padding: 1.75rem 1.5rem;
    margin-bottom: 1rem;
    box-shadow: 0 2px 12px rgba(0,0,0,0.07);
    border: 1px solid #e9ecef;
  }
  .quiz-question h2 {
    font-family: var(--font-heading, 'Oswald', sans-serif);
    font-size: clamp(1.1rem, 3vw, 1.5rem);
    font-weight: 700;
    color: #212529;
    margin-bottom: 1.25rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    line-height: 1.25;
  }

  /* Options */
  .quiz-options {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .quiz-option {
    background: #f8f9fa;
    border: 2px solid #dee2e6;
    border-radius: 12px;
    cursor: pointer;
    font-size: 0.95rem;
    font-weight: 500;
    padding: 0.9rem 1.1rem;
    text-align: left;
    transition: all 0.15s ease;
    color: #343a40;
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }
  .quiz-option:hover {
    border-color: #3aaa35;
    background: #f4fdf4;
    color: #1e6b2b;
    transform: translateX(4px);
  }
  .quiz-option.selected {
    border-color: #3aaa35;
    background: #eaf7ec;
    color: #1e6b2b;
    font-weight: 700;
  }

  /* Result */
  #quiz-result {
    display: none;
    margin-top: 0;
  }
  .result-card-img {
    width: 100%;
    border-radius: 14px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.15);
    display: block;
    margin-bottom: 1rem;
  }
  .result-label {
    text-align: center;
    font-family: var(--font-heading, 'Oswald', sans-serif);
    font-size: 1rem;
    color: #868e96;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 0.25rem;
  }
  .result-player {
    text-align: center;
    font-family: var(--font-heading, 'Oswald', sans-serif);
    font-size: clamp(1.4rem, 4vw, 2rem);
    font-weight: 700;
    color: #212529;
    text-transform: uppercase;
    margin-bottom: 0.4rem;
  }
  .result-desc {
    text-align: center;
    font-size: 0.88rem;
    color: #868e96;
    margin-bottom: 1.25rem;
    line-height: 1.5;
  }
  .result-actions {
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }
  .btn-share {
    background: #3aaa35;
    border: none;
    border-radius: 10px;
    color: #fff;
    cursor: pointer;
    font-size: 0.95rem;
    font-weight: 700;
    padding: 0.9rem;
    transition: background 0.2s;
  }
  .btn-share:hover { background: #2d8c2a; }
  .btn-dl {
    background: #fff;
    border: 2px solid #dee2e6;
    border-radius: 10px;
    color: #495057;
    cursor: pointer;
    font-size: 0.9rem;
    font-weight: 700;
    padding: 0.85rem;
    transition: border-color 0.2s;
  }
  .btn-dl:hover { border-color: #3aaa35; color: #2d8c2a; }
  .btn-retry {
    background: transparent;
    border: none;
    color: #adb5bd;
    cursor: pointer;
    font-size: 0.82rem;
    padding: 0.5rem;
    transition: color 0.2s;
  }
  .btn-retry:hover { color: #495057; }
</style>

<div class="quiz-section">
  <div class="quiz-wrap">
    <div class="quiz-header">
      <span class="quiz-badge">Tennis Style Quiz</span>
      <h1>What's Your Tennis Style?</h1>
      <p>4 questions — find out which legend plays like you</p>
    </div>

    <div id="quiz-body">
      <div class="quiz-progress">
        <div class="quiz-progress-label">
          <span id="q-label">Question 1 of 4</span>
          <span id="q-pct">0%</span>
        </div>
        <div class="quiz-progress-bar">
          <div class="quiz-progress-fill" id="q-fill" style="width:0%"></div>
        </div>
      </div>

      <div class="quiz-question">
        <h2 id="q-text"></h2>
        <div class="quiz-options" id="q-options"></div>
      </div>
    </div>

    <div id="quiz-result">
      <p class="result-label">Your tennis style matches</p>
      <p class="result-player" id="res-player"></p>
      <p class="result-desc" id="res-desc"></p>
      <img id="res-img" class="result-card-img" src="" alt="" width="1080" height="1350" loading="eager" />
      <div class="result-actions">
        <button class="btn-share" onclick="shareResult()">🔗 Share my style</button>
        <button class="btn-dl" onclick="downloadResult()">💾 Save as Image</button>
        <button class="btn-retry" onclick="restartQuiz()">↺ Take the quiz again</button>
      </div>
    </div>
  </div>
</div>

<script is:inline>
const PLAYERS = {
  alcaraz: { name: 'Carlos Alcaraz',  id: 'carlos-alcaraz',  desc: 'Explosive, athletic, and fearless — you attack from any situation and never stop moving.' },
  djokovic: { name: 'Novak Djokovic', id: 'novak-djokovic',  desc: 'Ice-cold under pressure, unbreakable from the baseline — the most complete player of the modern era.' },
  nadal:    { name: 'Rafael Nadal',   id: 'rafael-nadal',    desc: 'Relentless topspin and iron will — you outgrind every opponent until they crack.' },
  federer:  { name: 'Roger Federer',  id: 'roger-federer',   desc: 'Effortless elegance, a magical touch, and the full range of shots — true all-court artistry.' },
  murray:   { name: 'Andy Murray',    id: 'andy-murray',     desc: 'Smart, gritty, and never beaten — you turn defense into offense better than anyone.' },
  isner:    { name: 'John Isner',     id: 'john-isner',      desc: 'Your serve is a weapon like no other — when it\'s on, opponents can\'t do a thing.' },
  edberg:   { name: 'Stefan Edberg',  id: 'stefan-edberg',   desc: 'Smooth, attacking, and always moving forward — you love to finish points at the net.' },
  agassi:   { name: 'Andre Agassi',   id: 'andre-agassi',    desc: 'Pure striking ability and tactical brilliance — you return serves and redirect pace like a master.' },
};

const QUESTIONS = [
  {
    text: 'When you get a chance to attack, you…',
    options: [
      { text: '💥 Rip a winner down the line',             scores: { alcaraz:3, agassi:2 } },
      { text: '🎯 Rush the net and put it away',           scores: { edberg:3, federer:2 } },
      { text: '🔄 Reset safely, keep the rally going',     scores: { djokovic:2, murray:2, nadal:1 } },
      { text: '🌀 Load up heavy topspin, push them back',  scores: { nadal:3, murray:1 } },
    ],
  },
  {
    text: 'Your biggest weapon on court?',
    options: [
      { text: '🔥 A thundering forehand winner',           scores: { alcaraz:3, agassi:2 } },
      { text: '🎾 A precise, penetrating backhand',        scores: { djokovic:3, murray:2 } },
      { text: '🚀 A heavy serve — make it an ace!',        scores: { isner:3, edberg:2 } },
      { text: '🎩 Touch and variety — drop shots, slices', scores: { federer:3, agassi:1 } },
    ],
  },
  {
    text: 'When the match is on the line…',
    options: [
      { text: '💪 Raise my level and go for broke',        scores: { alcaraz:3, federer:1, agassi:1 } },
      { text: '🧊 Stay ice-cold, make them earn every point', scores: { djokovic:3, murray:1 } },
      { text: '🏃 Run down every single ball — never quit', scores: { nadal:3, murray:2 } },
      { text: '💣 Trust my serve to get me out of trouble', scores: { isner:3, edberg:1 } },
    ],
  },
  {
    text: 'Your dream surface?',
    options: [
      { text: '🏖️ Clay — long rallies, pure mental battle',  scores: { nadal:3, murray:1 } },
      { text: '🌿 Grass — fast and explosive, serve big',    scores: { edberg:3, isner:2, federer:1 } },
      { text: '🏟️ Hard court — neutral, best player wins',   scores: { djokovic:2, agassi:3, alcaraz:1 } },
      { text: '🏠 Any surface — I adapt to everything',      scores: { federer:3, murray:2, djokovic:1 } },
    ],
  },
];

let current = 0;
let scores = {};
let resultPlayer = null;

function initScores() {
  scores = {};
  Object.keys(PLAYERS).forEach(k => scores[k] = 0);
}

function renderQuestion() {
  const q = QUESTIONS[current];
  const pct = Math.round((current / QUESTIONS.length) * 100);
  document.getElementById('q-label').textContent = `Question ${current + 1} of ${QUESTIONS.length}`;
  document.getElementById('q-pct').textContent = pct + '%';
  document.getElementById('q-fill').style.width = pct + '%';
  document.getElementById('q-text').textContent = q.text;

  const opts = document.getElementById('q-options');
  opts.innerHTML = q.options.map((o, i) => `
    <button class="quiz-option" onclick="answer(${i})">${o.text}</button>
  `).join('');
}

function answer(optIdx) {
  const q = QUESTIONS[current];
  const chosen = q.options[optIdx];

  // Highlight chosen
  document.querySelectorAll('.quiz-option').forEach((b, i) => {
    if (i === optIdx) b.classList.add('selected');
    b.disabled = true;
  });

  // Add scores
  Object.entries(chosen.scores).forEach(([k, v]) => {
    scores[k] = (scores[k] || 0) + v;
  });

  setTimeout(() => {
    current++;
    if (current < QUESTIONS.length) {
      renderQuestion();
    } else {
      showResult();
    }
  }, 380);
}

function showResult() {
  // Find player with highest score
  const winner = Object.entries(scores).sort((a, b) => b[1] - a[1])[0][0];
  resultPlayer = PLAYERS[winner];

  document.getElementById('quiz-body').style.display = 'none';
  const result = document.getElementById('quiz-result');
  result.style.display = 'block';

  document.getElementById('res-player').textContent = resultPlayer.name;
  document.getElementById('res-desc').textContent = resultPlayer.desc;
  const img = document.getElementById('res-img');
  img.src = `/images/style-cards/${resultPlayer.id}.png`;
  img.alt = `My tennis style: ${resultPlayer.name}`;

  result.scrollIntoView({ behavior: 'smooth', block: 'start' });
}

function restartQuiz() {
  current = 0;
  initScores();
  resultPlayer = null;
  document.getElementById('quiz-result').style.display = 'none';
  document.getElementById('quiz-body').style.display = 'block';
  renderQuestion();
}

async function getBlob() {
  const res = await fetch(`/images/style-cards/${resultPlayer.id}.png`);
  return res.blob();
}

async function shareResult() {
  if (!resultPlayer) return;
  const blob = await getBlob();
  const file = new File([blob], `my-tennis-style-${resultPlayer.id}.png`, { type: 'image/png' });
  if (navigator.canShare && navigator.canShare({ files: [file] })) {
    try {
      await navigator.share({
        files: [file],
        title: `My Tennis Style: ${resultPlayer.name}`,
        text: `My tennis style is closest to ${resultPlayer.name} 🎾\nWhat's yours? super.tennis/tennis-playing-style`,
      });
      return;
    } catch (e) {
      if (e.name === 'AbortError') return;
    }
  }
  downloadResult();
}

async function downloadResult() {
  if (!resultPlayer) return;
  const blob = await getBlob();
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url;
  a.download = `my-tennis-style-${resultPlayer.id}.png`;
  a.click();
  URL.revokeObjectURL(url);
}

// Init
initScores();
renderQuestion();
</script>

</BaseLayout>
