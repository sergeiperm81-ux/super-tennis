---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getLatestRankings, getPlayerBySlug } from '../../lib/supabase';
import { fallbackPlayers, countryFlags, getFlagUrl } from '../../lib/fallback-data';

// Generic placeholder — tennis ball silhouette
const PLACEHOLDER_IMG = '/placeholder-player.svg';

// Fetch photos for popular articles section
let djokovicPhoto = '', alcarazPhoto = '', swiatekPhoto = '';
let sinnerPhoto = '', sabalenkaPhoto = '', federerPhoto = '', nadalPhoto = '', gauffPhoto = '';
try {
  const [d, a, s, si, sab, f, n, g] = await Promise.all([
    getPlayerBySlug('novak-djokovic'),
    getPlayerBySlug('carlos-alcaraz'),
    getPlayerBySlug('iga-swiatek'),
    getPlayerBySlug('jannik-sinner'),
    getPlayerBySlug('aryna-sabalenka'),
    getPlayerBySlug('roger-federer'),
    getPlayerBySlug('rafael-nadal'),
    getPlayerBySlug('coco-gauff'),
  ]);
  djokovicPhoto = d?.image_url || '';
  alcarazPhoto = a?.image_url || '';
  swiatekPhoto = s?.image_url || '';
  sinnerPhoto = si?.image_url || '';
  sabalenkaPhoto = sab?.image_url || '';
  federerPhoto = f?.image_url || '';
  nadalPhoto = n?.image_url || '';
  gauffPhoto = g?.image_url || '';
} catch {}

// Fetch real ranked players from Supabase
let atpRankings = await getLatestRankings('atp', 20);
let wtaRankings = await getLatestRankings('wta', 20);

// Map a ranking record to player card format
function mapRanking(r: any) {
  const p = r.players;
  const slug = p?.slug || '';
  const fb = fallbackPlayers[slug]; // Check if we have a fallback entry with photo
  return {
    first_name: p?.first_name || '',
    last_name: p?.last_name || '',
    slug,
    country_code: p?.country_code || '',
    tour: r.tour,
    ranking: r.ranking,
    points: r.points || 0,
    career_titles: p?.career_titles || fb?.career_titles || 0,
    grand_slam_titles: p?.grand_slam_titles || fb?.grand_slam_titles || 0,
    image_url: p?.image_url || fb?.image_url?.replace('w=800', 'w=400') || PLACEHOLDER_IMG,
  };
}

// Map fallback data to same format (used when Supabase is unavailable)
function mapFallback(p: any, ranking: number) {
  return {
    ...p,
    ranking,
    points: 0,
    image_url: p.image_url?.replace('w=800', 'w=400') || PLACEHOLDER_IMG,
  };
}

// Use real data if available, fall back to hardcoded
let atpPlayers: any[];
let wtaPlayers: any[];

if (atpRankings.length > 0) {
  atpPlayers = atpRankings.map(mapRanking);
} else {
  atpPlayers = Object.values(fallbackPlayers)
    .filter((p: any) => p.tour === 'atp')
    .map((p: any, i: number) => mapFallback(p, i + 1));
}

if (wtaRankings.length > 0) {
  wtaPlayers = wtaRankings.map(mapRanking);
} else {
  wtaPlayers = Object.values(fallbackPlayers)
    .filter((p: any) => p.tour === 'wta')
    .map((p: any, i: number) => mapFallback(p, i + 1));
}
---

<BaseLayout
  title="Tennis Players — Profiles, Rankings & Stats"
  description="Explore profiles of top ATP and WTA tennis players. Career stats, Grand Slam titles, rankings, net worth, and equipment."
  ogImage="/og/players.png"
>
  <div class="players-page">
    <div class="container">
      <nav class="breadcrumbs"><a href="/">Home</a> <span class="sep">/</span> <span class="current">Players</span></nav>
      <section class="page-hero">
        <h1>Tennis Players</h1>
        <p class="subtitle">Profiles, rankings, stats and stories of the world's best tennis players</p>
      </section>

      <!-- Search & Filter -->
      <div class="search-bar">
        <div class="search-input-wrap">
          <svg class="search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          <input type="text" id="player-search" placeholder="Search players..." autocomplete="off" />
        </div>
        <div class="tour-filters">
          <button class="tour-filter active" data-tour="all">All</button>
          <button class="tour-filter" data-tour="atp">ATP</button>
          <button class="tour-filter" data-tour="wta">WTA</button>
        </div>
      </div>

      <!-- ATP Section -->
      <section class="tour-section" data-tour="atp">
        <div class="tour-header">
          <h2>ATP Tour <span class="tour-badge atp">Men's</span></h2>
          <a href="/rankings/" class="view-all">Full Rankings →</a>
        </div>
        <div class="players-grid">
          {atpPlayers.map((player, i) => (
            <a href={`/players/${player.slug}/`} class="player-card" data-name={`${player.first_name} ${player.last_name}`.toLowerCase()}>
              <div class="player-rank">#{player.ranking}</div>
              <div class="player-photo">
                <img
                  src={player.image_url}
                  alt={`${player.first_name} ${player.last_name}`}
                  loading={i < 4 ? 'eager' : 'lazy'}
                  width="400"
                  height="400"
                  decoding="async"
                />
              </div>
              <div class="player-info">
                {getFlagUrl(player.country_code || '') ? (<img src={getFlagUrl(player.country_code || '', 24)} alt={player.country_code || ''} class="player-flag-img" width="24" height="18" loading="lazy" decoding="async" />) : (<span class="player-flag">{countryFlags[player.country_code || ''] || ''}</span>)}
                <h3>{player.first_name} <strong>{player.last_name}</strong></h3>
                <div class="player-stats">
                  <span class="stat">
                    <em>{player.career_titles}</em> Titles
                  </span>
                  {player.grand_slam_titles > 0 && (
                    <span class="stat gs">
                      <em>{player.grand_slam_titles}</em> GS
                    </span>
                  )}
                  <span class="stat pts">
                    <em>{player.points?.toLocaleString()}</em> pts
                  </span>
                </div>
              </div>
            </a>
          ))}
        </div>
      </section>

      <!-- WTA Section -->
      <section class="tour-section" data-tour="wta">
        <div class="tour-header">
          <h2>WTA Tour <span class="tour-badge wta">Women's</span></h2>
          <a href="/rankings/" class="view-all">Full Rankings →</a>
        </div>
        <div class="players-grid">
          {wtaPlayers.map((player, i) => (
            <a href={`/players/${player.slug}/`} class="player-card" data-name={`${player.first_name} ${player.last_name}`.toLowerCase()}>
              <div class="player-rank">#{player.ranking}</div>
              <div class="player-photo">
                <img
                  src={player.image_url}
                  alt={`${player.first_name} ${player.last_name}`}
                  loading="lazy"
                  width="400"
                  height="400"
                  decoding="async"
                />
              </div>
              <div class="player-info">
                {getFlagUrl(player.country_code || '') ? (<img src={getFlagUrl(player.country_code || '', 24)} alt={player.country_code || ''} class="player-flag-img" width="24" height="18" loading="lazy" decoding="async" />) : (<span class="player-flag">{countryFlags[player.country_code || ''] || ''}</span>)}
                <h3>{player.first_name} <strong>{player.last_name}</strong></h3>
                <div class="player-stats">
                  <span class="stat">
                    <em>{player.career_titles}</em> Titles
                  </span>
                  {player.grand_slam_titles > 0 && (
                    <span class="stat gs">
                      <em>{player.grand_slam_titles}</em> GS
                    </span>
                  )}
                  <span class="stat pts">
                    <em>{player.points?.toLocaleString()}</em> pts
                  </span>
                </div>
              </div>
            </a>
          ))}
        </div>
      </section>

      <!-- Popular Articles -->
      <section class="related-content">
        <h2>Popular Player Articles</h2>
        <div class="articles-row">
          <a href="/players/novak-djokovic/" class="article-card">
            <img src={djokovicPhoto || PLACEHOLDER_IMG} alt="Novak Djokovic net worth" loading="lazy" decoding="async" width="400" height="267" />
            <h3>Novak Djokovic Net Worth in 2026</h3>
          </a>
          <a href="/players/carlos-alcaraz/" class="article-card">
            <img src={alcarazPhoto || PLACEHOLDER_IMG} alt="Carlos Alcaraz racket" loading="lazy" decoding="async" width="400" height="267" />
            <h3>What Racket Does Carlos Alcaraz Use?</h3>
          </a>
          <a href="/players/iga-swiatek/" class="article-card">
            <img src={swiatekPhoto || PLACEHOLDER_IMG} alt="Iga Swiatek profile" loading="lazy" decoding="async" width="400" height="267" />
            <h3>Iga Swiatek — Complete Player Profile</h3>
          </a>
        </div>
      </section>

      <!-- Trending: Relationships & Personal Life -->
      <section class="related-content">
        <h2>Relationships & Personal Life</h2>
        <div class="articles-row">
          <a href="/players/jannik-sinner/" class="article-card">
            <img src={sinnerPhoto || PLACEHOLDER_IMG} alt="Jannik Sinner girlfriend" loading="lazy" decoding="async" width="400" height="267" />
            <h3>Jannik Sinner Girlfriend — Who Is He Dating?</h3>
          </a>
          <a href="/players/novak-djokovic/" class="article-card">
            <img src={djokovicPhoto || PLACEHOLDER_IMG} alt="Novak Djokovic wife" loading="lazy" decoding="async" width="400" height="267" />
            <h3>Novak Djokovic Wife — Jelena Djokovic</h3>
          </a>
          <a href="/players/aryna-sabalenka/" class="article-card">
            <img src={sabalenkaPhoto || PLACEHOLDER_IMG} alt="Aryna Sabalenka boyfriend" loading="lazy" decoding="async" width="400" height="267" />
            <h3>Aryna Sabalenka Boyfriend — Relationship Status</h3>
          </a>
          <a href="/players/carlos-alcaraz/" class="article-card">
            <img src={alcarazPhoto || PLACEHOLDER_IMG} alt="Carlos Alcaraz girlfriend" loading="lazy" decoding="async" width="400" height="267" />
            <h3>Carlos Alcaraz Girlfriend — Who Is He Dating?</h3>
          </a>
        </div>
      </section>

      <!-- Trending: Age & Bio -->
      <section class="related-content">
        <h2>How Old Are They?</h2>
        <div class="articles-row">
          <a href="/players/carlos-alcaraz/" class="article-card">
            <img src={alcarazPhoto || PLACEHOLDER_IMG} alt="Carlos Alcaraz age" loading="lazy" decoding="async" width="400" height="267" />
            <h3>How Old Is Carlos Alcaraz? Age & Birthday</h3>
          </a>
          <a href="/players/roger-federer/" class="article-card">
            <img src={federerPhoto || PLACEHOLDER_IMG} alt="Roger Federer age" loading="lazy" decoding="async" width="400" height="267" />
            <h3>How Old Is Roger Federer? Age & Bio</h3>
          </a>
          <a href="/players/coco-gauff/" class="article-card">
            <img src={gauffPhoto || PLACEHOLDER_IMG} alt="Coco Gauff age" loading="lazy" decoding="async" width="400" height="267" />
            <h3>How Old Is Coco Gauff? Age & Height</h3>
          </a>
          <a href="/players/rafael-nadal/" class="article-card">
            <img src={nadalPhoto || PLACEHOLDER_IMG} alt="Rafael Nadal age" loading="lazy" decoding="async" width="400" height="267" />
            <h3>How Old Is Rafael Nadal? Age & Career</h3>
          </a>
        </div>
      </section>

      <!-- Career Stats -->
      <section class="related-content">
        <h2>Career Stats & Records</h2>
        <div class="articles-row">
          <a href="/players/novak-djokovic/" class="article-card">
            <img src={djokovicPhoto || PLACEHOLDER_IMG} alt="Novak Djokovic stats" loading="lazy" decoding="async" width="400" height="267" />
            <h3>Djokovic Career Stats — Titles & Win Rate</h3>
          </a>
          <a href="/players/jannik-sinner/" class="article-card">
            <img src={sinnerPhoto || PLACEHOLDER_IMG} alt="Jannik Sinner stats" loading="lazy" decoding="async" width="400" height="267" />
            <h3>Sinner Career Stats — Rise to No. 1</h3>
          </a>
          <a href="/players/iga-swiatek/" class="article-card">
            <img src={swiatekPhoto || PLACEHOLDER_IMG} alt="Iga Swiatek stats" loading="lazy" decoding="async" width="400" height="267" />
            <h3>Swiatek Career Stats — Titles & Records</h3>
          </a>
          <a href="/players/aryna-sabalenka/" class="article-card">
            <img src={sabalenkaPhoto || PLACEHOLDER_IMG} alt="Aryna Sabalenka stats" loading="lazy" decoding="async" width="400" height="267" />
            <h3>Sabalenka Career Stats — Grand Slams</h3>
          </a>
        </div>
      </section>
    </div>
  </div>
</BaseLayout>

<style>
  .players-page {
    padding: 0 24px 60px;
    max-width: 1280px;
    margin: 0 auto;
  }

  .page-hero {
    padding: 48px 0 32px;
    border-bottom: 3px solid var(--court-green);
    margin-bottom: 40px;
  }
  .page-hero h1 {
    font-family: var(--font-heading);
    font-size: 2.8rem;
    text-transform: uppercase;
    color: var(--dark);
    margin: 0;
  }
  .subtitle {
    color: #666;
    font-size: 1.1rem;
    margin: 8px 0 0;
  }

  .tour-section {
    margin-bottom: 48px;
  }

  .tour-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 24px;
  }
  .tour-header h2 {
    font-family: var(--font-heading);
    font-size: 1.6rem;
    text-transform: uppercase;
    display: flex;
    align-items: center;
    gap: 12px;
    margin: 0;
  }
  .tour-badge {
    font-size: 0.7rem;
    padding: 3px 10px;
    border-radius: 4px;
    font-family: var(--font-body);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .tour-badge.atp { background: #003580; color: white; }
  .tour-badge.wta { background: #7b2d8e; color: white; }

  .view-all {
    color: var(--court-green);
    font-weight: 600;
    text-decoration: none;
    font-size: 0.9rem;
  }
  .view-all:hover { text-decoration: underline; }

  .players-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
  }

  .player-card {
    text-decoration: none;
    color: inherit;
    background: white;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 2px 8px rgba(0,0,0,0.08);
    transition: transform 0.2s, box-shadow 0.2s;
    position: relative;
  }
  .player-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.12);
  }

  .player-rank {
    position: absolute;
    top: 12px;
    left: 12px;
    background: rgba(0,0,0,0.75);
    color: var(--ball-yellow);
    font-family: var(--font-heading);
    font-size: 0.9rem;
    padding: 4px 10px;
    border-radius: 6px;
    z-index: 2;
  }

  .player-photo {
    aspect-ratio: 1;
    overflow: hidden;
  }
  .player-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top;
    transition: transform 0.3s;
  }
  .player-card:hover .player-photo img {
    transform: scale(1.05);
  }

  .player-info {
    padding: 14px 16px 18px;
  }
  .player-flag {
    font-size: 1.2rem;
    margin-bottom: 4px;
    display: inline-block;
  }
  .player-flag-img {
    margin-bottom: 4px;
    display: inline-block;
    border-radius: 2px;
  }
  .player-info h3 {
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 400;
    margin: 4px 0 8px;
    line-height: 1.3;
  }
  .player-info h3 strong {
    font-weight: 700;
    text-transform: uppercase;
    font-family: var(--font-heading);
    font-size: 1.05rem;
  }

  .player-stats {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }
  .stat {
    font-size: 0.8rem;
    color: #888;
  }
  .stat em {
    font-style: normal;
    font-weight: 700;
    color: var(--dark);
    margin-right: 2px;
  }
  .stat.gs em { color: #d4a017; }

  /* Related content */
  .related-content {
    margin-top: 48px;
    padding-top: 32px;
    border-top: 2px solid #eee;
  }
  .related-content h2 {
    font-family: var(--font-heading);
    font-size: 1.4rem;
    text-transform: uppercase;
    margin: 0 0 20px;
  }
  .articles-row {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 20px;
  }
  .article-card {
    text-decoration: none;
    color: inherit;
    border-radius: 10px;
    overflow: hidden;
    box-shadow: 0 2px 8px rgba(0,0,0,0.08);
    transition: transform 0.2s;
  }
  .article-card:hover { transform: translateY(-3px); }
  .article-card img {
    width: 100%;
    aspect-ratio: 3/2;
    object-fit: cover;
    object-position: top;
  }
  .article-card h3 {
    padding: 12px 14px 16px;
    font-size: 0.95rem;
    font-weight: 600;
    margin: 0;
    line-height: 1.4;
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .players-grid { grid-template-columns: repeat(3, 1fr); }
  }
  @media (max-width: 768px) {
    .players-grid { grid-template-columns: repeat(2, 1fr); }
    .articles-row { grid-template-columns: 1fr; }
    .page-hero h1 { font-size: 2rem; }
  }
  /* Search & Filter */
  .search-bar {
    display: flex;
    gap: 16px;
    align-items: center;
    margin-bottom: 32px;
    flex-wrap: wrap;
  }
  .search-input-wrap {
    position: relative;
    flex: 1;
    min-width: 200px;
  }
  .search-icon {
    position: absolute;
    left: 14px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--gray-400);
    pointer-events: none;
  }
  #player-search {
    width: 100%;
    padding: 12px 16px 12px 42px;
    border: 2px solid var(--gray-200);
    border-radius: var(--radius);
    font-size: 0.95rem;
    font-family: var(--font-body);
    background: white;
    transition: border-color 0.2s;
  }
  #player-search:focus {
    outline: none;
    border-color: var(--court-green);
  }
  #player-search::placeholder {
    color: var(--gray-400);
  }
  .tour-filters {
    display: flex;
    gap: 4px;
    background: var(--gray-100);
    border-radius: var(--radius);
    padding: 4px;
  }
  .tour-filter {
    padding: 8px 18px;
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    border-radius: var(--radius-sm);
    color: var(--gray-600);
    transition: all 0.2s;
    font-family: var(--font-body);
  }
  .tour-filter:hover {
    color: var(--gray-900);
  }
  .tour-filter.active {
    background: white;
    color: var(--court-green);
    box-shadow: var(--shadow);
  }
  .no-results {
    display: none;
    text-align: center;
    padding: 48px 24px;
    color: var(--gray-500);
    font-size: 1rem;
    grid-column: 1 / -1;
  }
  .no-results.visible {
    display: block;
  }

  @media (max-width: 480px) {
    .players-grid { grid-template-columns: 1fr 1fr; gap: 12px; }
    .player-info { padding: 10px 12px 14px; }
    .player-info h3 { font-size: 0.9rem; }
    .search-bar { flex-direction: column; gap: 12px; }
    .search-input-wrap { width: 100%; }
  }
  @media (max-width: 360px) {
    .players-grid { grid-template-columns: 1fr; gap: 16px; }
  }
</style>

<script>
  const searchInput = document.getElementById('player-search') as HTMLInputElement;
  const tourFilters = document.querySelectorAll('.tour-filter');
  const tourSections = document.querySelectorAll<HTMLElement>('.tour-section[data-tour]');
  let activeTour = 'all';

  function filterPlayers() {
    const query = searchInput?.value.toLowerCase().trim() || '';

    tourSections.forEach(section => {
      const tour = section.dataset.tour || '';
      const showSection = activeTour === 'all' || activeTour === tour;
      section.style.display = showSection ? '' : 'none';

      if (showSection) {
        const cards = section.querySelectorAll<HTMLElement>('.player-card');
        let visibleCount = 0;
        cards.forEach(card => {
          const name = card.dataset.name || '';
          const matches = !query || name.includes(query);
          card.style.display = matches ? '' : 'none';
          if (matches) visibleCount++;
        });

        // Show/hide no results message
        let noResults = section.querySelector('.no-results') as HTMLElement;
        if (!noResults) {
          noResults = document.createElement('div');
          noResults.className = 'no-results';
          noResults.textContent = 'No players found';
          section.querySelector('.players-grid')?.appendChild(noResults);
        }
        noResults.classList.toggle('visible', visibleCount === 0 && query.length > 0);
      }
    });
  }

  searchInput?.addEventListener('input', filterPlayers);

  tourFilters.forEach(btn => {
    btn.addEventListener('click', () => {
      tourFilters.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      activeTour = (btn as HTMLElement).dataset.tour || 'all';
      filterPlayers();
    });
  });
</script>
