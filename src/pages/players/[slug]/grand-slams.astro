---
import ArticleLayout from '../../../layouts/ArticleLayout.astro';
import ArticleFooter from '../../../components/ArticleFooter.astro';
import { getPlayerBySlug, getTopPlayerSlugs, getArticleBySlug } from '../../../lib/supabase';
import { fallbackPlayers, countryNames, countryFlags, handLabels, getFlagUrl } from '../../../lib/fallback-data';
import { addInterlinks } from '../../../lib/interlinks';
import { marked } from 'marked';

export async function getStaticPaths() {
  let slugs: string[] = [];
  try {
    slugs = await getTopPlayerSlugs(100);
  } catch (e) {
    console.warn('grand-slams getStaticPaths: Supabase unavailable');
  }

  const fbSlugs = Object.keys(fallbackPlayers);
  const allSlugs = [...new Set([...slugs, ...fbSlugs])];

  return allSlugs.map(slug => ({ params: { slug } }));
}

const { slug } = Astro.params;

let player = await getPlayerBySlug(slug as string);
if (!player) {
  player = fallbackPlayers[slug as string] || null;
}

if (!player) {
  return Astro.redirect('/players/');
}

const name = `${player.first_name} ${player.last_name}`;
const country = countryNames[player.country_code || ''] || player.country_code || '';
const tour = player.tour === 'atp' ? 'ATP' : 'WTA';

// Try article
const articleSlug = `${slug}-grand-slams`;
let article: any = null;
try { article = await getArticleBySlug(articleSlug); } catch {}

const rawHtml = article?.body ? marked.parse(article.body) : null;
const bodyHtml = rawHtml ? await addInterlinks(rawHtml as string, `/players/${slug}/grand-slams/`) : null;

const gs = player.grand_slam_titles || 0;
const wl = player.win_loss || '';
const [wins, losses] = wl.split('-').map(Number);
const winPct = wins && losses ? Math.round((wins / (wins + losses)) * 100) : null;

// FAQ JSON-LD
const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: `How many Grand Slams has ${name} won?`,
      acceptedAnswer: {
        '@type': 'Answer',
        text: gs > 0
          ? `${name} has won ${gs} Grand Slam singles title${gs > 1 ? 's' : ''}.`
          : `${name} has not yet won a Grand Slam singles title.`
      }
    },
    {
      '@type': 'Question',
      name: `What is ${name}'s career win-loss record?`,
      acceptedAnswer: {
        '@type': 'Answer',
        text: wl
          ? `${name}'s career win-loss record is ${wl}${winPct ? ` (${winPct}% win rate)` : ''}.`
          : `Detailed win-loss record is being updated.`
      }
    },
  ]
};
---

<ArticleLayout
  title={`${name} Grand Slam Record — Titles, Finals & Results`}
  description={article?.meta_description || `${name}'s complete Grand Slam record. ${gs > 0 ? `${gs} title${gs > 1 ? 's' : ''} won.` : 'Finals, best results, and performance'} at Australian Open, Roland Garros, Wimbledon, and US Open.`}
  breadcrumbs={[
    { label: 'Home', href: '/' },
    { label: 'Players', href: '/players/' },
    { label: name, href: `/players/${slug}/` },
    { label: 'Grand Slam Record' },
  ]}
>
  <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />

  <!-- Grand Slam Stats Banner -->
  <div class="gs-banner">
    <div class="gs-stat gs-stat--big">
      <span class="gs-stat-value">{gs}</span>
      <span class="gs-stat-label">Grand Slam Titles</span>
    </div>
    <div class="gs-stat">
      <span class="gs-stat-value">{player.career_titles || 0}</span>
      <span class="gs-stat-label">Career Titles</span>
    </div>
    <div class="gs-stat">
      <span class="gs-stat-value">{wl || '—'}</span>
      <span class="gs-stat-label">Win-Loss Record</span>
    </div>
    {winPct && (
      <div class="gs-stat">
        <span class="gs-stat-value">{winPct}%</span>
        <span class="gs-stat-label">Win Rate</span>
      </div>
    )}
  </div>

  {bodyHtml ? (
    <div set:html={bodyHtml} />
  ) : (
    <div class="gs-content">
      <h2>Grand Slam Overview</h2>
      <p>
        {name} has {gs > 0
          ? `won ${gs} Grand Slam singles title${gs > 1 ? 's' : ''}, establishing ${player.tour === 'atp' ? 'himself' : 'herself'} as one of the elite champions in tennis history`
          : `competed at the Grand Slam level as a ${tour} professional from ${country}`}.
        With a career record of <strong>{wl || 'N/A'}</strong>{winPct ? ` (${winPct}% win rate)` : ''} and
        <strong>{player.career_titles || 0} total titles</strong>, {name} has been a significant force on the tour.
      </p>

      <h2>Grand Slam Performance by Tournament</h2>
      <div class="gs-grid">
        <div class="gs-tournament gs-tournament--ao">
          <div class="gs-emoji">🇦🇺</div>
          <div class="gs-name">Australian Open</div>
          <div class="gs-surface">Hard Court — Melbourne</div>
        </div>
        <div class="gs-tournament gs-tournament--rg">
          <div class="gs-emoji">🇫🇷</div>
          <div class="gs-name">Roland Garros</div>
          <div class="gs-surface">Clay Court — Paris</div>
        </div>
        <div class="gs-tournament gs-tournament--wim">
          <div class="gs-emoji">🇬🇧</div>
          <div class="gs-name">Wimbledon</div>
          <div class="gs-surface">Grass Court — London</div>
        </div>
        <div class="gs-tournament gs-tournament--uso">
          <div class="gs-emoji">🇺🇸</div>
          <div class="gs-name">US Open</div>
          <div class="gs-surface">Hard Court — New York</div>
        </div>
      </div>

      <p><em>Detailed round-by-round Grand Slam results coming soon.</em></p>

      <h2>Frequently Asked Questions</h2>
      <h3>How many Grand Slams has {name} won?</h3>
      <p>{gs > 0 ? `${name} has won ${gs} Grand Slam singles title${gs > 1 ? 's' : ''}.` : `${name} has not yet won a Grand Slam singles title.`}</p>

      <h3>What is {name}'s career win-loss record?</h3>
      <p>{wl ? `${name}'s career record is ${wl}${winPct ? ` (${winPct}% win rate)` : ''}.` : 'Detailed record is being updated.'}</p>
    </div>
  )}

  <ArticleFooter
    backLabel={`${name}'s Profile`}
    backHref={`/players/${slug}/`}
    relatedLinks={[
      { label: `${name}'s Career Timeline`, href: `/players/${slug}/career-timeline/` },
      { label: `${name}'s Stats`, href: `/players/${slug}/stats/` },
      { label: `${name}'s Net Worth`, href: `/players/${slug}/net-worth/` },
      { label: 'Records', href: '/records/' },
    ]}
  />
</ArticleLayout>

<style>
  .gs-banner {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
    gap: 16px;
    background: linear-gradient(135deg, #065f46 0%, #047857 100%);
    border-radius: var(--radius);
    padding: 24px;
    margin-bottom: 32px;
    color: white;
  }
  .gs-stat { text-align: center; }
  .gs-stat--big .gs-stat-value { font-size: 2.5rem; }
  .gs-stat-label {
    display: block;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    opacity: 0.8;
    margin-top: 4px;
  }
  .gs-stat-value {
    display: block;
    font-family: var(--font-heading);
    font-size: 1.4rem;
    font-weight: 700;
  }
  .gs-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: 12px;
    margin: 20px 0;
  }
  .gs-tournament {
    background: var(--gray-50);
    border: 1px solid var(--gray-200);
    border-radius: var(--radius);
    padding: 16px;
    text-align: center;
  }
  .gs-emoji { font-size: 1.5rem; margin-bottom: 4px; }
  .gs-name { font-weight: 700; font-size: 0.9rem; color: var(--gray-900); }
  .gs-surface { font-size: 0.75rem; color: var(--gray-500); margin-top: 4px; }
  .gs-tournament--ao { border-top: 3px solid #2563eb; }
  .gs-tournament--rg { border-top: 3px solid #dc6b20; }
  .gs-tournament--wim { border-top: 3px solid #16a34a; }
  .gs-tournament--uso { border-top: 3px solid #7c3aed; }
  @media (max-width: 480px) {
    .gs-banner { grid-template-columns: 1fr 1fr; }
    .gs-grid { grid-template-columns: 1fr 1fr; }
  }
</style>
