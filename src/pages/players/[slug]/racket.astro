---
import ArticleLayout from '../../../layouts/ArticleLayout.astro';
import ArticleFooter from '../../../components/ArticleFooter.astro';
import { getPlayerBySlug, getTopPlayerSlugs, getArticleBySlug } from '../../../lib/supabase';
import { fallbackPlayers, countryNames, countryFlags, handLabels, getFlagUrl } from '../../../lib/fallback-data';
import { addInterlinks } from '../../../lib/interlinks';
import { marked } from 'marked';

export async function getStaticPaths() {
  let slugs: string[] = [];
  try {
    slugs = await getTopPlayerSlugs(50);
  } catch (e) {
    console.warn('racket getStaticPaths: Supabase unavailable');
  }

  const fbSlugs = Object.keys(fallbackPlayers);
  const allSlugs = [...new Set([...slugs, ...fbSlugs])];

  return allSlugs.map(slug => ({ params: { slug } }));
}

const { slug } = Astro.params;

let player = await getPlayerBySlug(slug as string);
if (!player) {
  player = fallbackPlayers[slug as string] || null;
}

if (!player) {
  return Astro.redirect('/players/');
}

const name = `${player.first_name} ${player.last_name}`;
const country = countryNames[player.country_code || ''] || player.country_code || '';
const flag = countryFlags[player.country_code || ''] || '🏳️';
const hand = handLabels[player.hand || ''] || player.hand || 'Unknown';

// Try to find the racket article
const articleSlug = `${slug}-racket`;
let article: any = null;
try {
  article = await getArticleBySlug(articleSlug);
} catch (e) {
  console.warn(`racket: article not found for ${articleSlug}`);
}

const rawHtml = article?.body ? marked.parse(article.body) : null;
const bodyHtml = rawHtml ? await addInterlinks(rawHtml as string, `/players/${slug}/racket/`) : null;
const hasRichContent = !!bodyHtml;
---

<ArticleLayout
  title={`What Racket Does ${name} Use? — Equipment & Specs`}
  description={article?.meta_description || `What racket does ${name} use? Complete equipment setup, racket specs, strings, and gear for the ${player.tour === 'atp' ? 'ATP' : 'WTA'} star.`}
  breadcrumbs={[
    { label: 'Home', href: '/' },
    { label: 'Players', href: '/players/' },
    { label: name, href: `/players/${slug}/` },
    { label: 'Racket & Equipment' },
  ]}
  category="gear"
  categoryLabel="Gear"
  categoryHref="/gear/"
>
  {!hasRichContent && <meta name="robots" content="noindex, follow" />}

  <!-- Quick Facts Banner -->
  <div class="eq-banner">
    <div class="eq-stat">
      <span class="eq-stat-label">Playing Hand</span>
      <span class="eq-stat-value">{hand}</span>
    </div>
    {player.height_cm && (
      <div class="eq-stat">
        <span class="eq-stat-label">Height</span>
        <span class="eq-stat-value">{player.height_cm}cm</span>
      </div>
    )}
    <div class="eq-stat">
      <span class="eq-stat-label">Career Titles</span>
      <span class="eq-stat-value">{player.career_titles}</span>
    </div>
    <div class="eq-stat">
      <span class="eq-stat-label">Country</span>
      <span class="eq-stat-value">
        {getFlagUrl(player.country_code || '') ? (
          <img src={getFlagUrl(player.country_code || '')} alt={player.country_code || ''} class="stat-flag" width="20" height="15" loading="lazy" decoding="async" />
        ) : (
          <span>{flag}</span>
        )}
        {country}
      </span>
    </div>
  </div>

  {bodyHtml ? (
    <div set:html={bodyHtml} />
  ) : (
    <div class="placeholder-content">
      <h2>Equipment Setup</h2>
      <p>
        {name} is a {hand.toLowerCase()} {player.tour === 'atp' ? 'ATP' : 'WTA'} player
        from {country}{player.height_cm ? `, standing ${player.height_cm}cm tall` : ''}.
        With <strong>{player.career_titles} career titles</strong>, their equipment setup
        is dialed in for professional-level performance.
      </p>

      <h2>Pro Player Equipment Note</h2>
      <p>
        Professional tennis players typically use custom-specification rackets that may differ
        significantly from retail versions. While a racket may look like a commercially
        available model, the weight, balance, and string pattern are often customized
        to the player's exact preferences.
      </p>

      <h2>Similar Rackets for Recreational Players</h2>
      <p>
        If you want to play with a setup similar to {name}'s, look for rackets in the
        {player.tour === 'atp' ? '300-340g' : '280-310g'} range with a
        {hand === 'Left-Handed' ? ' frame suited for varied spins' : ' balanced control-power profile'}.
      </p>

      <p><em>Detailed equipment analysis coming soon. Check back for a complete breakdown of {name}'s racket, strings, and gear.</em></p>
    </div>
  )}

  <ArticleFooter
    backLabel={`${name}'s Profile`}
    backHref={`/players/${slug}/`}
    relatedLinks={[
      { label: `${name}'s Net Worth`, href: `/players/${slug}/net-worth/` },
      { label: 'All Players', href: '/players/' },
      { label: 'Gear Guides', href: '/gear/' },
      { label: 'Rankings', href: '/rankings/' },
    ]}
  />
</ArticleLayout>

<style>
  .eq-banner {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
    gap: 16px;
    background: var(--gray-50);
    border: 1px solid var(--gray-200);
    border-radius: var(--radius);
    padding: 20px;
    margin-bottom: 32px;
  }
  .eq-stat {
    text-align: center;
  }
  .eq-stat-label {
    display: block;
    font-size: 0.75rem;
    color: var(--gray-500);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 4px;
  }
  .eq-stat-value {
    display: block;
    font-family: var(--font-heading);
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--gray-900);
  }

  .placeholder-content {
    color: var(--gray-700);
  }

  .stat-flag {
    vertical-align: middle;
    margin-right: 4px;
    border-radius: 2px;
  }

  @media (max-width: 480px) {
    .eq-banner { grid-template-columns: 1fr 1fr; }
    .eq-stat-value { font-size: 1rem; }
  }
</style>
