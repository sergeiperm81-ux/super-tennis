---
import ArticleLayout from '../../../layouts/ArticleLayout.astro';
import ArticleFooter from '../../../components/ArticleFooter.astro';
import { getPlayerBySlug, getTopPlayerSlugs } from '../../../lib/supabase';
import { fallbackPlayers, countryNames, countryFlags, getFlagUrl } from '../../../lib/fallback-data';

export async function getStaticPaths() {
  let slugs: string[] = [];
  try {
    slugs = await getTopPlayerSlugs(100);
  } catch (e) {
    console.warn('stats getStaticPaths: Supabase unavailable');
  }

  const fbSlugs = Object.keys(fallbackPlayers);
  const allSlugs = [...new Set([...slugs, ...fbSlugs])];

  return allSlugs.map(slug => ({ params: { slug } }));
}

const { slug } = Astro.params;

let player = await getPlayerBySlug(slug as string);
if (!player) {
  player = fallbackPlayers[slug as string] || null;
}

if (!player) {
  return Astro.redirect('/players/');
}

const name = `${player.first_name} ${player.last_name}`;
const country = countryNames[player.country_code || ''] || player.country_code || '';
const isWTA = player.tour === 'wta';
const pronoun = isWTA ? 'she' : 'he';
const possessive = isWTA ? 'her' : 'his';

// Calculate age
function getAge(birthDate: string | null): string {
  if (!birthDate) return 'N/A';
  const birth = new Date(birthDate);
  const now = new Date();
  let age = now.getFullYear() - birth.getFullYear();
  const monthDiff = now.getMonth() - birth.getMonth();
  if (monthDiff < 0 || (monthDiff === 0 && now.getDate() < birth.getDate())) age--;
  return String(age);
}

// Win percentage
const totalMatches = player.career_win + player.career_loss;
const winPctNum = totalMatches > 0 ? (player.career_win / totalMatches) * 100 : 0;
const winPct = totalMatches > 0 ? winPctNum.toFixed(1) : 'N/A';

// Prize money
function formatPrize(amount: number): string {
  if (!amount) return 'N/A';
  if (amount >= 1_000_000) return `$${(amount / 1_000_000).toFixed(1)}M`;
  if (amount >= 1_000) return `$${(amount / 1_000).toFixed(0)}K`;
  return `$${amount}`;
}

const prizeMoney = formatPrize(player.career_prize_usd || 0);
const age = getAge(player.birth_date);

// Height
function formatHeight(cm: number | null): string {
  if (!cm) return 'N/A';
  const feet = Math.floor(cm / 30.48);
  const inches = Math.round((cm / 2.54) % 12);
  return cm + ' cm (' + feet + "'" + inches + '")';
}

const height = formatHeight(player.height_cm);
const handLabel = player.hand === 'R' ? 'Right-Handed' : player.hand === 'L' ? 'Left-Handed' : 'Ambidextrous';
const tourName = player.tour === 'atp' ? 'ATP' : 'WTA';
const ageDesc = age !== 'N/A' ? `a ${age}-year-old` : 'a';
const gsDesc = player.grand_slam_titles > 0
  ? ` ${pronoun.charAt(0).toUpperCase() + pronoun.slice(1)} has won ${player.grand_slam_titles} Grand Slam title${player.grand_slam_titles > 1 ? 's' : ''}, placing ${pronoun === 'she' ? 'her' : 'him'} among the greatest players in tennis history.`
  : '';
const gsShort = player.grand_slam_titles > 0 ? `, including ${player.grand_slam_titles} Grand Slam${player.grand_slam_titles > 1 ? 's' : ''}` : '';
const lossWidth = 100 - parseFloat(winPct as string);
const pageTitle = `${name} Career Stats — Titles, Win-Loss Record & Rankings`;
const pageDesc = `${name} career statistics: ${player.career_titles} titles, ${player.career_win}-${player.career_loss} win-loss record (${winPct}%), ${player.grand_slam_titles} Grand Slams, ${prizeMoney} prize money.`;
const playerHref = `/players/${slug}/`;
const ageDisplay = age !== 'N/A' ? `${age} years old` : 'N/A';
const backLabel = `${name}'s Profile`;
const nwLabel = `${name}'s Net Worth`;
const nwHref = `/players/${slug}/net-worth/`;
const racketLabel = `${name}'s Racket`;
const racketHref = `/players/${slug}/racket/`;
const ageLabel = `${name}'s Age & Bio`;
const ageHref = `/players/${slug}/age/`;
const faqTitles = `How many titles has ${name} won?`;
const faqTitlesAnswer = `${name} has won ${player.career_titles} career titles${gsShort}.`;
const faqWL = `What is ${name}'s win-loss record?`;
const faqWLAnswer = `${name}'s career record is ${player.career_win}-${player.career_loss} (${winPct}% win rate).`;
const faqPrize = `How much has ${name} earned in prize money?`;
const faqPrizeAnswer = `${name} has earned ${prizeMoney} in career prize money on the ${tourName} Tour.`;
const winsWidth = `width: ${winPct}%`;
const lossesWidth = `width: ${lossWidth}%`;
---

<ArticleLayout
  title={pageTitle}
  description={pageDesc}
  breadcrumbs={[
    { label: 'Home', href: '/' },
    { label: 'Players', href: '/players/' },
    { label: name, href: playerHref },
    { label: 'Career Stats' },
  ]}
  category="players"
>
  <!-- Stats Hero -->
  <div class="stats-hero">
    <div class="stat-big">
      <span class="stat-big-value">{player.career_titles}</span>
      <span class="stat-big-label">Career Titles</span>
    </div>
    <div class="stat-big gs">
      <span class="stat-big-value">{player.grand_slam_titles}</span>
      <span class="stat-big-label">Grand Slams</span>
    </div>
    <div class="stat-big">
      <span class="stat-big-value">{winPct}%</span>
      <span class="stat-big-label">Win Rate</span>
    </div>
    <div class="stat-big">
      <span class="stat-big-value">{prizeMoney}</span>
      <span class="stat-big-label">Prize Money</span>
    </div>
  </div>

  <!-- Full Stats Table -->
  <h2>Career Statistics</h2>
  <div class="stats-table-wrap">
    <table class="stats-table">
      <tbody>
        <tr>
          <td class="st-label">Full Name</td>
          <td class="st-value">{name}</td>
        </tr>
        <tr>
          <td class="st-label">Age</td>
          <td class="st-value">{ageDisplay}</td>
        </tr>
        <tr>
          <td class="st-label">Country</td>
          <td class="st-value">
            {getFlagUrl(player.country_code || '') ? (
              <img src={getFlagUrl(player.country_code || '')} alt={country} class="st-flag" width="20" height="15" loading="lazy" />
            ) : null}
            {country}
          </td>
        </tr>
        <tr>
          <td class="st-label">Height</td>
          <td class="st-value">{height}</td>
        </tr>
        <tr>
          <td class="st-label">Playing Hand</td>
          <td class="st-value">{handLabel}</td>
        </tr>
        <tr>
          <td class="st-label">Tour</td>
          <td class="st-value">{player.tour === 'atp' ? 'ATP' : 'WTA'}</td>
        </tr>
        <tr class="highlight">
          <td class="st-label">Career Titles</td>
          <td class="st-value"><strong>{player.career_titles}</strong></td>
        </tr>
        <tr class="highlight">
          <td class="st-label">Grand Slam Titles</td>
          <td class="st-value"><strong>{player.grand_slam_titles}</strong></td>
        </tr>
        <tr>
          <td class="st-label">Career Wins</td>
          <td class="st-value">{player.career_win}</td>
        </tr>
        <tr>
          <td class="st-label">Career Losses</td>
          <td class="st-value">{player.career_loss}</td>
        </tr>
        <tr class="highlight">
          <td class="st-label">Win-Loss Record</td>
          <td class="st-value"><strong>{player.career_win}-{player.career_loss}</strong> ({winPct}%)</td>
        </tr>
        <tr class="highlight">
          <td class="st-label">Career Prize Money</td>
          <td class="st-value"><strong>{prizeMoney}</strong></td>
        </tr>
        <tr>
          <td class="st-label">Status</td>
          <td class="st-value">{player.is_active ? '🟢 Active' : '🔴 Retired'}</td>
        </tr>
      </tbody>
    </table>
  </div>

  <h2>Career Overview</h2>
  <p>
    {name} is {ageDesc} {country} tennis player
    with {player.career_titles} career titles to {possessive} name.
    {gsDesc}
  </p>
  <p>
    With a career win-loss record of <strong>{player.career_win}-{player.career_loss}</strong> ({winPct}% win rate),
    {player.first_name} has earned <strong>{prizeMoney}</strong> in career prize money on the {tourName} Tour.
  </p>

  {totalMatches > 0 && (
    <>
      <h2>Win-Loss Breakdown</h2>
      <div class="wl-visual">
        <div class="wl-bar">
          <div class="wl-wins" style={winsWidth}>
            <span>{player.career_win}W</span>
          </div>
          <div class="wl-losses" style={lossesWidth}>
            <span>{player.career_loss}L</span>
          </div>
        </div>
      </div>
    </>
  )}

  <!-- FAQ -->
  <div class="faq-section">
    <h2>Frequently Asked Questions</h2>
    <div class="faq-item">
      <h3>How many titles has {name} won?</h3>
      <p>{name} has won {player.career_titles} career titles{gsShort}.</p>
    </div>
    <div class="faq-item">
      <h3>What is {name}'s win-loss record?</h3>
      <p>{name}'s career record is {player.career_win}-{player.career_loss} ({winPct}% win rate).</p>
    </div>
    <div class="faq-item">
      <h3>How much has {name} earned in prize money?</h3>
      <p>{name} has earned {prizeMoney} in career prize money on the {tourName} Tour.</p>
    </div>
  </div>

  <!-- FAQPage JSON-LD -->
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      { '@type': 'Question', name: faqTitles, acceptedAnswer: { '@type': 'Answer', text: faqTitlesAnswer } },
      { '@type': 'Question', name: faqWL, acceptedAnswer: { '@type': 'Answer', text: faqWLAnswer } },
      { '@type': 'Question', name: faqPrize, acceptedAnswer: { '@type': 'Answer', text: faqPrizeAnswer } },
    ],
  })} />

  <ArticleFooter
    backLabel={backLabel}
    backHref={playerHref}
    relatedLinks={[
      { label: nwLabel, href: nwHref },
      { label: racketLabel, href: racketHref },
      { label: ageLabel, href: ageHref },
      { label: 'Rankings', href: '/rankings/' },
    ]}
  />
</ArticleLayout>

<style>
  .stats-hero {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
    margin-bottom: 32px;
  }
  .stat-big {
    text-align: center;
    background: var(--gray-50);
    border: 1px solid var(--gray-200);
    border-radius: var(--radius);
    padding: 20px 12px;
  }
  .stat-big.gs {
    background: linear-gradient(135deg, #fffbeb, #fef3c7);
    border-color: #d4a017;
  }
  .stat-big-value {
    display: block;
    font-family: var(--font-heading);
    font-size: 2rem;
    font-weight: 800;
    color: var(--gray-900);
    line-height: 1.1;
  }
  .stat-big.gs .stat-big-value { color: #b8860b; }
  .stat-big-label {
    display: block;
    font-size: 0.7rem;
    color: var(--gray-500);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-top: 6px;
  }

  .stats-table-wrap {
    margin-bottom: 32px;
    overflow-x: auto;
  }
  .stats-table {
    width: 100%;
    border-collapse: collapse;
  }
  .stats-table tr {
    border-bottom: 1px solid var(--gray-100);
  }
  .stats-table tr:hover {
    background: var(--gray-50);
  }
  .stats-table tr.highlight {
    background: #f0fdf4;
  }
  .st-label {
    font-weight: 600;
    color: var(--gray-500);
    text-transform: uppercase;
    font-size: 0.75rem;
    letter-spacing: 0.05em;
    padding: 12px 16px;
    width: 160px;
  }
  .st-value {
    padding: 12px 16px;
    font-size: 1rem;
    color: var(--gray-900);
  }
  .st-flag {
    vertical-align: middle;
    margin-right: 6px;
    border-radius: 2px;
  }

  .wl-visual {
    margin: 16px 0 32px;
  }
  .wl-bar {
    display: flex;
    height: 40px;
    border-radius: var(--radius);
    overflow: hidden;
    font-size: 0.85rem;
    font-weight: 700;
  }
  .wl-wins {
    background: #16a34a;
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 40px;
  }
  .wl-losses {
    background: #dc2626;
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 40px;
  }

  .faq-section {
    margin-top: 48px;
    border-top: 1px solid var(--gray-200);
    padding-top: 32px;
  }
  .faq-item {
    margin-bottom: 24px;
  }
  .faq-item h3 {
    font-size: 1.1rem;
    color: var(--gray-900);
    margin-bottom: 8px;
  }
  .faq-item p {
    color: var(--gray-600);
    line-height: 1.6;
  }

  @media (max-width: 600px) {
    .stats-hero { grid-template-columns: 1fr 1fr; }
    .stat-big-value { font-size: 1.5rem; }
    .st-label { width: 120px; }
  }
</style>
