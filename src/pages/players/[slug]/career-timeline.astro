---
import ArticleLayout from '../../../layouts/ArticleLayout.astro';
import ArticleFooter from '../../../components/ArticleFooter.astro';
import { getPlayerBySlug, getTopPlayerSlugs, getArticleBySlug } from '../../../lib/supabase';
import { fallbackPlayers, countryNames, countryFlags, handLabels, getFlagUrl } from '../../../lib/fallback-data';
import { addInterlinks } from '../../../lib/interlinks';
import { marked } from 'marked';

export async function getStaticPaths() {
  let slugs: string[] = [];
  try {
    slugs = await getTopPlayerSlugs(100);
  } catch (e) {
    console.warn('career-timeline getStaticPaths: Supabase unavailable');
  }

  const fbSlugs = Object.keys(fallbackPlayers);
  const allSlugs = [...new Set([...slugs, ...fbSlugs])];

  return allSlugs.map(slug => ({ params: { slug } }));
}

const { slug } = Astro.params;

let player = await getPlayerBySlug(slug as string);
if (!player) {
  player = fallbackPlayers[slug as string] || null;
}

if (!player) {
  return Astro.redirect('/players/');
}

const name = `${player.first_name} ${player.last_name}`;
const country = countryNames[player.country_code || ''] || player.country_code || '';
const flag = countryFlags[player.country_code || ''] || '';
const hand = handLabels[player.hand || ''] || player.hand || 'Unknown';
const tour = player.tour === 'atp' ? 'ATP' : 'WTA';

// Try to find the career timeline article
const articleSlug = `${slug}-career-timeline`;
let article: any = null;
try {
  article = await getArticleBySlug(articleSlug);
} catch (e) {}

const rawHtml = article?.body ? marked.parse(article.body) : null;
const bodyHtml = rawHtml ? await addInterlinks(rawHtml as string, `/players/${slug}/career-timeline/`) : null;
const hasRichContent = !!bodyHtml;

// Build career milestones from available data
const milestones: { year: string; event: string }[] = [];

if (player.birth_date) {
  const birthYear = new Date(player.birth_date).getFullYear();
  milestones.push({ year: String(birthYear), event: `Born in ${country}` });
  milestones.push({ year: String(birthYear + 5), event: 'Started playing tennis (estimated)' });
}

if (player.pro_since) {
  milestones.push({ year: String(player.pro_since), event: `Turned professional on the ${tour} Tour` });
}

if (player.career_high_rank && player.career_high_date) {
  const year = String(player.career_high_date).slice(0, 4);
  milestones.push({ year, event: `Reached career-high ranking of No. ${player.career_high_rank}` });
}

if (player.grand_slam_titles && player.grand_slam_titles > 0) {
  milestones.push({ year: '—', event: `Won ${player.grand_slam_titles} Grand Slam title${player.grand_slam_titles > 1 ? 's' : ''}` });
}

if (player.career_titles && player.career_titles > 0) {
  milestones.push({ year: '—', event: `${player.career_titles} career titles and counting` });
}

milestones.sort((a, b) => {
  if (a.year === '—') return 1;
  if (b.year === '—') return -1;
  return Number(a.year) - Number(b.year);
});

// JSON-LD
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: `${name} Career Timeline — Key Moments & Milestones`,
  description: `Complete career timeline for ${name}. Key milestones, turning points, and achievements throughout their ${tour} career.`,
  about: {
    '@type': 'Person',
    name,
    nationality: country,
    jobTitle: 'Professional Tennis Player',
  },
};
---

<ArticleLayout
  title={`${name} Career Timeline — Key Moments & Milestones`}
  description={article?.meta_description || `Complete career timeline for ${name}. Key milestones, Grand Slam results, and turning points in their ${tour} career.`}
  breadcrumbs={[
    { label: 'Home', href: '/' },
    { label: 'Players', href: '/players/' },
    { label: name, href: `/players/${slug}/` },
    { label: 'Career Timeline' },
  ]}
>
  {!hasRichContent && <meta name="robots" content="noindex, follow" />}

  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <!-- Quick Stats -->
  <div class="timeline-stats">
    <div class="stat">
      <span class="stat-label">Turned Pro</span>
      <span class="stat-value">{player.pro_since || 'N/A'}</span>
    </div>
    <div class="stat">
      <span class="stat-label">Career Titles</span>
      <span class="stat-value">{player.career_titles || 0}</span>
    </div>
    <div class="stat">
      <span class="stat-label">Grand Slams</span>
      <span class="stat-value">{player.grand_slam_titles || 0}</span>
    </div>
    <div class="stat">
      <span class="stat-label">Highest Rank</span>
      <span class="stat-value">No. {player.career_high_rank || '—'}</span>
    </div>
  </div>

  {bodyHtml ? (
    <div set:html={bodyHtml} />
  ) : (
    <>
      <!-- Auto-generated timeline -->
      <h2>Career Milestones</h2>
      <div class="timeline">
        {milestones.map(m => (
          <div class="timeline-item">
            <div class="timeline-year">{m.year}</div>
            <div class="timeline-event">{m.event}</div>
          </div>
        ))}
      </div>

      <h2>Career Overview</h2>
      <p>
        {name} is a {hand.toLowerCase()} {tour} professional tennis player
        from {country}. {player.pro_since ? `Turning professional in ${player.pro_since}, ` : ''}
        {name} has accumulated <strong>{player.career_titles || 0} career titles</strong>
        {player.grand_slam_titles ? `, including ${player.grand_slam_titles} Grand Slam title${player.grand_slam_titles > 1 ? 's' : ''}` : ''}
        and reached a career-high ranking of <strong>No. {player.career_high_rank || '—'}</strong>.
      </p>

      <h2>Playing Style & Legacy</h2>
      <p>
        Known for their {hand === 'Left-Handed' ? 'left-handed game and unique angles' : 'powerful all-court game'},
        {name} has been a significant figure on the {tour} Tour.
        {player.career_titles >= 10 ? ` With ${player.career_titles} titles, they rank among the most decorated players of their generation.` : ''}
      </p>

      <p><em>Detailed career timeline coming soon with match-by-match highlights and key turning points.</em></p>
    </>
  )}

  <ArticleFooter
    backLabel={`${name}'s Profile`}
    backHref={`/players/${slug}/`}
    relatedLinks={[
      { label: `${name}'s Stats`, href: `/players/${slug}/stats/` },
      { label: `${name}'s Net Worth`, href: `/players/${slug}/net-worth/` },
      { label: `${name}'s Racket`, href: `/players/${slug}/racket/` },
      { label: 'All Players', href: '/players/' },
    ]}
  />
</ArticleLayout>

<style>
  .timeline-stats {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
    gap: 16px;
    background: var(--gray-50);
    border: 1px solid var(--gray-200);
    border-radius: var(--radius);
    padding: 20px;
    margin-bottom: 32px;
  }
  .stat { text-align: center; }
  .stat-label {
    display: block;
    font-size: 0.75rem;
    color: var(--gray-500);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 4px;
  }
  .stat-value {
    display: block;
    font-family: var(--font-heading);
    font-size: 1.3rem;
    font-weight: 700;
    color: var(--gray-900);
  }
  .timeline {
    position: relative;
    padding-left: 32px;
    margin: 24px 0;
  }
  .timeline::before {
    content: '';
    position: absolute;
    left: 8px;
    top: 0;
    bottom: 0;
    width: 2px;
    background: var(--gray-200);
  }
  .timeline-item {
    position: relative;
    padding: 12px 0;
    display: flex;
    gap: 16px;
    align-items: baseline;
  }
  .timeline-item::before {
    content: '';
    position: absolute;
    left: -28px;
    top: 18px;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--court-green, #16a34a);
    border: 2px solid white;
    box-shadow: 0 0 0 2px var(--gray-200);
  }
  .timeline-year {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 1.1rem;
    color: var(--gray-900);
    min-width: 50px;
  }
  .timeline-event {
    color: var(--gray-700);
    line-height: 1.5;
  }
  @media (max-width: 480px) {
    .timeline-stats { grid-template-columns: 1fr 1fr; }
  }
</style>
