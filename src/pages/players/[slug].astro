        )}

        {articles['age'].exists && (
          <div class="age-section">
            <h3>Age & Life Facts</h3>
            <div class="article-content" set:html={articles['age'].html} />
          </div>
        )}
      </div>

      <!-- Sidebar -->
      <aside class="sidebar">
        <!-- Table of Contents -->
        <div class="sidebar-widget toc-widget">
          <h3>📑 Contents</h3>
          <nav class="toc-nav">
            <a href="#facts" class="toc-link">Quick Facts</a>
            <a href="#achievements" class="toc-link">Achievements</a>
            <a href="#biography" class="toc-link">Biography</a>
            {articles['racket'].exists && <a href="#equipment" class="toc-link">Equipment</a>}
            {articles['net-worth'].exists && <a href="#finance" class="toc-link">Earnings</a>}
            {articles['partner'].exists && <a href="#personal" class="toc-link">Personal Life</a>}
          </nav>
        </div>

        <!-- Compare Player -->
        <div class="sidebar-widget compare-widget">
          <h3>⚖️ Compare</h3>
          <p class="compare-text">Compare stats with another player</p>
          <a href={`/vs/${player.slug}-vs-${relatedSlugs[0]?.slug || 'nadal'}/`} class="compare-btn">
            Compare with {relatedSlugs[0]?.last_name || 'Nadal'} →
          </a>
        </div>

        <!-- Share Buttons -->
        <div class="sidebar-widget share-widget">
          <h3>📤 Share</h3>
          <div class="share-buttons">
            <a href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(`Check out ${player.first_name} ${player.last_name}'s profile on SUPER.TENNIS`)}&url=https://super.tennis/players/${player.slug}/`} target="_blank" rel="noopener noreferrer" class="share-btn twitter" title="Share on Twitter">𝕏</a>
            <a href={`https://www.linkedin.com/sharing/share-offsite/?url=https://super.tennis/players/${player.slug}/`} target="_blank" rel="noopener noreferrer" class="share-btn linkedin" title="Share on LinkedIn">in</a>
            <a href={`https://reddit.com/submit?url=https://super.tennis/players/${player.slug}/&title=${encodeURIComponent(player.first_name + ' ' + player.last_name)}`} target="_blank" rel="noopener noreferrer" class="share-btn reddit" title="Share on Reddit">🔗</a>
          </div>
        </div>

        <!-- Similar Players -->
        <div class="sidebar-widget">
          <h3>👥 Similar Players</h3>
          <div class="similar-players">
            {relatedSlugs.map((p: any) => (
              <a href={`/players/${p.slug}/`} class="similar-player">
                <img
                  src={p.image_url}
                  alt={`${p.first_name} ${p.last_name}`}
                  width="48"
                  height="48"
                  loading="lazy"
                />
                <div>
                  <span class="sp-name">{p.first_name} <strong>{p.last_name}</strong></span>
                  <span class="sp-country">
                    {getFlagUrl(p.country_code || '') ? (
                      <img src={getFlagUrl(p.country_code || '', 16)} alt={p.country_code || ''} class="sp-flag" width="16" height="12" loading="lazy" decoding="async" />
                    ) : null}
                    {countryNames[p.country_code || ''] || p.country_code || ''}
                  </span>
                </div>
              </a>
            ))}
          </div>
        </div>

        {playerH2h.length > 0 && (
          <div class="sidebar-widget">
            <h3>⚔️ Head to Head</h3>
            <div class="h2h-links">
              {playerH2h.map(h => (
                <a href={`/vs/${h.slug}/`} class="h2h-link">
                  <span class="h2h-icon">vs</span>
                  <span>{player.last_name} {h.vs}</span>
                </a>
              ))}
              <a href="/vs/" class="h2h-link h2h-all">
                <span>All Rivalries →</span>
              </a>
            </div>
          </div>
        )}

        <div class="sidebar-widget">
          <h3>🔗 Quick Links</h3>
          <ul class="quick-links">
            <li><a href="/rankings/">{tourLabel} Rankings</a></li>
            <li><a href="/records/">Tennis Records</a></li>
            <li><a href="/vs/">Head to Head</a></li>
            <li><a href="/gear/">Gear Guides</a></li>
            <li><a href="/tournaments/">Tournaments</a></li>
            <li><a href="/players/">All Players</a></li>
          </ul>
        </div>
      </aside>
    </div>
  </article>
</BaseLayout>

<style>
