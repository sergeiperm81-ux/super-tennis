---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getPlayerBySlug, getTopPlayerSlugs, getRelatedPlayers, getArticleBySlug } from '../../lib/supabase';
import { fallbackPlayers, countryFlags, countryNames, handLabels, getFlagUrl } from '../../lib/fallback-data';
import { addInterlinks } from '../../lib/interlinks';
import { marked } from 'marked';

// SSG: generate paths for all top players from Supabase + fallback
export async function getStaticPaths() {
  // Try to get slugs from Supabase (top 100 ATP + top 100 WTA by career titles)
  let dbSlugs: string[] = [];
  try {
    const { getTopPlayerSlugs: getSlugs } = await import('../../lib/supabase');
    dbSlugs = await getSlugs(100);
  } catch (e) {
    console.warn('getStaticPaths: Supabase unavailable, using fallback slugs');
  }

  // Always include fallback slugs as safety net
  const fbMod = await import('../../lib/fallback-data');
  const fallbackSlugs = Object.keys(fbMod.fallbackPlayers);

  const allSlugs = [...new Set([...dbSlugs, ...fallbackSlugs])];

  return allSlugs.map(slug => ({
    params: { slug },
  }));
}

const { slug } = Astro.params;

// Try Supabase first, fall back to hardcoded data
let player = await getPlayerBySlug(slug as string);
if (!player) {
  player = fallbackPlayers[slug as string] || null;
}

if (!player) {
  return Astro.redirect('/players/');
}

// Calculate age
function getAge(birthDate: string | null): number | null {
  if (!birthDate) return null;
  const birth = new Date(birthDate);
  const today = new Date();
  let age = today.getFullYear() - birth.getFullYear();
  const m = today.getMonth() - birth.getMonth();
  if (m < 0 || (m === 0 && today.getDate() < birth.getDate())) age--;
  return age;
}

const age = getAge(player.birth_date);
const winPct = player.career_win && player.career_loss
  ? ((player.career_win / (player.career_win + player.career_loss)) * 100).toFixed(1)
  : null;
const flag = countryFlags[player.country_code || ''] || '🏳️';
const flagImg = getFlagUrl(player.country_code || '', 40);
const country = countryNames[player.country_code || ''] || player.country_code || 'Unknown';
const tourLabel = player.tour === 'atp' ? 'ATP' : 'WTA';
const tourColor = player.tour === 'atp' ? '#003580' : '#7b2d8e';

// JSON-LD structured data
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: `${player.first_name} ${player.last_name}`,
  url: `https://super.tennis/players/${player.slug}/`,
  image: player.image_url,
  nationality: { '@type': 'Country', name: country },
  birthDate: player.birth_date || undefined,
  height: player.height_cm ? { '@type': 'QuantitativeValue', value: player.height_cm, unitCode: 'CMT' } : undefined,
  description: player.bio_short || `Professional tennis player from ${country}`,
  sport: 'Tennis',
};

// Format prize money
function formatPrize(amount: number): string {
  if (amount >= 1_000_000) return `$${(amount / 1_000_000).toFixed(1)}M`;
  if (amount >= 1_000) return `$${(amount / 1_000).toFixed(0)}K`;
  return `$${amount}`;
}

// Related players (same tour, for sidebar)
let relatedSlugs: any[] = [];
try {
  relatedSlugs = await getRelatedPlayers(player.tour, player.slug, 4);
} catch (e) {
  // Fallback to hardcoded related players
}
if (relatedSlugs.length === 0) {
  relatedSlugs = Object.values(fallbackPlayers)
    .filter((p: any) => p.tour === player.tour && p.slug !== player.slug)
    .slice(0, 4);
}

// H2H rivalry links
const h2hMap: Record<string, { slug: string; vs: string }[]> = {
  'novak-djokovic': [
    { slug: 'djokovic-vs-nadal', vs: 'vs Nadal' },
    { slug: 'djokovic-vs-federer', vs: 'vs Federer' },
    { slug: 'djokovic-vs-alcaraz', vs: 'vs Alcaraz' },
    { slug: 'djokovic-vs-murray', vs: 'vs Murray' },
  ],
  'rafael-nadal': [
    { slug: 'djokovic-vs-nadal', vs: 'vs Djokovic' },
    { slug: 'federer-vs-nadal', vs: 'vs Federer' },
  ],
  'roger-federer': [
    { slug: 'federer-vs-nadal', vs: 'vs Nadal' },
    { slug: 'djokovic-vs-federer', vs: 'vs Djokovic' },
    { slug: 'federer-vs-murray', vs: 'vs Murray' },
  ],
  'carlos-alcaraz': [
    { slug: 'alcaraz-vs-sinner', vs: 'vs Sinner' },
    { slug: 'djokovic-vs-alcaraz', vs: 'vs Djokovic' },
    { slug: 'zverev-vs-alcaraz', vs: 'vs Zverev' },
  ],
  'jannik-sinner': [
    { slug: 'alcaraz-vs-sinner', vs: 'vs Alcaraz' },
    { slug: 'medvedev-vs-sinner', vs: 'vs Medvedev' },
  ],
  'alexander-zverev': [{ slug: 'zverev-vs-alcaraz', vs: 'vs Alcaraz' }],
  'daniil-medvedev': [
    { slug: 'medvedev-vs-sinner', vs: 'vs Sinner' },
    { slug: 'tsitsipas-vs-medvedev', vs: 'vs Tsitsipas' },
  ],
  'andy-murray': [
    { slug: 'djokovic-vs-murray', vs: 'vs Djokovic' },
    { slug: 'federer-vs-murray', vs: 'vs Federer' },
  ],
  'iga-swiatek': [
    { slug: 'swiatek-vs-sabalenka', vs: 'vs Sabalenka' },
    { slug: 'gauff-vs-swiatek', vs: 'vs Gauff' },
  ],
  'aryna-sabalenka': [{ slug: 'swiatek-vs-sabalenka', vs: 'vs Swiatek' }],
  'coco-gauff': [{ slug: 'gauff-vs-swiatek', vs: 'vs Swiatek' }],
  'serena-williams': [
    { slug: 'williams-vs-williams', vs: 'vs Venus' },
    { slug: 'sharapova-vs-williams', vs: 'vs Sharapova' },
  ],
  'nick-kyrgios': [{ slug: 'kyrgios-vs-djokovic', vs: 'vs Djokovic' }],
};
const playerH2h = h2hMap[slug as string] || [];

// Load all article sections (profile, stats, grand-slams, career-timeline, net-worth, racket, partner, age)
const articleSlugs = ['profile', 'stats', 'grand-slams', 'career-timeline', 'net-worth', 'racket', 'partner', 'age'];
const articles: Record<string, { html: string | null; exists: boolean }> = {};

for (const articleType of articleSlugs) {
  const slug = articleType === 'profile' ? player.slug : `${player.slug}-${articleType}`;
  let html: string | null = null;
  try {
    const article = await getArticleBySlug(slug);
    if (article?.body) {
      const rawHtml = marked.parse(article.body) as string;
      html = await addInterlinks(rawHtml, `/players/${player.slug}/`);
    }
  } catch (e) {
    // Article not found
  }
  articles[articleType] = { html, exists: !!html };
}

const profileArticleHtml = articles['profile'].html;
---

<BaseLayout
  title={`${player.first_name} ${player.last_name} — Height, Age, Stats & Bio${player.height_cm ? ` | ${player.height_cm}cm` : ''}`}
  description={player.bio_short || `${player.first_name} ${player.last_name}${age ? `, age ${age}` : ''}${player.height_cm ? `, height ${player.height_cm}cm (${Math.floor(player.height_cm / 30.48)}'${Math.round((player.height_cm % 30.48) / 2.54)}")` : ''} — ${player.tour === 'atp' ? 'ATP' : 'WTA'} tennis player from ${country}. Career stats, rankings, net worth, and racket on SUPER.TENNIS.`}
  ogImage={player.image_url || '/og/players.png'}
>
  <!-- JSON-LD -->
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://super.tennis/' },
      { '@type': 'ListItem', position: 2, name: 'Players', item: 'https://super.tennis/players/' },
      { '@type': 'ListItem', position: 3, name: `${player.first_name} ${player.last_name}` },
    ]
  })} />

  <article class="player-profile">
    <!-- Breadcrumbs -->
    <nav class="breadcrumbs">
      <a href="/">Home</a>
      <span class="sep">/</span>
      <a href="/players/">Players</a>
      <span class="sep">/</span>
      <span class="current">{player.first_name} {player.last_name}</span>
    </nav>

    <!-- Hero Section -->
    <section class="hero">
      <div class="hero-photo">
        <img
          src={player.image_url || '/placeholder-player.svg'}
          alt={`${player.first_name} ${player.last_name}`}
          width="400"
          height="400"
          loading="eager"
          decoding="async"
        />
        <span class="tour-badge" style={`background: ${tourColor}`}>{tourLabel}</span>
      </div>

      <div class="hero-info">
        <div class="hero-name-row">
          {flagImg ? (
            <img src={flagImg} alt={country} class="hero-flag-img" width="40" height="30" loading="eager" decoding="async" />
          ) : (
            <span class="hero-flag">{flag}</span>
          )}
          <h1>
            {player.first_name}
            <strong>{player.last_name}</strong>
          </h1>
        </div>
        <p class="hero-country">{country}</p>

        <div class="hero-stats">
          <div class="hero-stat">
            <span class="hero-stat-value">{player.career_titles}</span>
            <span class="hero-stat-label">Career Titles</span>
          </div>
          {player.grand_slam_titles > 0 && (
            <div class="hero-stat gs">
              <span class="hero-stat-value">{player.grand_slam_titles}</span>
              <span class="hero-stat-label">Grand Slams</span>
            </div>
          )}
          <div class="hero-stat">
            <span class="hero-stat-value">{player.career_win}-{player.career_loss}</span>
            <span class="hero-stat-label">Win-Loss ({winPct}%)</span>
          </div>
          {(player.career_prize_usd || 0) > 0 && (
            <div class="hero-stat">
              <span class="hero-stat-value">{formatPrize(player.career_prize_usd)}</span>
              <span class="hero-stat-label">Prize Money</span>
            </div>
          )}
        </div>
      </div>
    </section>

    <!-- Content Grid: Main + Sidebar -->
    <div class="content-grid">
      <div class="content-main">
        <!-- Quick Facts -->
        <section class="quick-facts" id="facts">
          <div class="section-header">
            <span class="section-icon">📋</span>
            <h2>Quick Facts</h2>
          </div>
          <div class="facts-grid">
            {age && (
              <div class="fact">
                <span class="fact-label">Age</span>
                <span class="fact-value">{age} years</span>
              </div>
            )}
            {player.birth_date && (
              <div class="fact">
                <span class="fact-label">Born</span>
                <span class="fact-value">{new Date(player.birth_date).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}</span>
              </div>
            )}
            {player.height_cm && (
              <div class="fact">
                <span class="fact-label">Height</span>
                <span class="fact-value">{player.height_cm} cm ({Math.floor(player.height_cm / 2.54 / 12)}'{Math.round(player.height_cm / 2.54 % 12)}")</span>
              </div>
            )}
            {player.hand && (
              <div class="fact">
                <span class="fact-label">Plays</span>
                <span class="fact-value">{handLabels[player.hand] || player.hand}</span>
              </div>
            )}
            <div class="fact">
              <span class="fact-label">Country</span>
              <span class="fact-value">
                {flagImg ? (
                  <img src={getFlagUrl(player.country_code || '', 20)} alt={player.country_code || ''} style="vertical-align:middle;margin-right:4px;border-radius:2px;" width="20" height="15" loading="lazy" decoding="async" />
                ) : null}
                {country}
              </span>
            </div>
            <div class="fact">
              <span class="fact-label">Tour</span>
              <span class="fact-value"><span class="mini-badge" style={`background: ${tourColor}`}>{tourLabel}</span></span>
            </div>
            {player.weight_kg && (
              <div class="fact">
                <span class="fact-label">Weight</span>
                <span class="fact-value">{player.weight_kg} kg ({Math.round(player.weight_kg * 2.205)} lbs)</span>
              </div>
            )}
            {player.birthplace && (
              <div class="fact">
                <span class="fact-label">Birthplace</span>
                <span class="fact-value">{player.birthplace}</span>
              </div>
            )}
            {player.coach && (
              <div class="fact">
                <span class="fact-label">Coach</span>
                <span class="fact-value">{player.coach}</span>
              </div>
            )}
            {player.backhand && (
              <div class="fact">
                <span class="fact-label">Backhand</span>
                <span class="fact-value" style="text-transform:capitalize">{player.backhand}</span>
              </div>
            )}
            {player.turned_pro && (
              <div class="fact">
                <span class="fact-label">Turned Pro</span>
                <span class="fact-value">{player.turned_pro}</span>
              </div>
            )}
            {player.best_ranking && (
              <div class="fact">
                <span class="fact-label">Career-High Ranking</span>
                <span class="fact-value">#{player.best_ranking}</span>
              </div>
            )}
          </div>

          {/* Social Media Links */}
          {(player.social_instagram || player.social_twitter || player.social_facebook) && (
            <div class="social-links">
              {player.social_instagram && (
                <a href={player.social_instagram} target="_blank" rel="noopener" class="social-link instagram" title="Instagram">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
                </a>
              )}
              {player.social_twitter && (
                <a href={player.social_twitter} target="_blank" rel="noopener" class="social-link twitter" title="X / Twitter">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                </a>
              )}
              {player.social_facebook && (
                <a href={player.social_facebook} target="_blank" rel="noopener" class="social-link facebook" title="Facebook">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
                </a>
              )}
            </div>
          )}
        </section>

        <!-- Achievements & Career Section -->
        <section class="section-group achievements" id="achievements">
          <div class="section-header">
            <span class="section-icon">🏆</span>
            <h2>Career Achievements</h2>
          </div>

          <!-- Key Highlight -->
          {player.grand_slam_titles > 0 && (
            <div class="key-highlight">
              <div class="highlight-value">{player.grand_slam_titles}</div>
              <div class="highlight-label">Grand Slam Titles</div>
              <div class="highlight-note">
                {player.grand_slam_titles === 24 ? '2nd All-Time Record' : `${Math.max(0, 24 - player.grand_slam_titles)} behind Nadal's record`}
              </div>
            </div>
          )}

          <!-- Career Stats Table -->
          <div class="stats-table">
            <table>
              <thead>
                <tr>
                  <th>Statistic</th>
                  <th>Value</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td>Career Titles</td>
                  <td class="stat-val">{player.career_titles}</td>
                </tr>
                {player.grand_slam_titles > 0 && (
                  <tr class="gs-row">
                    <td>Grand Slam Titles</td>
                    <td class="stat-val gs-val">{player.grand_slam_titles}</td>
                  </tr>
                )}
                <tr>
                  <td>Win-Loss Record</td>
                  <td class="stat-val">{player.career_win} - {player.career_loss}</td>
                </tr>
                {winPct && (
                  <tr>
                    <td>Win Percentage</td>
                    <td class="stat-val">{winPct}%</td>
                  </tr>
                )}
                {(player.career_prize_usd || 0) > 0 && (
                  <tr>
                    <td>Career Prize Money</td>
                    <td class="stat-val">${player.career_prize_usd.toLocaleString()}</td>
                  </tr>
                )}
              </tbody>
            </table>
          </div>

          {/* YTD Stats */}
          {(player.ytd_win > 0 || player.ytd_titles > 0) && (
            <div class="ytd-stats">
              <h3>2026 Season</h3>
              <div class="ytd-grid">
                {player.ytd_titles > 0 && (
                  <div class="ytd-item">
                    <span class="ytd-val">{player.ytd_titles}</span>
                    <span class="ytd-label">Titles</span>
                  </div>
                )}
                <div class="ytd-item">
                  <span class="ytd-val">{player.ytd_win}-{player.ytd_loss}</span>
                  <span class="ytd-label">W-L</span>
                </div>
                {(player.ytd_prize_usd || 0) > 0 && (
                  <div class="ytd-item">
                    <span class="ytd-val">{formatPrize(player.ytd_prize_usd)}</span>
                    <span class="ytd-label">Prize Money</span>
                  </div>
                )}
              </div>
            </div>
          )}

          {/* Serving & Return Stats */}
          {player.serve_1st_pct && (
            <div class="serve-return-stats" id="serve-stats">
              <h3>Serving & Return Stats</h3>
              <div class="sr-grid">
                <div class="sr-col">
                  <h4>Serve</h4>
                  {player.serve_aces != null && (
                    <div class="sr-row"><span class="sr-label">Aces</span><span class="sr-val">{player.serve_aces.toLocaleString()}</span></div>
                  )}
                  {player.serve_double_faults != null && (
                    <div class="sr-row"><span class="sr-label">Double Faults</span><span class="sr-val">{player.serve_double_faults.toLocaleString()}</span></div>
                  )}
                  {player.serve_1st_pct != null && (
                    <div class="sr-row"><span class="sr-label">1st Serve %</span><span class="sr-val">{player.serve_1st_pct}%</span></div>
                  )}
                  {player.serve_1st_won_pct != null && (
                    <div class="sr-row"><span class="sr-label">1st Serve Won</span><span class="sr-val">{player.serve_1st_won_pct}%</span></div>
                  )}
                  {player.serve_2nd_won_pct != null && (
                    <div class="sr-row"><span class="sr-label">2nd Serve Won</span><span class="sr-val">{player.serve_2nd_won_pct}%</span></div>
                  )}
                  {player.serve_bp_saved_pct != null && (
                    <div class="sr-row"><span class="sr-label">Break Points Saved</span><span class="sr-val">{player.serve_bp_saved_pct}%</span></div>
                  )}
                  {player.serve_hold_pct != null && (
                    <div class="sr-row"><span class="sr-label">Service Games Won</span><span class="sr-val">{player.serve_hold_pct}%</span></div>
                  )}
                </div>
                <div class="sr-col">
                  <h4>Return</h4>
                  {player.return_points_won_pct != null && (
                    <div class="sr-row"><span class="sr-label">Return Points Won</span><span class="sr-val">{player.return_points_won_pct}%</span></div>
                  )}
                  {player.return_1st_won_pct != null && (
                    <div class="sr-row"><span class="sr-label">1st Return Won</span><span class="sr-val">{player.return_1st_won_pct}%</span></div>
                  )}
                  {player.return_2nd_won_pct != null && (
                    <div class="sr-row"><span class="sr-label">2nd Return Won</span><span class="sr-val">{player.return_2nd_won_pct}%</span></div>
                  )}
                  {player.return_bp_converted_pct != null && (
                    <div class="sr-row"><span class="sr-label">Break Points Converted</span><span class="sr-val">{player.return_bp_converted_pct}%</span></div>
                  )}
                  {player.return_games_won_pct != null && (
                    <div class="sr-row"><span class="sr-label">Return Games Won</span><span class="sr-val">{player.return_games_won_pct}%</span></div>
                  )}
                </div>
              </div>
            </div>
          )}

          <!-- Detailed Stats Article (merged) -->
          {articles['stats'].exists && (
            <div class="detailed-stats">
              <h3>Detailed Statistics</h3>
              <div class="article-content" set:html={articles['stats'].html} />
            </div>
          )}

          <!-- Grand Slams -->
          {articles['grand-slams'].exists && (
            <div class="grand-slams-section">
              <h3>Grand Slam Record</h3>
              <div class="article-content" set:html={articles['grand-slams'].html} />
            </div>
          )}
        </section>

        <!-- Biography & Playing Style Section -->
        <section class="section-group biography" id="biography">
          <div class="section-header">
            <span class="section-icon">🎾</span>
            <h2>Biography & Playing Style</h2>
          </div>

          {player.bio_short && (
            <div class="bio-section">
              <p class="bio-text">{player.bio_short}</p>
            </div>
          )}

          {profileArticleHtml && (
            <div class="profile-article">
              <div class="article-content" set:html={profileArticleHtml} />
            </div>
          )}

          {articles['career-timeline'].exists && (
            <div class="timeline-section">
              <h3>Career Timeline</h3>
              <div class="article-content" set:html={articles['career-timeline'].html} />
            </div>
          )}
        </section>

        <!-- Equipment & Gear Section -->
        {articles['racket'].exists && (
          <section class="section-group equipment" id="equipment">
            <div class="section-header">
              <span class="section-icon">🎾</span>
              <h2>Equipment & Gear</h2>
            </div>
            <div class="article-content" set:html={articles['racket'].html} />
          </section>
        )}

        <!-- Finance & Net Worth Section -->
        {articles['net-worth'].exists && (
          <section class="section-group finance" id="finance">
            <div class="section-header">
              <span class="section-icon">💰</span>
              <h2>Net Worth & Earnings</h2>
            </div>
            <div class="article-content" set:html={articles['net-worth'].html} />
          </section>
        )}

        <!-- Personal Life Section -->
        {articles['partner'].exists && (
          <section class="section-group personal" id="personal">
            <div class="section-header">
              <span class="section-icon">👤</span>
              <h2>Personal Life & Background</h2>
            </div>
            <div class="article-content" set:html={articles['partner'].html} />
