---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page Not Found" description="The page you're looking for doesn't exist. Browse our tennis content instead.">
  <div class="not-found">
    <div class="nf-ball">
      <svg width="80" height="80" viewBox="0 0 64 64" aria-hidden="true">
        <circle cx="32" cy="32" r="30" fill="#ccff00" stroke="#8B9A2B" stroke-width="2"/>
        <path d="M10 32 C20 20, 44 20, 54 32" fill="none" stroke="#fff" stroke-width="3"/>
        <path d="M10 32 C20 44, 44 44, 54 32" fill="none" stroke="#fff" stroke-width="3"/>
      </svg>
    </div>

    <h1>404</h1>
    <p class="nf-subtitle">Fault! Page not found.</p>
    <p class="nf-text">The page you're looking for seems to have gone out of bounds.</p>

    <div class="nf-links">
      <a href="/" class="nf-btn primary">Back to Home</a>
      <a href="/players/" class="nf-btn">Browse Players</a>
      <a href="/rankings/" class="nf-btn">View Rankings</a>
    </div>

    <div class="nf-explore">
      <h2>Or explore:</h2>
      <div class="nf-grid">
        <a href="/records/">Tennis Records</a>
        <a href="/vs/">Head to Head</a>
        <a href="/gear/">Gear Guides</a>
        <a href="/tournaments/">Tournaments</a>
        <a href="/lifestyle/">Lifestyle</a>
        <a href="/calendar/">Calendar</a>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .not-found {
    max-width: 600px;
    margin: 0 auto;
    padding: 80px 24px 60px;
    text-align: center;
  }

  .nf-ball {
    margin-bottom: 24px;
    opacity: 0.7;
  }

  h1 {
    font-family: var(--font-heading);
    font-size: 5rem;
    color: var(--court-green);
    margin: 0;
    line-height: 1;
  }

  .nf-subtitle {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    text-transform: uppercase;
    color: var(--gray-900);
    margin: 8px 0 12px;
  }

  .nf-text {
    color: var(--gray-600);
    font-size: 1.05rem;
    margin: 0 0 32px;
  }

  .nf-links {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 48px;
  }

  .nf-btn {
    padding: 10px 24px;
    border-radius: 8px;
    font-weight: 600;
    font-size: 0.92rem;
    border: 2px solid var(--gray-200);
    color: var(--gray-700);
    transition: all 0.2s;
  }
  .nf-btn:hover {
    border-color: var(--court-green);
    color: var(--court-green);
  }
  .nf-btn.primary {
    background: var(--court-green);
    color: white;
    border-color: var(--court-green);
  }
  .nf-btn.primary:hover {
    background: var(--court-green-dark);
    border-color: var(--court-green-dark);
  }

  .nf-explore {
    padding-top: 32px;
    border-top: 2px solid var(--gray-200);
  }

  .nf-explore h2 {
    font-family: var(--font-heading);
    font-size: 0.9rem;
    text-transform: uppercase;
    color: var(--gray-500);
    letter-spacing: 0.1em;
    margin: 0 0 16px;
  }

  .nf-grid {
    display: flex;
    gap: 10px;
    justify-content: center;
    flex-wrap: wrap;
  }
  .nf-grid a {
    padding: 6px 16px;
    border-radius: 20px;
    background: var(--gray-50);
    border: 1px solid var(--gray-200);
    font-size: 0.88rem;
    font-weight: 500;
    color: var(--gray-700);
    transition: all 0.2s;
  }
  .nf-grid a:hover {
    color: var(--court-green);
    border-color: var(--court-green);
    background: white;
  }
</style>
