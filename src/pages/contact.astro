---
import BaseLayout from '../layouts/BaseLayout.astro';

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://super.tennis/' },
    { '@type': 'ListItem', position: 2, name: 'Contact' },
  ],
};
---

<BaseLayout
  title="Contact SUPER.TENNIS"
  description="Get in touch with the SUPER.TENNIS team. Questions, suggestions, corrections, or partnership inquiries — we'd love to hear from you."
>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />

  <div class="contact-page">
    <nav class="breadcrumbs"><a href="/">Home</a> <span class="sep">/</span> <span class="current">Contact</span></nav>

    <header class="page-hero">
      <h1>Contact Us</h1>
      <p class="subtitle">We'd love to hear from you</p>
    </header>

    <section class="contact-section">
      <h2>Get in Touch</h2>
      <p>
        Have a question about our content? Spotted an error in our stats? Want to suggest a feature
        or a player profile? We welcome all feedback.
      </p>
      <div class="contact-card">
        <div class="contact-method">
          <span class="contact-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="4" width="20" height="16" rx="2"/>
              <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
            </svg>
          </span>
          <div>
            <h3>Email</h3>
            <a href="mailto:contact@super.tennis" class="contact-email">contact@super.tennis</a>
          </div>
        </div>
      </div>
    </section>

    <section class="contact-section">
      <h2>Follow Us</h2>
      <p>Stay up to date with the latest tennis content on our social channels.</p>
      <div class="social-links">
        <a href="https://www.youtube.com/@SuperTennisNews" target="_blank" rel="noopener noreferrer" class="social-link">
          <svg viewBox="0 0 24 24" fill="currentColor" width="22" height="22"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
          YouTube
        </a>
        <a href="https://www.tiktok.com/@supertennisnews" target="_blank" rel="noopener noreferrer" class="social-link">
          <svg viewBox="0 0 24 24" fill="currentColor" width="22" height="22"><path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/></svg>
          TikTok
        </a>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .contact-page {
    max-width: 700px;
    margin: 0 auto;
    padding: 0 24px 60px;
  }

  .breadcrumbs {
    padding: 20px 0;
    font-size: 0.82rem;
    color: var(--gray-500);
  }
  .breadcrumbs a { color: var(--gray-600); transition: color 0.2s; }
  .breadcrumbs a:hover { color: var(--court-green); }
  .sep { margin: 0 8px; }
  .current { color: var(--gray-800); font-weight: 500; }

  .page-hero {
    padding: 48px 0 32px;
    border-bottom: 3px solid var(--court-green);
    margin-bottom: 36px;
  }
  .page-hero h1 {
    font-family: var(--font-heading);
    font-size: 2.4rem;
    text-transform: uppercase;
    color: var(--gray-900);
    margin: 0;
  }
  .subtitle {
    color: var(--gray-600);
    font-size: 1.1rem;
    margin: 8px 0 0;
  }

  .contact-section {
    margin-bottom: 40px;
  }
  .contact-section h2 {
    font-family: var(--font-heading);
    font-size: 1.3rem;
    text-transform: uppercase;
    color: var(--gray-900);
    margin: 0 0 16px;
    padding-bottom: 10px;
    border-bottom: 2px solid var(--gray-200);
  }
  .contact-section p {
    color: var(--gray-700);
    font-size: 1.02rem;
    line-height: 1.8;
    margin: 0 0 16px;
  }

  .contact-card {
    background: var(--gray-50);
    border: 1px solid var(--gray-200);
    border-radius: var(--radius);
    padding: 28px 32px;
    margin-top: 8px;
  }
  .contact-method {
    display: flex;
    align-items: center;
    gap: 16px;
  }
  .contact-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: color-mix(in srgb, var(--court-green) 12%, transparent);
    color: var(--court-green);
    flex-shrink: 0;
  }
  .contact-method h3 {
    font-family: var(--font-body);
    font-size: 0.82rem;
    font-weight: 600;
    text-transform: uppercase;
    color: var(--gray-500);
    margin: 0 0 4px;
    letter-spacing: 0.04em;
  }
  .contact-email {
    color: var(--court-green);
    font-size: 1.1rem;
    font-weight: 600;
    text-decoration: none;
    transition: color 0.2s;
  }
  .contact-email:hover { text-decoration: underline; }

  .social-links {
    display: flex;
    gap: 16px;
  }
  .social-link {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 12px 20px;
    background: var(--gray-50);
    border: 1px solid var(--gray-200);
    border-radius: var(--radius-sm);
    color: var(--gray-700);
    font-weight: 600;
    font-size: 0.92rem;
    text-decoration: none;
    transition: all 0.2s;
  }
  .social-link:hover {
    border-color: var(--court-green);
    color: var(--court-green);
    transform: translateY(-1px);
  }

  @media (max-width: 480px) {
    .page-hero h1 { font-size: 1.8rem; }
    .social-links { flex-direction: column; }
    .contact-card { padding: 20px; }
  }
</style>
