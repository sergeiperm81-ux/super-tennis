---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Search" description="Search SUPER.TENNIS — find players, articles, gear guides, records, and more.">
  <div class="search-page">
    <div class="container">
      <h1>Search SUPER.TENNIS</h1>
      <div id="search"></div>
    </div>
  </div>

  <link href="/pagefind/pagefind-ui.css" rel="stylesheet" />
  <script is:inline src="/pagefind/pagefind-ui.js"></script>
  <script is:inline>
    window.addEventListener('DOMContentLoaded', function() {
      new PagefindUI({
        element: '#search',
        showSubResults: true,
        showImages: true,
        autofocus: true,
      });
    });
  </script>
</BaseLayout>

<style>
  .search-page {
    padding: 40px 0 80px;
    min-height: 60vh;
  }
  .search-page h1 {
    font-family: var(--font-heading);
    font-size: 2rem;
    margin-bottom: 24px;
  }
  .search-page :global(.pagefind-ui__search-input) {
    font-size: 1.1rem;
    padding: 12px 16px;
    border: 2px solid var(--gray-300);
    border-radius: var(--radius);
    width: 100%;
  }
  .search-page :global(.pagefind-ui__search-input:focus) {
    border-color: var(--court-green, #16a34a);
    outline: none;
  }
  .search-page :global(.pagefind-ui__result-link) {
    color: #2563eb;
    font-weight: 600;
  }
</style>
