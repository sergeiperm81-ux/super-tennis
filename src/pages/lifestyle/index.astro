---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getArticles } from '../../lib/supabase';

// Fetch real lifestyle articles from Supabase
let lifestyleArticles: any[] = [];
try {
  lifestyleArticles = await getArticles({ category: 'lifestyle', limit: 20 });
} catch (e) {
  console.warn('Lifestyle index: Supabase unavailable');
}

// Icon mapping for lifestyle article slugs
const iconMap: Record<string, string> = {
  'richest-tennis-players': '💰',
  'tennis-fashion-iconic-outfits': '👗',
  'tennis-player-diet-nutrition': '🥗',
  'tennis-fitness-training-guide': '💪',
  'life-after-tennis-retirement': '🌟',
  'best-tennis-movies-documentaries': '🎬',
  'tennis-travel-bucket-list': '✈️',
  'tennis-mental-health-pressure': '🧠',
  'tennis-beginners-guide': '📖',
  'tennis-stats-analytics-guide': '📊',
};
---

<BaseLayout
  title="Tennis Lifestyle — Net Worth, Culture & Stories"
  description="Tennis lifestyle content: player net worth rankings, behind-the-scenes stories, fitness, fashion, rivalries, and the culture of professional tennis."
>
  <div class="lifestyle-page">
    <div class="container">
      <section class="page-hero">
        <h1>Tennis Lifestyle</h1>
        <p class="subtitle">Net worth, culture, rivalries, and stories from the world of professional tennis</p>
      </section>

      {lifestyleArticles.length > 0 ? (
        <div class="articles-grid">
          {lifestyleArticles.map((article, i) => (
            <a href={`/lifestyle/${article.slug}/`} class={`article-card ${i === 0 ? 'featured' : ''}`}>
              <div class="article-icon">{iconMap[article.slug] || '🎾'}</div>
              <div class="article-content">
                <h2>{article.title}</h2>
                <p>{article.excerpt || article.meta_description || ''}</p>
              </div>
              <span class="read-link">Read Article →</span>
            </a>
          ))}
        </div>
      ) : (
        <div class="empty-state">
          <p>Lifestyle articles are coming soon. Check back shortly!</p>
        </div>
      )}

      <section class="related-section">
        <h2>Explore More</h2>
        <div class="cta-links">
          <a href="/players/">👥 Player Profiles</a>
          <a href="/records/">🏆 Tennis Records</a>
          <a href="/gear/">🎾 Gear Reviews</a>
          <a href="/rankings/">📊 Rankings</a>
        </div>
      </section>
    </div>
  </div>
</BaseLayout>

<style>
  .lifestyle-page {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 24px 60px;
  }

  .page-hero {
    padding: 48px 0 32px;
    border-bottom: 3px solid var(--court-green);
    margin-bottom: 40px;
  }
  .page-hero h1 {
    font-family: var(--font-heading);
    font-size: 2.8rem;
    text-transform: uppercase;
    color: var(--gray-900);
    margin: 0;
  }
  .subtitle {
    color: var(--gray-600);
    font-size: 1.1rem;
    margin: 8px 0 0;
  }

  .articles-grid {
    display: flex;
    flex-direction: column;
    gap: 16px;
    margin-bottom: 48px;
  }

  .article-card {
    display: flex;
    gap: 20px;
    align-items: flex-start;
    padding: 24px;
    background: white;
    border: 1px solid var(--gray-200);
    border-radius: var(--radius);
    text-decoration: none;
    color: inherit;
    transition: all 0.2s;
  }
  .article-card:hover {
    border-color: var(--court-green);
    box-shadow: var(--shadow);
  }
  .article-card.featured {
    background: linear-gradient(135deg, #f0fdf4 0%, white 100%);
    border-color: var(--court-green);
    padding: 28px;
  }

  .article-icon {
    font-size: 2.2rem;
    flex-shrink: 0;
    line-height: 1;
    padding-top: 4px;
  }

  .article-content {
    flex: 1;
  }
  .article-content h2 {
    font-family: var(--font-body);
    font-size: 1.1rem;
    font-weight: 700;
    margin: 0 0 8px;
    line-height: 1.35;
  }
  .article-card.featured .article-content h2 {
    font-size: 1.2rem;
  }
  .article-content p {
    color: var(--gray-600);
    font-size: 0.9rem;
    line-height: 1.6;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .read-link {
    color: var(--court-green);
    font-weight: 600;
    font-size: 0.85rem;
    flex-shrink: 0;
    align-self: center;
  }

  .empty-state {
    text-align: center;
    padding: 60px 24px;
    color: var(--gray-500);
    background: var(--gray-50);
    border-radius: var(--radius);
    margin-bottom: 48px;
  }

  .related-section {
    text-align: center;
    padding: 40px;
    background: var(--gray-50);
    border-radius: var(--radius);
  }
  .related-section h2 {
    font-family: var(--font-heading);
    font-size: 1.4rem;
    text-transform: uppercase;
    margin: 0 0 20px;
  }
  .cta-links {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
  }
  .cta-links a {
    color: var(--court-green);
    font-weight: 600;
    font-size: 0.95rem;
    text-decoration: none;
  }
  .cta-links a:hover { text-decoration: underline; }

  @media (max-width: 768px) {
    .page-hero h1 { font-size: 2rem; }
    .article-card { flex-direction: column; gap: 12px; }
    .read-link { align-self: flex-start; }
  }
</style>
