---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getArticles } from '../../lib/supabase';
import { stripMarkdown } from '../../lib/fallback-data';
import { getArticlePhotosForCategory } from '../../lib/player-photos';

// Get URL search params for filtering
const url = new URL(Astro.request.url);
const filterSubcat = url.searchParams.get('cat') || 'all';
const searchQuery = url.searchParams.get('q') || '';

// Fetch real lifestyle articles from Supabase
let lifestyleArticles: any[] = [];
try {
  lifestyleArticles = await getArticles({ category: 'lifestyle', limit: 100 });
} catch (e) {
  console.warn('Lifestyle index: Supabase unavailable');
}

// Filter by subcategory
let filteredArticles = lifestyleArticles;
if (filterSubcat !== 'all') {
  filteredArticles = lifestyleArticles.filter(a => (a.subcategory || 'culture') === filterSubcat);
}

// Filter by search query
if (searchQuery) {
  const query = searchQuery.toLowerCase();
  filteredArticles = filteredArticles.filter(a =>
    a.title.toLowerCase().includes(query) ||
    (a.excerpt || '').toLowerCase().includes(query)
  );
}

// Batch-fetch all article photos (player photos + local)
const articlePhotos = await getArticlePhotosForCategory(filteredArticles, 'lifestyle');

// Detect if a photo URL is a player photo (Wikimedia)
function isPlayerPhoto(url: string | null | undefined): boolean {
  return !!url && (url.includes('wikimedia') || url.includes('wikipedia'));
}

// Pagination: First 2 articles go into the top row (bigger), next 12 in grid
const topArticles = filteredArticles.slice(0, 2);
const gridArticles = filteredArticles.slice(2, 14);
const totalGridArticles = filteredArticles.length - 2;
const hasMore = totalGridArticles > 12;

// ItemList JSON-LD for first 10 articles
const itemListJsonLd = filteredArticles.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  itemListElement: filteredArticles.slice(0, 10).map((article, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: article.title,
    url: `https://super.tennis/lifestyle/${article.slug}/`,
  })),
} : null;
---

<BaseLayout
  title="Tennis Lifestyle — Net Worth, Culture & Stories"
  description="Tennis lifestyle content: player net worth rankings, behind-the-scenes stories, fitness, fashion, rivalries, and the culture of professional tennis."
  ogImage="/og/lifestyle.png"
>
  {itemListJsonLd && <script type="application/ld+json" set:html={JSON.stringify(itemListJsonLd)} />}
  <div class="lifestyle-page">
    <div class="container">
      <nav class="breadcrumbs"><a href="/">Home</a> <span class="sep">/</span> <span class="current">Lifestyle</span></nav>
      <section class="page-hero">
        <h1>Tennis Lifestyle</h1>
        <p class="subtitle">Net worth, culture, rivalries, and stories from the world of professional tennis{lifestyleArticles.length > 0 && ` — ${lifestyleArticles.length} articles`}</p>
      </section>

      {/* Search & Filter Section */}
      <div class="filter-section">
        <input
          type="text"
          class="search-input"
          id="search-input"
          placeholder="🔍 Search lifestyle articles..."
          value={searchQuery}
        />
      </div>

      {/* Category filters */}
      <div class="cat-filters" id="cat-filters">
        <a href="?cat=all" class={`cat-btn ${filterSubcat === 'all' ? 'active' : ''}`} data-subcat="all">All</a>
        <a href="?cat=culture" class={`cat-btn ${filterSubcat === 'culture' ? 'active' : ''}`} data-subcat="culture" style="--cat-color: #2563eb">Culture</a>
        <a href="?cat=health" class={`cat-btn ${filterSubcat === 'health' ? 'active' : ''}`} data-subcat="health" style="--cat-color: #059669">Health</a>
        <a href="?cat=style" class={`cat-btn ${filterSubcat === 'style' ? 'active' : ''}`} data-subcat="style" style="--cat-color: #9333ea">Style</a>
        <a href="?cat=media" class={`cat-btn ${filterSubcat === 'media' ? 'active' : ''}`} data-subcat="media" style="--cat-color: #f97316">Media</a>
        <a href="?cat=career" class={`cat-btn ${filterSubcat === 'career' ? 'active' : ''}`} data-subcat="career" style="--cat-color: #dc2626">Career</a>
        <a href="?cat=money" class={`cat-btn ${filterSubcat === 'money' ? 'active' : ''}`} data-subcat="money" style="--cat-color: #d4a017">Money</a>
        <a href="?cat=travel" class={`cat-btn ${filterSubcat === 'travel' ? 'active' : ''}`} data-subcat="travel" style="--cat-color: #0891b2">Travel</a>
      </div>

      {filteredArticles.length === 0 ? (
        <div class="empty-state">
          <p>No articles found{searchQuery ? ` for "${searchQuery}"` : ''}{filterSubcat !== 'all' ? ` in this category` : ''}. Try a different search or category.</p>
        </div>
      ) : null}

      {filteredArticles.length > 0 ? (
        <>
          {topArticles.length > 0 && (
            <div class="top-row">
              {topArticles.map((article) => {
                const photo = articlePhotos.get(article.slug);
                return (
                  <a href={`/lifestyle/${article.slug}/`} class="top-card">
                    <div class={`top-card-img ${isPlayerPhoto(photo) ? 'player-photo' : ''}`}>
                      {photo ? (
                        <img src={photo} alt={article.title} loading="eager" decoding="async" width="600" height="400" onerror="this.parentElement.classList.add('no-img')" />
                      ) : (
                        <div class="img-placeholder"></div>
                      )}
                      <div class="top-card-overlay">
                        <h2>{article.title}</h2>
                      </div>
                    </div>
                  </a>
                );
              })}
            </div>
          )}

          {gridArticles.length > 0 && (
            <div class="card-grid" id="card-grid">
              {gridArticles.map((article) => {
                const photo = articlePhotos.get(article.slug);
                return (
                  <a href={`/lifestyle/${article.slug}/`} class="card">
                    <div class={`card-img ${isPlayerPhoto(photo) ? 'player-photo' : ''}`}>
                      {photo ? (
                        <img src={photo} alt={article.title} loading="lazy" decoding="async" width="400" height="400" onerror="this.parentElement.classList.add('no-img')" />
                      ) : (
                        <div class="img-placeholder"></div>
                      )}
                    </div>
                    <div class="card-body">
                      <h3>{article.title}</h3>
                      <p>{stripMarkdown(article.excerpt || article.meta_description || '')}</p>
                      <span class="card-link">Read Article →</span>
                    </div>
                  </a>
                );
              })}
            </div>
          )}

          {hasMore && (
            <div class="load-more-section">
              <button class="load-more-btn" id="load-more-btn">
                Load More ({totalGridArticles - 12} more)
              </button>
            </div>
          )}
        </>
      ) : null}

      <section class="related-section">
        <h2>Explore More</h2>
        <div class="cta-links">
          <a href="/players/">Player Profiles</a>
          <a href="/records/">Tennis Records</a>
          <a href="/gear/">Gear Reviews</a>
          <a href="/rankings/">Rankings</a>
        </div>
      </section>
    </div>
  </div>

  <script is:inline>
    // Search functionality
    const searchInput = document.getElementById('search-input');
    if (searchInput) {
      searchInput.addEventListener('keyup', function(e) {
        if (e.key === 'Enter') {
          const query = this.value.trim();
          const cat = new URLSearchParams(window.location.search).get('cat') || 'all';
          if (query) {
            window.location.href = `?cat=${cat}&q=${encodeURIComponent(query)}`;
          } else {
            window.location.href = `?cat=${cat}`;
          }
        }
      });
    }

    // Load More functionality
    const loadMoreBtn = document.getElementById('load-more-btn');
    if (loadMoreBtn) {
      loadMoreBtn.addEventListener('click', async function() {
        const currentCat = new URLSearchParams(window.location.search).get('cat') || 'all';
        const currentQ = new URLSearchParams(window.location.search).get('q') || '';

        // Fetch all articles and filter client-side
        try {
          const response = await fetch(`/api/lifestyle-articles?cat=${currentCat}${currentQ ? `&q=${encodeURIComponent(currentQ)}` : ''}`);
          const articles = await response.json();

          const cardGrid = document.getElementById('card-grid');
          const currentCount = cardGrid.querySelectorAll('.card').length;

          // Append next 12 articles
          articles.slice(currentCount + 2, currentCount + 14).forEach(article => {
            const card = createArticleCard(article);
            cardGrid.appendChild(card);
          });

          // Hide Load More if no more articles
          if (currentCount + 14 >= articles.length) {
            loadMoreBtn.parentElement.style.display = 'none';
          } else {
            loadMoreBtn.textContent = `Load More (${articles.length - currentCount - 14} more)`;
          }
        } catch (error) {
          console.error('Failed to load more articles:', error);
        }
      });
    }

    function createArticleCard(article) {
      const a = document.createElement('a');
      a.href = `/lifestyle/${article.slug}/`;
      a.className = 'card';
      a.innerHTML = `
        <div class="card-img">
          <img src="${article.photo || ''}" alt="${article.title}" loading="lazy" onerror="this.parentElement.classList.add('no-img')" />
        </div>
        <div class="card-body">
          <h3>${article.title}</h3>
          <p>${article.excerpt || ''}</p>
          <span class="card-link">Read Article →</span>
        </div>
      `;
      return a;
    }
  </script>
</BaseLayout>

<style>
  .filter-section {
    margin-bottom: 24px;
  }

  .search-input {
    width: 100%;
    padding: 12px 16px;
    font-size: 0.95rem;
    border: 1px solid #d1d5db;
    border-radius: var(--radius);
    background: white;
    color: #111827;
    transition: all 0.2s;
  }
  .search-input:focus {
    outline: none;
    border-color: var(--court-green);
    box-shadow: 0 0 0 3px rgba(34, 197, 94, 0.1);
  }
  .search-input::placeholder {
    color: #9ca3af;
  }

  .cat-filters {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin-bottom: 28px;
    padding-bottom: 16px;
    border-bottom: 1px solid #e5e7eb;
  }

  .cat-btn {
    display: inline-block;
    padding: 6px 16px;
    border-radius: 20px;
    border: 1px solid #d1d5db;
    background: transparent;
    font-size: 0.85rem;
    font-weight: 600;
    cursor: pointer;
    color: #374151;
    text-decoration: none;
    transition: all 0.2s;
  }
  .cat-btn:hover {
    border-color: var(--cat-color, #6b7280);
    color: var(--cat-color, #6b7280);
  }
  .cat-btn.active {
    background: var(--cat-color, #111827);
    color: #fff;
    border-color: var(--cat-color, #111827);
  }
  .lifestyle-page {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 24px 60px;
  }

  .page-hero {
    padding: 48px 0 32px;
    border-bottom: 3px solid var(--court-green);
    margin-bottom: 28px;
  }
  .page-hero h1 {
    font-family: var(--font-heading);
    font-size: 2.8rem;
    text-transform: uppercase;
    color: var(--gray-900);
    margin: 0;
  }
  .subtitle {
    color: var(--gray-600);
    font-size: 1.1rem;
    margin: 8px 0 0;
  }

  /* ── Top row: 2 large cards ── */
  .top-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin-bottom: 20px;
  }

  .top-card {
    display: block;
    text-decoration: none;
    color: inherit;
    border-radius: var(--radius);
    overflow: hidden;
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .top-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 30px rgba(0,0,0,0.12);
  }

  .top-card-img {
    position: relative;
    aspect-ratio: 4 / 3;
    background: var(--gray-100);
    border-radius: var(--radius);
  }
  .top-card-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
    border-radius: var(--radius);
    display: block;
  }
  .top-card-img.player-photo img {
    object-position: top;
  }
  .top-card-img.no-img img { display: none; }

  .top-card-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(0deg, rgba(0,0,0,0.75) 0%, rgba(0,0,0,0.1) 50%, transparent 100%);
    display: flex;
    align-items: flex-end;
    padding: 24px;
  }
  .top-card-overlay h2 {
    color: white;
    font-family: var(--font-heading);
    font-size: 1.25rem;
    text-transform: uppercase;
    margin: 0;
    line-height: 1.3;
  }

  /* ── Main grid: uniform cards ── */
  .card-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-bottom: 48px;
  }

  .card {
    text-decoration: none;
    color: inherit;
    background: white;
    border: 1px solid var(--gray-200);
    border-radius: var(--radius);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: all 0.2s;
  }
  .card:hover {
    border-color: var(--court-green);
    box-shadow: var(--shadow);
    transform: translateY(-2px);
  }

  /* Square image */
  .card-img {
    aspect-ratio: 1 / 1;
    overflow: hidden;
    background: var(--gray-100);
    border-radius: var(--radius);
  }
  .card-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
    border-radius: var(--radius);
    display: block;
  }
  .card-img.player-photo img {
    object-position: top;
  }
  .card-img.no-img img { display: none; }

  .img-placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, #f0fdf4 0%, #dcfce7 100%);
  }

  /* Card body */
  .card-body {
    padding: 16px 18px 20px;
    flex: 1;
    display: flex;
    flex-direction: column;
  }
  .card-body h3 {
    font-family: var(--font-body);
    font-size: 0.95rem;
    font-weight: 700;
    margin: 0 0 8px;
    line-height: 1.4;
    color: var(--gray-900);
  }
  .card-body p {
    color: var(--gray-600);
    font-size: 0.82rem;
    line-height: 1.6;
    margin: 0;
    flex: 1;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .card-link {
    color: var(--court-green);
    font-weight: 600;
    font-size: 0.82rem;
    margin-top: 12px;
  }

  /* ── Related / footer ── */
  .empty-state {
    text-align: center;
    padding: 60px 24px;
    color: var(--gray-500);
    background: var(--gray-50);
    border-radius: var(--radius);
    margin-bottom: 48px;
  }

  .related-section {
    text-align: center;
    padding: 40px;
    background: var(--gray-50);
    border-radius: var(--radius);
  }
  .related-section h2 {
    font-family: var(--font-heading);
    font-size: 1.4rem;
    text-transform: uppercase;
    margin: 0 0 20px;
  }
  .cta-links {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
  }
  .cta-links a {
    color: var(--court-green);
    font-weight: 600;
    font-size: 0.95rem;
    text-decoration: none;
  }
  .cta-links a:hover { text-decoration: underline; }

  /* ── Load More ── */
  .load-more-section {
    display: flex;
    justify-content: center;
    margin: 48px 0;
  }
  .load-more-btn {
    padding: 12px 32px;
    font-size: 0.95rem;
    font-weight: 600;
    color: white;
    background: var(--court-green);
    border: none;
    border-radius: var(--radius);
    cursor: pointer;
    transition: all 0.2s;
  }
  .load-more-btn:hover {
    background: #16a34a;
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(34, 197, 94, 0.3);
  }
  .load-more-btn:active {
    transform: translateY(0);
  }

  /* ── Responsive ── */
  @media (max-width: 1024px) {
    .card-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 768px) {
    .page-hero h1 { font-size: 2rem; }
    .top-row { grid-template-columns: 1fr; }
    .card-grid { grid-template-columns: 1fr 1fr; }
    .top-card-overlay h2 { font-size: 1.1rem; }
    .search-input { font-size: 1rem; }
  }
  @media (max-width: 480px) {
    .card-grid { grid-template-columns: 1fr; }
    .cat-filters { gap: 6px; }
    .cat-btn { padding: 5px 12px; font-size: 0.8rem; }
  }
</style>
