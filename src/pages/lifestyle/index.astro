---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getArticles } from '../../lib/supabase';
import { stripMarkdown } from '../../lib/fallback-data';
import { getArticlePhotosForCategory } from '../../lib/player-photos';

// Fetch real lifestyle articles from Supabase
let lifestyleArticles: any[] = [];
try {
  lifestyleArticles = await getArticles({ category: 'lifestyle', limit: 100 });
} catch (e) {
  console.warn('Lifestyle index: Supabase unavailable');
}

// Batch-fetch all article photos (player photos + local)
const articlePhotos = await getArticlePhotosForCategory(lifestyleArticles, 'lifestyle');

// Detect if a photo URL is a player photo (Wikimedia)
function isPlayerPhoto(url: string | null | undefined): boolean {
  return !!url && (url.includes('wikimedia') || url.includes('wikipedia'));
}

// First 2 articles go into the top row (bigger), rest into the grid
const topArticles = lifestyleArticles.slice(0, 2);
const gridArticles = lifestyleArticles.slice(2);

// ItemList JSON-LD for first 10 articles
const itemListJsonLd = lifestyleArticles.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  itemListElement: lifestyleArticles.slice(0, 10).map((article, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: article.title,
    url: `https://super.tennis/lifestyle/${article.slug}/`,
  })),
} : null;
---

<BaseLayout
  title="Tennis Lifestyle — Net Worth, Culture & Stories"
  description="Tennis lifestyle content: player net worth rankings, behind-the-scenes stories, fitness, fashion, rivalries, and the culture of professional tennis."
  ogImage="/og/lifestyle.png"
>
  {itemListJsonLd && <script type="application/ld+json" set:html={JSON.stringify(itemListJsonLd)} />}
  <div class="lifestyle-page">
    <div class="container">
      <nav class="breadcrumbs"><a href="/">Home</a> <span class="sep">/</span> <span class="current">Lifestyle</span></nav>
      <section class="page-hero">
        <h1>Tennis Lifestyle</h1>
        <p class="subtitle">Net worth, culture, rivalries, and stories from the world of professional tennis{lifestyleArticles.length > 0 && ` — ${lifestyleArticles.length} articles`}</p>
      </section>

      {lifestyleArticles.length > 0 ? (
        <>
          {/* Top row — 2 large cards side by side */}
          <div class="top-row">
            {topArticles.map((article) => {
              const photo = articlePhotos.get(article.slug);
              return (
                <a href={`/lifestyle/${article.slug}/`} class="top-card">
                  <div class={`top-card-img ${isPlayerPhoto(photo) ? 'player-photo' : ''}`}>
                    {photo ? (
                      <img src={photo} alt={article.title} loading="eager" onerror="this.parentElement.classList.add('no-img')" />
                    ) : (
                      <div class="img-placeholder"></div>
                    )}
                    <div class="top-card-overlay">
                      <h2>{article.title}</h2>
                    </div>
                  </div>
                </a>
              );
            })}
          </div>

          {/* Main grid — uniform cards with square photos */}
          <div class="card-grid">
            {gridArticles.map((article) => {
              const photo = articlePhotos.get(article.slug);
              return (
                <a href={`/lifestyle/${article.slug}/`} class="card">
                  <div class={`card-img ${isPlayerPhoto(photo) ? 'player-photo' : ''}`}>
                    {photo ? (
                      <img src={photo} alt={article.title} loading="lazy" onerror="this.parentElement.classList.add('no-img')" />
                    ) : (
                      <div class="img-placeholder"></div>
                    )}
                  </div>
                  <div class="card-body">
                    <h3>{article.title}</h3>
                    <p>{stripMarkdown(article.excerpt || article.meta_description || '')}</p>
                    <span class="card-link">Read Article →</span>
                  </div>
                </a>
              );
            })}
          </div>
        </>
      ) : (
        <div class="empty-state">
          <p>Lifestyle articles are coming soon. Check back shortly!</p>
        </div>
      )}

      <section class="related-section">
        <h2>Explore More</h2>
        <div class="cta-links">
          <a href="/players/">Player Profiles</a>
          <a href="/records/">Tennis Records</a>
          <a href="/gear/">Gear Reviews</a>
          <a href="/rankings/">Rankings</a>
        </div>
      </section>
    </div>
  </div>
</BaseLayout>

<style>
  .lifestyle-page {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 24px 60px;
  }

  .page-hero {
    padding: 48px 0 32px;
    border-bottom: 3px solid var(--court-green);
    margin-bottom: 28px;
  }
  .page-hero h1 {
    font-family: var(--font-heading);
    font-size: 2.8rem;
    text-transform: uppercase;
    color: var(--gray-900);
    margin: 0;
  }
  .subtitle {
    color: var(--gray-600);
    font-size: 1.1rem;
    margin: 8px 0 0;
  }

  /* ── Top row: 2 large cards ── */
  .top-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin-bottom: 20px;
  }

  .top-card {
    display: block;
    text-decoration: none;
    color: inherit;
    border-radius: var(--radius);
    overflow: hidden;
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .top-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 30px rgba(0,0,0,0.12);
  }

  .top-card-img {
    position: relative;
    aspect-ratio: 4 / 3;
    background: var(--gray-100);
  }
  .top-card-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
  }
  .top-card-img.player-photo img {
    object-position: top;
  }
  .top-card-img.no-img img { display: none; }

  .top-card-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(0deg, rgba(0,0,0,0.75) 0%, rgba(0,0,0,0.1) 50%, transparent 100%);
    display: flex;
    align-items: flex-end;
    padding: 24px;
  }
  .top-card-overlay h2 {
    color: white;
    font-family: var(--font-heading);
    font-size: 1.25rem;
    text-transform: uppercase;
    margin: 0;
    line-height: 1.3;
  }

  /* ── Main grid: uniform cards ── */
  .card-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-bottom: 48px;
  }

  .card {
    text-decoration: none;
    color: inherit;
    background: white;
    border: 1px solid var(--gray-200);
    border-radius: var(--radius);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: all 0.2s;
  }
  .card:hover {
    border-color: var(--court-green);
    box-shadow: var(--shadow);
    transform: translateY(-2px);
  }

  /* Square image */
  .card-img {
    aspect-ratio: 1 / 1;
    overflow: hidden;
    background: var(--gray-100);
  }
  .card-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
  }
  .card-img.player-photo img {
    object-position: top;
  }
  .card-img.no-img img { display: none; }

  .img-placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, #f0fdf4 0%, #dcfce7 100%);
  }

  /* Card body */
  .card-body {
    padding: 16px 18px 20px;
    flex: 1;
    display: flex;
    flex-direction: column;
  }
  .card-body h3 {
    font-family: var(--font-body);
    font-size: 0.95rem;
    font-weight: 700;
    margin: 0 0 8px;
    line-height: 1.4;
    color: var(--gray-900);
  }
  .card-body p {
    color: var(--gray-600);
    font-size: 0.82rem;
    line-height: 1.6;
    margin: 0;
    flex: 1;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .card-link {
    color: var(--court-green);
    font-weight: 600;
    font-size: 0.82rem;
    margin-top: 12px;
  }

  /* ── Related / footer ── */
  .empty-state {
    text-align: center;
    padding: 60px 24px;
    color: var(--gray-500);
    background: var(--gray-50);
    border-radius: var(--radius);
    margin-bottom: 48px;
  }

  .related-section {
    text-align: center;
    padding: 40px;
    background: var(--gray-50);
    border-radius: var(--radius);
  }
  .related-section h2 {
    font-family: var(--font-heading);
    font-size: 1.4rem;
    text-transform: uppercase;
    margin: 0 0 20px;
  }
  .cta-links {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
  }
  .cta-links a {
    color: var(--court-green);
    font-weight: 600;
    font-size: 0.95rem;
    text-decoration: none;
  }
  .cta-links a:hover { text-decoration: underline; }

  /* ── Responsive ── */
  @media (max-width: 1024px) {
    .card-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 768px) {
    .page-hero h1 { font-size: 2rem; }
    .top-row { grid-template-columns: 1fr; }
    .card-grid { grid-template-columns: 1fr 1fr; }
    .top-card-overlay h2 { font-size: 1.1rem; }
  }
  @media (max-width: 480px) {
    .card-grid { grid-template-columns: 1fr; }
  }
</style>
