---
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import ArticleFooter from '../../components/ArticleFooter.astro';
import RelatedArticles from '../../components/RelatedArticles.astro';
import PlayerGearBlock from '../../components/PlayerGearBlock.astro';
import TennisFitnessBlock from '../../components/TennisFitnessBlock.astro';
import { getArticleBySlug, getArticleSlugs } from '../../lib/supabase';
import { addInterlinks } from '../../lib/interlinks';
import { getArticlePhotoUrl } from '../../lib/player-photos';
import { buildHowToSchema } from '../../lib/howto-schema';
import { findGearForArticle } from '../../lib/player-gear';
import { marked } from 'marked';

export async function getStaticPaths() {
  let slugs: string[] = [];
  try {
    slugs = await getArticleSlugs('lifestyle');
  } catch (e) {
    console.warn('lifestyle getStaticPaths: Supabase unavailable');
  }

  if (slugs.length === 0) {
    slugs = [
      'richest-tennis-players-2026', 'tennis-fashion-on-court', 'how-to-start-playing-tennis',
      'tennis-diet-nutrition-guide', 'tennis-fitness-training', 'tennis-retirement-second-careers',
      'best-tennis-movies-documentaries', 'tennis-travel-bucket-list', 'tennis-mental-health',
      'tennis-betting-guide',
    ];
  }

  return slugs.map(slug => ({ params: { slug } }));
}

const { slug } = Astro.params;

let article: any = null;
try {
  article = await getArticleBySlug(slug as string);
} catch (e) {
  console.warn(`Lifestyle article not found: ${slug}`);
}

if (!article) {
  return Astro.redirect('/lifestyle/');
}

const heroImage = await getArticlePhotoUrl(slug as string, 'lifestyle') || article.image_url || null;

const rawHtml = article.body ? marked.parse(article.body) : '';
const bodyHtml = rawHtml ? await addInterlinks(rawHtml as string, `/lifestyle/${slug}/`) : '';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: article.title,
  description: article.meta_description || article.excerpt,
  url: `https://super.tennis/lifestyle/${slug}/`,
  ...(article.created_at && { datePublished: article.created_at }),
  ...(article.updated_at && { dateModified: article.updated_at }),
  author: {
    '@type': 'Organization',
    '@id': 'https://super.tennis/#organization',
    name: 'SUPER.TENNIS Editorial',
    url: 'https://super.tennis/about/',
  },
  publisher: {
    '@type': 'Organization',
    name: 'SUPER.TENNIS',
    url: 'https://super.tennis',
    logo: { '@type': 'ImageObject', url: 'https://super.tennis/og/default.png' },
  },
  ...(heroImage && { image: heroImage }),
};

const faqJsonLd = article.faqs && Array.isArray(article.faqs) && article.faqs.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: article.faqs.map((faq: { question: string; answer: string }) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
} : null;

// HowTo JSON-LD for how-to-* articles (Codex SEO audit 2026-05-17)
const howToJsonLd = buildHowToSchema(
  slug as string,
  article.title,
  article.meta_description || article.excerpt || '',
  bodyHtml,
  'lifestyle',
);

// Monetization block routing (2026-06-12 audit):
//   - health/fitness articles → Tennis Fitness program (50% commission,
//     far higher ROI than Amazon's ~3%). Skip when the body already has an
//     inline TF link to avoid a duplicate.
//   - everything else → gear block: player racket (title/body match) or a
//     generic /gear/ CTA fallback so EVERY article has a money path.
// The writing bot stays untouched — all routing is site-side.
const isHealth = article.subcategory === 'health';
const hasInlineTF = /tennisfitness|Fq9Sy7S5/i.test(article.body || '');
const showTennisFitness = isHealth && !hasInlineTF;
const gearMatch = isHealth ? null : findGearForArticle(article.title || '', article.body || '');

// Topic-aware fallback (2026-06-12): the 'travel'/'style' subcategories are
// too mixed to blanket-route (e.g. "Padel Explained" and "Tennis Couples"
// live there too), so we match on the title instead. Genuine travel guides
// → the tennis-bags guide; everything else keeps the generic /gear/ fallback.
const isTravelGuide = /\btravel\b/i.test(article.title || '');
const fallbackCfg = isTravelGuide
  ? {
      fallbackHref: '/gear/best-tennis-bags-guide/',
      fallbackTitle: '🎒 Travel-Ready: Tennis Bags',
      fallbackLead: 'Racquet bags, backpacks & carry-ons for the road',
      fallbackCta: 'See the best tennis bags →',
    }
  : {};
---

<ArticleLayout
  title={article.meta_title || article.title}
  description={article.meta_description || article.excerpt || `${article.title} — Tennis lifestyle on SUPER.TENNIS.`}
  breadcrumbs={[
    { label: 'Home', href: '/' },
    { label: 'Lifestyle', href: '/lifestyle/' },
    { label: article.title },
  ]}
  image={heroImage || undefined}
  category="lifestyle"
  categoryLabel="Lifestyle"
  categoryHref="/lifestyle/"
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  {faqJsonLd && <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />}
  {howToJsonLd && <script type="application/ld+json" set:html={JSON.stringify(howToJsonLd)} />}

  <div set:html={bodyHtml} />

  {showTennisFitness ? (
    <TennisFitnessBlock />
  ) : !isHealth && (
    <PlayerGearBlock
      playerSlug={gearMatch?.slug}
      playerName={gearMatch?.name}
      heading="🎾 Gear from this story"
      fallback
      {...fallbackCfg}
    />
  )}

  <RelatedArticles category="lifestyle" currentSlug={slug as string} />
  <ArticleFooter backLabel="All Lifestyle Articles" backHref="/lifestyle/" />
</ArticleLayout>
