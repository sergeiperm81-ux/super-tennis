---
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import { getArticleBySlug, getArticleSlugs } from '../../lib/supabase';
import { marked } from 'marked';

export async function getStaticPaths() {
  let slugs: string[] = [];
  try {
    slugs = await getArticleSlugs('lifestyle');
  } catch (e) {
    console.warn('lifestyle getStaticPaths: Supabase unavailable');
  }

  if (slugs.length === 0) {
    slugs = [
      'richest-tennis-players-2026', 'tennis-fashion-on-court', 'how-to-start-playing-tennis',
      'tennis-diet-nutrition', 'tennis-fitness-training', 'tennis-retirement-second-careers',
      'best-tennis-movies-documentaries', 'tennis-travel-bucket-list', 'tennis-mental-health',
      'tennis-betting-guide',
    ];
  }

  return slugs.map(slug => ({ params: { slug } }));
}

const { slug } = Astro.params;

let article: any = null;
try {
  article = await getArticleBySlug(slug as string);
} catch (e) {
  console.warn(`Lifestyle article not found: ${slug}`);
}

if (!article) {
  return Astro.redirect('/lifestyle/');
}

const bodyHtml = article.body ? marked.parse(article.body) : '';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: article.title,
  description: article.meta_description || article.excerpt,
  url: `https://super.tennis/lifestyle/${slug}/`,
  publisher: {
    '@type': 'Organization',
    name: 'SUPER.TENNIS',
    url: 'https://super.tennis',
  },
};
---

<ArticleLayout
  title={article.meta_title || article.title}
  description={article.meta_description || article.excerpt || `${article.title} — Tennis lifestyle on SUPER.TENNIS.`}
  breadcrumbs={[
    { label: 'Home', href: '/' },
    { label: 'Lifestyle', href: '/lifestyle/' },
    { label: article.title },
  ]}
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <div set:html={bodyHtml} />

  <div class="article-nav">
    <a href="/lifestyle/" class="nav-back">← All Lifestyle Articles</a>
    <div class="nav-related">
      <a href="/players/">👥 Player Profiles</a>
      <a href="/gear/">🎾 Gear Guides</a>
    </div>
  </div>
</ArticleLayout>

<style>
  .article-nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 16px;
    margin-top: 40px;
    padding-top: 24px;
    border-top: 2px solid var(--gray-200);
  }
  .nav-back {
    color: var(--court-green);
    font-weight: 600;
    font-size: 0.95rem;
  }
  .nav-back:hover { text-decoration: underline; }
  .nav-related { display: flex; gap: 16px; }
  .nav-related a {
    color: var(--gray-600);
    font-size: 0.9rem;
    font-weight: 500;
    transition: color 0.2s;
  }
  .nav-related a:hover { color: var(--court-green); }
</style>
