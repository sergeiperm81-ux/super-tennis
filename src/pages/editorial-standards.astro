---
import BaseLayout from '../layouts/BaseLayout.astro';
import { buildAlternates } from '../lib/i18n';
const alternates = buildAlternates('/editorial-standards/', ['es']);

// Editorial Standards page (2026-06-17 GEO/E-E-A-T audit).
// Publishes the REAL editorial process that was previously only asserted
// inside llms.txt where readers never see it. No fabricated author personas
// — attribution stays at the honest "SUPER.TENNIS Editorial" org level.
const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://super.tennis/' },
    { '@type': 'ListItem', position: 2, name: 'Editorial Standards' },
  ],
};

// AboutPage referencing the publisher entity already defined in BaseLayout.
const pageJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'AboutPage',
  name: 'Editorial Standards — SUPER.TENNIS',
  url: 'https://super.tennis/editorial-standards/',
  description: 'How SUPER.TENNIS reports tennis: faithful-rewrite-only news, named sources, fact-checking, corrections, and transparency about AI assistance.',
  publisher: { '@id': 'https://super.tennis/#organization' },
  dateModified: '2026-06-17',
};
---

<BaseLayout
  title="Editorial Standards — How SUPER.TENNIS Reports Tennis"
  description="Our editorial process: faithful-rewrite-only news from named sources, fact-checked stats, a clear corrections policy, and honest transparency about where automation is and isn't used."
  alternates={alternates}
>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />
  <script type="application/ld+json" set:html={JSON.stringify(pageJsonLd)} />

  <div class="about-page">
    <nav class="breadcrumbs"><a href="/">Home</a> <span class="sep">/</span> <span class="current">Editorial Standards</span></nav>

    <header class="page-hero">
      <h1>Editorial Standards</h1>
      <p class="subtitle">How we report tennis — and how we keep it honest</p>
    </header>

    <section class="about-section">
      <h2>Who writes SUPER.TENNIS</h2>
      <p>
        SUPER.TENNIS is an independent tennis publisher. Our content is produced and reviewed by the
        <strong>SUPER.TENNIS Editorial</strong> team. We do not invent author personas or fake bylines —
        articles are attributed honestly to our editorial team rather than to fictional writers. We are not
        affiliated with the ATP, WTA, or ITF; all trademarks belong to their respective owners.
      </p>
    </section>

    <section class="about-section">
      <h2>How we report the news</h2>
      <p>
        Our daily news items are <strong>faithful rewrites</strong> of stories first reported by established
        outlets. That means we summarise a real, already-published event in our own words — we never invent
        quotes, scores, transfers, injuries, or relationships, and we never add drama that wasn't in the
        original reporting.
      </p>
      <ul>
        <li><strong>Every news item links to its original source</strong>, named in plain text (e.g. ESPN, BBC Sport).</li>
        <li>We don't break news or claim first-hand reporting — we summarise and point you to the source.</li>
        <li>Headlines avoid tabloid sensationalism; an automated filter rejects clickbait and fabrication keywords before publication.</li>
      </ul>
    </section>

    <section class="about-section">
      <h2>Where our data comes from</h2>
      <p>
        Player statistics, rankings, head-to-head records, and all-time records are sourced from publicly
        available <strong>ATP Tour</strong>, <strong>WTA Tour</strong>, and <strong>ITF</strong> data, along
        with established reference databases and Wikipedia. News is summarised from outlets including ESPN,
        BBC Sport, Tennis World USA, Daily Mail Sport, and Bleacher Report.
      </p>
      <p>
        Statistical claims on our evergreen pages (records, rankings, prize money) are cross-checked against
        official tour and tournament sources before publication.
      </p>
    </section>

    <section class="about-section">
      <h2>Transparency about automation</h2>
      <p>
        We believe in being honest about how content is made. News summaries are drafted with the help of
        automation from source RSS feeds, then passed through a fidelity filter that rejects anything that
        deviates from the source. A weekly quality check removes any item that fails a source-faithfulness
        review.
      </p>
      <p>
        Our long-form work — gear guides, lifestyle features, records explainers, head-to-head analyses, and
        tournament guides — is written and reviewed manually before it goes live.
      </p>
    </section>

    <section class="about-section">
      <h2>Corrections</h2>
      <p>
        We fix mistakes. If you spot a factual error, a broken stat, or a mis-stated record, please tell us
        via our <a href="/contact/">contact page</a> and we'll review and correct it. When we materially
        update an article, the page's "Updated" date reflects the change.
      </p>
    </section>

    <section class="about-section">
      <h2>Affiliate disclosure</h2>
      <p>
        Some pages — mainly gear guides and certain lifestyle articles — contain affiliate links. If you buy
        through one, we may earn a small commission at no extra cost to you. Affiliate relationships never
        influence our editorial recommendations or rankings; we flag affiliate content with a visible
        disclosure on the page.
      </p>
    </section>

    <section class="about-section">
      <h2>More</h2>
      <p>
        Learn more <a href="/about/">about SUPER.TENNIS</a> or <a href="/contact/">get in touch</a>.
      </p>
    </section>
  </div>
</BaseLayout>

<style>
  .about-page {
    max-width: 800px;
    margin: 0 auto;
    padding: 0 24px 60px;
  }
  .breadcrumbs {
    padding: 20px 0;
    font-size: 0.82rem;
    color: var(--gray-500);
  }
  .breadcrumbs a { color: var(--gray-600); transition: color 0.2s; }
  .breadcrumbs a:hover { color: var(--court-green); }
  .sep { margin: 0 8px; }
  .current { color: var(--gray-800); font-weight: 500; }

  .page-hero {
    padding: 48px 0 32px;
    border-bottom: 3px solid var(--court-green);
    margin-bottom: 36px;
  }
  .page-hero h1 {
    font-family: var(--font-heading);
    font-size: 2.4rem;
    text-transform: uppercase;
    color: var(--gray-900);
    margin: 0;
  }
  .subtitle {
    color: var(--gray-600);
    font-size: 1.1rem;
    margin: 8px 0 0;
  }

  .about-section { margin-bottom: 40px; }
  .about-section h2 {
    font-family: var(--font-heading);
    font-size: 1.3rem;
    text-transform: uppercase;
    color: var(--gray-900);
    margin: 0 0 16px;
    padding-bottom: 10px;
    border-bottom: 2px solid var(--gray-200);
  }
  .about-section p {
    color: var(--gray-700);
    font-size: 1.02rem;
    line-height: 1.8;
    margin: 0 0 16px;
  }
  .about-section ul {
    margin: 0 0 16px;
    padding-left: 22px;
    color: var(--gray-700);
    font-size: 1.02rem;
    line-height: 1.7;
  }
  .about-section li { margin-bottom: 8px; }
  .about-section a {
    color: var(--court-green);
    font-weight: 500;
    transition: color 0.2s;
  }
  .about-section a:hover { text-decoration: underline; }

  @media (max-width: 768px) {
    .page-hero h1 { font-size: 1.8rem; }
  }
</style>
