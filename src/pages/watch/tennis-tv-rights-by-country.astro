  .context-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 12px;
  }
  .context-card {
    display: flex;
    flex-direction: column;
    padding: 14px 16px;
    background: var(--gray-50);
    border: 1px solid var(--gray-200);
    border-radius: var(--radius);
    text-decoration: none;
    color: var(--gray-800);
    transition: var(--transition);
  }
  .context-card:hover {
    border-color: var(--court-green);
    background: white;
    transform: translateY(-1px);
  }
  .context-label {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--court-green);
    font-weight: 700;
    margin-bottom: 4px;
  }
  .context-title { font-size: 0.86rem; line-height: 1.35; font-weight: 600; color: var(--gray-900); }

  @media (max-width: 1024px) { .context-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 600px) { .context-grid { grid-template-columns: 1fr; } .article-hero h1 { font-size: 1.6rem; } }
</style>
