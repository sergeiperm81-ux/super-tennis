    padding: 10px 14px;
    border-bottom: 1px solid var(--gray-200);
    vertical-align: top;
  }
  .format-table th {
    background: var(--gray-50);
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--gray-700);
    font-weight: 700;
  }
  .format-table td { line-height: 1.5; }
  .price-free { color: var(--court-green); font-weight: 700; }
  .price-paid { color: var(--gray-800); }

  .section-title {
