        </a>
        <a href="/rules/how-many-sets-in-tennis/" class="context-card">
          <span class="context-label">Rules</span>
          <span class="context-title">How Many Sets in a Match</span>
        </a>
        <a href="/rankings/" class="context-card">
          <span class="context-label">Rankings</span>
          <span class="context-title">ATP & WTA Rankings</span>
        </a>
      </div>
    </section>

    <FaqBlock faqs={faqs} title="Tennis Scoring — Frequently Asked Questions" />
  </article>
</BaseLayout>

