---
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import ArticleFooter from '../../components/ArticleFooter.astro';
import RelatedArticles from '../../components/RelatedArticles.astro';
import LiteYouTube from '../../components/LiteYouTube.astro';
import { getArticleBySlug, getArticleSlugs } from '../../lib/supabase';
import { addInterlinks } from '../../lib/interlinks';
import { getArticlePhotoUrl } from '../../lib/player-photos';
import { tournamentVideos } from '../../data/youtube-channels';
import { marked } from 'marked';

export async function getStaticPaths() {
  let slugs: string[] = [];
  try {
    slugs = await getArticleSlugs('tournaments');
  } catch (e) {
    console.warn('tournaments getStaticPaths: Supabase unavailable');
  }

  if (slugs.length === 0) {
    slugs = [
      'australian-open-guide', 'wimbledon-guide', 'us-open-guide', 'roland-garros-guide',
      'indian-wells-guide', 'miami-open-guide', 'atp-finals-guide', 'wta-finals-guide',
      'davis-cup-guide', 'monte-carlo-masters-guide', 'shanghai-masters-guide', 'laver-cup-guide',
    ];
  }

  return slugs.map(slug => ({ params: { slug } }));
}

const { slug } = Astro.params;

let article: any = null;
try {
  article = await getArticleBySlug(slug as string);
} catch (e) {
  console.warn(`Tournament article not found: ${slug}`);
}

if (!article) {
  return Astro.redirect('/tournaments/');
}

const heroImage = await getArticlePhotoUrl(slug as string, 'tournaments');

const rawHtml = article.body ? marked.parse(article.body) : '';
const bodyHtml = rawHtml ? await addInterlinks(rawHtml as string, `/tournaments/${slug}/`) : '';

const videos = tournamentVideos[slug as string] || [];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: article.title,
  description: article.meta_description || article.excerpt,
  url: `https://super.tennis/tournaments/${slug}/`,
  publisher: {
    '@type': 'Organization',
    name: 'SUPER.TENNIS',
    url: 'https://super.tennis',
  },
  about: {
    '@type': 'SportsEvent',
    name: article.title,
    sport: 'Tennis',
  },
};
---

<ArticleLayout
  title={article.meta_title || article.title}
  description={article.meta_description || article.excerpt || `${article.title} — Tournament guide on SUPER.TENNIS.`}
  breadcrumbs={[
    { label: 'Home', href: '/' },
    { label: 'Tournaments', href: '/tournaments/' },
    { label: article.title },
  ]}
  image={heroImage || undefined}
  category="tournaments"
  categoryLabel="Tournament Guide"
  categoryHref="/tournaments/"
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <div set:html={bodyHtml} />

  {videos.length > 0 && (
    <section class="tournament-videos">
      <h2>Videos</h2>
      <div class="tournament-videos__grid">
        {videos.map(v => (
          <div class="tournament-video">
            <LiteYouTube videoId={v.id} title={v.title} />
            <p class="tournament-video__source">{v.channelName}</p>
          </div>
        ))}
      </div>
    </section>
  )}

  <RelatedArticles category="tournaments" currentSlug={slug as string} />

  <ArticleFooter
    backLabel="All Tournaments"
    backHref="/tournaments/"
    relatedLinks={[
      { label: 'Calendar', href: '/calendar/' },
      { label: 'Rankings', href: '/rankings/' },
      { label: 'Player Profiles', href: '/players/' },
      { label: 'Head to Head', href: '/vs/' },
    ]}
  />
</ArticleLayout>

<style>
  .tournament-videos {
    margin-top: 48px;
    padding-top: 32px;
    border-top: 2px solid var(--gray-200);
  }
  .tournament-videos h2 {
    font-family: var(--font-heading);
    font-size: 1.4rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--gray-900);
    margin: 0 0 20px;
  }
  .tournament-videos__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
  }
  .tournament-video__source {
    font-size: 0.78rem;
    color: var(--gray-500);
    margin: 8px 0 0;
  }
  @media (max-width: 768px) {
    .tournament-videos__grid { grid-template-columns: 1fr; }
  }
</style>
