---
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import { getArticleBySlug, getArticleSlugs } from '../../lib/supabase';
import { marked } from 'marked';

export async function getStaticPaths() {
  let slugs: string[] = [];
  try {
    slugs = await getArticleSlugs('tournaments');
  } catch (e) {
    console.warn('tournaments getStaticPaths: Supabase unavailable');
  }

  if (slugs.length === 0) {
    slugs = [
      'australian-open-guide', 'wimbledon-guide', 'us-open-guide', 'roland-garros-guide',
      'indian-wells-guide', 'miami-open-guide', 'atp-finals-guide', 'wta-finals-guide',
      'davis-cup-guide', 'monte-carlo-masters-guide', 'shanghai-masters-guide', 'laver-cup-guide',
    ];
  }

  return slugs.map(slug => ({ params: { slug } }));
}

const { slug } = Astro.params;

let article: any = null;
try {
  article = await getArticleBySlug(slug as string);
} catch (e) {
  console.warn(`Tournament article not found: ${slug}`);
}

if (!article) {
  return Astro.redirect('/tournaments/');
}

const bodyHtml = article.body ? marked.parse(article.body) : '';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: article.title,
  description: article.meta_description || article.excerpt,
  url: `https://super.tennis/tournaments/${slug}/`,
  publisher: {
    '@type': 'Organization',
    name: 'SUPER.TENNIS',
    url: 'https://super.tennis',
  },
  about: {
    '@type': 'SportsEvent',
    name: article.title,
    sport: 'Tennis',
  },
};
---

<ArticleLayout
  title={article.meta_title || article.title}
  description={article.meta_description || article.excerpt || `${article.title} — Tournament guide on SUPER.TENNIS.`}
  breadcrumbs={[
    { label: 'Home', href: '/' },
    { label: 'Tournaments', href: '/tournaments/' },
    { label: article.title },
  ]}
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <div set:html={bodyHtml} />

  <div class="article-nav">
    <a href="/tournaments/" class="nav-back">← All Tournaments</a>
    <div class="nav-related">
      <a href="/calendar/">📅 Calendar</a>
      <a href="/rankings/">📊 Rankings</a>
      <a href="/players/">👥 Players</a>
    </div>
  </div>
</ArticleLayout>

<style>
  .article-nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 16px;
    margin-top: 40px;
    padding-top: 24px;
    border-top: 2px solid var(--gray-200);
  }
  .nav-back {
    color: var(--court-green);
    font-weight: 600;
    font-size: 0.95rem;
  }
  .nav-back:hover { text-decoration: underline; }
  .nav-related { display: flex; gap: 16px; }
  .nav-related a {
    color: var(--gray-600);
    font-size: 0.9rem;
    font-weight: 500;
    transition: color 0.2s;
  }
  .nav-related a:hover { color: var(--court-green); }
</style>
