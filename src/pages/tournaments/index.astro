---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getArticles } from '../../lib/supabase';

// Fetch real tournament articles from Supabase
let tournamentArticles: any[] = [];
try {
  tournamentArticles = await getArticles({ category: 'tournaments', limit: 20 });
} catch (e) {
  console.warn('Tournaments index: Supabase unavailable');
}

// Icon/emoji mapping for tournament articles
const iconMap: Record<string, string> = {
  'australian-open': '🇦🇺',
  'roland-garros-french-open': '🇫🇷',
  'wimbledon': '🇬🇧',
  'us-open': '🇺🇸',
  'indian-wells': '🌴',
  'miami-open': '🌊',
  'atp-finals': '🏅',
  'wta-finals': '🏅',
  'davis-cup': '🏳️',
  'monte-carlo-masters': '🇲🇨',
  'shanghai-masters': '🇨🇳',
  'laver-cup': '🌍',
};

// Category labeling
function getLevel(slug: string): string {
  if (['australian-open', 'roland-garros-french-open', 'wimbledon', 'us-open'].includes(slug)) return 'Grand Slam';
  if (['atp-finals', 'wta-finals'].includes(slug)) return 'Finals';
  if (['davis-cup', 'laver-cup'].includes(slug)) return 'Team Event';
  return 'Masters 1000';
}

function getLevelClass(slug: string): string {
  const level = getLevel(slug);
  if (level === 'Grand Slam') return 'gs';
  if (level === 'Finals') return 'finals';
  if (level === 'Team Event') return 'team';
  return 'masters';
}

// Sort: Grand Slams first, then Finals, then Masters, then Team
const levelOrder: Record<string, number> = { 'Grand Slam': 0, 'Finals': 1, 'Masters 1000': 2, 'Team Event': 3 };
const sortedArticles = [...tournamentArticles].sort((a, b) => {
  return (levelOrder[getLevel(a.slug)] ?? 9) - (levelOrder[getLevel(b.slug)] ?? 9);
});
---

<BaseLayout
  title="Tennis Tournaments — Grand Slams, Masters & More"
  description="Complete guides to every major tennis tournament. Grand Slam history, Masters 1000 events, ATP & WTA Finals, and team competitions."
>
  <div class="tournaments-page">
    <div class="container">
      <section class="page-hero">
        <h1>Tennis Tournaments</h1>
        <p class="subtitle">Complete guides to Grand Slams, Masters 1000, and the biggest events in tennis</p>
      </section>

      {sortedArticles.length > 0 ? (
        <div class="tournaments-grid">
          {sortedArticles.map(article => (
            <a href={`/tournaments/${article.slug}/`} class={`tournament-card ${getLevelClass(article.slug)}`}>
              <div class="card-header">
                <span class="tournament-icon">{iconMap[article.slug] || '🎾'}</span>
                <span class={`level-badge ${getLevelClass(article.slug)}`}>{getLevel(article.slug)}</span>
              </div>
              <h2>{article.title}</h2>
              <p>{article.excerpt || article.meta_description || ''}</p>
              <span class="read-more">Read Guide →</span>
            </a>
          ))}
        </div>
      ) : (
        <div class="empty-state">
          <p>Tournament guides are coming soon. Check back shortly!</p>
        </div>
      )}

      <section class="related-section">
        <div class="related-links">
          <a href="/calendar/" class="related-card">
            <span class="related-icon">📅</span>
            <div>
              <h3>Tournament Calendar</h3>
              <p>See the full 2026 ATP & WTA schedule</p>
            </div>
          </a>
          <a href="/rankings/" class="related-card">
            <span class="related-icon">📊</span>
            <div>
              <h3>Live Rankings</h3>
              <p>Current ATP & WTA ranking tables</p>
            </div>
          </a>
          <a href="/players/" class="related-card">
            <span class="related-icon">👥</span>
            <div>
              <h3>Player Profiles</h3>
              <p>Stats, bios, and career highlights</p>
            </div>
          </a>
        </div>
      </section>
    </div>
  </div>
</BaseLayout>

<style>
  .tournaments-page {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px 60px;
  }

  .page-hero {
    padding: 48px 0 32px;
    border-bottom: 3px solid var(--court-green);
    margin-bottom: 40px;
  }
  .page-hero h1 {
    font-family: var(--font-heading);
    font-size: 2.8rem;
    text-transform: uppercase;
    color: var(--gray-900);
    margin: 0;
  }
  .subtitle {
    color: var(--gray-600);
    font-size: 1.1rem;
    margin: 8px 0 0;
  }

  .tournaments-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-bottom: 48px;
  }

  .tournament-card {
    text-decoration: none;
    color: inherit;
    background: white;
    border: 1px solid var(--gray-200);
    border-radius: var(--radius);
    padding: 24px;
    display: flex;
    flex-direction: column;
    transition: all 0.2s;
  }
  .tournament-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow);
  }
  .tournament-card.gs {
    border-left: 4px solid #d4a017;
  }
  .tournament-card.finals {
    border-left: 4px solid #8b5cf6;
  }
  .tournament-card.masters {
    border-left: 4px solid var(--court-green);
  }
  .tournament-card.team {
    border-left: 4px solid #3b82f6;
  }

  .card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 12px;
  }

  .tournament-icon {
    font-size: 2rem;
  }

  .level-badge {
    font-family: var(--font-heading);
    font-size: 0.6rem;
    text-transform: uppercase;
    padding: 3px 10px;
    border-radius: 4px;
    letter-spacing: 0.05em;
  }
  .level-badge.gs {
    background: #fef3c7;
    color: #92400e;
  }
  .level-badge.finals {
    background: #ede9fe;
    color: #6d28d9;
  }
  .level-badge.masters {
    background: #dcfce7;
    color: #166534;
  }
  .level-badge.team {
    background: #dbeafe;
    color: #1e40af;
  }

  .tournament-card h2 {
    font-family: var(--font-body);
    font-size: 1.05rem;
    font-weight: 700;
    margin: 0 0 8px;
    line-height: 1.35;
  }
  .tournament-card p {
    color: var(--gray-600);
    font-size: 0.85rem;
    line-height: 1.6;
    margin: 0;
    flex: 1;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .read-more {
    color: var(--court-green);
    font-weight: 600;
    font-size: 0.85rem;
    margin-top: 16px;
  }

  .empty-state {
    text-align: center;
    padding: 60px 24px;
    color: var(--gray-500);
    background: var(--gray-50);
    border-radius: var(--radius);
    margin-bottom: 48px;
  }

  .related-section {
    margin-top: 16px;
  }

  .related-links {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }

  .related-card {
    display: flex;
    gap: 14px;
    align-items: flex-start;
    padding: 20px;
    background: var(--gray-50);
    border-radius: var(--radius);
    text-decoration: none;
    color: inherit;
    transition: all 0.2s;
  }
  .related-card:hover {
    background: #f0fdf4;
  }

  .related-icon {
    font-size: 1.8rem;
    flex-shrink: 0;
  }

  .related-card h3 {
    font-family: var(--font-heading);
    font-size: 0.9rem;
    text-transform: uppercase;
    margin: 0 0 4px;
  }
  .related-card p {
    color: var(--gray-600);
    font-size: 0.8rem;
    margin: 0;
    line-height: 1.4;
  }

  @media (max-width: 1024px) {
    .tournaments-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 768px) {
    .tournaments-grid { grid-template-columns: 1fr; }
    .related-links { grid-template-columns: 1fr; }
    .page-hero h1 { font-size: 2rem; }
  }
</style>
