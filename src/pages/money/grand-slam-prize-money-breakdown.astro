  .article-hero {
    text-align: center;
    padding: 24px 0 28px;
    border-bottom: 3px solid var(--court-green);
    margin-bottom: 28px;
  }
  .hero-emoji { font-size: 2.6rem; margin-bottom: 8px; }
  .article-hero h1 {
    font-family: var(--font-heading);
    font-size: 2.2rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin: 0 0 8px;
    color: var(--gray-900);
    line-height: 1.2;
  }
  .byline { color: var(--gray-500); font-size: 0.85rem; margin: 0; }
  .byline a { color: var(--gray-600); }

  .quick-answer {
    margin: 0 0 20px;
    padding: 18px 22px;
    background: linear-gradient(135deg, var(--gray-50) 0%, #fff 100%);
    border-left: 3px solid var(--court-green);
    border-radius: 0 var(--radius) var(--radius) 0;
  }
  .qa-label {
    font-family: var(--font-heading);
    font-size: 0.78rem;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--court-green);
    margin: 0 0 8px;
  }
  .qa-text { margin: 0; font-size: 0.98rem; line-height: 1.65; color: var(--gray-800); }

  .system-note {
    margin: 0 0 32px;
    padding: 12px 18px;
    background: #fffbeb;
    border: 1px solid #fde68a;
    border-radius: var(--radius);
    font-size: 0.88rem;
    line-height: 1.55;
    color: var(--gray-700);
  }
  .system-note-label {
    display: inline-block;
    font-family: var(--font-heading);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #b45309;
    background: #fef3c7;
    padding: 2px 8px;
    border-radius: 4px;
    margin-right: 8px;
    font-weight: 700;
  }
  .system-note p { display: inline; margin: 0; }
