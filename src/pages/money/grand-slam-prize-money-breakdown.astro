  .article-body { color: var(--gray-800); }
  .article-body h2 {
    font-family: var(--font-heading);
    font-size: 1.35rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin: 32px 0 14px;
    color: var(--gray-900);
  }
