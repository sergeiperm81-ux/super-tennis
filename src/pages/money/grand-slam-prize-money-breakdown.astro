---
/**
 * /money/grand-slam-prize-money-breakdown/ — Slam-specific deep-dive.
 * Codex Round 3 evergreen cluster #3.
 *
 * Search intent: "Wimbledon prize money 2026", "Roland Garros prize",
 * "US Open total prize pool", "Australian Open winner check",
 * "Slam prize money per round". Concrete lookup tables.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import FaqBlock from '../../components/FaqBlock.astro';

const title = 'Grand Slam Prize Money Breakdown — 2026 Tables (AO/RG/W/USO) | SUPER.TENNIS';
const h1 = 'Grand Slam Prize Money Breakdown';
const metaDescription = '2026 Grand Slam prize money: singles champion checks, per-round prize money, total prize pools at the Australian Open, Roland Garros, Wimbledon, and US Open. Doubles + qualifying + wheelchair amounts included.';
const publishedDate = '2026-05-17';

const quickAnswer = "2026 Grand Slam prize money — singles champion checks: Australian Open A$3.5M (~US$2.3M), Roland Garros €2.4M, Wimbledon £3.0M (~US$3.8M), US Open ~$3.6M. Total prize pools: Australian Open A$96.5M (largest in tennis history), US Open ~$75M, Wimbledon £53M, Roland Garros €58M. Even first-round losers earn $60-100K. Equal men's and women's prize money has been standard since 2007 (US Open since 1973, Australian Open since 2001).";

// Per-round dollar amounts approximated for 2026
const slamSinglesTable = [
  { round: 'Champion', ao: 'A$3.5M', rg: '€2.4M', wimbledon: '£3.0M', usOpen: '$3.6M' },
  { round: 'Finalist', ao: 'A$1.9M', rg: '€1.27M', wimbledon: '£1.52M', usOpen: '$1.8M' },
  { round: 'Semifinalist', ao: 'A$1.1M', rg: '€780K', wimbledon: '£775K', usOpen: '$1.0M' },
  { round: 'Quarterfinalist', ao: 'A$665K', rg: '€440K', wimbledon: '£440K', usOpen: '$530K' },
  { round: 'Round of 16', ao: 'A$405K', rg: '€265K', wimbledon: '£265K', usOpen: '$325K' },
  { round: 'Round of 32', ao: 'A$255K', rg: '€158K', wimbledon: '£158K', usOpen: '$215K' },
  { round: 'Round of 64', ao: 'A$170K', rg: '€100K', wimbledon: '£105K', usOpen: '$140K' },
  { round: 'Round of 128 (first-round)', ao: 'A$120K', rg: '€78K', wimbledon: '£66K', usOpen: '$100K' },
];

const totalPools = [
  { event: 'Australian Open 2026', total: 'A$96.5M (~$63M)', date: 'January', notes: 'Largest total prize pool in tennis history' },
  { event: 'Roland Garros 2026', total: '€58M (~$63M)', date: 'May-June', notes: 'Includes singles, doubles, mixed, wheelchair' },
  { event: 'Wimbledon 2026', total: '£53M (~$67M)', date: 'June-July', notes: '~£25M to singles main draw' },
  { event: 'US Open 2026', total: '~$75M', date: 'August-September', notes: 'Largest in USD terms among Slams' },
];

const otherCategories = [
  { category: 'Singles', share: '~70%', detail: '128 main draw + 128 qualifying. Champion gets the biggest single check.' },
  { category: 'Doubles', share: '~12-15%', detail: 'Champion teams typically earn $700K-$1M per Slam (split between the two players).' },
  { category: 'Mixed doubles', share: '~2-3%', detail: 'Champion team typically earns $200K-$400K combined.' },
  { category: 'Qualifying singles', share: '~5-7%', detail: 'Players who reach main draw via qualifying earn $25-50K just for the run.' },
  { category: 'Wheelchair singles + doubles', share: '~3-5%', detail: 'Equal prize money increases each year; now well above $500K for singles champions.' },
];

const winnerOverTime = [
  { year: '1968', wimbledon: '£2,000', usOpen: '$14,000', note: 'Open Era begins' },
  { year: '1980', wimbledon: '£20,000', usOpen: '$46,000', note: 'Borg-McEnroe era' },
  { year: '1990', wimbledon: '£230,000', usOpen: '$350,000', note: 'Sampras era' },
  { year: '2000', wimbledon: '£477,500', usOpen: '$800,000', note: 'Pete Sampras 7th Wimbledon' },
  { year: '2010', wimbledon: '£1.0M', usOpen: '$1.7M', note: 'Federer-Nadal era peak' },
  { year: '2015', wimbledon: '£1.88M', usOpen: '$3.3M', note: 'Big Three dominance' },
  { year: '2020', wimbledon: '— (canceled)', usOpen: '$3.0M', note: 'COVID year' },
  { year: '2025', wimbledon: '£3.0M', usOpen: '$3.6M', note: 'Modern figures' },
  { year: '2026', wimbledon: '£3.0M', usOpen: '~$3.6M+', note: 'Current — confirmed by tournaments' },
];

const faqs = [
  {
    q: 'Which Grand Slam has the largest prize money?',
    a: 'In 2026, the Australian Open has the largest total prize pool at A$96.5 million (approximately US$63M) — the largest in tennis history. The US Open is largest in USD terms at ~$75M total. Roland Garros: €58M (~$63M). Wimbledon: £53M (~$67M). All four pay similar amounts to the singles champion (~$2.3-3.6M); differences come from how the total is distributed across doubles, qualifying, and wheelchair.',
  },
  {
    q: 'How much does a Wimbledon champion earn in 2026?',
    a: 'The 2026 Wimbledon singles champion receives £3.0 million (approximately $3.8M at current exchange rates). This is identical for men\'s and women\'s singles winners (equal prize money since 2007). Doubles champion teams earn approximately £700K total (£350K per player). Junior champions earn £30K. Wheelchair singles champions earn £75K+.',
  },
  {
    q: "What's the US Open prize money for 2026?",
    a: 'The 2026 US Open singles champion is expected to earn approximately $3.6M+ (the exact figure is confirmed by the USTA ~6 weeks before the event each year). Total prize pool: ~$75M, the largest in USD terms among the four Slams. The US Open has consistently led other Slams in prize money increases, often by 5-8% year-over-year.',
  },
  {
    q: 'How much does a first-round loser at a Grand Slam earn?',
    a: '2026 first-round prize money at each Slam: Australian Open A$120K (~$78K), Roland Garros €78K (~$85K), Wimbledon £66K (~$83K), US Open ~$100K. Players who lose in the first round still take home meaningful money — designed to make competing at Slams financially viable for players who travel long distances and have significant operating costs.',
  },
  {
    q: 'When did Grand Slam prize money first exceed $1M for the singles champion?',
    a: "The US Open was the first Slam to pay $1M+ to the singles champion, reaching $1M in 2002 (men's, women's became equal soon after at the higher figure). Wimbledon followed in 2003 (men's; women's reached parity in 2007). Australian Open reached A$1M in 2004. Roland Garros reached €1M in 2006. All four Slams have continued increasing the champion's purse roughly 5-10% per year since.",
  },
  {
    q: 'Why does Australian Open have such a high total prize pool?',
    a: 'The Australian Open\'s 2026 total prize pool of A$96.5M is the largest because of: (1) aggressive prize money increases at lower rounds — AO pays more to first-round losers than other Slams; (2) expansion of doubles and wheelchair prize money; (3) currency effects — A$ totals look larger than the equivalent USD amount; (4) strong title sponsorship from Asian-Pacific brands. In US-dollar terms (~$63M), it\'s slightly below the US Open\'s ~$75M.',
  },
  {
    q: 'Do tennis players get bonus money for winning multiple Slams in a year?',
    a: 'Not directly from the Slams themselves — each Slam pays its own prize money independently. However, some sponsorship deals include Slam-win bonuses. For example, racket and apparel sponsors typically pay $500K-$2M bonuses for a Slam title. Additionally, the player earns 2,000 ranking points per Slam title — affecting endorsement deal renegotiation at year-end. Career Grand Slam winners (winning all four in a career) often receive additional sponsor bonuses too.',
  },
];

const articleJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: h1,
  description: metaDescription,
  url: 'https://super.tennis/money/grand-slam-prize-money-breakdown/',
  datePublished: publishedDate,
  dateModified: publishedDate,
  author: {
    '@type': 'Organization',
    '@id': 'https://super.tennis/#organization',
    name: 'SUPER.TENNIS Editorial',
    url: 'https://super.tennis/about/',
  },
  publisher: {
    '@type': 'Organization',
    name: 'SUPER.TENNIS',
    url: 'https://super.tennis',
    logo: { '@type': 'ImageObject', url: 'https://super.tennis/og/default.png' },
  },
};

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://super.tennis/' },
    { '@type': 'ListItem', position: 2, name: 'Money', item: 'https://super.tennis/money/' },
    { '@type': 'ListItem', position: 3, name: 'Grand Slam Prize Money' },
  ],
};
---

<BaseLayout title={title} description={metaDescription} ogType="article">
  <script type="application/ld+json" set:html={JSON.stringify(articleJsonLd)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />

  <article class="rules-article">
    <nav class="breadcrumbs">
      <a href="/">Home</a> <span class="sep">/</span>
      <a href="/money/">Money</a> <span class="sep">/</span>
      <span class="current">Grand Slam Prize Money</span>
    </nav>

    <header class="article-hero">
      <div class="hero-emoji">🏆</div>
      <h1>{h1}</h1>
      <p class="byline">By <a href="/about/">SUPER.TENNIS Editorial</a> · Updated {publishedDate}</p>
    </header>

    <section class="quick-answer">
      <h2 class="qa-label">Quick Answer</h2>
      <p class="qa-text">{quickAnswer}</p>
    </section>

    <aside class="system-note">
      <span class="system-note-label">Current System Note</span>
      <p>Per-round figures reflect <strong>2026 confirmed amounts</strong> as announced by each Slam ~3-4 weeks before its event. Exact dollar conversions vary day-to-day with exchange rates — figures here use approximate end-of-2025 conversions. Each Slam publishes its prize money breakdown on its official website.</p>
    </aside>

    <div class="article-body">
      <h2 id="total-pools">2026 Total Prize Pools</h2>
      <div class="points-table-wrap">
        <table class="points-table">
          <thead><tr><th>Event</th><th>Total Prize Money</th><th>Dates</th><th>Notes</th></tr></thead>
          <tbody>
            {totalPools.map(p => <tr><td><strong>{p.event}</strong></td><td>{p.total}</td><td>{p.date}</td><td class="ctx">{p.notes}</td></tr>)}
          </tbody>
        </table>
      </div>

      <h2 id="singles-by-round">Singles Prize Money by Round (2026)</h2>
      <p>
        All four Slams pay equal amounts to men's and women's singles winners (since 2007). Below: approximate per-round figures in each Slam's native currency.
      </p>
      <div class="points-table-wrap">
        <table class="points-table">
          <thead>
            <tr>
              <th>Round Reached</th>
              <th>AO 🇦🇺</th>
              <th>RG 🇫🇷</th>
              <th>Wim 🇬🇧</th>
              <th>USO 🇺🇸</th>
            </tr>
          </thead>
          <tbody>
            {slamSinglesTable.map(r => (
              <tr>
                <td><strong>{r.round}</strong></td>
                <td>{r.ao}</td>
                <td>{r.rg}</td>
                <td>{r.wimbledon}</td>
                <td>{r.usOpen}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p>
        <em>Note:</em> qualifying-round prize money (for players competing to enter the main draw) is paid separately: ~$30-50K to qualifying-draw winners across all four Slams.
      </p>

      <h2 id="other-categories">Beyond Singles: Where the Rest of the Pool Goes</h2>
      <p>
        Singles draws absorb the majority of each Slam's prize pool — but not all of it. The remaining ~30% is split across:
      </p>
      <div class="points-table-wrap">
        <table class="points-table">
          <thead><tr><th>Category</th><th>Share of Pool</th><th>Detail</th></tr></thead>
          <tbody>
            {otherCategories.map(c => <tr><td><strong>{c.category}</strong></td><td>{c.share}</td><td class="ctx">{c.detail}</td></tr>)}
          </tbody>
        </table>
      </div>

      <h2 id="historical">Champion's Check Over Time: 1968-2026</h2>
      <p>
        Tracking the Wimbledon and US Open singles champion's check across the Open Era shows how dramatically the sport's economics have grown:
      </p>
      <div class="points-table-wrap">
        <table class="points-table">
          <thead><tr><th>Year</th><th>Wimbledon Champion</th><th>US Open Champion</th><th>Era</th></tr></thead>
          <tbody>
            {winnerOverTime.map(r => <tr><td>{r.year}</td><td>{r.wimbledon}</td><td>{r.usOpen}</td><td class="ctx">{r.note}</td></tr>)}
          </tbody>
        </table>
      </div>
      <p>
        From 1968 (£2,000 at Wimbledon) to 2026 (£3,000,000), the champion's check has grown roughly <strong>1,500-fold</strong>. Even adjusting for inflation (£2,000 in 1968 ≈ £40,000 in 2026), the real-terms increase is about 75×. The drivers: global TV deals, sponsorship inflation, women's sports investment growth, and competitive pressure between the four Slams to maintain prestige.
      </p>

      <h2 id="comparison-to-other-sports">How Tennis Prize Money Compares to Other Sports</h2>
      <p>
        Tennis is one of the most lucrative individual sports for the top players, but compared to team sports it's more uneven:
      </p>
      <ul>
        <li><strong>Golf majors</strong> — Masters 2026 champion: ~$3.6M; PGA Championship: ~$3.3M; comparable to tennis Slams.</li>
        <li><strong>Formula 1</strong> — top drivers earn $40-70M/year in base salary alone, but FIA prize money is far smaller. F1 economics are more team-based.</li>
        <li><strong>Boxing pay-per-view</strong> — major fights can pay $50-150M+ per bout. Tennis Slams pay less per event but happen four times a year for every player who qualifies.</li>
        <li><strong>NBA / NFL / Premier League</strong> — top players earn $50-100M+ salary (without prize money structures). Tennis's prize-money model is more meritocratic but less consistent.</li>
      </ul>
    </div>

    <section class="related-context">
      <h2 class="section-title">Continue Reading</h2>
      <div class="context-grid">
        <a href="/money/" class="context-card">
          <span class="context-label">Hub</span>
          <span class="context-title">Tennis Money & Earnings</span>
        </a>
        <a href="/money/tennis-prize-money-explained/" class="context-card">
          <span class="context-label">Money</span>
          <span class="context-title">How Prize Money Works</span>
        </a>
        <a href="/money/how-much-tennis-players-earn/" class="context-card">
          <span class="context-label">Money</span>
          <span class="context-title">How Much Players Actually Earn</span>
        </a>
        <a href="/tournaments/" class="context-card">
          <span class="context-label">Tournaments</span>
          <span class="context-title">Grand Slam Guides</span>
        </a>
      </div>
    </section>

    <FaqBlock faqs={faqs} title="Grand Slam Prize Money — FAQ" />
  </article>
</BaseLayout>

<style>
  .rules-article { max-width: 760px; margin: 0 auto; padding: 0 24px 60px; }
  .breadcrumbs { padding: 20px 0; font-size: 0.82rem; color: var(--gray-500); }
  .breadcrumbs a { color: var(--gray-600); text-decoration: none; }
  .breadcrumbs a:hover { color: var(--court-green); }
