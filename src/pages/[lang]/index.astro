  .fun-tool-card { align-items: center; background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.1); border-radius: 14px; color: inherit; display: flex; gap: 1rem; padding: 1rem 1.1rem; text-decoration: none; transition: border-color 0.2s, background 0.2s; }
  .fun-tool-card:hover { background: rgba(255,255,255,0.07); text-decoration: none; }
  .quiz-card { border-color: rgba(232,197,71,0.2); }
  .quiz-card:hover { border-color: rgba(232,197,71,0.5); background: rgba(232,197,71,0.06); }
  .fun-tool-icon { font-size: 1.8rem; flex-shrink: 0; }
  .fun-tool-body { flex: 1; }
  .fun-tool-badge { font-size: 0.65rem; font-weight: 800; letter-spacing: 1.5px; text-transform: uppercase; color: #e8845a; margin-bottom: 0.2rem; }
  .quiz-card .fun-tool-badge { color: #e8c547; }
  .fun-tool-name { font-size: 0.9rem; font-weight: 700; color: var(--text-primary); line-height: 1.3; margin-bottom: 0.2rem; }
  .fun-tool-desc { font-size: 0.78rem; color: var(--text-secondary); }
  .fun-tool-arrow { color: rgba(255,255,255,0.3); font-size: 1rem; flex-shrink: 0; }
</style>

<script>
  const nfBtns = document.querySelectorAll('.nf-btn');
  const newsItems = document.querySelectorAll<HTMLElement>('.news-item');
  nfBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      nfBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      const cat = (btn as HTMLElement).dataset.cat || 'all';
      newsItems.forEach(item => {
        item.style.display = (cat === 'all' || item.dataset.cat === cat) ? '' : 'none';
      });
    });
  });
</script>
<script src="/js/dynamic-content.js" defer></script>
