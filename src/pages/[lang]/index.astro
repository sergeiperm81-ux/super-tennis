---
/**
 * Localized homepage (/es/, future fr/zh) — a FAITHFUL 1:1 copy of src/pages/index.astro:
 * identical magazine structure, sections, sidebar and styles. Only the text is translated
 * and internal links point to /es/ where a localized page exists (English fallback avoids 404s).
 * The English homepage file is left untouched (zero risk to production).
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getLatestRankings, getPlayerBySlug, getArticles, supabase } from '../../lib/supabase';
import { countryFlags, fallbackPlayers, getFlagUrl } from '../../lib/fallback-data';
import { getActiveLocales, buildAlternates, type Locale } from '../../lib/i18n';

export async function getStaticPaths() {
  const SUPPORTED = ['es'];
  return getActiveLocales()
    .filter((locale) => SUPPORTED.includes(locale))
    .map((locale) => ({ params: { lang: locale }, props: { locale } }));
}
const { locale } = Astro.props as { locale: Locale };
const homeAlternates = buildAlternates('/', [locale]);
const DATE_LOCALE: Record<string, string> = { es: 'es-ES', fr: 'fr-FR', zh: 'zh-CN' };

async function getPlayerPhoto(slug: string): Promise<string> {
  try {
    const p = await getPlayerBySlug(slug);
    if (p?.image_url) return p.image_url;
  } catch {}
  return fallbackPlayers[slug]?.image_url || '';
}

// Sidebar rankings + profile (identical to English)
let atpTop5: any[] = [];
let sidebarPlayer: any = null;
try {
  const rankings = await getLatestRankings('atp', 5);
  atpTop5 = rankings.map((r: any) => ({
    rank: r.ranking,
    name: `${r.players?.first_name} ${r.players?.last_name}`,
    slug: r.players?.slug,
    country: r.players?.country_code || '',
    points: r.points?.toLocaleString(DATE_LOCALE[locale] ?? 'es-ES') || '0',
  }));
  sidebarPlayer = await getPlayerBySlug('jannik-sinner');
} catch {}
if (atpTop5.length === 0) {
  atpTop5 = [
    { rank: 1, name: 'Jannik Sinner', slug: 'jannik-sinner', country: 'ITA', points: '11.830' },
    { rank: 2, name: 'Alexander Zverev', slug: 'alexander-zverev', country: 'GER', points: '9.855' },
    { rank: 3, name: 'Carlos Alcaraz', slug: 'carlos-alcaraz', country: 'ESP', points: '7.190' },
    { rank: 4, name: 'Novak Djokovic', slug: 'novak-djokovic', country: 'SRB', points: '6.875' },
    { rank: 5, name: 'Daniil Medvedev', slug: 'daniil-medvedev', country: 'RUS', points: '6.445' },
  ];
}

const [sinnerPhoto, djokovicPhoto, swiatekPhoto, alcarazPhoto, federerPhoto,
       nadalPhoto, serenaPhoto, zverevPhoto, sabalenkaPhoto, gauffPhoto] = await Promise.all([
  getPlayerPhoto('jannik-sinner'), getPlayerPhoto('novak-djokovic'), getPlayerPhoto('iga-swiatek'),
  getPlayerPhoto('carlos-alcaraz'), getPlayerPhoto('roger-federer'), getPlayerPhoto('rafael-nadal'),
  getPlayerPhoto('serena-williams'), getPlayerPhoto('alexander-zverev'), getPlayerPhoto('aryna-sabalenka'),
  getPlayerPhoto('coco-gauff'),
]);

// Set of slugs that have a published es translation → localize link only when it exists.
const esSlugs = new Set<string>();
try {
  const { data: trans } = await supabase.from('article_translations').select('article_id').eq('lang', locale).eq('status', 'published');
  const ids = (trans || []).map((t: any) => t.article_id);
  if (ids.length) {
    const { data: arts } = await supabase.from('articles').select('slug').in('id', ids);
    for (const a of arts || []) esSlugs.add(a.slug);
  }
} catch {}
const lp = `/${locale}`;
function locUrl(category: string, slug: string): string {
  return esSlugs.has(slug) ? `${lp}/${category}/${slug}/` : `/${category}/${slug}/`;
}

// Map of news_id → localized {title, summary, slug} so the client-side dynamic
// news blocks (buzz / trending) can render in Spanish (see dynamic-content.js).
const newsMap: Record<string, { t: string; s: string; slug: string }> = {};
try {
  // Paginate — a single select caps at 1000 rows; ~1400 es translations, and recent news
  // (highest IDs) would otherwise fall outside the cap and render English in the buzz.
  const nt: any[] = [];
  for (let from = 0; ; from += 1000) {
    const { data } = await supabase.from('news_translations').select('news_id, title, summary').eq('lang', locale).eq('status', 'published').range(from, from + 999);
    if (!data || data.length === 0) break;
    nt.push(...data);
    if (data.length < 1000) break;
  }
  const nids = (nt || []).map((r: any) => r.news_id);
  if (nids.length) {
    const nrows: any[] = [];
    for (let from = 0; ; from += 1000) {
      const { data } = await supabase.from('news').select('id, slug').in('id', nids).range(from, from + 999);
      if (!data || data.length === 0) break;
      nrows.push(...data);
      if (data.length < 1000) break;
    }
    const slugById = new Map((nrows || []).map((n: any) => [n.id, n.slug]));
    for (const r of nt || []) {
      const slug = slugById.get(r.news_id);
      if (slug) newsMap[String(r.news_id)] = { t: r.title, s: r.summary || '', slug };
    }
  }
} catch {}

const badgeColors: Record<string, string> = {
  PLAYERS: '#4CAF50', RECORDS: '#FF9800', GEAR: '#2196F3', LIFESTYLE: '#E91E63',
  MONEY: '#FFD700', RANKINGS: '#9C27B0', TOURNAMENTS: '#00BCD4', H2H: '#FF5722',
};
const BADGE_LABEL: Record<string, Record<string, string>> = {
  es: { PLAYERS: 'JUGADORES', RECORDS: 'RÉCORDS', GEAR: 'EQUIPO', LIFESTYLE: 'ESTILO', MONEY: 'DINERO', RANKINGS: 'RANKING', TOURNAMENTS: 'TORNEOS', H2H: 'H2H' },
};
const bl = BADGE_LABEL[locale] ?? BADGE_LABEL.es;

// ── Editorial cards (Spanish copy; hrefs localized where a translation exists) ──
const row3a = [
  { title: "Iga Swiatek: cinco veces campeona de Roland Garros a la caza de una temporada de regreso", badge: "PLAYERS", image: swiatekPhoto, href: locUrl('players', 'iga-swiatek') },
  { title: "Más títulos de Grand Slam de la historia — masculino y femenino", badge: "RECORDS", image: nadalPhoto, href: locUrl('records', 'most-grand-slam-titles') },
  { title: "Las mejores raquetas de tenis para principiantes en 2026", badge: "GEAR", image: gauffPhoto, href: locUrl('gear', 'best-tennis-rackets-beginners') },
];
const row2 = [
  { title: "Cómo Novak Djokovic construyó un imperio de 250 millones de dólares", badge: "MONEY", image: djokovicPhoto, href: locUrl('players', 'novak-djokovic') },
  { title: "El patrimonio de Roger Federer — un imperio del tenis de 550 millones", badge: "MONEY", image: federerPhoto, href: locUrl('players', 'roger-federer') },
];
const compactCards = [
  { title: "Los saques más rápidos de la historia del tenis — clasificación actualizada", badge: "RECORDS", image: zverevPhoto, href: locUrl('records', 'fastest-tennis-serves-ever') },
  { title: "Las reglas del tenis explicadas — guía completa para principiantes", badge: "LIFESTYLE", image: alcarazPhoto, href: locUrl('lifestyle', 'tennis-rules-explained') },
];
const featureCard = { title: "La moda del tenis a través de las décadas — de los corsés victorianos a las colaboraciones con Nike", badge: "LIFESTYLE", image: '/images/tennis-fashion-cover.webp', href: locUrl('lifestyle', 'tennis-fashion-through-decades'), desc: "Un recorrido visual por 140 años de moda del tenis — de las faldas hasta los tobillos a los monos de Serena." };
const hero4 = { title: "El partido que cambió el tenis: un nuevo documental revisita Djokovic vs Nadal, Abierto de Australia 2012", badge: "LIFESTYLE", image: '/images/tournaments/melbourne-park.webp', href: locUrl('lifestyle', 'the-match-that-changed-tennis-2012-australian-open-documentary'), desc: "Cinco horas y cincuenta y tres minutos. Una ceremonia de entrega en la que ambos finalistas tuvieron que sentarse. Un nuevo documental de Discovery+ se pregunta qué fue realmente aquella noche." };
const row3b = [
  { title: "¿Qué raqueta usa Rafael Nadal?", badge: "GEAR", image: nadalPhoto, href: locUrl('players', 'rafael-nadal') },
  { title: "Aryna Sabalenka — dominando el tenis femenino", badge: "PLAYERS", image: sabalenkaPhoto, href: locUrl('players', 'aryna-sabalenka') },
  { title: "El debate del GOAT — ¿quién es el mejor tenista de la historia?", badge: "RECORDS", image: djokovicPhoto, href: locUrl('records', 'tennis-goat-debate') },
];

// DB article lists — translate title/excerpt where available, localize href.
async function localizeArticles(arts: any[]): Promise<any[]> {
  if (!arts.length || locale === 'en') return arts;
  const ids = arts.map((a: any) => a.id).filter(Boolean);
  const map = new Map<number, { title: string; excerpt: string | null }>();
  if (ids.length) {
    const { data } = await supabase.from('article_translations').select('article_id, title, excerpt').eq('lang', locale).eq('status', 'published').in('article_id', ids);
    for (const t of data || []) map.set(t.article_id, { title: t.title, excerpt: t.excerpt });
  }
  return arts.map((a: any) => {
    const t = map.get(a.id);
    return t ? { ...a, title: t.title, excerpt: t.excerpt ?? a.excerpt } : a;
  });
}

let latestLifestyle: any[] = [];
try { latestLifestyle = await localizeArticles(await getArticles({ category: 'lifestyle', limit: 2, status: ['published'] })); } catch {}

let latestArticles: any[] = [];
try {
  const editorialSlugs = new Set(['most-grand-slam-titles', 'fastest-tennis-serves-ever', 'most-weeks-number-one', 'tennis-goat-debate', 'best-tennis-rackets-beginners', 'tennis-rules-explained']);
  const cats = ['players', 'vs', 'records', 'gear', 'lifestyle', 'tournaments'];
  const perCat = await Promise.all(cats.map(c => getArticles({ category: c, limit: 5 })));
  const picked = new Set<string>();
  const result: any[] = [];
  for (const articles of perCat) {
    let count = 0;
    for (const a of articles) {
      if (count >= 2) break;
      if (!editorialSlugs.has(a.slug) && a.title && a.category && !picked.has(a.slug)) { result.push(a); picked.add(a.slug); count++; }
    }
  }
  for (const articles of perCat) {
    for (const a of articles) {
      if (result.length >= 18) break;
      if (!editorialSlugs.has(a.slug) && a.title && a.category && !picked.has(a.slug)) { result.push(a); picked.add(a.slug); }
    }
  }
  latestArticles = await localizeArticles(result);
} catch {}

const categoryUrl: Record<string, string> = { players: '/players/', records: '/records/', gear: '/gear/', lifestyle: '/lifestyle/', tournaments: '/tournaments/', vs: '/vs/' };
function articleUrl(art: { category: string; slug: string }): string {
  if (art.category === 'players') {
    const subPageSuffixes = ['-racket', '-net-worth', '-stats', '-grand-slams', '-career-timeline', '-partner', '-age'];
    const baseSlug = subPageSuffixes.reduce((slug, suffix) => slug.endsWith(suffix) ? slug.slice(0, -suffix.length) : slug, art.slug);
    return locUrl('players', baseSlug);
  }
  return locUrl(art.category, art.slug);
}

const categoryLabels: Record<string, string> = { players: 'Jugadores', records: 'Récords', gear: 'Equipo', lifestyle: 'Estilo', tournaments: 'Torneos', vs: 'H2H' };
const categoryColors: Record<string, string> = { players: '#4CAF50', records: '#FF9800', gear: '#2196F3', lifestyle: '#E91E63', tournaments: '#00BCD4', vs: '#FF5722' };

const recentScores = [
  { p1: 'J. Sinner', p2: 'C. Alcaraz', score: '6-4  3-6  7-6', tournament: 'Indian Wells Masters', round: 'Final', winner: 1 },
  { p1: 'A. Sabalenka', p2: 'I. Swiatek', score: '7-5  6-3', tournament: 'Dubai Open', round: 'Final', winner: 1 },
  { p1: 'N. Djokovic', p2: 'D. Medvedev', score: '6-7  6-4  6-2', tournament: 'Australian Open', round: 'SF', winner: 1 },
];

// UI strings
const S = {
  trending: 'TENDENCIAS',
  h1: 'SUPER.TENNIS — Noticias, jugadores, equipamiento, récords y estilo de tenis',
  buzzTitle: 'Lo más candente', buzzAll: 'Todas las noticias →',
  follow: 'Síguenos',
  latest: 'Lo último', latestAll: 'Todos los artículos →',
  watch: 'Ver tenis', watchAll: 'Todos los canales →',
  more: 'Más historias',
  fAll: 'Todos', fPlayers: 'Jugadores', fRecords: 'Récords', fGear: 'Equipo', fLifestyle: 'Estilo', fVs: 'H2H',
  toolsTitle: '🎾 Herramientas para fans',
  quizBadge: 'TEST', quizName: '¿Qué leyenda del tenis<br/>eres?', quizDesc: '6 preguntas para encontrar tu leyenda del tenis',
  scores: 'Resultados', seeAll: 'Ver todos →',
  hotNow: 'Lo más visto ahora',
  atpRankings: 'Ranking ATP', fullTable: 'Tabla completa →',
};
---

<BaseLayout title="Inicio" description="Tenis para todos. Jugadores, récords, equipamiento y estilo de vida — el mundo del tenis más allá de la cancha." dynamicContent={true} locale={locale} alternates={homeAlternates}>
  <script type="application/json" id="es-news-map" set:html={JSON.stringify(newsMap)}></script>
  <div class="trending-bar" id="trending-bar">
    <div class="trending-bar__label">{S.trending}</div>
    <div class="trending-bar__track">
      <div class="trending-bar__scroll" id="trending-scroll" data-locale={locale}></div>
    </div>
  </div>

  <div class="news-page">
    <div class="container">
      <div class="news-layout">
        <main class="news-main">
          <h1 class="home-h1">{S.h1}</h1>

          <section class="buzz-section">
            <div class="buzz-header">
              <div class="buzz-header__left">
                <span class="buzz-dot"></span>
                <h2 class="buzz-title">{S.buzzTitle}</h2>
              </div>
              <a href={`${lp}/news/`} class="buzz-all">{S.buzzAll}</a>
            </div>
            <div class="buzz-grid" data-dynamic="news" data-limit="6" data-locale={locale}>
              <div class="buzz-card skeleton"></div>
              <div class="buzz-card skeleton"></div>
              <div class="buzz-card skeleton"></div>
              <div class="buzz-card skeleton"></div>
              <div class="buzz-card skeleton"></div>
              <div class="buzz-card skeleton"></div>
            </div>
          </section>

          <div class="social-strip">
            <span class="social-strip__label">{S.follow}</span>
            <a href="https://www.youtube.com/@SuperTennisNews" target="_blank" rel="noopener noreferrer" class="social-strip__link social-strip__link--yt" aria-label="YouTube">
              <svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
              YouTube
            </a>
            <a href="https://bsky.app/profile/supertennisnews.bsky.social" target="_blank" rel="noopener noreferrer" class="social-strip__link social-strip__link--bs" aria-label="Bluesky">
              <svg viewBox="0 0 568 501" fill="currentColor" width="16" height="16"><path d="M123.121 33.664C188.241 82.553 258.281 181.68 284 234.873c25.719-53.192 95.759-152.32 160.879-201.21C491.866-1.611 568-28.906 568 49.851c0 17.346-9.945 145.713-15.778 166.555-20.275 72.453-94.155 90.933-159.875 79.748C507.222 316.236 568 349.292 568 397.083c0 67.503-77.226 116.879-120.53 83.847C381.222 431.328 317.486 311.377 284 273.703c-33.486 37.674-97.222 157.625-163.47 207.227C77.226 513.962 0 464.586 0 397.083c0-47.791 60.778-80.847 175.653-100.929C109.933 307.334 36.053 288.859 15.778 216.406 9.945 195.564 0 67.197 0 49.851 0-28.906 76.134-1.611 123.121 33.664z"/></svg>
              Bluesky
            </a>
          </div>

          {latestLifestyle.length > 0 && (
            <section class="latest-lifestyle-section">
              <div class="latest-lifestyle-header">
                <h2 class="latest-lifestyle-title">{S.latest}</h2>
                <a href={`${lp}/lifestyle/`} class="latest-lifestyle-all">{S.latestAll}</a>
              </div>
              {latestLifestyle.map((art: any, i: number) => (
                <a href={locUrl('lifestyle', art.slug)} class="card-hero">
                  <img src={art.image_url || '/og/lifestyle.png'} alt={art.title} loading={i === 0 ? 'eager' : 'lazy'} decoding="async" width="800" height="400" />
                  <div class="card-hero__overlay"></div>
                  <div class="card-hero__content">
                    <span class="badge" style="background: #E91E63; color: #fff;">{bl.LIFESTYLE}</span>
                    <h3 class="card-hero__title">{art.title}</h3>
                    {art.excerpt && (<p class="card-hero__desc">{art.excerpt.slice(0, 140)}{art.excerpt.length > 140 ? '...' : ''}</p>)}
                  </div>
                </a>
              ))}
            </section>
          )}

          <section class="videos-section">
            <div class="videos-header">
              <h2 class="videos-title">{S.watch}</h2>
              <a href="/video/" class="videos-all">{S.watchAll}</a>
            </div>
            <div class="video-pair" data-dynamic="videos" data-slots="0,1"></div>
          </section>

          <div class="row-3-compact">
            {row3a.map((card, i) => (
              <a href={card.href} class="compact-card">
                <div class="compact-card__img">
                  <img src={card.image} alt={card.title} loading={i === 0 ? 'eager' : 'lazy'} fetchpriority={i === 0 ? 'high' : 'auto'} decoding="async" width="400" height="267" />
                </div>
                <div class="compact-card__body">
                  <span class="badge" style={`background: ${badgeColors[card.badge]}; color: #000;`}>{bl[card.badge]}</span>
                  <h3 class="compact-card__title">{card.title}</h3>
                </div>
              </a>
            ))}
          </div>

          <div class="video-pair" data-dynamic="videos" data-slots="2,3"></div>

          <div class="row-2">
            {row2.map(card => (
              <a href={card.href} class="vcard">
                <div class="vcard__img"><img src={card.image} alt={card.title} loading="lazy" decoding="async" width="400" height="267" /></div>
                <h3 class="vcard__title">{card.title}</h3>
              </a>
            ))}
          </div>

          <div class="row-2">
            {compactCards.map(card => (
              <a href={card.href} class="hcard">
                <div class="hcard__img"><img src={card.image} alt={card.title} loading="lazy" decoding="async" width="400" height="267" /></div>
                <div class="hcard__body"><h3 class="hcard__title">{card.title}</h3></div>
              </a>
            ))}
          </div>

          <a href={featureCard.href} class="feature-card">
            <div class="feature-card__img"><img src={featureCard.image} alt={featureCard.title} loading="lazy" decoding="async" width="600" height="400" /></div>
            <div class="feature-card__body">
              <span class="badge" style={`background: ${badgeColors[featureCard.badge]}; color: #000;`}>{bl[featureCard.badge]}</span>
              <h3 class="feature-card__title">{featureCard.title}</h3>
              <p class="feature-card__desc">{featureCard.desc}</p>
            </div>
          </a>

          <a href={hero4.href} class="card-hero">
            <img src={hero4.image} alt={hero4.title} loading="lazy" decoding="async" width="800" height="400" />
            <div class="card-hero__overlay"></div>
            <div class="card-hero__content">
              <span class="badge" style={`background: ${badgeColors[hero4.badge]}; color: #000;`}>{bl[hero4.badge]}</span>
              <h3 class="card-hero__title">{hero4.title}</h3>
              <p class="card-hero__desc">{hero4.desc}</p>
            </div>
          </a>

          <div class="row-3">
            {row3b.map(card => (
              <a href={card.href} class="vcard">
                <div class="vcard__img"><img src={card.image} alt={card.title} loading="lazy" decoding="async" width="400" height="267" /></div>
                <h3 class="vcard__title">{card.title}</h3>
              </a>
            ))}
          </div>

          <div class="video-pair" data-dynamic="videos" data-slots="4,5"></div>

          <a href={`${lp}/tennis-playing-style/`} class="inline-banner-link">
            <img src="/images/style-banner.png" alt="¿Cuál es tu estilo de tenis? — Haz el test" class="inline-banner-img" width="1600" height="900" loading="lazy" decoding="async" />
          </a>

          <div class="social-strip">
            <span class="social-strip__label">{S.follow}</span>
            <a href="https://www.youtube.com/@SuperTennisNews" target="_blank" rel="noopener noreferrer" class="social-strip__link social-strip__link--yt" aria-label="YouTube">
              <svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
              YouTube
            </a>
            <a href="https://bsky.app/profile/supertennisnews.bsky.social" target="_blank" rel="noopener noreferrer" class="social-strip__link social-strip__link--bs" aria-label="Bluesky">
              <svg viewBox="0 0 568 501" fill="currentColor" width="16" height="16"><path d="M123.121 33.664C188.241 82.553 258.281 181.68 284 234.873c25.719-53.192 95.759-152.32 160.879-201.21C491.866-1.611 568-28.906 568 49.851c0 17.346-9.945 145.713-15.778 166.555-20.275 72.453-94.155 90.933-159.875 79.748C507.222 316.236 568 349.292 568 397.083c0 67.503-77.226 116.879-120.53 83.847C381.222 431.328 317.486 311.377 284 273.703c-33.486 37.674-97.222 157.625-163.47 207.227C77.226 513.962 0 464.586 0 397.083c0-47.791 60.778-80.847 175.653-100.929C109.933 307.334 36.053 288.859 15.778 216.406 9.945 195.564 0 67.197 0 49.851 0-28.906 76.134-1.611 123.121 33.664z"/></svg>
              Bluesky
            </a>
          </div>

          {latestArticles.length > 0 && (
            <section class="news-section">
              <div class="news-section__header">
                <h2 class="news-section__title">{S.more}</h2>
                <div class="news-section__filters">
                  <button class="nf-btn active" data-cat="all">{S.fAll}</button>
                  <button class="nf-btn" data-cat="players">{S.fPlayers}</button>
                  <button class="nf-btn" data-cat="records">{S.fRecords}</button>
