---
/**
 * Localized Head-to-Head hub (/es/vs/) — faithful 1:1 copy of src/pages/vs/index.astro:
 * featured rivalry hero (dual player photos + VS), era filters, h2h matchup card grid,
 * load-more, FAQ, related. Self-contained client-side search/filter/load-more.
 */
import BaseLayout from '../../../layouts/BaseLayout.astro';
import FaqBlock from '../../../components/FaqBlock.astro';
import { getActiveLocales, buildAlternates, type Locale } from '../../../lib/i18n';
import { getArticles, supabase } from '../../../lib/supabase';
import { stripMarkdown } from '../../../lib/fallback-data';
import { vsPlayerSlugs, getAllVsPlayerSlugs, getPlayerPhotosBatch, slugToName } from '../../../lib/player-photos';

export async function getStaticPaths() {
  const SUPPORTED = ['es'];
  return getActiveLocales().filter((l) => SUPPORTED.includes(l)).map((locale) => ({ params: { lang: locale }, props: { locale } }));
}
const { locale } = Astro.props as { locale: Locale };
const lp = `/${locale}`;

let enArts: any[] = [];
try { enArts = await getArticles({ category: 'vs', limit: 100 }); } catch {}
const ids = enArts.map((a: any) => a.id);
const tmap = new Map<number, { title: string; excerpt: string | null }>();
if (ids.length) {
  const { data } = await supabase.from('article_translations').select('article_id, title, excerpt').eq('lang', locale).eq('status', 'published').in('article_id', ids);
  for (const t of data || []) tmap.set(t.article_id, { title: t.title, excerpt: t.excerpt });
}

const photoMap = await getPlayerPhotosBatch(getAllVsPlayerSlugs());
function getVsPlayerPhotos(slug: string) {
  const pair = vsPlayerSlugs[slug];
  if (!pair) return { p1: null as string | null, p2: null as string | null, name1: '', name2: '' };
  return { p1: photoMap.get(pair[0]) || null, p2: photoMap.get(pair[1]) || null, name1: slugToName(pair[0]), name2: slugToName(pair[1]) };
}
const ERA_LABEL: Record<string, string> = { 'Current Era': 'Era actual', 'Big Three Era': 'Era del Big Three', "Women's Tennis": 'Tenis femenino', 'Classic Era': 'Era clásica', 'Rivalry': 'Rivalidad' };
function getEra(slug: string): string {
  const modern = ['alcaraz-vs-sinner', 'djokovic-vs-alcaraz', 'swiatek-vs-sabalenka', 'medvedev-vs-sinner', 'zverev-vs-alcaraz', 'gauff-vs-swiatek', 'kyrgios-vs-djokovic'];
  const bigThree = ['djokovic-vs-nadal', 'federer-vs-nadal', 'djokovic-vs-federer', 'djokovic-vs-murray', 'nadal-vs-federer-clay', 'federer-vs-djokovic-wimbledon', 'nadal-vs-djokovic-french-open', 'big-three-comparison', 'federer-vs-murray', 'tsitsipas-vs-medvedev'];
  const women = ['evert-vs-navratilova', 'williams-vs-williams', 'graf-vs-seles', 'sharapova-vs-williams', 'henin-vs-clijsters'];
  const classic = ['sampras-vs-agassi', 'borg-vs-mcenroe', 'connors-vs-lendl'];
  if (modern.includes(slug)) return 'Current Era';
  if (bigThree.includes(slug)) return 'Big Three Era';
  if (women.includes(slug)) return "Women's Tennis";
  if (classic.includes(slug)) return 'Classic Era';
  return 'Rivalry';
}
function getEraClass(slug: string): string {
  const era = getEra(slug);
  if (era === 'Current Era') return 'current';
  if (era === 'Big Three Era') return 'big-three';
  if (era === "Women's Tennis") return 'wta';
  if (era === 'Classic Era') return 'classic';
  return 'default';
}
const eraLabel = (slug: string) => ERA_LABEL[getEra(slug)] ?? getEra(slug);

const eraOrder: Record<string, number> = { 'Big Three Era': 0, 'Current Era': 1, "Women's Tennis": 2, 'Classic Era': 3, 'Rivalry': 4 };
const articles = enArts
  .filter((a: any) => tmap.has(a.id))
  .map((a: any) => ({ slug: a.slug, title: tmap.get(a.id)!.title, excerpt: tmap.get(a.id)!.excerpt || '' }))
  .sort((a, b) => (eraOrder[getEra(a.slug)] ?? 9) - (eraOrder[getEra(b.slug)] ?? 9));

const featured = articles.length > 0 ? articles[0] : null;
const featuredPhotos = featured ? getVsPlayerPhotos(featured.slug) : null;
const rest = articles.slice(1);
const initialVisible = 12;

const ERA_FILTERS = [
  { key: 'all', label: 'Todos' }, { key: 'big-three', label: 'Big Three' }, { key: 'current', label: 'Era actual' }, { key: 'wta', label: 'Femenino' }, { key: 'classic', label: 'Clásica' },
];

const faqs = [
  { q: '¿Quién ha ganado más Grand Slams: Federer o Nadal?', a: 'Rafael Nadal ganó 22 títulos de Grand Slam; Roger Federer, 20. Su cara a cara fue de 24-16 a favor de Nadal, aunque Federer dominaba en hierba (Wimbledon) mientras que Nadal reinaba en tierra (Roland Garros, 14 títulos). Ambos terminaron sus carreras con Novak Djokovic superándolos finalmente con 24 Grand Slams.' },
  { q: '¿Cuál es el cara a cara entre Sinner y Alcaraz?', a: 'A fecha de 2026, el cara a cara Sinner-Alcaraz está muy igualado, con Carlos Alcaraz ligeramente por delante. Entre sus enfrentamientos más destacados están la final de Roland Garros 2025 (ganó Alcaraz), las ATP Finals 2025 (ganó Sinner) y varias finales de Masters 1000. La rivalidad se considera el duelo que define la era post-Big Three.' },
  { q: '¿Es la rivalidad Federer-Nadal la mejor del tenis?', a: 'Estadística y culturalmente, Federer-Nadal está considerada la mejor rivalidad de la historia del tenis: 40 enfrentamientos en 16 años, estilos de juego opuestos (arte en hierba vs desgaste en tierra) y respeto mutuo fuera de la pista. Las rivalidades Djokovic-Nadal y Djokovic-Federer son estadísticamente relevantes, pero generaron menos tensión narrativa.' },
  { q: '¿Quién tiene el mejor palmarés de Grand Slam en tierra batida?', a: 'Rafael Nadal posee el palmarés en tierra más dominante de la historia con 14 títulos de Roland Garros (2005-2022). Solo perdió 4 partidos en el torneo en toda su carrera. Björn Borg ganó 6 Roland Garros en los años 70-80 y Chris Evert encabeza la lista femenina con 7 títulos en RG.' },
  { q: '¿Quién es el mayor rival de Novak Djokovic?', a: 'La rivalidad de Djokovic con Rafael Nadal es estadísticamente la más prolífica: 60 enfrentamientos (Djokovic lidera 31-29). Djokovic-Federer terminó 27-23 a favor de Djokovic. En la nueva generación, su rivalidad con Carlos Alcaraz ya ha producido 3 finales de Grand Slam y está marcando el tramo final de su carrera.' },
  { q: '¿Qué es un cara a cara en el tenis?', a: 'Un cara a cara (H2H) recoge todos los partidos oficiales de los circuitos ATP/WTA entre dos jugadores, ordenados por superficie, categoría del torneo y ronda. Por ejemplo, «Sinner 5-3 vs Alcaraz» significa que Sinner ha ganado 5 de sus 8 enfrentamientos en el circuito. En algunas estadísticas, los cara a cara excluyen exhibiciones, Copa Davis y Juegos Olímpicos.' },
];
const alternates = buildAlternates('/vs/', [locale]);
---

<BaseLayout
  alternates={alternates}
  locale={locale}
  title="Cara a cara del tenis — Las mejores rivalidades y comparativas"
  description="Historiales de cara a cara e historias de las mejores rivalidades del tenis. Djokovic vs Nadal, Federer vs Nadal, Alcaraz vs Sinner y más."
  ogImage="/og/vs.png"
>
  <div class="vs-page" lang={locale}>
    <div class="container">
      <nav class="breadcrumbs"><a href={`${lp}/`}>Inicio</a> <span class="sep">/</span> <span class="current">Cara a cara</span></nav>
      <section class="page-hero">
        <h1>Cara a cara</h1>
        <p class="subtitle">Las mejores rivalidades, duelos e historiales de cara a cara de la historia del tenis{articles.length > 0 && ` — ${articles.length} análisis de rivalidades`}</p>
      </section>

      <div class="filter-section">
        <input type="text" class="search-input" id="search-input" placeholder="🔍 Buscar rivalidades (Federer, Nadal, etc.)..." />
      </div>

      <div class="era-filters" id="era-filters">
        {ERA_FILTERS.map((e) => (<button class={`era-filter ${e.key === 'all' ? 'active' : ''}`} data-era={e.key}>{e.label}</button>))}
      </div>

      <div class="empty-state" id="empty-state" style="display:none;"><p>No se han encontrado rivalidades. Prueba otra búsqueda u otra era.</p></div>

      {featured && featuredPhotos && (
        <a href={`${lp}/vs/${featured.slug}/`} class="vs-hero" id="vs-featured" data-era={getEraClass(featured.slug)} data-title={featured.title.toLowerCase()}>
          <div class="vs-hero-photos">
            <div class="vs-hero-player vs-hero-left">
              {featuredPhotos.p1 ? (<img src={featuredPhotos.p1} alt={featuredPhotos.name1} loading="eager" decoding="async" width="400" height="400" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />) : null}
              <div class="vs-hero-placeholder" style={featuredPhotos.p1 ? 'display:none' : ''}>{featuredPhotos.name1.charAt(0)}</div>
              <span class="vs-hero-name">{featuredPhotos.name1}</span>
            </div>
            <div class="vs-hero-divider">VS</div>
            <div class="vs-hero-player vs-hero-right">
              {featuredPhotos.p2 ? (<img src={featuredPhotos.p2} alt={featuredPhotos.name2} loading="eager" decoding="async" width="400" height="400" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />) : null}
              <div class="vs-hero-placeholder" style={featuredPhotos.p2 ? 'display:none' : ''}>{featuredPhotos.name2.charAt(0)}</div>
              <span class="vs-hero-name">{featuredPhotos.name2}</span>
            </div>
          </div>
          <div class="vs-hero-content">
            <span class={`era-badge ${getEraClass(featured.slug)}`}>{eraLabel(featured.slug)}</span>
            <h2>{featured.title}</h2>
            <p>{stripMarkdown(featured.excerpt || '')}</p>
            <span class="read-more">Leer análisis completo →</span>
          </div>
        </a>
      )}

      {rest.length > 0 && (
        <div class="h2h-grid" id="h2h-grid">
          {rest.map((article, i) => {
            const photos = getVsPlayerPhotos(article.slug);
            return (
              <a href={`${lp}/vs/${article.slug}/`} class={`h2h-card ${getEraClass(article.slug)}`} data-era={getEraClass(article.slug)} data-title={article.title.toLowerCase()} style={i >= initialVisible ? 'display:none;' : ''}>
                <div class="card-player-duo">
                  <div class="duo-player">
                    {photos.p1 ? (<img src={photos.p1} alt={photos.name1} class="duo-avatar" loading="lazy" decoding="async" width="80" height="80" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />) : null}
                    <div class="duo-placeholder" style={photos.p1 ? 'display:none' : ''}>{photos.name1.charAt(0)}</div>
                    <span class="duo-name">{photos.name1.split(' ').pop()}</span>
                  </div>
                  <span class="duo-vs">vs</span>
                  <div class="duo-player">
                    {photos.p2 ? (<img src={photos.p2} alt={photos.name2} class="duo-avatar" loading="lazy" decoding="async" width="80" height="80" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />) : null}
                    <div class="duo-placeholder" style={photos.p2 ? 'display:none' : ''}>{photos.name2.charAt(0)}</div>
                    <span class="duo-name">{photos.name2.split(' ').pop()}</span>
                  </div>
                </div>
                <span class={`era-badge ${getEraClass(article.slug)}`}>{eraLabel(article.slug)}</span>
                <h2>{article.title}</h2>
                <p>{stripMarkdown(article.excerpt || '')}</p>
                <span class="read-more">Leer análisis →</span>
              </a>
            );
          })}
        </div>
      )}

      {rest.length > initialVisible && (
        <div class="load-more-section" id="load-more-section">
          <button class="load-more-btn" id="load-more-btn">Ver más ({rest.length - initialVisible} más)</button>
        </div>
      )}

      <section class="related-section">
        <div class="related-links">
          <a href={`${lp}/players/`}>Perfiles de jugadores</a>
          <a href={`${lp}/records/`}>Récords</a>
          <a href={`${lp}/rankings/`}>Ranking actual</a>
          <a href={`${lp}/tournaments/`}>Guías de torneos</a>
        </div>
      </section>

      <FaqBlock faqs={faqs} title="Preguntas frecuentes" />
    </div>
  </div>

  <script is:inline define:vars={{ initialVisible }}>
    (function () {
      var search = document.getElementById('search-input');
      var pills = Array.from(document.querySelectorAll('.era-filter'));
      var grid = document.getElementById('h2h-grid');
      var featured = document.getElementById('vs-featured');
      var loadSection = document.getElementById('load-more-section');
      var loadBtn = document.getElementById('load-more-btn');
      var empty = document.getElementById('empty-state');
      var activeEra = 'all', query = '', revealed = initialVisible;
      function matches(el) {
        var okEra = activeEra === 'all' || el.getAttribute('data-era') === activeEra;
        var okQ = !query || (el.getAttribute('data-title') || '').indexOf(query) !== -1;
        return okEra && okQ;
      }
      function apply() {
        var cards = grid ? Array.from(grid.querySelectorAll('.h2h-card')) : [];
        var total = 0;
        if (featured) featured.style.display = matches(featured) ? '' : 'none';
        cards.forEach(function (c) {
          if (matches(c)) { total++; c.style.display = (total <= revealed) ? '' : 'none'; }
          else c.style.display = 'none';
        });
        if (loadSection) {
          var remaining = total - revealed;
          if (remaining > 0) { loadSection.style.display = ''; loadBtn.textContent = 'Ver más (' + remaining + ' más)'; }
          else loadSection.style.display = 'none';
        }
        var featShown = featured && matches(featured);
        if (empty) empty.style.display = (total === 0 && !featShown) ? '' : 'none';
      }
      if (search) search.addEventListener('input', function () { query = this.value.trim().toLowerCase(); revealed = initialVisible; apply(); });
      pills.forEach(function (p) { p.addEventListener('click', function () { pills.forEach(function (x) { x.classList.remove('active'); }); p.classList.add('active'); activeEra = p.getAttribute('data-era'); revealed = initialVisible; apply(); }); });
      if (loadBtn) loadBtn.addEventListener('click', function () { revealed += 12; apply(); });
    })();
  </script>
</BaseLayout>

<style>
  .vs-page { max-width: 1200px; margin: 0 auto; padding: 0 24px 60px; }
  .breadcrumbs { padding: 20px 0 0; font-size: 0.82rem; color: var(--gray-500); }
  .breadcrumbs a { color: var(--gray-600); text-decoration: none; }
  .breadcrumbs a:hover { color: var(--court-green); }
  .sep { margin: 0 8px; }
  .current { color: var(--gray-800); font-weight: 500; }
  .page-hero { padding: 48px 0 32px; border-bottom: 3px solid var(--court-green); margin-bottom: 32px; }
  .page-hero h1 { font-family: var(--font-heading); font-size: 2.8rem; text-transform: uppercase; color: var(--gray-900); margin: 0; }
  .subtitle { color: var(--gray-600); font-size: 1.1rem; margin: 8px 0 0; }
  .filter-section { margin-bottom: 24px; }
  .search-input { width: 100%; padding: 12px 16px; font-size: 0.95rem; border: 1px solid #d1d5db; border-radius: var(--radius); background: white; color: #111827; transition: all 0.2s; }
  .search-input:focus { outline: none; border-color: var(--court-green); box-shadow: 0 0 0 3px rgba(34, 197, 94, 0.1); }
  .search-input::placeholder { color: #9ca3af; }
  .era-filters { display: flex; gap: 8px; margin-bottom: 24px; flex-wrap: wrap; padding-bottom: 16px; border-bottom: 1px solid #e5e7eb; }
  .era-filter { display: inline-block; font-family: var(--font-body); font-size: 0.82rem; font-weight: 500; padding: 6px 16px; border-radius: 20px; color: var(--gray-600); background: var(--gray-50); border: 1px solid var(--gray-200); cursor: pointer; transition: all 0.2s; }
  .era-filter:hover { border-color: var(--gray-400); color: var(--gray-900); }
  .era-filter.active { background: var(--gray-900); color: white; border-color: var(--gray-900); }
  .vs-hero { display: block; text-decoration: none; color: inherit; background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%); border-radius: var(--radius); overflow: hidden; margin-bottom: 32px; transition: transform 0.2s, box-shadow 0.2s; }
  .vs-hero:hover { transform: translateY(-3px); box-shadow: 0 12px 40px rgba(0,0,0,0.2); }
  .vs-hero-photos { display: flex; align-items: center; justify-content: center; gap: 0; padding: 32px 24px 16px; position: relative; }
  .vs-hero-player { flex: 1; display: flex; flex-direction: column; align-items: center; position: relative; }
  .vs-hero-player img { width: 140px; height: 140px; border-radius: 50%; object-fit: cover; object-position: top; border: 3px solid rgba(255,255,255,0.3); }
  .vs-hero-placeholder { width: 140px; height: 140px; border-radius: 50%; background: rgba(255,255,255,0.1); border: 3px solid rgba(255,255,255,0.3); display: flex; align-items: center; justify-content: center; font-size: 3rem; color: rgba(255,255,255,0.5); font-family: var(--font-heading); }
  .vs-hero-name { color: rgba(255,255,255,0.9); font-family: var(--font-heading); font-size: 1rem; text-transform: uppercase; margin-top: 12px; letter-spacing: 0.05em; }
  .vs-hero-divider { font-family: var(--font-heading); font-size: 2rem; color: var(--ball-yellow); font-weight: 700; flex-shrink: 0; padding: 0 24px; text-shadow: 0 2px 8px rgba(0,0,0,0.3); }
  .vs-hero-content { padding: 16px 32px 32px; text-align: center; }
  .vs-hero-content .era-badge { margin-bottom: 12px; display: inline-block; }
  .vs-hero-content h2 { color: white; font-family: var(--font-heading); font-size: 1.5rem; text-transform: uppercase; margin: 0 0 12px; }
  .vs-hero-content p { color: rgba(255,255,255,0.7); font-size: 0.95rem; line-height: 1.6; max-width: 600px; margin: 0 auto 16px; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
  .vs-hero-content .read-more { color: var(--ball-yellow); }
  .h2h-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-bottom: 48px; }
  .h2h-card { text-decoration: none; color: inherit; background: white; border: 1px solid var(--gray-200); border-radius: var(--radius); padding: 20px; display: flex; flex-direction: column; transition: all 0.2s; border-top: 3px solid var(--gray-200); }
  .h2h-card:hover { transform: translateY(-2px); box-shadow: var(--shadow); }
  .h2h-card.big-three { border-top-color: #d4a017; }
  .h2h-card.current { border-top-color: var(--court-green); }
  .h2h-card.wta { border-top-color: #7b2d8e; }
  .h2h-card.classic { border-top-color: #6b7280; }
  .card-player-duo { display: flex; align-items: center; justify-content: center; gap: 8px; margin-bottom: 14px; padding-bottom: 14px; border-bottom: 1px solid var(--gray-100); }
  .duo-player { display: flex; flex-direction: column; align-items: center; gap: 4px; }
  .duo-avatar { width: 52px; height: 52px; border-radius: 50%; object-fit: cover; object-position: top; border: 2px solid var(--gray-200); }
  .duo-placeholder { width: 52px; height: 52px; border-radius: 50%; background: var(--gray-100); border: 2px solid var(--gray-200); display: flex; align-items: center; justify-content: center; font-size: 1.2rem; color: var(--gray-400); font-family: var(--font-heading); }
  .duo-name { font-size: 0.65rem; color: var(--gray-500); font-weight: 500; text-transform: uppercase; letter-spacing: 0.02em; max-width: 60px; text-align: center; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .duo-vs { font-family: var(--font-heading); font-size: 0.75rem; color: var(--gray-400); font-weight: 700; text-transform: uppercase; flex-shrink: 0; }
  .era-badge { font-family: var(--font-heading); font-size: 0.6rem; text-transform: uppercase; padding: 3px 10px; border-radius: 4px; letter-spacing: 0.05em; align-self: flex-start; margin-bottom: 10px; }
  .era-badge.big-three { background: #fef3c7; color: #92400e; }
  .era-badge.current { background: #dcfce7; color: #166534; }
  .era-badge.wta { background: #f3e8ff; color: #6d28d9; }
  .era-badge.classic { background: #f3f4f6; color: #374151; }
  .h2h-card h2 { font-family: var(--font-body); font-size: 1rem; font-weight: 700; margin: 0 0 8px; line-height: 1.35; }
  .h2h-card p { color: var(--gray-600); font-size: 0.82rem; line-height: 1.6; margin: 0; flex: 1; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
  .read-more { color: var(--court-green); font-weight: 600; font-size: 0.85rem; margin-top: 14px; }
  .empty-state { text-align: center; padding: 60px 24px; color: var(--gray-500); background: var(--gray-50); border-radius: var(--radius); margin-bottom: 48px; }
  .related-section { text-align: center; padding: 32px; background: var(--gray-50); border-radius: var(--radius); }
  .related-links { display: flex; gap: 24px; justify-content: center; flex-wrap: wrap; }
  .related-links a { color: var(--court-green); font-weight: 600; font-size: 0.95rem; text-decoration: none; }
  .related-links a:hover { text-decoration: underline; }
  .load-more-section { display: flex; justify-content: center; margin: 48px 0; }
  .load-more-btn { padding: 12px 32px; font-size: 0.95rem; font-weight: 600; color: white; background: var(--court-green); border: none; border-radius: var(--radius); cursor: pointer; transition: all 0.2s; }
  .load-more-btn:hover { background: #16a34a; transform: translateY(-2px); box-shadow: 0 4px 12px rgba(34, 197, 94, 0.3); }
  @media (max-width: 1024px) { .h2h-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 768px) { .h2h-grid { grid-template-columns: 1fr; } .page-hero h1 { font-size: 2rem; } .vs-hero-player img, .vs-hero-placeholder { width: 100px; height: 100px; } .vs-hero-divider { font-size: 1.5rem; padding: 0 16px; } .vs-hero-content h2 { font-size: 1.2rem; } .vs-hero-photos { padding: 24px 16px 12px; } .vs-hero-content { padding: 12px 20px 24px; } }
</style>
