---
/**
 * Localized 2026 tennis calendar (/es/calendar/, future fr/zh).
 * Reuses the shared season dataset (src/lib/calendar-data.ts); month names, surfaces,
 * date abbreviations, country names and chrome are localized here. Single-column — the
 * English sidebar loads client-side widgets, omitted for a clean localized page.
 */
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getActiveLocales, buildAlternates, type Locale } from '../../../lib/i18n';
import { months, surfaceColors, getCountryCode, parseDateRange } from '../../../lib/calendar-data';
import { getLatestRankings, getArticles, supabase } from '../../../lib/supabase';
import { countryFlags, getFlagUrl } from '../../../lib/fallback-data';

export async function getStaticPaths() {
  const locales = getActiveLocales();
  if (locales.length === 0) return [];
  return locales.map((locale) => ({ params: { lang: locale }, props: { locale } }));
}

const { locale } = Astro.props as { locale: Locale };

// ---- Localization maps (es pilot) ----
const MONTH_NAMES: Record<string, Record<string, string>> = {
  es: {
    'January': 'Enero', 'February': 'Febrero', 'March': 'Marzo', 'April': 'Abril', 'May': 'Mayo',
    'June–July': 'Junio–Julio', 'August': 'Agosto', 'September–October': 'Septiembre–Octubre', 'November': 'Noviembre',
  },
};
const MONTH_ABBR: Record<string, Record<string, string>> = {
  es: { JAN: 'ENE', FEB: 'FEB', MAR: 'MAR', APR: 'ABR', MAY: 'MAY', JUN: 'JUN', AUG: 'AGO', SEP: 'SEP', NOV: 'NOV' },
};
const DATE_ABBR: Record<string, Record<string, string>> = {
  es: { Jan: 'ene', Feb: 'feb', Mar: 'mar', Apr: 'abr', May: 'may', Jun: 'jun', Jul: 'jul', Aug: 'ago', Sep: 'sep', Oct: 'oct', Nov: 'nov', Dec: 'dic' },
};
const SURFACE: Record<string, Record<string, string>> = {
  es: { 'Hard': 'Dura', 'Clay': 'Tierra batida', 'Grass': 'Hierba', 'Hard (Indoor)': 'Dura (indoor)' },
};
const LEVEL: Record<string, Record<string, string>> = {
  es: { 'Grand Slam': 'Grand Slam', 'Tour Finals': 'Finales de temporada', 'Team Event': 'Evento por equipos', 'Masters 1000': 'Masters 1000', 'ATP/WTA 1000': 'ATP/WTA 1000', 'ATP 500': 'ATP 500', 'WTA 500': 'WTA 500', 'ATP 250': 'ATP 250', 'WTA 250': 'WTA 250' },
};
const COUNTRY: Record<string, Record<string, string>> = {
  es: {
    'Australia': 'Australia', 'New Zealand': 'Nueva Zelanda', 'UAE': 'EAU', 'Qatar': 'Catar', 'USA': 'EE. UU.',
    'Monaco': 'Mónaco', 'Spain': 'España', 'Germany': 'Alemania', 'Italy': 'Italia', 'France': 'Francia', 'UK': 'Reino Unido',
    'Canada': 'Canadá', 'China': 'China', 'Saudi Arabia': 'Arabia Saudí', 'Europe': 'Europa', 'TBD': 'Por definir',
  },
};

const mName = MONTH_NAMES[locale] ?? {};
const mAbbr = MONTH_ABBR[locale] ?? {};
const dAbbr = DATE_ABBR[locale] ?? {};
const surf = SURFACE[locale] ?? {};
const lvl = LEVEL[locale] ?? {};
const ctry = COUNTRY[locale] ?? {};

/** "Jan 19 – Feb 1" → "19 ene – 1 feb"; bare-day part "– 12" → "– 12". */
function localizeDates(dates: string): string {
  return dates
    .split('–')
    .map((part) => {
      const seg = part.trim().split(/\s+/);
      if (seg.length >= 2 && dAbbr[seg[0]]) return `${seg[1]} ${dAbbr[seg[0]]}`;
      return part.trim();
    })
    .join(' – ');
}
/** "Melbourne, Australia" → "Melbourne, Australia"; translates the country token only. */
function localizeLocation(loc: string): string {
  const segs = loc.split(', ');
  const last = segs[segs.length - 1];
  if (ctry[last]) segs[segs.length - 1] = ctry[last];
  return segs.join(', ');
}

// ---- Chrome ----
type Chrome = {
  metaTitle: string; metaDesc: string; home: string; crumb: string; h1: string; subtitle: string;
  source: string; approx: string; legHard: string; legClay: string; legGrass: string; legIndoor: string;
  relGuides: string; relRankings: string; relPlayers: string;
};
const CHROME: Record<string, Chrome> = {
  es: {
    metaTitle: 'Calendario de Tenis 2026 — Programa de torneos',
    metaDesc: 'Calendario completo de torneos de tenis 2026. Grand Slams, Masters 1000, fechas de los circuitos ATP y WTA, sedes y superficies.',
    home: 'Inicio', crumb: 'Calendario', h1: 'Calendario de Tenis 2026',
    subtitle: 'Programa completo de torneos de los circuitos ATP y WTA',
    source: 'Fuente', approx: 'Fechas aproximadas, sujetas a cambios',
    legHard: 'Pista dura', legClay: 'Tierra batida', legGrass: 'Hierba', legIndoor: 'Indoor',
    relGuides: 'Guías de torneos', relRankings: 'Ranking actual', relPlayers: 'Perfiles de jugadores',
  },
};
const c = CHROME[locale] ?? CHROME.es;

// Event JSON-LD (localized description; dates stay ISO).
const allTournaments = months.flatMap((m) => m.tournaments);
const eventsJsonLd = allTournaments.map((t) => {
  const { start, end } = parseDateRange(t.dates);
  return {
    '@context': 'https://schema.org',
    '@type': 'SportsEvent',
    name: t.name,
    startDate: start,
    endDate: end,
    inLanguage: locale,
    eventStatus: 'https://schema.org/EventScheduled',
    eventAttendanceMode: 'https://schema.org/OfflineEventAttendanceMode',
    description: `${t.name} — torneo de tenis ${lvl[t.level] ?? t.level} sobre ${surf[t.surface] ?? t.surface} en ${localizeLocation(t.location)}. Parte de la temporada 2026 de los circuitos ATP/WTA.`,
  };
});

const alternates = buildAlternates('/calendar/', [locale]);
const lp = `/${locale}`;

// ── Sidebar (matches the English calendar: ATP top 5 + dynamic news/videos + Explore) ──
let atpTop5: any[] = [];
try {
  const rankings = await getLatestRankings('atp', 5);
  atpTop5 = rankings.map((r: any) => ({ rank: r.ranking, name: `${r.players?.first_name} ${r.players?.last_name}`, slug: r.players?.slug, country: r.players?.country_code || '', points: r.points?.toLocaleString(locale === 'es' ? 'es-ES' : 'en-US') || '0' }));
} catch {}
if (atpTop5.length === 0) {
  atpTop5 = [
    { rank: 1, name: 'Jannik Sinner', slug: 'jannik-sinner', country: 'ITA', points: '11.830' },
    { rank: 2, name: 'Alexander Zverev', slug: 'alexander-zverev', country: 'GER', points: '9.855' },
    { rank: 3, name: 'Carlos Alcaraz', slug: 'carlos-alcaraz', country: 'ESP', points: '7.190' },
    { rank: 4, name: 'Novak Djokovic', slug: 'novak-djokovic', country: 'SRB', points: '6.875' },
    { rank: 5, name: 'Daniil Medvedev', slug: 'daniil-medvedev', country: 'RUS', points: '6.445' },
  ];
}
const esSlugs = new Set<string>();
try {
  const { data: trans } = await supabase.from('article_translations').select('article_id').eq('lang', locale).eq('status', 'published');
  const ids = (trans || []).map((x: any) => x.article_id);
  if (ids.length) { const { data: arts } = await supabase.from('articles').select('slug').in('id', ids); for (const a of arts || []) esSlugs.add(a.slug); }
} catch {}
const playerHref = (slug: string) => esSlugs.has(slug) ? `/${locale}/players/${slug}/` : `/players/${slug}/`;
const artHref = (cat: string, slug: string) => esSlugs.has(slug) ? `/${locale}/${cat}/${slug}/` : `/${cat}/${slug}/`;

let sidebarArticles: any[] = [];
try {
  const [tourArts, recArts] = await Promise.all([getArticles({ category: 'tournaments', limit: 6 }), getArticles({ category: 'records', limit: 6 })]);
  let all = [...tourArts, ...recArts].filter((a: any) => a.title);
  for (let i = all.length - 1; i > 0; i--) { const j = ((i + 5) * 11) % (i + 1); [all[i], all[j]] = [all[j], all[i]]; }
  all = all.slice(0, 4);
  const ids = all.map((a: any) => a.id);
  const tmap = new Map<number, string>();
  if (ids.length) { const { data } = await supabase.from('article_translations').select('article_id, title').eq('lang', locale).eq('status', 'published').in('article_id', ids); for (const tr of data || []) tmap.set(tr.article_id, tr.title); }
  sidebarArticles = all.map((a: any) => ({ ...a, title: tmap.get(a.id) ?? a.title }));
} catch {}
const sbCatColors: Record<string, string> = { tournaments: '#00BCD4', records: '#FF9800' };
const sbCatL: Record<string, string> = locale === 'es' ? { tournaments: 'Torneos', records: 'Récords' } : { tournaments: 'Tournaments', records: 'Records' };

const newsMap: Record<string, { t: string; s: string; slug: string }> = {};
try {
  const { data: nt } = await supabase.from('news_translations').select('news_id, title, summary').eq('lang', locale).eq('status', 'published');
  const nids = (nt || []).map((r: any) => r.news_id);
  if (nids.length) { const { data: nrows } = await supabase.from('news').select('id, slug').in('id', nids); const slugById = new Map((nrows || []).map((n: any) => [n.id, n.slug])); for (const r of nt || []) { const slug = slugById.get(r.news_id); if (slug) newsMap[String(r.news_id)] = { t: r.title, s: r.summary || '', slug }; } }
} catch {}
const sbStr = locale === 'es'
  ? { atp: 'Ranking ATP', full: 'Tabla completa →', explore: 'Explorar' }
  : { atp: 'ATP Rankings', full: 'Full table →', explore: 'Explore' };
---

<BaseLayout title={c.metaTitle} description={c.metaDesc} ogImage="/og/calendar.png" locale={locale} alternates={alternates} dynamicContent={true}>
  {eventsJsonLd.map((event) => (
    <script type="application/ld+json" set:html={JSON.stringify(event)} />
  ))}
  <script type="application/json" id="es-news-map" set:html={JSON.stringify(newsMap)}></script>
  <div class="calendar-page" lang={locale}>
    <div class="container">
      <nav class="breadcrumbs"><a href="/">{c.home}</a> <span class="sep">/</span> <span class="current">{c.crumb}</span></nav>
      <section class="page-hero">
        <h1>{c.h1}</h1>
        <p class="subtitle">{c.subtitle}</p>
        <p class="data-source">
          {c.source}: <a href="https://www.atptour.com" target="_blank" rel="noopener nofollow">ATP Tour</a>
          {' · '}<a href="https://www.wtatennis.com" target="_blank" rel="noopener nofollow">WTA</a>
          {' · '}{c.approx}
        </p>
      </section>

      <div class="calendar-layout">
      <main class="calendar-main">
        <div class="surface-legend">
          <span class="legend-item"><span class="legend-dot" style="background: #2563eb"></span> {c.legHard}</span>
          <span class="legend-item"><span class="legend-dot" style="background: #dc6b20"></span> {c.legClay}</span>
          <span class="legend-item"><span class="legend-dot" style="background: #16a34a"></span> {c.legGrass}</span>
          <span class="legend-item"><span class="legend-dot" style="background: #7c3aed"></span> {c.legIndoor}</span>
        </div>

        <div class="timeline">
          {months.map((month) => (
            <section class={`timeline-month season-${month.season}`}>
              <div class="month-marker">
                <div class="month-dot"></div>
                <span class="month-abbr">{mAbbr[month.abbr] ?? month.abbr}</span>
              </div>
              <div class="month-content">
                <h2 class="month-name">{mName[month.name] ?? month.name}</h2>
                <div class="tournaments-list">
                  {month.tournaments.map((t) => {
                    const isGS = t.level === 'Grand Slam' || t.level === 'Tour Finals';
                    const cc = getCountryCode(t.location);
                    return (
                      <div class={`tournament-card ${isGS ? 'gs-highlight' : ''}`}>
                        {cc && (
                          <img src={`https://flagcdn.com/w40/${cc}.png`} srcset={`https://flagcdn.com/w80/${cc}.png 2x`} alt={localizeLocation(t.location)} class="tourney-flag" loading="lazy" onerror="this.style.display='none'" />
                        )}
                        <div class="tourney-info">
                          <h3>{t.name}</h3>
                          <div class="tourney-meta">
                            <span class="tourney-dates">{localizeDates(t.dates)}</span>
                            <span class="tourney-location">{localizeLocation(t.location)}</span>
                          </div>
                        </div>
                        <div class="tourney-badges">
                          <span class="surface-badge" style={`background: ${surfaceColors[t.surface] || '#666'}`}>{surf[t.surface] ?? t.surface}</span>
                          <span class={`level-badge ${isGS ? 'gs' : ''}`}>{lvl[t.level] ?? t.level}</span>
                        </div>
                      </div>
                    );
                  })}
                </div>
              </div>
            </section>
          ))}
        </div>

        <section class="related-section">
          <div class="related-links">
            <a href={`${lp}/tournaments/`}>{c.relGuides}</a>
            <a href={`${lp}/rankings/`}>{c.relRankings}</a>
            <a href={`${lp}/players/`}>{c.relPlayers}</a>
          </div>
        </section>
      </main>

      <aside class="sb">
        <div class="sb-block" data-dynamic="sidebar-videos" data-slots="4"></div>
        <div class="sb-rankings">
          <div class="sb-rankings__header">
            <span class="sb-rankings__label">{sbStr.atp}</span>
            <a href={`${lp}/rankings/`} class="sb-link">{sbStr.full}</a>
          </div>
          <table class="sb-rankings__table">
            <tbody>
              {atpTop5.map((r: any) => (
                <tr>
                  <td class="sb-rankings__rank">{r.rank}</td>
                  <td class="sb-rankings__name">
                    <a href={playerHref(r.slug)}>
                      {getFlagUrl(r.country) ? (<img src={getFlagUrl(r.country, 20)} alt={r.country} class="sb-flag" width="20" height="15" loading="lazy" decoding="async" />) : (<span>{countryFlags[r.country] || ''}</span>)}
                      {r.name}
                    </a>
                  </td>
                  <td class="sb-rankings__pts">{r.points}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
        <div class="sb-block" data-dynamic="sidebar-news" data-limit="3" data-locale={locale}></div>
        {sidebarArticles.length > 0 && (
          <div class="sb-articles">
            <div class="sb-articles__header"><span class="sb-articles__label">{sbStr.explore}</span></div>
            <div class="sb-articles__list">
              {sidebarArticles.map((art: any) => (
                <a href={artHref(art.category, art.slug)} class="sb-articles__item">
                  <span class="sb-articles__cat" style={`background: ${sbCatColors[art.category] || '#666'}`}>{sbCatL[art.category] || art.category}</span>
                  <span class="sb-articles__link">{art.title}</span>
                </a>
              ))}
            </div>
          </div>
        )}
      </aside>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .calendar-page { padding: 0 24px 60px; }
  .container { max-width: 1200px; margin: 0 auto; }
  .calendar-layout { display: grid; grid-template-columns: 1fr 320px; gap: 32px; align-items: start; }
  .calendar-main { min-width: 0; }

  /* Sidebar (matches English calendar) */
  .sb { position: sticky; top: calc(var(--header-height) + 8px); display: flex; flex-direction: column; gap: 24px; }
  .sb-link { font-size: 0.72rem; color: var(--court-green); font-weight: 600; }
  .sb-link:hover { text-decoration: underline; }
  .sb-block, .sb-rankings, .sb-articles { background: #fff; border-radius: var(--radius); overflow: hidden; border: 1px solid var(--gray-200); }
  .sb-rankings__header, .sb-articles__header { display: flex; justify-content: space-between; align-items: center; padding: 14px 16px; background: var(--gray-900); }
  .sb-rankings__label, .sb-articles__label { font-family: var(--font-heading); font-size: 0.8rem; font-weight: 700; text-transform: uppercase; letter-spacing: 2px; color: #fff; }
  .sb-rankings__table { width: 100%; border-collapse: collapse; }
  .sb-rankings__table tr { border-bottom: 1px solid var(--gray-100); }
  .sb-rankings__table tr:last-child { border-bottom: none; }
  .sb-rankings__rank { padding: 10px 12px; font-family: var(--font-heading); font-weight: 700; font-size: 0.9rem; color: var(--court-green); width: 28px; }
  .sb-rankings__name { padding: 10px 6px; font-size: 0.8rem; }
  .sb-rankings__name a { color: var(--gray-900); text-decoration: none; font-weight: 600; display: flex; align-items: center; gap: 6px; }
  .sb-rankings__name a:hover { color: var(--court-green); }
  .sb-flag { vertical-align: middle; border-radius: 2px; }
  .sb-rankings__pts { padding: 10px 14px; text-align: right; font-family: var(--font-heading); font-size: 0.78rem; font-weight: 600; color: var(--gray-400); }
  .sb-articles__list { display: flex; flex-direction: column; }
  .sb-articles__item { display: flex; align-items: flex-start; gap: 8px; padding: 10px 14px; border-bottom: 1px solid var(--gray-100); text-decoration: none; transition: background 0.15s; }
  .sb-articles__item:last-child { border-bottom: none; }
  .sb-articles__item:hover { background: var(--gray-50); }
  .sb-articles__cat { display: inline-block; padding: 2px 6px; border-radius: 3px; font-size: 0.55rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; color: #fff; white-space: nowrap; flex-shrink: 0; margin-top: 2px; }
  .sb-articles__link { font-size: 0.82rem; font-weight: 600; line-height: 1.3; color: var(--gray-800); display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
  .sb-articles__item:hover .sb-articles__link { color: var(--court-green); }

  @media (max-width: 1024px) { .calendar-layout { grid-template-columns: 1fr 280px; gap: 24px; } }
  @media (max-width: 900px) { .calendar-layout { grid-template-columns: 1fr; } .sb { position: static; display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px; } }
  @media (max-width: 560px) { .sb { grid-template-columns: 1fr; } }
  .breadcrumbs { padding: 20px 0 0; font-size: 0.82rem; color: var(--gray-500); }
  .breadcrumbs a { color: var(--gray-600); text-decoration: none; }
  .breadcrumbs a:hover { color: var(--court-green); }
  .sep { margin: 0 8px; }
  .current { color: var(--gray-800); font-weight: 500; }

  .page-hero { padding: 24px 0 28px; border-bottom: 3px solid var(--court-green); margin-bottom: 32px; }
  .page-hero h1 { font-family: var(--font-heading); font-size: 2.8rem; text-transform: uppercase; color: var(--gray-900); margin: 0; }
  .subtitle { color: var(--gray-600); font-size: 1.05rem; margin: 8px 0 0; }
  .data-source { color: var(--gray-500); font-size: 0.8rem; margin: 6px 0 0; }
  .data-source a { color: var(--gray-500); text-decoration: underline; }

  .surface-legend { display: flex; flex-wrap: wrap; gap: 16px; margin-bottom: 28px; padding: 12px 16px; background: var(--gray-50); border-radius: var(--radius); }
  .legend-item { display: flex; align-items: center; gap: 6px; font-size: 0.82rem; color: var(--gray-700); }
  .legend-dot { width: 12px; height: 12px; border-radius: 50%; display: inline-block; }

  .timeline { position: relative; }
  .timeline-month { display: grid; grid-template-columns: 64px 1fr; gap: 16px; padding-bottom: 28px; }
  .month-marker { display: flex; flex-direction: column; align-items: center; gap: 6px; }
  .month-dot { width: 14px; height: 14px; border-radius: 50%; background: var(--court-green); margin-top: 4px; }
  .season-clay .month-dot { background: #dc6b20; }
  .season-grass .month-dot { background: #16a34a; }
  .season-indoor .month-dot { background: #7c3aed; }
  .month-abbr { font-family: var(--font-heading); font-size: 0.72rem; letter-spacing: 0.06em; color: var(--gray-500); writing-mode: vertical-rl; }
  .month-name { font-family: var(--font-heading); font-size: 1.3rem; text-transform: uppercase; color: var(--gray-900); margin: 0 0 12px; }

  .tournaments-list { display: flex; flex-direction: column; gap: 10px; }
  .tournament-card { display: flex; align-items: center; gap: 14px; padding: 12px 16px; background: var(--white); border: 1px solid var(--gray-200); border-radius: var(--radius); }
  .tournament-card.gs-highlight { border-color: var(--court-green); background: #f0fdf4; }
  .tourney-flag { width: 28px; height: 21px; object-fit: cover; border-radius: 2px; flex-shrink: 0; }
  .tourney-info { flex: 1; min-width: 0; }
  .tourney-info h3 { font-size: 0.98rem; margin: 0 0 3px; color: var(--gray-900); }
  .tourney-name-link { color: var(--court-green); text-decoration: none; }
  .tourney-name-link:hover { text-decoration: underline; }
  .tourney-meta { display: flex; flex-wrap: wrap; gap: 4px 12px; font-size: 0.8rem; color: var(--gray-500); }
  .tourney-badges { display: flex; flex-direction: column; gap: 4px; align-items: flex-end; flex-shrink: 0; }
  .surface-badge { font-size: 0.62rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em; color: #fff; padding: 2px 8px; border-radius: 4px; white-space: nowrap; }
  .level-badge { font-size: 0.62rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em; color: var(--gray-600); background: var(--gray-100); padding: 2px 8px; border-radius: 4px; white-space: nowrap; }
  .level-badge.gs { background: var(--court-green); color: #fff; }

  .related-section { margin-top: 24px; padding-top: 24px; border-top: 1px solid var(--gray-200); }
  .related-links { display: flex; flex-wrap: wrap; gap: 12px; }
  .related-links a { font-size: 0.9rem; color: var(--court-green); text-decoration: none; padding: 8px 14px; border: 1px solid var(--gray-200); border-radius: var(--radius); }
  .related-links a:hover { border-color: var(--court-green); }

  @media (max-width: 640px) {
    .page-hero h1 { font-size: 2rem; }
    .timeline-month { grid-template-columns: 44px 1fr; gap: 10px; }
    .tournament-card { flex-wrap: wrap; }
    .tourney-badges { flex-direction: row; }
  }
</style>
