                      <div class="article-card__img"><img src={img} alt={art.title} loading="lazy" decoding="async" width="400" height="225" onerror="this.src='/images/records/tennis-trophy-gold.webp'" /><span class="article-card__badge">{meta.icon} {meta.label}</span></div>
