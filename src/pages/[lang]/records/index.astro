---
/**
 * Localized Records hub (/es/records/) — faithful 1:1 copy of src/pages/records/index.astro:
 * hero + stat banner, category nav, 24 curated record cards (4 categories) with photo
 * breaks, Deep Dive article grid (filter tabs + search + load-more), 3 dynamic leaderboards
 * (career titles ATP/WTA, Grand Slams, win%), related + 2-column sidebar. Leaderboard data is
 * language-neutral; curated records / chrome translated; deep-dive is self-contained client-side.
 */
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getActiveLocales, buildAlternates, type Locale } from '../../../lib/i18n';
import { getLeaderboard, getArticles, getPlayerBySlug, supabase } from '../../../lib/supabase';
import { countryFlags, fallbackPlayers, getFlagUrl, stripMarkdown } from '../../../lib/fallback-data';

export async function getStaticPaths() {
  const SUPPORTED = ['es'];
  return getActiveLocales().filter((l) => SUPPORTED.includes(l)).map((locale) => ({ params: { lang: locale }, props: { locale } }));
}
const { locale } = Astro.props as { locale: Locale };
const lp = `/${locale}`;

// ── Dynamic leaderboards (language-neutral data) ──
let mostTitlesATP: any[] = [], mostTitlesWTA: any[] = [], mostGrandSlams: any[] = [], highestWinPct: any[] = [];
try {
  [mostTitlesATP, mostTitlesWTA, mostGrandSlams] = await Promise.all([
    getLeaderboard('career_titles', 'atp', 10), getLeaderboard('career_titles', 'wta', 10), getLeaderboard('grand_slam_titles', null, 10),
  ]);
  const allPlayers = await getLeaderboard('career_win', null, 50);
  highestWinPct = allPlayers.filter((p: any) => (p.career_win + p.career_loss) >= 200)
    .map((p: any) => ({ ...p, win_pct: ((p.career_win / (p.career_win + p.career_loss)) * 100).toFixed(1) }))
    .sort((a: any, b: any) => parseFloat(b.win_pct) - parseFloat(a.win_pct)).slice(0, 10);
} catch {}

// ── Translated record articles (deep-dive) ──
let enArts: any[] = [];
try { enArts = await getArticles({ category: 'records', limit: 100 }); } catch {}
const artIds = enArts.map((a: any) => a.id);
const artTmap = new Map<number, { title: string; excerpt: string | null }>();
if (artIds.length) {
  const { data } = await supabase.from('article_translations').select('article_id, title, excerpt').eq('lang', locale).eq('status', 'published').in('article_id', artIds);
  for (const t of data || []) artTmap.set(t.article_id, { title: t.title, excerpt: t.excerpt });
}
const recordArticles = enArts.filter((a: any) => artTmap.has(a.id)).map((a: any) => ({ slug: a.slug, image_url: a.image_url, title: artTmap.get(a.id)!.title, excerpt: artTmap.get(a.id)!.excerpt || '' }));

const esSlugs = new Set<string>();
try {
  const { data: trans } = await supabase.from('article_translations').select('article_id').eq('lang', locale).eq('status', 'published');
  const tids = (trans || []).map((t: any) => t.article_id);
  if (tids.length) { const { data: arts } = await supabase.from('articles').select('slug').in('id', tids); for (const a of arts || []) esSlugs.add(a.slug); }
} catch {}
const ph = (slug: string) => esSlugs.has(slug) ? `${lp}/players/${slug}/` : `/players/${slug}/`;
const recHref = (slug: string) => esSlugs.has(slug) ? `${lp}/records/${slug}/` : `/records/${slug}/`;

const sectionPhotos = [
  { image: '/images/tournaments/wimbledon.webp', caption: 'El All England Club — donde se hace la historia' },
  { image: '/images/records/tennis-court-aerial.webp', caption: 'El camino al No. 1 empieza aquí' },
  { image: '/images/tournaments/roland-garros.webp', caption: 'Roland Garros — la prueba definitiva de resistencia' },
];

const records = [
  { category: 'Récords de Grand Slam', icon: '🏆', items: [
    { title: 'Más títulos de Grand Slam (individual masculino)', holder: 'Novak Djokovic', value: '24', slug: 'novak-djokovic', detail: 'Abierto de Australia (10), Roland Garros (3), Wimbledon (7), US Open (4)', articleSlug: 'most-grand-slam-titles-mens' },
    { title: 'Más títulos de Grand Slam (individual femenino)', holder: 'Margaret Court', value: '24', slug: null, detail: 'Abierto de Australia (11), Roland Garros (5), Wimbledon (3), US Open (5)', articleSlug: 'most-grand-slam-titles-womens' },
    { title: 'Más títulos de Grand Slam (Era Abierta, femenino)', holder: 'Serena Williams', value: '23', slug: null, detail: 'Abierto de Australia (7), Roland Garros (3), Wimbledon (7), US Open (6)', articleSlug: 'serena-williams-grand-slam-record' },
    { title: 'Más títulos de Grand Slam consecutivos', holder: 'Novak Djokovic', value: '4', slug: 'novak-djokovic', detail: '2015-16: Wimbledon, US Open, Abierto de Australia, Roland Garros', articleSlug: 'most-consecutive-grand-slam-titles' },
    { title: 'Campeón de Grand Slam más joven (masculino)', holder: 'Michael Chang', value: '17a 3m', slug: null, detail: 'Roland Garros 1989', articleSlug: 'youngest-grand-slam-champions' },
    { title: 'Campeona de Grand Slam más joven (femenino)', holder: 'Martina Hingis', value: '16a 3m', slug: null, detail: 'Abierto de Australia 1997', articleSlug: 'youngest-grand-slam-champions' },
  ] },
  { category: 'Récords de ranking', icon: '📊', items: [
    { title: 'Más semanas como No. 1 (masculino)', holder: 'Novak Djokovic', value: '428', slug: 'novak-djokovic', detail: 'Superó las 310 semanas de Roger Federer en marzo de 2023', articleSlug: 'most-weeks-at-number-one' },
    { title: 'Más semanas como No. 1 (femenino)', holder: 'Steffi Graf', value: '377', slug: null, detail: 'Posee el récord desde 1997', articleSlug: 'most-weeks-at-number-one' },
    { title: 'No. 1 más joven (masculino)', holder: 'Carlos Alcaraz', value: '19a 4m', slug: 'carlos-alcaraz', detail: '12 de septiembre de 2022, tras ganar el US Open', articleSlug: 'youngest-world-number-one' },
    { title: 'No. 1 más joven (femenino)', holder: 'Martina Hingis', value: '16a 6m', slug: null, detail: '31 de marzo de 1997', articleSlug: 'youngest-world-number-one' },
    { title: 'Más veces No. 1 de fin de año (masculino)', holder: 'Novak Djokovic', value: '8', slug: 'novak-djokovic', detail: '2011, 2012, 2014, 2015, 2018, 2020, 2021, 2023', articleSlug: 'year-end-number-one-records' },
    { title: 'Más veces No. 1 de fin de año (femenino)', holder: 'Steffi Graf', value: '8', slug: null, detail: '1987, 1988, 1989, 1990, 1993, 1995, 1996', articleSlug: 'year-end-number-one-records' },
  ] },
  { category: 'Récords de partidos y saque', icon: '⚡', items: [
    { title: 'Saque más rápido jamás registrado', holder: 'Sam Groth', value: '263.4 km/h', slug: null, detail: 'Busan Challenger 2012 (no reconocido por la ATP)', articleSlug: 'fastest-tennis-serves-ever' },
    { title: 'Saque más rápido (reconocido por la ATP)', holder: 'John Isner', value: '253.0 km/h', slug: null, detail: 'Copa Davis 2016', articleSlug: 'fastest-tennis-serves-ever' },
    { title: 'Partido más largo de la historia', holder: 'Isner vs. Mahut', value: '11h 5m', slug: null, detail: 'Wimbledon 2010, marcador final 70-68 en el 5º set', articleSlug: 'longest-tennis-match-in-history' },
    { title: 'Más títulos de carrera (masculino, Era Abierta)', holder: 'Jimmy Connors', value: '109', slug: null, detail: 'Récord masculino de todos los tiempos. Le siguen Roger Federer (103) y Novak Djokovic (99+)', articleSlug: 'most-career-titles-mens' },
    { title: 'Más títulos de carrera (femenino, Era Abierta)', holder: 'Martina Navratilova', value: '167', slug: null, detail: 'Incluidos 59 títulos de Grand Slam (individual + dobles)', articleSlug: 'most-career-titles-womens' },
    { title: 'Más premios de carrera (masculino)', holder: 'Novak Djokovic', value: '$185M+', slug: 'novak-djokovic', detail: 'Primer jugador en superar los 180 millones de dólares en premios', articleSlug: 'highest-tennis-prize-money-earners' },
  ] },
  { category: 'Récords por superficie', icon: '🎾', items: [
    { title: 'Más títulos de Roland Garros (masculino)', holder: 'Rafael Nadal', value: '14', slug: null, detail: 'Ganados entre 2005-2022, perdió solo 4 partidos en total', articleSlug: 'rafael-nadal-roland-garros-record' },
    { title: 'Más títulos de Wimbledon (masculino)', holder: 'Roger Federer', value: '8', slug: null, detail: 'Ganados entre 2003-2017, incluidos 5 consecutivos (2003-07)', articleSlug: 'most-wimbledon-titles-mens' },
    { title: 'Más títulos del Abierto de Australia (masculino)', holder: 'Novak Djokovic', value: '10', slug: 'novak-djokovic', detail: '2008, 2011, 2012, 2013, 2015, 2016, 2019, 2020, 2023', articleSlug: 'most-australian-open-titles' },
    { title: 'Más títulos del US Open (Era Abierta, masculino)', holder: 'Jimmy Connors / Pete Sampras / Roger Federer', value: '5', slug: null, detail: 'Récord compartido entre tres leyendas', articleSlug: 'most-us-open-titles-mens' },
    { title: 'Racha de victorias más larga en tierra', holder: 'Rafael Nadal', value: '81 partidos', slug: null, detail: 'De abril de 2005 a mayo de 2007', articleSlug: 'longest-winning-streaks-tennis' },
    { title: 'Racha de victorias más larga en hierba', holder: 'Roger Federer', value: '65 partidos', slug: null, detail: 'De 2003 a 2008', articleSlug: 'longest-winning-streaks-tennis' },
  ] },
];

// Sidebar featured player
let sidebarPlayer: any = null;
try { sidebarPlayer = await getPlayerBySlug('novak-djokovic'); } catch {}
if (!sidebarPlayer) sidebarPlayer = fallbackPlayers['novak-djokovic'] || { first_name: 'Novak', last_name: 'Djokovic', country_code: 'SRB', career_titles: 99, grand_slam_titles: 24, slug: 'novak-djokovic', image_url: '' };

let sidebarArticles: any[] = [];
try {
  const [playersArts, vsArts] = await Promise.all([getArticles({ category: 'players', limit: 6 }), getArticles({ category: 'vs', limit: 6 })]);
  let combined = [...playersArts, ...vsArts].filter((a: any) => a.title);
  for (let i = combined.length - 1; i > 0; i--) { const j = ((i + 3) * 17) % (i + 1); [combined[i], combined[j]] = [combined[j], combined[i]]; }
  combined = combined.slice(0, 4);
  const ids = combined.map((a: any) => a.id);
  const tm = new Map<number, string>();
  if (ids.length) { const { data } = await supabase.from('article_translations').select('article_id, title').eq('lang', locale).eq('status', 'published').in('article_id', ids); for (const t of data || []) tm.set(t.article_id, t.title); }
  sidebarArticles = combined.map((a: any) => ({ ...a, title: tm.get(a.id) ?? a.title }));
} catch {}
const sbCatColors: Record<string, string> = { players: '#4CAF50', records: '#FF9800', gear: '#2196F3', lifestyle: '#E91E63', tournaments: '#00BCD4', vs: '#FF5722' };
const sbCatLabels: Record<string, string> = locale === 'es' ? { players: 'Jugadores', records: 'Récords', gear: 'Equipo', lifestyle: 'Estilo', tournaments: 'Torneos', vs: 'H2H' } : { players: 'Players', records: 'Records', gear: 'Gear', lifestyle: 'Lifestyle', tournaments: 'Tournaments', vs: 'H2H' };
function sbArticleUrl(art: { category: string; slug: string }): string {
  if (art.category === 'players') { const sfx = ['-racket', '-net-worth', '-stats', '-grand-slams', '-career-timeline', '-partner', '-age']; const base = sfx.reduce((s, x) => s.endsWith(x) ? s.slice(0, -x.length) : s, art.slug); return ph(base); }
  return esSlugs.has(art.slug) ? `${lp}/${art.category}/${art.slug}/` : `/${art.category}/${art.slug}/`;
}

// es news map for the client-loaded sidebar news
const newsMap: Record<string, { t: string; s: string; slug: string }> = {};
try {
  const { data: nt } = await supabase.from('news_translations').select('news_id, title, summary').eq('lang', locale).eq('status', 'published');
  const nids = (nt || []).map((r: any) => r.news_id);
  if (nids.length) { const { data: nrows } = await supabase.from('news').select('id, slug').in('id', nids); const slugById = new Map((nrows || []).map((n: any) => [n.id, n.slug])); for (const r of nt || []) { const slug = slugById.get(r.news_id); if (slug) newsMap[String(r.news_id)] = { t: r.title, s: r.summary || '', slug }; } }
} catch {}

// Deep-dive: classify + image diversifier (self-contained; all cards pre-rendered)
function classifyArticle(art: { title: string; slug: string }): string {
  const text = (art.title + ' ' + art.slug).toLowerCase();
  if (/\b(grand-slam|grand-slams|slam|slams|wimbledon|roland|french-open|australian-open|us-open|hat-trick|hat-tricks|olympic|davis-cup)\b/.test(text)) return 'slams';
  if (/\b(ranking|rankings|ranked|no-1|number-one|year-end|weeks|world-number-one|world-no)\b/.test(text)) return 'rankings';
  if (/\b(serve|serves|ace|aces|fastest|tiebreak|tiebreaks|double-fault|double-faults|longest-match|longest-matches)\b/.test(text)) return 'serves';
  if (/\b(streak|streaks|consecutive|undefeated|surface|surfaces|comeback|comebacks|winning-streak|winning-streaks)\b/.test(text)) return 'streaks';
  return 'career';
}
const filterTabs = [
  { id: 'all', label: 'Todos', icon: '📚' }, { id: 'slams', label: 'Grand Slams', icon: '🏆' }, { id: 'rankings', label: 'Ranking', icon: '📊' },
  { id: 'serves', label: 'Saque y partidos', icon: '⚡' }, { id: 'streaks', label: 'Rachas', icon: '🔥' }, { id: 'career', label: 'Carrera', icon: '👑' },
];
const RECORD_IMAGE_POOL: Record<string, string[]> = {
  slams: ['/images/tournaments/melbourne-park.webp', '/images/tournaments/roland-garros.webp', '/images/tournaments/wimbledon.webp', '/images/tournaments/us-open.webp', '/images/records/tennis-trophy-gold.webp', '/images/records/titles-single-year.webp', '/images/lifestyle/tennis-trophy.webp', '/images/lifestyle/tennis-fans-crowd.webp', '/images/lifestyle/tennis-court-sunset.webp'],
  rankings: ['/images/records/tennis-court-aerial.webp', '/images/records/titles-single-year.webp', '/images/lifestyle/tennis-fans-crowd.webp', '/images/lifestyle/tennis-fan-culture.webp', '/images/lifestyle/tennis-court-sunset.webp', '/images/lifestyle/tennis-watching-guide.webp', '/images/lifestyle/tennis-podcasts.webp', '/images/tournaments/atp-finals.webp', '/images/tournaments/wta-finals.webp'],
  serves: ['/images/records/fastest-serves.webp', '/images/records/most-aces.webp', '/images/records/tennis-aces.webp', '/images/records/double-faults.webp', '/images/records/longest-matches.webp', '/images/lifestyle/tennis-training.webp', '/images/lifestyle/tennis-coaching.webp', '/images/lifestyle/tennis-rituals.webp'],
  streaks: ['/images/lifestyle/tennis-court-sunset.webp', '/images/lifestyle/tennis-academy.webp', '/images/lifestyle/tennis-training.webp', '/images/lifestyle/tennis-superstitions.webp', '/images/records/titles-single-year.webp', '/images/records/tennis-trophy-gold.webp', '/images/tournaments/monte-carlo.webp', '/images/tournaments/indian-wells.webp'],
  career: ['/images/lifestyle/tennis-prize-money.webp', '/images/lifestyle/tennis-trophy.webp', '/images/lifestyle/tennis-after-50.webp', '/images/lifestyle/tennis-retirement-tour.webp', '/images/lifestyle/tennis-academy.webp', '/images/lifestyle/tennis-become-pro.webp', '/images/lifestyle/tennis-fashion.webp', '/images/lifestyle/tennis-tattoos.webp', '/images/records/titles-single-year.webp', '/images/records/prize-money-check.webp', '/images/tournaments/laver-cup.webp', '/images/tournaments/davis-cup.webp'],
};
const GENERIC_IMAGES = new Set(['/images/records/tennis-court-aerial.webp', '/images/records/tennis-trophy-gold.webp']);
function visualKey(img: string): string { if (img.includes('bagels')) return 'bagels'; if (img.includes('prize-money')) return 'prize-money'; if (img.includes('fastest-serve')) return 'fastest-serve'; if (img.includes('longest-match')) return 'longest-match'; return img; }
const usedImageCounts = new Map<string, number>();
function pickRecordImage(article: { image_url?: string }, subcategory: string): string {
  if (article.image_url && !GENERIC_IMAGES.has(article.image_url)) { const k = visualKey(article.image_url); usedImageCounts.set(k, (usedImageCounts.get(k) || 0) + 1); return article.image_url; }
  const pool = RECORD_IMAGE_POOL[subcategory] || RECORD_IMAGE_POOL.career;
  let best = pool[0], bestN = usedImageCounts.get(visualKey(best)) ?? 0;
  for (const img of pool) { const c = usedImageCounts.get(visualKey(img)) ?? 0; if (c < bestN) { best = img; bestN = c; } }
  usedImageCounts.set(visualKey(best), bestN + 1); return best;
}
const articleSlugSet = new Set(recordArticles.map((a) => a.slug));
const findRecordArticle = (rec: { articleSlug?: string }) => rec.articleSlug && articleSlugSet.has(rec.articleSlug) ? recHref(rec.articleSlug) : null;
const initialVisible = 12;

const faqJsonLd = {
  '@context': 'https://schema.org', '@type': 'FAQPage', inLanguage: locale,
  mainEntity: [
    { '@type': 'Question', name: '¿Quién ha ganado más títulos de Grand Slam en el tenis masculino?', acceptedAnswer: { '@type': 'Answer', text: 'Novak Djokovic tiene el récord con 24 títulos individuales de Grand Slam — Abierto de Australia (10), Roland Garros (3), Wimbledon (7) y US Open (4). Superó los 22 de Rafael Nadal y los 20 de Roger Federer para lograr el récord masculino de todos los tiempos.' } },
    { '@type': 'Question', name: '¿Quién ha ganado más títulos de Grand Slam en el tenis femenino?', acceptedAnswer: { '@type': 'Answer', text: 'Margaret Court tiene el récord de todos los tiempos con 24 títulos individuales de Grand Slam. En la Era Abierta (desde 1968), Serena Williams lidera con 23 títulos individuales de Grand Slam.' } },
    { '@type': 'Question', name: '¿Cuál es el saque más rápido jamás registrado en el tenis?', acceptedAnswer: { '@type': 'Answer', text: 'Sam Groth tiene el récord no oficial con un saque de 263,4 km/h en el Busan Challenger de 2012. El saque más rápido reconocido por la ATP es el de John Isner, de 253,0 km/h, en la Copa Davis de 2016.' } },
    { '@type': 'Question', name: '¿Cuál es el partido de tenis más largo de la historia?', acceptedAnswer: { '@type': 'Answer', text: 'John Isner venció a Nicolas Mahut por 70-68 en el quinto set en Wimbledon 2010 — un partido que duró 11 horas y 5 minutos a lo largo de tres días. Es el partido de tenis profesional más largo jamás disputado.' } },
    { '@type': 'Question', name: '¿Quién tiene el récord de más semanas como No. 1 del mundo?', acceptedAnswer: { '@type': 'Answer', text: 'Novak Djokovic tiene el récord masculino con 428 semanas como No. 1, superando las 310 de Roger Federer en marzo de 2023. En el circuito femenino, Steffi Graf posee el récord con 377 semanas como No. 1.' } },
    { '@type': 'Question', name: '¿Quién ha ganado más títulos de Roland Garros?', acceptedAnswer: { '@type': 'Answer', text: 'Rafael Nadal domina Roland Garros con 14 títulos individuales masculinos, ganados entre 2005 y 2022. Perdió solo 4 partidos en el torneo en toda su carrera — el récord de Grand Slam más dominante de la historia del tenis.' } },
    { '@type': 'Question', name: '¿Quién es el campeón de Grand Slam más joven de la historia del tenis?', acceptedAnswer: { '@type': 'Answer', text: 'Michael Chang es el campeón de Grand Slam masculino más joven, con 17 años y 3 meses cuando ganó Roland Garros en 1989. Martina Hingis es la campeona femenina más joven, con 16 años y 3 meses en el Abierto de Australia de 1997.' } },
    { '@type': 'Question', name: '¿Cuál es la racha de victorias más larga de la historia del tenis?', acceptedAnswer: { '@type': 'Answer', text: 'La racha de 81 victorias de Rafael Nadal en tierra batida (abril de 2005 a mayo de 2007) es la más larga en una sola superficie de la Era Abierta. En hierba, Roger Federer tiene el récord con 65 victorias consecutivas (2003-2008).' } },
    { '@type': 'Question', name: '¿Quién ha ganado más premios en el tenis?', acceptedAnswer: { '@type': 'Answer', text: 'Novak Djokovic es el jugador con más ganancias de la historia, con más de 185 millones de dólares en premios de carrera — el primero en superar los 180 millones en el circuito ATP o WTA.' } },
  ],
};

const S = { home: 'Inicio', crumb: 'Récords', h1: 'Récords del tenis', subtitle: 'Los mayores logros e hitos de la historia del tenis', qaLabel: 'Respuesta rápida', qa: 'Novak Djokovic tiene el récord masculino de Grand Slam de todos los tiempos (24 títulos) y de más semanas como No. 1 (428). Margaret Court lidera la lista general femenina de Grand Slam (24 títulos), y Serena Williams posee el récord femenino de la Era Abierta (23). Otros récords destacados: el saque más rápido de la historia de Sam Groth (263,4 km/h, 2012), el partido más largo (Isner vs. Mahut, 11h 5m en Wimbledon 2010) y las 377 semanas de Steffi Graf como No. 1 femenina.', heroStatLabel: 'títulos de Grand Slam — el récord masculino de todos los tiempos de Novak Djokovic', navTitles: 'Clasificación de títulos', navGs: 'Líderes GS', navWin: '% victorias', deepDive: 'Análisis en profundidad', searchPh: 'Buscar artículos...', readMore: 'Leer más →', loadMore: 'Cargar más artículos', remaining: 'restantes', lbTitles: 'Clasificación de títulos de carrera', lbAtp: 'ATP — Más títulos de carrera', lbWta: 'WTA — Más títulos de carrera', lbGs: 'Títulos de Grand Slam — Líderes de todos los tiempos', lbWin: 'Mayor porcentaje de victorias (200+ partidos)', colPlayer: 'Jugador', colTitles: 'Títulos', colTour: 'Circuito', colTotal: 'Títulos totales', colWinPct: '% victorias', exploreMore: 'Explora más', featured: 'Jugador destacado', viewAll: 'Ver todos →', gsStat: 'Grand Slams', careerTitles: 'Títulos de carrera', explore: 'Explorar', empty: 'No hay artículos en esta categoría todavía. Prueba otro filtro.' };
const alternates = buildAlternates('/records/', [locale]);
---

<BaseLayout alternates={alternates} locale={locale} title="Récords del tenis — Estadísticas y logros de todos los tiempos" description="Lista completa de récords del tenis. Récords de Grand Slam, hitos de ranking, récords de velocidad de saque y logros de todos los tiempos en el tenis masculino y femenino." ogImage="/og/records.png" dynamicContent={true}>
  <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />
  <script type="application/json" id="es-news-map" set:html={JSON.stringify(newsMap)}></script>

  <div class="records-page" lang={locale}>
    <div class="container">
      <nav class="breadcrumbs"><a href={`${lp}/`}>{S.home}</a> <span class="sep">/</span> <span class="current">{S.crumb}</span></nav>
      <section class="page-hero"><h1>{S.h1}</h1><p class="subtitle">{S.subtitle}</p></section>

      <section class="quick-answer"><h2 class="qa-label">{S.qaLabel}</h2><p class="qa-text">{S.qa}</p></section>

      <div class="records-hero">
        <img src="/images/records/tennis-trophy-gold.webp" alt="Trofeo de campeón de tenis" class="records-hero-img" loading="eager" decoding="async" width="1200" height="400" onerror="this.parentElement.style.display='none'" />
        <div class="records-hero-overlay"><div class="records-hero-stat"><span class="hero-stat-value">24</span><span class="hero-stat-label">{S.heroStatLabel}</span></div></div>
      </div>

      <div class="records-layout">
        <main class="records-main">
