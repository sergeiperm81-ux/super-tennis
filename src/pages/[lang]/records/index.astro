                            <td class="lb-rank">{i + 1}</td>
                            <td class="lb-player"><a href={ph(p.slug)}>{p.image_url ? (<img src={p.image_url} alt={`${p.first_name} ${p.last_name}`} class="lb-avatar" width="28" height="28" loading="lazy" decoding="async" onerror="this.style.display='none'" />) : null}{getFlagUrl(p.country_code || '') ? (<img src={getFlagUrl(p.country_code || '', 20)} alt={p.country_code || ''} class="lb-flag-img" width="20" height="15" loading="lazy" decoding="async" />) : (<span class="lb-flag">{countryFlags[p.country_code || ''] || ''}</span>)}{p.first_name} <strong>{p.last_name}</strong></a></td>
                            <td class="lb-value">{p.career_titles}</td>
                            <td class="lb-gs">{p.grand_slam_titles || 0}</td>
                            <td class="lb-wl">{p.career_win}-{p.career_loss}</td>
                          </tr>
                        ))}
                      </tbody>
                    </table>
                  </div>
                ))}
              </div>
            </section>
          )}

          {mostGrandSlams.length > 0 && (
            <section class="records-section leaderboard-section" id="grand-slam-leaderboard">
