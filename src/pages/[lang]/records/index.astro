  <script is:inline define:vars={{ initialVisible, emptyLabel: S.empty, loadMoreLabel: S.loadMore, remainingLabel: S.remaining }}>
    (function () {
      var search = document.getElementById('recordSearch');
      var tabs = Array.from(document.querySelectorAll('.filter-tab'));
      var grid = document.getElementById('articlesGrid');
      var loadBtn = document.getElementById('recordsLoadMoreBtn');
      var activeFilter = 'all', query = '', revealed = initialVisible;
      function matches(c) {
        var okCat = activeFilter === 'all' || (c.getAttribute('data-category') || 'career') === activeFilter;
        var okQ = !query || (c.getAttribute('data-title') || '').indexOf(query) !== -1;
        return okCat && okQ;
      }
      function apply() {
        if (!grid) return;
        var cards = Array.from(grid.querySelectorAll('.article-card'));
        var total = 0;
        cards.forEach(function (c) { if (matches(c)) { total++; c.style.display = (total <= revealed) ? '' : 'none'; } else c.style.display = 'none'; });
        var empty = grid.querySelector('.articles-empty');
        if (total === 0) { if (!empty) { empty = document.createElement('div'); empty.className = 'articles-empty'; empty.textContent = emptyLabel; grid.appendChild(empty); } }
        else if (empty) empty.remove();
        if (loadBtn) { var rem = total - revealed; if (rem > 0) { loadBtn.style.display = ''; loadBtn.textContent = loadMoreLabel + ' (' + rem + ' ' + remainingLabel + ')'; } else loadBtn.style.display = 'none'; }
      }
      if (search) search.addEventListener('input', function () { query = this.value.trim().toLowerCase(); revealed = initialVisible; apply(); });
      tabs.forEach(function (t) { t.addEventListener('click', function () { tabs.forEach(function (x) { x.classList.remove('active'); }); t.classList.add('active'); activeFilter = t.getAttribute('data-filter') || 'all'; revealed = initialVisible; apply(); }); });
      if (loadBtn) loadBtn.addEventListener('click', function () { revealed += 12; apply(); });
    })();
  </script>

