---
/**
 * Localized article renderer for all article-backed sections
 * (/es/{lifestyle|gear|vs|records|tournaments}/[slug], future fr/zh).
 * Renders translated title/body + hero via the locale-aware ArticleLayout.
 * Pilot: clean Spanish content; section-specific extras (H2H stats, gear product blocks,
 * related, English interlinks) are omitted rather than shown half-English.
 *
 * Coexists with [lang]/[...page].astro (evergreen page_translations) — the two emit disjoint
 * paths (article categories here vs rules/money/... there).
 */
import ArticleLayout from '../../../layouts/ArticleLayout.astro';
import {
  getActiveLocales,
  getArticleTranslation,
  buildAlternates,
  type Locale,
} from '../../../lib/i18n';
import { getArticleBySlug, supabase } from '../../../lib/supabase';
import { getArticlePhotoUrl } from '../../../lib/player-photos';
import { sanitizeArticleHtml } from '../../../lib/sanitize-core.mjs';
import { marked } from 'marked';

export async function getStaticPaths() {
  // Declared inside — Astro's getStaticPaths runs in an isolated scope and can't see
  // module-level frontmatter consts.
  const ARTICLE_CATEGORIES = ['lifestyle', 'gear', 'vs', 'records', 'tournaments', 'players'];
  const locales = getActiveLocales();
  if (locales.length === 0) return [];

  const paths: Array<{ params: { lang: string; category: string; slug: string }; props: { locale: Locale; category: string; articleId: number; slug: string } }> = [];
  for (const locale of locales) {
    for (const category of ARTICLE_CATEGORIES) {
      const { data: arts } = await supabase
        .from('articles')
        .select('id, slug')
        .eq('category', category)
        .eq('status', 'published');
      const byId = new Map((arts || []).map((a) => [a.id, a.slug]));
      if (byId.size === 0) continue;

      const { data: trans } = await supabase
        .from('article_translations')
        .select('article_id')
        .eq('lang', locale)
        .eq('status', 'published')
        .in('article_id', [...byId.keys()]);
      for (const row of trans || []) {
        const slug = byId.get(row.article_id);
        if (slug) paths.push({ params: { lang: locale, category, slug }, props: { locale, category, articleId: row.article_id, slug } });
      }
    }
  }
  return paths;
}

// Localized category labels (breadcrumb + hero chip).
const CAT_LABEL: Record<string, Record<string, string>> = {
  lifestyle: { es: 'Estilo de vida', fr: 'Style de vie', zh: '生活方式' },
  gear: { es: 'Equipamiento', fr: 'Équipement', zh: '装备' },
  vs: { es: 'Cara a cara', fr: 'Face à face', zh: '对阵' },
  records: { es: 'Récords', fr: 'Records', zh: '纪录' },
  tournaments: { es: 'Torneos', fr: 'Tournois', zh: '赛事' },
  players: { es: 'Jugadores', fr: 'Joueurs', zh: '球员' },
};
const HOME_LABEL: Record<string, string> = { es: 'Inicio', fr: 'Accueil', zh: '首页' };

const { locale, category, articleId, slug } = Astro.props as { locale: Locale; category: string; articleId: number; slug: string };
const t = await getArticleTranslation(articleId, locale);
const enArticle = await getArticleBySlug(slug);
if (!t || !enArticle) return Astro.redirect('/');

const heroImage = (await getArticlePhotoUrl(slug, category)) || enArticle.image_url || null;
const rawHtml = t.body ? (marked.parse(t.body) as string) : '';
const bodyHtml = rawHtml ? sanitizeArticleHtml(rawHtml) : ''; // [P1] sanitize on read

const catLabel = CAT_LABEL[category]?.[locale] ?? category;
const enPath = `/${category}/${slug}/`;
const alternates = buildAlternates(enPath, [locale]);

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: t.title,
  description: t.meta_description || t.excerpt || '',
  inLanguage: locale,
  url: `https://super.tennis/${locale}/${category}/${slug}/`,
  ...(enArticle.updated_at && { dateModified: enArticle.updated_at }),
  author: { '@type': 'Organization', '@id': 'https://super.tennis/#organization', name: 'SUPER.TENNIS Editorial', url: 'https://super.tennis/about/' },
  publisher: { '@type': 'Organization', name: 'SUPER.TENNIS', url: 'https://super.tennis', logo: { '@type': 'ImageObject', url: 'https://super.tennis/og/default.png' } },
  ...(heroImage && { image: heroImage }),
};
---

<ArticleLayout
  title={t.meta_title || t.title}
  description={t.meta_description || t.excerpt || t.title}
  breadcrumbs={[
    { label: HOME_LABEL[locale] ?? 'Inicio', href: '/' },
    { label: catLabel, href: `/${locale}/${category}/` },
    { label: t.title },
  ]}
  image={heroImage || undefined}
  category={category}
  categoryLabel={catLabel}
  categoryHref={`/${locale}/${category}/`}
  locale={locale}
  alternates={alternates}
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <div set:html={bodyHtml} />
</ArticleLayout>
