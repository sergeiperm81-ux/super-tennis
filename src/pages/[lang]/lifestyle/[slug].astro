---
/**
 * Localized lifestyle article (/es/lifestyle/[slug], future fr/zh).
 * Renders from article_translations via the (locale-aware) ArticleLayout.
 * Pilot: Spanish content + hero image + localized chrome. Monetization/related/interlinks
 * (English) are omitted for now — clean Spanish page over dirty half-English.
 */
import ArticleLayout from '../../../layouts/ArticleLayout.astro';
import {
  getActiveLocales,
  getArticleTranslation,
  buildAlternates,
  type Locale,
} from '../../../lib/i18n';
import { getArticleBySlug, supabase } from '../../../lib/supabase';
import { getArticlePhotoUrl } from '../../../lib/player-photos';
import { sanitizeArticleHtml } from '../../../lib/sanitize-core.mjs';
import { marked } from 'marked';

export async function getStaticPaths() {
  const locales = getActiveLocales();
  if (locales.length === 0) return [];

  const paths: Array<{ params: { lang: string; slug: string }; props: { locale: Locale; articleId: number; slug: string } }> = [];
  for (const locale of locales) {
    const { data: arts } = await supabase
      .from('articles')
      .select('id, slug')
      .eq('category', 'lifestyle')
      .eq('status', 'published');
    const byId = new Map((arts || []).map((a) => [a.id, a.slug]));
    if (byId.size === 0) continue;

    const { data: trans } = await supabase
      .from('article_translations')
      .select('article_id')
      .eq('lang', locale)
      .eq('status', 'published')
      .in('article_id', [...byId.keys()]);
    for (const row of trans || []) {
      const slug = byId.get(row.article_id);
      if (slug) paths.push({ params: { lang: locale, slug }, props: { locale, articleId: row.article_id, slug } });
    }
  }
  return paths;
}

const CAT_LABEL: Record<string, string> = { es: 'Estilo de vida', fr: 'Style de vie', zh: '生活方式' };
const HOME_LABEL: Record<string, string> = { es: 'Inicio', fr: 'Accueil', zh: '首页' };

const { locale, articleId, slug } = Astro.props as { locale: Locale; articleId: number; slug: string };
const t = await getArticleTranslation(articleId, locale);
const enArticle = await getArticleBySlug(slug);
if (!t || !enArticle) return Astro.redirect('/');

const heroImage = (await getArticlePhotoUrl(slug, 'lifestyle')) || enArticle.image_url || null;
const rawHtml = t.body ? (marked.parse(t.body) as string) : '';
const bodyHtml = rawHtml ? sanitizeArticleHtml(rawHtml) : ''; // [P1] sanitize on read

const enPath = `/lifestyle/${slug}/`;
const alternates = buildAlternates(enPath, [locale]);

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: t.title,
  description: t.meta_description || t.excerpt || '',
  inLanguage: locale,
  url: `https://super.tennis/${locale}/lifestyle/${slug}/`,
  ...(enArticle.updated_at && { dateModified: enArticle.updated_at }),
  author: { '@type': 'Organization', '@id': 'https://super.tennis/#organization', name: 'SUPER.TENNIS Editorial', url: 'https://super.tennis/about/' },
  publisher: { '@type': 'Organization', name: 'SUPER.TENNIS', url: 'https://super.tennis', logo: { '@type': 'ImageObject', url: 'https://super.tennis/og/default.png' } },
  ...(heroImage && { image: heroImage }),
};
---

<ArticleLayout
  title={t.meta_title || t.title}
  description={t.meta_description || t.excerpt || t.title}
  breadcrumbs={[
    { label: HOME_LABEL[locale] ?? 'Inicio', href: '/' },
    { label: CAT_LABEL[locale] ?? 'Lifestyle', href: '/lifestyle/' },
    { label: t.title },
  ]}
  image={heroImage || undefined}
  category="lifestyle"
  categoryLabel={CAT_LABEL[locale] ?? 'Lifestyle'}
  categoryHref="/lifestyle/"
  locale={locale}
  alternates={alternates}
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <div set:html={bodyHtml} />
</ArticleLayout>
