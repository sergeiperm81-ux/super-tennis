---
/**
 * Localized Lifestyle hub (/es/lifestyle/) — faithful 1:1 copy of src/pages/lifestyle/index.astro:
 * same hero, search, subcategory filters, top-2 featured, card grid, load-more, related + FAQ.
 * Self-contained: search / filter / load-more run client-side (no English API endpoints).
 * Only translated articles are listed. Overrides the generic [lang]/[category]/index.astro for lifestyle.
 */
import BaseLayout from '../../../layouts/BaseLayout.astro';
import FaqBlock from '../../../components/FaqBlock.astro';
import { getActiveLocales, buildAlternates, type Locale } from '../../../lib/i18n';
import { getArticles, supabase } from '../../../lib/supabase';
import { stripMarkdown } from '../../../lib/fallback-data';
import { getArticlePhotosForCategory } from '../../../lib/player-photos';

export async function getStaticPaths() {
  const SUPPORTED = ['es'];
  return getActiveLocales().filter((l) => SUPPORTED.includes(l)).map((locale) => ({ params: { lang: locale }, props: { locale } }));
}
const { locale } = Astro.props as { locale: Locale };
const lp = `/${locale}`;

// English articles + their Spanish translations → keep only translated ones, in original order.
let enArts: any[] = [];
try { enArts = await getArticles({ category: 'lifestyle', limit: 100 }); } catch {}
const ids = enArts.map((a: any) => a.id);
const tmap = new Map<number, { title: string; excerpt: string | null }>();
if (ids.length) {
  const { data } = await supabase.from('article_translations').select('article_id, title, excerpt').eq('lang', locale).eq('status', 'published').in('article_id', ids);
  for (const t of data || []) tmap.set(t.article_id, { title: t.title, excerpt: t.excerpt });
}
const articles = enArts.filter((a: any) => tmap.has(a.id)).map((a: any) => ({
  slug: a.slug, subcategory: a.subcategory || 'culture',
  title: tmap.get(a.id)!.title, excerpt: tmap.get(a.id)!.excerpt || '',
}));

const articlePhotos = await getArticlePhotosForCategory(articles, 'lifestyle');
function isPlayerPhoto(url: string | null | undefined): boolean { return !!url && (url.includes('wikimedia') || url.includes('wikipedia')); }

const topArticles = articles.slice(0, 2);
const gridArticles = articles.slice(2);        // all; JS reveals beyond 12
const initialVisible = 12;

const SUBCATS = [
  { key: 'all', label: 'Todos', color: '' },
  { key: 'culture', label: 'Cultura', color: '#2563eb' },
  { key: 'health', label: 'Salud', color: '#059669' },
  { key: 'style', label: 'Estilo', color: '#9333ea' },
  { key: 'media', label: 'Medios', color: '#f97316' },
  { key: 'career', label: 'Carrera', color: '#dc2626' },
  { key: 'money', label: 'Dinero', color: '#d4a017' },
  { key: 'travel', label: 'Viajes', color: '#0891b2' },
];

const faqs = [
  { q: '¿Cómo puede un adulto aprender a jugar al tenis desde cero?', a: 'Empieza con 4-6 semanas de clases en grupo en un club local (normalmente 20-40 $ por sesión) para aprender lo básico: empuñadura, derecha, revés, saque y juego de pies. Entrena 2-3 veces por semana, al menos 30 minutos. La mayoría de los adultos alcanzan un nivel recreativo de peloteo (USTA 2.5-3.0) en 3-6 meses. En equipamiento, una raqueta de principiante de 80-120 $ y zapatillas específicas de tenis son suficientes para empezar.' },
  { q: '¿Es el tenis un buen ejercicio para perder peso?', a: 'Sí: una hora de tenis individual quema aproximadamente 400-600 calorías en un adulto de 70 kg, comparable a correr o ir en bici. El tenis combina intensidad cardiovascular (ráfagas por intervalos) con trabajo de fuerza (movimientos de rotación) y equilibrio. Los estudios relacionan el tenis regular con un menor riesgo de mortalidad cardiovascular y una mejor densidad ósea.' },
  { q: '¿Qué comen los tenistas profesionales?', a: 'Los profesionales suelen seguir una dieta alta en carbohidratos y proteína moderada para aguantar partidos de 3-5 horas. Antes del partido: avena, pasta, arroz y plátanos. Durante: plátanos, geles energéticos y bebidas con electrolitos. Sinner es conocido por una dieta italiana rica en pasta; Djokovic sigue un régimen estricto sin gluten y mayormente vegetal; Nadal come mediterráneo (pescado, aceite de oliva, pasta).' },
  { q: '¿Cuánto ganan los tenistas por patrocinios?', a: 'Los mejores ganan más de 20-50 M$ al año solo en patrocinios, mucho más que en premios. Federer llegó a ganar ~90 M$/año en su mejor momento con Uniqlo, Rolex, Mercedes, Wilson y otros. Sinner firmó acuerdos con Nike, Head y Rolex por unos ~30 M$ anuales combinados. Los jugadores de nivel medio (top 50) suelen ganar 200 000-2 M$ de patrocinadores según su perfil.' },
  { q: '¿Qué diferencia hay entre el tenis y el pádel?', a: 'El pádel se juega en una pista más pequeña (20×10 m) con paredes, palas macizas sin cuerdas y una bola despresurizada; a menudo se juega la bola contra las paredes (como el squash). El tenis usa una pista más grande (23,77×8,23 m en individual), raquetas encordadas y bolas estándar. El pádel es más fácil de empezar, más social (siempre en dobles) y crece más rápido en el mundo, sobre todo en España, Italia y Suecia.' },
  { q: '¿Cómo se ve el tenis por internet?', a: 'Los derechos de emisión varían por región. En EE. UU., Tennis Channel, ESPN y ESPN+ cubren la mayoría de los eventos. En Reino Unido, Sky Sports y BBC iPlayer (Wimbledon gratis). Tennis TV (suscripción de atptour.com) emite todos los partidos ATP en el mundo por ~120 $/año. Los partidos WTA están en WTA TV (~100 $/año). Los Grand Slam suelen ser gratis en las cadenas nacionales del país anfitrión.' },
];

const itemListJsonLd = articles.length > 0 ? {
  '@context': 'https://schema.org', '@type': 'ItemList',
  itemListElement: articles.slice(0, 10).map((a, i) => ({ '@type': 'ListItem', position: i + 1, name: a.title, url: `https://super.tennis/${locale}/lifestyle/${a.slug}/` })),
} : null;

const alternates = buildAlternates('/lifestyle/', [locale]);
---

<BaseLayout
  alternates={alternates}
  locale={locale}
  title="Estilo de vida del tenis — Patrimonio, cultura e historias"
  description="Contenido de estilo de vida del tenis: patrimonio de los jugadores, historias entre bastidores, fitness, moda, rivalidades y la cultura del tenis profesional."
  ogImage="/og/lifestyle.png"
>
  {itemListJsonLd && <script type="application/ld+json" set:html={JSON.stringify(itemListJsonLd)} />}
  <div class="lifestyle-page" lang={locale}>
    <div class="container">
      <nav class="breadcrumbs"><a href={`${lp}/`}>Inicio</a> <span class="sep">/</span> <span class="current">Estilo de vida</span></nav>
      <section class="page-hero">
        <h1>Estilo de vida del tenis</h1>
        <p class="subtitle">Patrimonio, cultura, rivalidades e historias del mundo del tenis profesional{articles.length > 0 && ` — ${articles.length} artículos`}</p>
      </section>

      <div class="filter-section">
        <input type="text" class="search-input" id="search-input" placeholder="🔍 Buscar artículos de estilo de vida..." />
      </div>

      <div class="cat-filters" id="cat-filters">
        {SUBCATS.map((s) => (
          <button class={`cat-btn ${s.key === 'all' ? 'active' : ''}`} data-subcat={s.key} style={s.color ? `--cat-color: ${s.color}` : ''}>{s.label}</button>
        ))}
      </div>

      <div class="empty-state" id="empty-state" style="display:none;"><p>No se han encontrado artículos. Prueba otra búsqueda o categoría.</p></div>

      {topArticles.length > 0 && (
        <div class="top-row" id="top-row">
          {topArticles.map((article) => {
            const photo = articlePhotos.get(article.slug);
            return (
              <a href={`${lp}/lifestyle/${article.slug}/`} class="top-card" data-subcat={article.subcategory} data-title={article.title.toLowerCase()}>
                <div class={`top-card-img ${isPlayerPhoto(photo) ? 'player-photo' : ''}`}>
                  {photo ? (<img src={photo} alt={article.title} loading="eager" decoding="async" width="600" height="400" onerror="this.parentElement.classList.add('no-img')" />) : (<div class="img-placeholder"></div>)}
                  <div class="top-card-overlay"><h2>{article.title}</h2></div>
                </div>
              </a>
            );
          })}
        </div>
      )}

      {gridArticles.length > 0 && (
        <div class="card-grid" id="card-grid">
          {gridArticles.map((article, i) => {
            const photo = articlePhotos.get(article.slug);
            return (
              <a href={`${lp}/lifestyle/${article.slug}/`} class="card" data-subcat={article.subcategory} data-title={article.title.toLowerCase()} data-idx={i} style={i >= initialVisible ? 'display:none;' : ''}>
                <div class={`card-img ${isPlayerPhoto(photo) ? 'player-photo' : ''}`}>
                  {photo ? (<img src={photo} alt={article.title} loading="lazy" decoding="async" width="400" height="400" onerror="this.parentElement.classList.add('no-img')" />) : (<div class="img-placeholder"></div>)}
                </div>
                <div class="card-body">
                  <h3>{article.title}</h3>
                  <p>{stripMarkdown(article.excerpt || '')}</p>
                  <span class="card-link">Leer artículo →</span>
                </div>
              </a>
            );
          })}
        </div>
      )}

      {gridArticles.length > initialVisible && (
        <div class="load-more-section" id="load-more-section">
          <button class="load-more-btn" id="load-more-btn">Ver más ({gridArticles.length - initialVisible} más)</button>
        </div>
      )}

      <section class="related-section">
        <h2>Explora más</h2>
        <div class="cta-links">
          <a href={`${lp}/players/`}>Perfiles de jugadores</a>
          <a href={`${lp}/records/`}>Récords</a>
          <a href={`${lp}/gear/`}>Equipamiento</a>
          <a href={`${lp}/rankings/`}>Ranking</a>
        </div>
      </section>

      <FaqBlock faqs={faqs} title="Preguntas frecuentes" />
    </div>
  </div>

  <script is:inline define:vars={{ initialVisible }}>
    (function () {
      var search = document.getElementById('search-input');
      var pills = Array.from(document.querySelectorAll('.cat-btn'));
      var grid = document.getElementById('card-grid');
      var topRow = document.getElementById('top-row');
      var loadSection = document.getElementById('load-more-section');
      var loadBtn = document.getElementById('load-more-btn');
      var empty = document.getElementById('empty-state');
      var activeCat = 'all';
      var query = '';
      var revealed = initialVisible;

      function matches(el) {
        var okCat = activeCat === 'all' || el.getAttribute('data-subcat') === activeCat;
        var okQ = !query || (el.getAttribute('data-title') || '').indexOf(query) !== -1;
        return okCat && okQ;
      }
      function apply() {
        var cards = grid ? Array.from(grid.querySelectorAll('.card')) : [];
        var shown = 0, total = 0;
        cards.forEach(function (c) {
          if (matches(c)) { total++; c.style.display = (total <= revealed) ? '' : 'none'; if (total <= revealed) shown++; }
          else c.style.display = 'none';
        });
        if (topRow) Array.from(topRow.querySelectorAll('.top-card')).forEach(function (c) { c.style.display = matches(c) ? '' : 'none'; });
        if (loadSection) {
          var remaining = total - revealed;
          if (remaining > 0) { loadSection.style.display = ''; loadBtn.textContent = 'Ver más (' + remaining + ' más)'; }
          else loadSection.style.display = 'none';
        }
        if (empty) empty.style.display = (total === 0) ? '' : 'none';
      }
      if (search) search.addEventListener('input', function () { query = this.value.trim().toLowerCase(); revealed = initialVisible; apply(); });
      pills.forEach(function (p) { p.addEventListener('click', function () { pills.forEach(function (x) { x.classList.remove('active'); }); p.classList.add('active'); activeCat = p.getAttribute('data-subcat'); revealed = initialVisible; apply(); }); });
      if (loadBtn) loadBtn.addEventListener('click', function () { revealed += 12; apply(); });
    })();
  </script>
</BaseLayout>

<style>
  .lifestyle-page { max-width: 1100px; margin: 0 auto; padding: 0 24px 60px; }
  .breadcrumbs { padding: 20px 0 0; font-size: 0.82rem; color: var(--gray-500); }
  .breadcrumbs a { color: var(--gray-600); text-decoration: none; }
  .breadcrumbs a:hover { color: var(--court-green); }
  .sep { margin: 0 8px; }
  .current { color: var(--gray-800); font-weight: 500; }
  .page-hero { padding: 48px 0 32px; border-bottom: 3px solid var(--court-green); margin-bottom: 28px; }
  .page-hero h1 { font-family: var(--font-heading); font-size: 2.8rem; text-transform: uppercase; color: var(--gray-900); margin: 0; }
  .subtitle { color: var(--gray-600); font-size: 1.1rem; margin: 8px 0 0; }
  .filter-section { margin-bottom: 24px; }
  .search-input { width: 100%; padding: 12px 16px; font-size: 0.95rem; border: 1px solid #d1d5db; border-radius: var(--radius); background: white; color: #111827; transition: all 0.2s; }
  .search-input:focus { outline: none; border-color: var(--court-green); box-shadow: 0 0 0 3px rgba(34, 197, 94, 0.1); }
  .search-input::placeholder { color: #9ca3af; }
  .cat-filters { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 28px; padding-bottom: 16px; border-bottom: 1px solid #e5e7eb; }
  .cat-btn { display: inline-block; padding: 6px 16px; border-radius: 20px; border: 1px solid #d1d5db; background: transparent; font-size: 0.85rem; font-weight: 600; cursor: pointer; color: #374151; text-decoration: none; transition: all 0.2s; }
  .cat-btn:hover { border-color: var(--cat-color, #6b7280); color: var(--cat-color, #6b7280); }
  .cat-btn.active { background: var(--cat-color, #111827); color: #fff; border-color: var(--cat-color, #111827); }
  .top-row { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 20px; }
  .top-card { display: block; text-decoration: none; color: inherit; border-radius: var(--radius); overflow: hidden; transition: transform 0.2s, box-shadow 0.2s; }
  .top-card:hover { transform: translateY(-3px); box-shadow: 0 8px 30px rgba(0,0,0,0.12); }
  .top-card-img { position: relative; aspect-ratio: 4 / 3; background: var(--gray-100); border-radius: var(--radius); }
  .top-card-img img { width: 100%; height: 100%; object-fit: cover; object-position: center 30%; border-radius: var(--radius); display: block; }
  .top-card-img.player-photo img { object-position: top; }
  .top-card-img.no-img img { display: none; }
  .top-card-overlay { position: absolute; inset: 0; background: linear-gradient(0deg, rgba(0,0,0,0.75) 0%, rgba(0,0,0,0.1) 50%, transparent 100%); display: flex; align-items: flex-end; padding: 24px; }
  .top-card-overlay h2 { color: white; font-family: var(--font-heading); font-size: 1.25rem; text-transform: uppercase; margin: 0; line-height: 1.3; }
  .card-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-bottom: 48px; }
  .card { text-decoration: none; color: inherit; background: white; border: 1px solid var(--gray-200); border-radius: var(--radius); overflow: hidden; display: flex; flex-direction: column; transition: all 0.2s; }
  .card:hover { border-color: var(--court-green); box-shadow: var(--shadow); transform: translateY(-2px); }
  .card-img { aspect-ratio: 1 / 1; overflow: hidden; background: var(--gray-100); border-radius: var(--radius); }
  .card-img img { width: 100%; height: 100%; object-fit: cover; object-position: center 30%; border-radius: var(--radius); display: block; }
  .card-img.player-photo img { object-position: top; }
  .card-img.no-img img { display: none; }
  .img-placeholder { width: 100%; height: 100%; background: linear-gradient(135deg, #f0fdf4 0%, #dcfce7 100%); }
  .card-body { padding: 16px 18px 20px; flex: 1; display: flex; flex-direction: column; }
  .card-body h3 { font-family: var(--font-body); font-size: 0.95rem; font-weight: 700; margin: 0 0 8px; line-height: 1.4; color: var(--gray-900); }
  .card-body p { color: var(--gray-600); font-size: 0.82rem; line-height: 1.6; margin: 0; flex: 1; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
  .card-link { color: var(--court-green); font-weight: 600; font-size: 0.82rem; margin-top: 12px; }
  .empty-state { text-align: center; padding: 60px 24px; color: var(--gray-500); background: var(--gray-50); border-radius: var(--radius); margin-bottom: 48px; }
  .related-section { text-align: center; padding: 40px; background: var(--gray-50); border-radius: var(--radius); }
  .related-section h2 { font-family: var(--font-heading); font-size: 1.4rem; text-transform: uppercase; margin: 0 0 20px; }
  .cta-links { display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; }
  .cta-links a { color: var(--court-green); font-weight: 600; font-size: 0.95rem; text-decoration: none; }
  .cta-links a:hover { text-decoration: underline; }
  .load-more-section { display: flex; justify-content: center; margin: 48px 0; }
  .load-more-btn { padding: 12px 32px; font-size: 0.95rem; font-weight: 600; color: white; background: var(--court-green); border: none; border-radius: var(--radius); cursor: pointer; transition: all 0.2s; }
  .load-more-btn:hover { background: #16a34a; transform: translateY(-2px); box-shadow: 0 4px 12px rgba(34, 197, 94, 0.3); }
  @media (max-width: 1024px) { .card-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 768px) { .page-hero h1 { font-size: 2rem; } .top-row { grid-template-columns: 1fr; } .card-grid { grid-template-columns: 1fr 1fr; } .top-card-overlay h2 { font-size: 1.1rem; } }
  @media (max-width: 480px) { .card-grid { grid-template-columns: 1fr; } .cat-filters { gap: 6px; } }
</style>
