---
import BaseLayout from '../../layouts/BaseLayout.astro';

const authors = [
  {
    id: 'alex-morgan',
    name: 'Alex Morgan',
    title: 'Senior Tennis Editor',
    bio: 'Alex has followed professional tennis for over a decade, covering ATP and WTA tours with a focus on player statistics, records, and the business of tennis. Alex specializes in data-driven analysis of ranking systems, Grand Slam records, and head-to-head rivalries.',
    expertise: ['ATP/WTA Rankings', 'Grand Slam Records', 'Player Statistics', 'Head-to-Head Analysis'],
    image: null,
  },
  {
    id: 'sara-kellner',
    name: 'Sara Kellner',
    title: 'Gear & Equipment Editor',
    bio: 'Sara covers tennis gear, equipment, and technology for SUPER.TENNIS. With experience testing rackets, strings, and footwear across different playing levels, Sara focuses on making equipment decisions accessible to tennis fans at every stage — from first-time buyers to experienced club players.',
    expertise: ['Racket Reviews', 'Tennis Shoes', 'String Technology', 'Equipment Buying Guides'],
    image: null,
  },
];

const orgJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'SUPER.TENNIS Editorial Team',
  description: 'The editors and writers behind SUPER.TENNIS',
  itemListElement: authors.map((a, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    item: {
      '@type': 'Person',
      name: a.name,
      jobTitle: a.title,
      url: `https://super.tennis/authors/${a.id}/`,
      worksFor: { '@type': 'Organization', name: 'SUPER.TENNIS', url: 'https://super.tennis' },
      description: a.bio,
    },
  })),
};

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://super.tennis/' },
    { '@type': 'ListItem', position: 2, name: 'Authors' },
  ],
};
---

<BaseLayout
  title="Our Editorial Team — SUPER.TENNIS"
  description="Meet the editors and writers behind SUPER.TENNIS. Expert coverage of tennis records, gear, rankings, and the culture of professional tennis."
  jsonLd={orgJsonLd}
>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />

  <div class="authors-page">
    <nav class="breadcrumbs">
      <a href="/">Home</a> <span class="sep">/</span> <span class="current">Authors</span>
    </nav>

    <header class="page-hero">
      <h1>Our Editorial Team</h1>
      <p class="subtitle">The people behind SUPER.TENNIS</p>
    </header>

    <div class="authors-grid">
      {authors.map(author => (
        <a href={`/authors/${author.id}/`} class="author-card">
          <div class="author-avatar">
            {author.name.split(' ').map(n => n[0]).join('')}
          </div>
          <div class="author-info">
            <h2 class="author-name">{author.name}</h2>
            <p class="author-title">{author.title}</p>
            <p class="author-bio">{author.bio}</p>
            <div class="author-expertise">
              {author.expertise.map(tag => (
                <span class="tag">{tag}</span>
              ))}
            </div>
          </div>
        </a>
      ))}
    </div>

    <section class="about-editorial">
      <h2>About Our Coverage</h2>
      <p>
        SUPER.TENNIS is built for everyone who finds professional tennis fascinating — whether you follow
        every Grand Slam or just discovered the sport. Our team covers player statistics, equipment,
        records, and the culture around the world's most elegant game.
      </p>
      <p>
        Our data is sourced from official ATP, WTA, and ITF records. Player statistics and rankings
        are updated regularly. For corrections or tips, contact us at
        <a href="mailto:contact@super.tennis">contact@super.tennis</a>.
      </p>
    </section>
  </div>
</BaseLayout>

<style>
  .authors-page {
    max-width: 800px;
    margin: 0 auto;
    padding: 0 24px 60px;
  }

  .breadcrumbs {
    padding: 20px 0;
    font-size: 0.82rem;
    color: var(--gray-500);
  }
  .breadcrumbs a { color: var(--gray-600); }
  .breadcrumbs a:hover { color: var(--court-green); }
  .sep { margin: 0 8px; }
  .current { color: var(--gray-800); font-weight: 500; }

  .page-hero {
    padding: 48px 0 32px;
    border-bottom: 3px solid var(--court-green);
    margin-bottom: 40px;
  }
  .page-hero h1 {
    font-family: var(--font-heading);
    font-size: 2.4rem;
    text-transform: uppercase;
    color: var(--gray-900);
    margin: 0;
  }
  .subtitle {
    color: var(--gray-600);
    font-size: 1.1rem;
    margin: 8px 0 0;
  }

  .authors-grid {
    display: flex;
    flex-direction: column;
    gap: 24px;
    margin-bottom: 48px;
  }

  .author-card {
    display: flex;
    gap: 24px;
    padding: 28px;
    background: var(--gray-50);
    border: 1px solid var(--gray-200);
    border-radius: var(--radius);
    text-decoration: none;
    color: inherit;
    transition: all 0.2s;
  }
  .author-card:hover {
    border-color: var(--court-green);
    box-shadow: var(--shadow);
  }

  .author-avatar {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: var(--court-green);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-heading);
    font-size: 1.4rem;
    font-weight: 700;
    flex-shrink: 0;
  }

  .author-info { flex: 1; }

  .author-name {
    font-family: var(--font-heading);
    font-size: 1.3rem;
    font-weight: 700;
    margin: 0 0 2px;
    color: var(--gray-900);
  }

  .author-title {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--court-green);
    margin: 0 0 12px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .author-bio {
    font-size: 0.92rem;
    line-height: 1.7;
    color: var(--gray-600);
    margin: 0 0 14px;
  }

  .author-expertise {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }
  .tag {
    padding: 3px 10px;
    background: white;
    border: 1px solid var(--gray-300);
    border-radius: 20px;
    font-size: 0.75rem;
    color: var(--gray-700);
  }

  .about-editorial {
    border-top: 1px solid var(--gray-200);
    padding-top: 36px;
  }
  .about-editorial h2 {
    font-family: var(--font-heading);
    font-size: 1.1rem;
    text-transform: uppercase;
    color: var(--gray-800);
    margin: 0 0 16px;
  }
  .about-editorial p {
    font-size: 0.95rem;
    line-height: 1.8;
    color: var(--gray-600);
    margin: 0 0 14px;
  }
  .about-editorial a { color: var(--court-green); }

  @media (max-width: 600px) {
    .author-card { flex-direction: column; }
    .page-hero h1 { font-size: 1.8rem; }
  }
</style>
