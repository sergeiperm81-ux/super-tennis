---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FaqBlock from '../../components/FaqBlock.astro';

const author = {
  id: 'alex-morgan',
  name: 'Alex Morgan',
  title: 'Senior Tennis Editor',
  bio: 'Alex Morgan is Senior Tennis Editor at SUPER.TENNIS. Alex has followed professional tennis for over a decade and writes about player statistics, ranking systems, Grand Slam records, and head-to-head rivalries.',
  expertise: [
    'ATP/WTA Rankings & Points',
    'Grand Slam Records',
    'Player Statistics & H2H',
    'Tournament History',
    'Career Achievement Analysis',
  ],
  beats: 'Rankings, records, head-to-head matchups, tournament guides',
  joinedYear: 2026,
  articles: [
    { title: 'Most Grand Slam Titles of All Time', href: '/records/most-grand-slam-titles-mens/' },
    { title: 'Most Weeks at World No. 1', href: '/records/most-weeks-at-number-one/' },
    { title: 'Djokovic vs Nadal Head-to-Head', href: '/vs/djokovic-vs-nadal/' },
    { title: 'Federer vs Nadal — The Greatest Rivalry', href: '/vs/federer-vs-nadal/' },
    { title: 'Fastest Serves in Tennis History', href: '/records/fastest-tennis-serves-ever/' },
    { title: 'Youngest Grand Slam Champions', href: '/records/youngest-grand-slam-champions/' },
    { title: 'ATP Finals Champions History', href: '/tournaments/atp-finals-guide/' },
  ],
  bioParas: [
    `Alex Morgan has been following professional tennis for over a decade, developing deep expertise in ATP and WTA tour statistics, Grand Slam history, and the economics of professional tennis. At SUPER.TENNIS, Alex oversees coverage of player rankings, records, head-to-head matchups, and tournament guides.`,
    `Alex's writing combines official ATP and WTA data with historical context to create content that's accessible to casual fans and informative for hardcore followers alike. Each player profile and record story on SUPER.TENNIS goes through Alex's editorial review before publication.`,
    `Areas of particular focus include Grand Slam title records, ranking point systems, head-to-head matchups that define each era, and the long arc of how tennis records have shifted across the Open Era. Alex pays close attention to surface specialization, year-end championship trends, and how prize money has scaled across the last 30 years.`,
  ],
  qaItems: [
    {
      q: 'What sources does Alex Morgan use for tennis statistics?',
      a: 'Primary sources are the official ATP Tour (atptour.com) and WTA (wtatennis.com) rankings pages, the four Grand Slam tournament websites for draw history, and Tennis Abstract\'s match database for head-to-head deep dives. For prize money figures, Alex cross-references the tournament prize-money tables published on the day of the final.',
    },
    {
      q: 'How are head-to-head records calculated on SUPER.TENNIS?',
      a: 'Head-to-head numbers include all ATP and WTA tour-level singles matches: Grand Slams, ATP/WTA 1000-500-250 events, ATP Finals/WTA Finals, and Davis Cup/Billie Jean King Cup ties. Exhibition matches, retired-from-injury results, and walkovers are excluded. When a rivalry spans more than 10 years, Alex breaks it out by surface and decade.',
    },
    {
      q: 'How often are player profiles updated?',
      a: 'Active player profiles are refreshed after each Grand Slam (4× per year minimum) and after any change to the player\'s top-50 career standing. Retired-player profiles get a refresh whenever a new biographical detail emerges (Hall of Fame induction, autobiography release, etc.). Every page on SUPER.TENNIS displays its last-updated date in the article header.',
    },
    {
      q: 'How does Alex decide which rivalries get a vs page?',
      a: 'A rivalry qualifies for its own /vs/ page when the two players have at least 8 tour-level matches against each other, or have met in at least 2 Grand Slam matches. Special exceptions exist for short-but-iconic rivalries (Borg vs. McEnroe at Wimbledon 1980, for example).',
    },
    {
      q: 'What\'s the editorial policy on rankings sources?',
      a: 'SUPER.TENNIS uses TennisLiveRanking.com as the primary live-rankings data source because its update cadence matches the official ATP/WTA Monday releases. Whenever live rankings differ from the previous week\'s official ATP/WTA tables, the page footer flags the discrepancy with a link to the official source.',
    },
  ],
  socialFootprint: [
    'Editor-level oversight on /players/, /records/, /rankings/, /tournaments/, /vs/',
    'Reviews every article tagged "records" or "vs" before publication',
    'Drafts the editorial calendar for each Grand Slam fortnight',
  ],
};

// Schema.org Person with full E-E-A-T signals
const personJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  '@id': `https://super.tennis/authors/${author.id}/#person`,
  name: author.name,
  givenName: 'Alex',
  familyName: 'Morgan',
  jobTitle: author.title,
  url: `https://super.tennis/authors/${author.id}/`,
  description: author.bio,
  worksFor: {
    '@type': 'Organization',
    '@id': 'https://super.tennis/#organization',
    name: 'SUPER.TENNIS',
    url: 'https://super.tennis',
  },
  knowsAbout: author.expertise,
  knowsLanguage: ['en'],
};

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://super.tennis/' },
    { '@type': 'ListItem', position: 2, name: 'Authors', item: 'https://super.tennis/authors/' },
    { '@type': 'ListItem', position: 3, name: author.name },
  ],
};
---

<BaseLayout
  title={`${author.name} — ${author.title} at SUPER.TENNIS`}
  description={author.bio}
  jsonLd={personJsonLd}
>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />

  <div class="author-page">
    <nav class="breadcrumbs">
      <a href="/">Home</a> <span class="sep">/</span>
      <a href="/authors/">Authors</a> <span class="sep">/</span>
      <span class="current">{author.name}</span>
    </nav>

    <header class="author-header">
      <div class="author-avatar">{author.name.split(' ').map(n => n[0]).join('')}</div>
      <div class="author-meta">
        <h1>{author.name}</h1>
        <p class="author-title">{author.title}</p>
        <p class="author-org">SUPER.TENNIS · Editor since {author.joinedYear}</p>
        <p class="author-beats">Covers: {author.beats}</p>
      </div>
    </header>

    <section class="author-bio">
      {author.bioParas.map(p => <p>{p}</p>)}
    </section>

    <section class="expertise-section">
      <h2>Areas of Expertise</h2>
      <div class="tags">
        {author.expertise.map(tag => <span class="tag">{tag}</span>)}
      </div>
    </section>

    <section class="methodology-section">
      <h2>Editorial Approach &amp; Sources</h2>
      <p class="methodology-text">
        Every record, ranking, and head-to-head number you see in Alex's articles is cross-checked against the official ATP Tour, WTA, and Grand Slam tournament databases. Where a source is debated or unofficial (e.g., serves recorded outside ATP-sanctioned events), the article explicitly flags the qualification. Page footers always show the last-updated date and the data sources used.
      </p>
      <ul class="methodology-list">
        {author.socialFootprint.map(item => <li>{item}</li>)}
      </ul>
    </section>

    <FaqBlock faqs={author.qaItems} title={`Q&A with ${author.name}`} />

    <section class="articles-section">
      <h2>Selected Articles by {author.name}</h2>
      <ul class="article-list">
        {author.articles.map(a => (
          <li><a href={a.href}>{a.title}</a></li>
        ))}
      </ul>
    </section>

    <section class="related-cats">
      <h2>Browse Alex's beats</h2>
      <div class="cat-pills">
        <a href="/records/" class="pill">🏆 Records</a>
        <a href="/rankings/" class="pill">📊 Rankings</a>
        <a href="/players/" class="pill">🎾 Players</a>
        <a href="/tournaments/" class="pill">🏟️ Tournaments</a>
        <a href="/vs/" class="pill">⚔️ Head-to-Head</a>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .author-page {
    max-width: 760px;
    margin: 0 auto;
    padding: 0 24px 60px;
  }
  .breadcrumbs {
    padding: 20px 0;
    font-size: 0.82rem;
    color: var(--gray-500);
  }
  .breadcrumbs a { color: var(--gray-600); text-decoration: none; }
  .breadcrumbs a:hover { color: var(--court-green); }
  .sep { margin: 0 8px; }
  .current { color: var(--gray-800); font-weight: 500; }

  .author-header {
    display: flex;
    align-items: center;
    gap: 24px;
    padding: 40px 0 32px;
    border-bottom: 3px solid var(--court-green);
    margin-bottom: 32px;
  }
  .author-avatar {
    width: 90px;
    height: 90px;
    border-radius: 50%;
    background: var(--court-green);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-heading);
    font-size: 2rem;
    font-weight: 700;
    flex-shrink: 0;
  }
  .author-meta h1 {
    font-family: var(--font-heading);
    font-size: 2.1rem;
    text-transform: uppercase;
    margin: 0 0 4px;
    color: var(--gray-900);
  }
  .author-title {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--court-green);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin: 0 0 4px;
  }
  .author-org {
    font-size: 0.85rem;
    color: var(--gray-500);
    margin: 0 0 4px;
  }
  .author-beats {
    font-size: 0.85rem;
    color: var(--gray-600);
    margin: 0;
  }

  .author-bio p {
    font-size: 1.02rem;
    line-height: 1.75;
    color: var(--gray-700);
    margin: 0 0 16px;
  }

  .expertise-section, .methodology-section, .articles-section, .related-cats {
    margin-top: 36px;
    padding-top: 24px;
    border-top: 1px solid var(--gray-200);
  }
  .expertise-section h2, .methodology-section h2, .articles-section h2, .related-cats h2 {
    font-family: var(--font-heading);
    font-size: 1rem;
    text-transform: uppercase;
    color: var(--gray-800);
    margin: 0 0 16px;
    letter-spacing: 0.5px;
  }
  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .tag {
    padding: 5px 12px;
    background: var(--gray-50);
    border: 1px solid var(--gray-300);
    border-radius: 20px;
    font-size: 0.82rem;
    color: var(--gray-700);
  }

  .methodology-text {
    font-size: 0.95rem;
    line-height: 1.7;
    color: var(--gray-700);
    margin: 0 0 16px;
  }
  .methodology-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .methodology-list li {
    padding: 8px 0 8px 22px;
    position: relative;
    font-size: 0.92rem;
    color: var(--gray-700);
    line-height: 1.5;
  }
  .methodology-list li::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: var(--court-green);
    font-weight: 700;
  }

  .article-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .article-list li {
    padding: 10px 0;
    border-bottom: 1px solid var(--gray-100);
  }
  .article-list a {
    color: var(--gray-800);
    text-decoration: none;
    font-size: 0.95rem;
    font-weight: 500;
  }
  .article-list a:hover { color: var(--court-green); }

  .cat-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }
  .pill {
    display: inline-block;
    padding: 8px 16px;
    background: var(--gray-50);
    border: 1.5px solid var(--gray-200);
    border-radius: 20px;
    color: var(--gray-700);
    text-decoration: none;
    font-size: 0.88rem;
    font-weight: 500;
    transition: var(--transition);
  }
  .pill:hover {
    border-color: var(--court-green);
    color: var(--court-green);
    background: white;
  }
</style>
