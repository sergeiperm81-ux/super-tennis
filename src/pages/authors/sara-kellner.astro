---
import BaseLayout from '../../layouts/BaseLayout.astro';

const author = {
  id: 'sara-kellner',
  name: 'Sara Kellner',
  title: 'Gear & Equipment Editor',
  bio: 'Sara covers tennis gear, equipment, and technology for SUPER.TENNIS, focusing on making equipment decisions accessible to tennis fans at every stage.',
  longBio: `Sara Kellner covers tennis equipment and gear for SUPER.TENNIS, bringing a practical perspective to racket reviews, string comparisons, and footwear guides.

Sara's gear coverage focuses on demystifying equipment decisions for recreational players and serious club competitors alike — explaining the difference between a 97 and 100 square-inch head size in plain language, or why string tension matters for elbow health.

Beyond technical reviews, Sara covers how professional players' equipment choices have evolved over time, and how consumer versions of pro gear actually perform for the rest of us.`,
  expertise: ['Racket Reviews', 'Tennis Shoes', 'String Technology', 'Equipment Buying Guides'],
  articles: [
    { title: 'Best Tennis Rackets for Beginners 2026', href: '/gear/best-tennis-rackets-beginners/' },
    { title: 'Best Tennis Shoes 2026', href: '/gear/best-tennis-shoes-2026/' },
    { title: 'Polyester vs Natural Gut Strings', href: '/faq/#gear' },
    { title: 'Head vs Wilson vs Babolat', href: '/gear/head-vs-wilson-vs-babolat/' },
    { title: 'Best Clay Court Tennis Shoes', href: '/gear/best-clay-court-shoes/' },
  ],
};

const personJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: author.name,
  jobTitle: author.title,
  url: `https://super.tennis/authors/${author.id}/`,
  description: author.bio,
  worksFor: {
    '@type': 'Organization',
    name: 'SUPER.TENNIS',
    url: 'https://super.tennis',
  },
  knowsAbout: author.expertise,
};

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://super.tennis/' },
    { '@type': 'ListItem', position: 2, name: 'Authors', item: 'https://super.tennis/authors/' },
    { '@type': 'ListItem', position: 3, name: author.name },
  ],
};
---

<BaseLayout
  title={`${author.name} — ${author.title} at SUPER.TENNIS`}
  description={author.bio}
  jsonLd={personJsonLd}
>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />

  <div class="author-page">
    <nav class="breadcrumbs">
      <a href="/">Home</a> <span class="sep">/</span>
      <a href="/authors/">Authors</a> <span class="sep">/</span>
      <span class="current">{author.name}</span>
    </nav>

    <header class="author-header">
      <div class="author-avatar">{author.name.split(' ').map(n => n[0]).join('')}</div>
      <div class="author-meta">
        <h1>{author.name}</h1>
        <p class="author-title">{author.title}</p>
        <p class="author-org">SUPER.TENNIS</p>
      </div>
    </header>

    <section class="author-bio">
      {author.longBio.split('\n\n').map(para => <p>{para}</p>)}
    </section>

    <section class="expertise-section">
      <h2>Areas of Expertise</h2>
      <div class="tags">
        {author.expertise.map(tag => <span class="tag">{tag}</span>)}
      </div>
    </section>

    <section class="articles-section">
      <h2>Selected Articles</h2>
      <ul class="article-list">
        {author.articles.map(a => (
          <li><a href={a.href}>{a.title}</a></li>
        ))}
      </ul>
    </section>
  </div>
</BaseLayout>

<style>
  .author-page {
    max-width: 720px;
    margin: 0 auto;
    padding: 0 24px 60px;
  }
  .breadcrumbs {
    padding: 20px 0;
    font-size: 0.82rem;
    color: var(--gray-500);
  }
  .breadcrumbs a { color: var(--gray-600); }
  .breadcrumbs a:hover { color: var(--court-green); }
  .sep { margin: 0 8px; }
  .current { color: var(--gray-800); font-weight: 500; }

  .author-header {
    display: flex;
    align-items: center;
    gap: 24px;
    padding: 40px 0 32px;
    border-bottom: 3px solid var(--court-green);
    margin-bottom: 32px;
  }
  .author-avatar {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    background: #7c3aed;
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-heading);
    font-size: 1.8rem;
    font-weight: 700;
    flex-shrink: 0;
  }
  .author-meta h1 {
    font-family: var(--font-heading);
    font-size: 2rem;
    text-transform: uppercase;
    margin: 0 0 4px;
    color: var(--gray-900);
  }
  .author-title {
    font-size: 0.9rem;
    font-weight: 600;
    color: #7c3aed;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin: 0 0 2px;
  }
  .author-org {
    font-size: 0.85rem;
    color: var(--gray-500);
    margin: 0;
  }

  .author-bio p {
    font-size: 1rem;
    line-height: 1.8;
    color: var(--gray-700);
    margin: 0 0 16px;
  }

  .expertise-section, .articles-section {
    margin-top: 32px;
    padding-top: 24px;
    border-top: 1px solid var(--gray-200);
  }
  .expertise-section h2, .articles-section h2 {
    font-family: var(--font-heading);
    font-size: 1rem;
    text-transform: uppercase;
    color: var(--gray-800);
    margin: 0 0 16px;
  }
  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .tag {
    padding: 5px 12px;
    background: var(--gray-50);
    border: 1px solid var(--gray-300);
    border-radius: 20px;
    font-size: 0.82rem;
    color: var(--gray-700);
  }
  .article-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .article-list li {
    padding: 10px 0;
    border-bottom: 1px solid var(--gray-100);
  }
  .article-list a {
    color: var(--gray-800);
    text-decoration: none;
    font-size: 0.95rem;
    font-weight: 500;
  }
  .article-list a:hover { color: #7c3aed; }
</style>
