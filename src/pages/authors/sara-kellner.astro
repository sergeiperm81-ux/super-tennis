---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FaqBlock from '../../components/FaqBlock.astro';

const author = {
  id: 'sara-kellner',
  name: 'Sara Kellner',
  title: 'Gear & Lifestyle Editor',
  bio: 'Sara Kellner is Gear & Lifestyle Editor at SUPER.TENNIS, covering tennis equipment, fashion, culture, and the lifestyle side of the sport. Sara writes about racket reviews, string tests, footwear, and the players and trends shaping tennis culture.',
  expertise: [
    'Racket Reviews & Buying Guides',
    'Tennis Shoe Reviews',
    'String & Tension Technology',
    'Tennis Fashion & Style',
    'Player Lifestyle Stories',
    'Equipment Brand Comparisons',
  ],
  beats: 'Gear reviews, lifestyle stories, tennis fashion, player profiles',
  joinedYear: 2026,
  articles: [
    { title: 'Best Tennis Rackets for Beginners 2026', href: '/gear/best-tennis-rackets-beginners/' },
    { title: 'Best Tennis Shoes 2026', href: '/gear/best-tennis-shoes-2026/' },
    { title: 'Head vs Wilson vs Babolat', href: '/gear/head-vs-wilson-vs-babolat/' },
    { title: 'Best Clay Court Tennis Shoes', href: '/gear/best-clay-court-shoes/' },
    { title: 'Tennis Fashion & Style', href: '/lifestyle/style/' },
    { title: 'Tennis Culture & Viral Moments', href: '/lifestyle/culture/' },
    { title: 'Most Stylish Players on Tour', href: '/lifestyle/best-dressed-tennis-players/' },
  ],
  bioParas: [
    `Sara Kellner covers tennis equipment, fashion, and the lifestyle side of the sport for SUPER.TENNIS. Her work spans racket reviews, string and footwear comparisons, and longer-form pieces on the players, brands, and viral moments shaping tennis culture in the 2020s.`,
    `Sara's gear coverage focuses on demystifying equipment decisions for recreational players and serious club competitors alike — explaining the difference between a 97 and 100 square-inch head size in plain language, or why string tension matters for elbow health. Every racket review on SUPER.TENNIS is grounded in published manufacturer specs and cross-referenced with player feedback from coaches and pro-shop staff.`,
    `Beyond technical reviews, Sara covers how professional players' equipment choices evolve over time, how consumer versions of pro gear actually perform for amateurs, and the rising "tennis core" fashion trend that's brought tennis style into the mainstream conversation.`,
  ],
  qaItems: [
    {
      q: 'How does Sara test the tennis rackets reviewed on SUPER.TENNIS?',
      a: 'Where possible, recommendations are built around published manufacturer specs (head size, weight, balance, string pattern, recommended tension) and cross-referenced with reviews from established pro shops (Tennis Warehouse, Tennis Express) and the input of teaching pros. SUPER.TENNIS clearly labels reviews based on hands-on testing vs. spec aggregation. We never claim a hands-on test that did not happen.',
    },
    {
      q: 'Why does SUPER.TENNIS include affiliate links?',
      a: 'Affiliate links (Amazon Associates, Skimlinks, Tennis Fitness coupon SERGEI) help us cover the cost of running the site. Affiliate status does not change product recommendations — Sara only recommends gear she would suggest to a friend. Every article that contains affiliate links discloses the relationship up front.',
    },
    {
      q: 'What string tension does Sara recommend for recreational players?',
      a: 'For most recreational players, Sara recommends starting at the middle of the racket\'s suggested range — typically 50-55 lbs for a 100-square-inch head. Higher tension gives more control but less power; lower tension does the opposite. Players with elbow or wrist issues should drop 2-4 lbs and consider a softer string (multifilament or natural gut rather than poly).',
    },
    {
      q: 'How does Sara decide which lifestyle stories to publish?',
      a: 'SUPER.TENNIS covers tennis lifestyle from the angle of fans who watch but don\'t necessarily play. Stories that qualify include player fashion moments at Slams, the Met Gala, on-court tech changes, social-media virality, and the people who turn tennis into mainstream entertainment. We avoid tabloid speculation and rumor-based reporting.',
    },
    {
      q: 'How often are gear reviews updated?',
      a: 'Gear category roundups (best rackets, best shoes) are refreshed twice a year — at the start of the European clay season (March) and the start of the hard-court swing (July). Individual product reviews are updated whenever the manufacturer releases a new generation of the model.',
    },
  ],
  socialFootprint: [
    'Editor-level oversight on /gear/, /lifestyle/ (excluding stats-heavy money articles)',
    'Coordinates affiliate disclosure across all gear and lifestyle articles',
    'Reviews lifestyle stories for tone and source quality before publication',
  ],
};

const personJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  '@id': `https://super.tennis/authors/${author.id}/#person`,
  name: author.name,
  givenName: 'Sara',
  familyName: 'Kellner',
  jobTitle: author.title,
  url: `https://super.tennis/authors/${author.id}/`,
  description: author.bio,
  worksFor: {
    '@type': 'Organization',
    '@id': 'https://super.tennis/#organization',
    name: 'SUPER.TENNIS',
    url: 'https://super.tennis',
  },
  knowsAbout: author.expertise,
  knowsLanguage: ['en'],
};

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://super.tennis/' },
    { '@type': 'ListItem', position: 2, name: 'Authors', item: 'https://super.tennis/authors/' },
    { '@type': 'ListItem', position: 3, name: author.name },
  ],
};
---

<BaseLayout
  title={`${author.name} — ${author.title} at SUPER.TENNIS`}
  description={author.bio}
  jsonLd={personJsonLd}
>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />

  <div class="author-page">
    <nav class="breadcrumbs">
      <a href="/">Home</a> <span class="sep">/</span>
      <a href="/authors/">Authors</a> <span class="sep">/</span>
      <span class="current">{author.name}</span>
    </nav>

    <header class="author-header">
      <div class="author-avatar">{author.name.split(' ').map(n => n[0]).join('')}</div>
      <div class="author-meta">
        <h1>{author.name}</h1>
        <p class="author-title">{author.title}</p>
        <p class="author-org">SUPER.TENNIS · Editor since {author.joinedYear}</p>
        <p class="author-beats">Covers: {author.beats}</p>
      </div>
    </header>

    <section class="author-bio">
      {author.bioParas.map(p => <p>{p}</p>)}
    </section>

    <section class="expertise-section">
      <h2>Areas of Expertise</h2>
      <div class="tags">
        {author.expertise.map(tag => <span class="tag">{tag}</span>)}
      </div>
    </section>

    <section class="methodology-section">
      <h2>Editorial Approach &amp; Sources</h2>
      <p class="methodology-text">
        Sara's gear recommendations are based on published manufacturer specs (head size, weight, balance, string pattern, recommended tension) cross-referenced with reviews from major tennis retailers and feedback from teaching professionals. Lifestyle stories rely on verified sources only — press releases, official player social channels, and reputable tennis media — and avoid tabloid speculation. SUPER.TENNIS discloses every affiliate relationship.
      </p>
      <ul class="methodology-list">
        {author.socialFootprint.map(item => <li>{item}</li>)}
      </ul>
    </section>

    <FaqBlock faqs={author.qaItems} title={`Q&A with ${author.name}`} />

    <section class="articles-section">
      <h2>Selected Articles by {author.name}</h2>
      <ul class="article-list">
        {author.articles.map(a => (
          <li><a href={a.href}>{a.title}</a></li>
        ))}
      </ul>
    </section>

    <section class="related-cats">
      <h2>Browse Sara's beats</h2>
      <div class="cat-pills">
        <a href="/gear/" class="pill">🎾 Gear</a>
        <a href="/lifestyle/style/" class="pill">👗 Style</a>
        <a href="/lifestyle/culture/" class="pill">🎭 Culture</a>
        <a href="/lifestyle/health/" class="pill">💪 Health</a>
        <a href="/lifestyle/" class="pill">📰 All Lifestyle</a>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .author-page {
    max-width: 760px;
    margin: 0 auto;
    padding: 0 24px 60px;
  }
  .breadcrumbs {
    padding: 20px 0;
    font-size: 0.82rem;
    color: var(--gray-500);
  }
  .breadcrumbs a { color: var(--gray-600); text-decoration: none; }
  .breadcrumbs a:hover { color: #7c3aed; }
  .sep { margin: 0 8px; }
  .current { color: var(--gray-800); font-weight: 500; }

  .author-header {
    display: flex;
    align-items: center;
    gap: 24px;
    padding: 40px 0 32px;
    border-bottom: 3px solid #7c3aed;
    margin-bottom: 32px;
  }
  .author-avatar {
    width: 90px;
    height: 90px;
    border-radius: 50%;
    background: #7c3aed;
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-heading);
    font-size: 2rem;
    font-weight: 700;
    flex-shrink: 0;
  }
  .author-meta h1 {
    font-family: var(--font-heading);
    font-size: 2.1rem;
    text-transform: uppercase;
    margin: 0 0 4px;
    color: var(--gray-900);
  }
  .author-title {
    font-size: 0.9rem;
    font-weight: 600;
    color: #7c3aed;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin: 0 0 4px;
  }
  .author-org {
    font-size: 0.85rem;
    color: var(--gray-500);
    margin: 0 0 4px;
  }
  .author-beats {
    font-size: 0.85rem;
    color: var(--gray-600);
    margin: 0;
  }

  .author-bio p {
    font-size: 1.02rem;
    line-height: 1.75;
    color: var(--gray-700);
    margin: 0 0 16px;
  }

  .expertise-section, .methodology-section, .articles-section, .related-cats {
    margin-top: 36px;
    padding-top: 24px;
    border-top: 1px solid var(--gray-200);
  }
  .expertise-section h2, .methodology-section h2, .articles-section h2, .related-cats h2 {
    font-family: var(--font-heading);
    font-size: 1rem;
    text-transform: uppercase;
    color: var(--gray-800);
    margin: 0 0 16px;
    letter-spacing: 0.5px;
  }
  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .tag {
    padding: 5px 12px;
    background: var(--gray-50);
    border: 1px solid var(--gray-300);
    border-radius: 20px;
    font-size: 0.82rem;
    color: var(--gray-700);
  }

  .methodology-text {
    font-size: 0.95rem;
    line-height: 1.7;
    color: var(--gray-700);
    margin: 0 0 16px;
  }
  .methodology-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .methodology-list li {
    padding: 8px 0 8px 22px;
    position: relative;
    font-size: 0.92rem;
    color: var(--gray-700);
    line-height: 1.5;
  }
  .methodology-list li::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: #7c3aed;
    font-weight: 700;
  }

  .article-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .article-list li {
    padding: 10px 0;
    border-bottom: 1px solid var(--gray-100);
  }
  .article-list a {
    color: var(--gray-800);
    text-decoration: none;
    font-size: 0.95rem;
    font-weight: 500;
  }
  .article-list a:hover { color: #7c3aed; }

  .cat-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }
  .pill {
    display: inline-block;
    padding: 8px 16px;
    background: var(--gray-50);
    border: 1.5px solid var(--gray-200);
    border-radius: 20px;
    color: var(--gray-700);
    text-decoration: none;
    font-size: 0.88rem;
    font-weight: 500;
    transition: var(--transition);
  }
  .pill:hover {
    border-color: #7c3aed;
    color: #7c3aed;
    background: white;
  }
</style>
