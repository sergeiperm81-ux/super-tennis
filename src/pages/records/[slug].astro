---
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import ArticleFooter from '../../components/ArticleFooter.astro';
import RelatedArticles from '../../components/RelatedArticles.astro';
import { getArticleBySlug, getArticleSlugs } from '../../lib/supabase';
import { addInterlinks } from '../../lib/interlinks';
import { getArticlePhotoUrl } from '../../lib/player-photos';
import { marked } from 'marked';
import { getArticleAlternates } from '../../lib/i18n';

export async function getStaticPaths() {
  let slugs: string[] = [];
  try {
    slugs = await getArticleSlugs('records');
  } catch (e) {
    console.warn('records getStaticPaths: Supabase unavailable');
  }

  // Fallback slugs in case DB is empty
  if (slugs.length === 0) {
    slugs = [
      'most-grand-slam-titles',
      'fastest-tennis-serves-ever',
      'longest-tennis-matches-history',
      'most-weeks-number-one',
      'most-career-titles-tennis',
      'longest-winning-streaks-tennis',
      'biggest-upsets-tennis',
      'golden-slam-calendar-slam',
      'youngest-oldest-tennis-records',
      'most-aces-tennis-history-records',
      'tennis-prize-money-history',
      'most-masters-1000-titles',
      'tennis-surface-records',
      'grand-slam-hat-tricks',
      'doubles-records-tennis',
    ];
  }

  return slugs.map(slug => ({ params: { slug } }));
}

const { slug } = Astro.params;

let article: any = null;
try {
  article = await getArticleBySlug(slug as string);
} catch (e) {
  console.warn(`Record article not found: ${slug}`);
}

if (!article) {
  return Astro.redirect('/records/');
}

const heroImage = await getArticlePhotoUrl(slug as string, 'records') || article.image_url || null;
const alternates = await getArticleAlternates(article.id, `/records/${slug}/`);

const rawHtml = article.body ? marked.parse(article.body) : '';
const bodyHtml = rawHtml ? await addInterlinks(rawHtml as string, `/records/${slug}/`) : '';

// JSON-LD for the article
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: article.title,
  description: article.meta_description || article.excerpt,
  url: `https://super.tennis/records/${slug}/`,
  ...(article.created_at && { datePublished: article.created_at }),
  ...(article.updated_at && { dateModified: article.updated_at }),
  author: {
    '@type': 'Organization',
    '@id': 'https://super.tennis/#organization',
    name: 'SUPER.TENNIS Editorial',
    url: 'https://super.tennis/about/',
  },
  publisher: {
    '@type': 'Organization',
    name: 'SUPER.TENNIS',
    url: 'https://super.tennis',
    logo: { '@type': 'ImageObject', url: 'https://super.tennis/og/default.png' },
  },
  ...(heroImage && { image: heroImage }),
  about: {
    '@type': 'Thing',
    name: 'Tennis Records',
  },
};

const faqJsonLd = article.faqs && Array.isArray(article.faqs) && article.faqs.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: article.faqs.map((faq: { question: string; answer: string }) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
} : null;

// Quick Answer (2026-06-17 GEO audit): records pages buried the key fact in
// generic intro prose ("Tennis is a sport steeped in tradition…"). Surface the
// first FAQ's answer — already vetted, factual and dated — as an extractable
// lead for AI Overviews/Perplexity/ChatGPT. Scales to every records page that
// has FAQs, with no body rewriting and no accuracy risk. (excerpt/meta were
// unusable — many empty or contained leaked "# heading" markdown.)
const firstFaq = Array.isArray(article.faqs) && article.faqs.length > 0 ? article.faqs[0] : null;
---

<ArticleLayout
  title={article.meta_title || article.title}
  description={article.meta_description || article.excerpt || `${article.title} — Tennis records and statistics on SUPER.TENNIS.`}
  breadcrumbs={[
    { label: 'Home', href: '/' },
    { label: 'Records', href: '/records/' },
    { label: article.title },
  ]}
  image={heroImage || undefined}
  publishedDate={article.created_at || undefined}
  updatedDate={article.updated_at || undefined}
  category="records"
  categoryLabel="Tennis Records"
  categoryHref="/records/"
  alternates={alternates}
>
  <!-- JSON-LD -->
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  {faqJsonLd && <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />}

  {firstFaq?.answer && (
    <aside class="record-quick-answer" aria-label="Quick answer">
      <span class="rqa-label">Quick Answer</span>
      {firstFaq.question && <p class="rqa-q">{firstFaq.question}</p>}
      <p class="rqa-a">{firstFaq.answer}</p>
    </aside>
  )}

  <div set:html={bodyHtml} />

  <RelatedArticles category="records" currentSlug={slug as string} />

  <ArticleFooter backLabel="All Tennis Records" backHref="/records/" />
</ArticleLayout>

<style>
  /* Quick Answer — extractable lead pulled from the page's first FAQ. */
  .record-quick-answer {
    margin: 0 0 28px;
    padding: 16px 20px;
    background: linear-gradient(135deg, #fef2f2 0%, #fff 100%);
    border-left: 3px solid #dc2626;
    border-radius: 0 var(--radius, 8px) var(--radius, 8px) 0;
  }
  .rqa-label {
    display: block;
    font-family: var(--font-heading);
    font-size: 0.78rem;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: #dc2626;
    margin: 0 0 8px;
  }
  .rqa-q {
    margin: 0 0 6px;
    font-weight: 700;
    color: var(--gray-900);
    font-size: 0.95rem;
  }
  .rqa-a {
    margin: 0;
    font-size: 1.02rem;
    line-height: 1.6;
    color: var(--gray-800);
  }
</style>
