---
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import ArticleFooter from '../../components/ArticleFooter.astro';
import RelatedArticles from '../../components/RelatedArticles.astro';
import { getArticleBySlug, getArticleSlugs } from '../../lib/supabase';
import { addInterlinks } from '../../lib/interlinks';
import { getArticlePhotoUrl } from '../../lib/player-photos';
import { marked } from 'marked';

export async function getStaticPaths() {
  let slugs: string[] = [];
  try {
    slugs = await getArticleSlugs('records');
  } catch (e) {
    console.warn('records getStaticPaths: Supabase unavailable');
  }

  // Fallback slugs in case DB is empty
  if (slugs.length === 0) {
    slugs = [
      'most-grand-slam-titles',
      'fastest-serve-tennis',
      'longest-match-tennis',
      'most-weeks-number-one',
      'most-career-titles-tennis',
      'longest-winning-streaks-tennis',
      'biggest-upsets-tennis',
      'golden-slam-calendar-slam',
      'youngest-oldest-tennis-records',
      'most-aces-tennis-records',
      'tennis-prize-money-history',
      'most-masters-1000-titles',
      'tennis-surface-records',
      'grand-slam-hat-tricks',
      'doubles-records-tennis',
    ];
  }

  return slugs.map(slug => ({ params: { slug } }));
}

const { slug } = Astro.params;

let article: any = null;
try {
  article = await getArticleBySlug(slug as string);
} catch (e) {
  console.warn(`Record article not found: ${slug}`);
}

if (!article) {
  return Astro.redirect('/records/');
}

const heroImage = await getArticlePhotoUrl(slug as string, 'records');

const rawHtml = article.body ? marked.parse(article.body) : '';
const bodyHtml = rawHtml ? await addInterlinks(rawHtml as string, `/records/${slug}/`) : '';

// JSON-LD for the article
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: article.title,
  description: article.meta_description || article.excerpt,
  url: `https://super.tennis/records/${slug}/`,
  ...(article.created_at && { datePublished: article.created_at }),
  ...(article.updated_at && { dateModified: article.updated_at }),
  author: { '@type': 'Organization', name: 'SUPER.TENNIS', url: 'https://super.tennis' },
  publisher: {
    '@type': 'Organization',
    name: 'SUPER.TENNIS',
    url: 'https://super.tennis',
    logo: { '@type': 'ImageObject', url: 'https://super.tennis/og-image.png' },
  },
  ...(heroImage && { image: heroImage }),
  about: {
    '@type': 'Thing',
    name: 'Tennis Records',
  },
};

const faqJsonLd = article.faqs && Array.isArray(article.faqs) && article.faqs.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: article.faqs.map((faq: { question: string; answer: string }) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
} : null;
---

<ArticleLayout
  title={article.meta_title || article.title}
  description={article.meta_description || article.excerpt || `${article.title} — Tennis records and statistics on SUPER.TENNIS.`}
  breadcrumbs={[
    { label: 'Home', href: '/' },
    { label: 'Records', href: '/records/' },
    { label: article.title },
  ]}
  image={heroImage || undefined}
  category="records"
  categoryLabel="Tennis Records"
  categoryHref="/records/"
>
  <!-- JSON-LD -->
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  {faqJsonLd && <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />}

  <div set:html={bodyHtml} />

  <RelatedArticles category="records" currentSlug={slug as string} />

  <ArticleFooter backLabel="All Tennis Records" backHref="/records/" />
</ArticleLayout>
