---
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import { getArticleBySlug, getArticleSlugs } from '../../lib/supabase';
import { marked } from 'marked';

export async function getStaticPaths() {
  let slugs: string[] = [];
  try {
    slugs = await getArticleSlugs('records');
  } catch (e) {
    console.warn('records getStaticPaths: Supabase unavailable');
  }

  // Fallback slugs in case DB is empty
  if (slugs.length === 0) {
    slugs = [
      'most-grand-slam-titles',
      'fastest-serve-tennis',
      'longest-match-tennis',
      'most-weeks-number-one',
    ];
  }

  return slugs.map(slug => ({ params: { slug } }));
}

const { slug } = Astro.params;

let article: any = null;
try {
  article = await getArticleBySlug(slug as string);
} catch (e) {
  console.warn(`Record article not found: ${slug}`);
}

if (!article) {
  return Astro.redirect('/records/');
}

const bodyHtml = article.body ? marked.parse(article.body) : '';

// JSON-LD for the article
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: article.title,
  description: article.meta_description || article.excerpt,
  url: `https://super.tennis/records/${slug}/`,
  publisher: {
    '@type': 'Organization',
    name: 'SUPER.TENNIS',
    url: 'https://super.tennis',
  },
  about: {
    '@type': 'Thing',
    name: 'Tennis Records',
  },
};
---

<ArticleLayout
  title={article.meta_title || article.title}
  description={article.meta_description || article.excerpt || `${article.title} — Tennis records and statistics on SUPER.TENNIS.`}
  breadcrumbs={[
    { label: 'Home', href: '/' },
    { label: 'Records', href: '/records/' },
    { label: article.title },
  ]}
>
  <!-- JSON-LD -->
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <div set:html={bodyHtml} />

  <!-- Navigation Links -->
  <div class="article-nav">
    <a href="/records/" class="nav-back">← All Tennis Records</a>
    <div class="nav-related">
      <a href="/players/">👥 Player Profiles</a>
      <a href="/rankings/">📊 Rankings</a>
    </div>
  </div>
</ArticleLayout>

<style>
  .article-nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 16px;
    margin-top: 40px;
    padding-top: 24px;
    border-top: 2px solid var(--gray-200);
  }
  .nav-back {
    color: var(--court-green);
    font-weight: 600;
    font-size: 0.95rem;
  }
  .nav-back:hover { text-decoration: underline; }

  .nav-related {
    display: flex;
    gap: 16px;
  }
  .nav-related a {
    color: var(--gray-600);
    font-size: 0.9rem;
    font-weight: 500;
    transition: color 0.2s;
  }
  .nav-related a:hover { color: var(--court-green); }
</style>
