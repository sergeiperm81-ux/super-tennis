---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LiteYouTube from '../../components/LiteYouTube.astro';
import { getLeaderboard, getArticles, getPlayerBySlug } from '../../lib/supabase';
import { countryFlags, fallbackPlayers, getFlagUrl, stripMarkdown } from '../../lib/fallback-data';

// Dynamic leaderboards from Supabase
let mostTitlesATP: any[] = [];
let mostTitlesWTA: any[] = [];
let mostGrandSlams: any[] = [];
let highestWinPct: any[] = [];

try {
  [mostTitlesATP, mostTitlesWTA, mostGrandSlams] = await Promise.all([
    getLeaderboard('career_titles', 'atp', 10),
    getLeaderboard('career_titles', 'wta', 10),
    getLeaderboard('grand_slam_titles', null, 10),
  ]);

  // For win percentage, we need to compute it client-side from the titles leaders
  const allPlayers = await getLeaderboard('career_win', null, 50);
  highestWinPct = allPlayers
    .filter((p: any) => (p.career_win + p.career_loss) >= 200) // Minimum 200 matches
    .map((p: any) => ({
      ...p,
      win_pct: ((p.career_win / (p.career_win + p.career_loss)) * 100).toFixed(1),
    }))
    .sort((a: any, b: any) => parseFloat(b.win_pct) - parseFloat(a.win_pct))
    .slice(0, 10);
} catch (e) {
  console.warn('Records: Supabase unavailable, using static data only');
}

// Fetch record articles from Supabase
let recordArticles: any[] = [];
try {
  recordArticles = await getArticles({ category: 'records', limit: 100 });
} catch (e) {}

// Filter record articles by search query and subcategory
const url = new URL(Astro.request.url);
const searchQuery = url.searchParams.get('q') || '';
let filteredRecordArticles = recordArticles;

if (searchQuery) {
  const query = searchQuery.toLowerCase();
  filteredRecordArticles = filteredRecordArticles.filter(a =>
    a.title.toLowerCase().includes(query) ||
    (a.excerpt || '').toLowerCase().includes(query)
  );
}

// Display first 12 articles, rest loaded via Load More
const displayedRecordArticles = filteredRecordArticles.slice(0, 12);
const remainingCount = filteredRecordArticles.length - 12;

// Section break photos (between record categories)
const sectionPhotos: { image: string; caption: string; credit: string }[] = [
  { image: '/images/tournaments/wimbledon.jpg', caption: 'The All England Club — where history is made', credit: '' },
  { image: '/images/records/tennis-court-aerial.jpg', caption: 'The path to No. 1 starts here', credit: '' },
  { image: '/images/tournaments/roland-garros.jpg', caption: 'Roland Garros — the ultimate test of endurance', credit: '' },
];

// Curated records data (editorial, not in database)
const records = [
  {
    category: 'Grand Slam Records',
    icon: '🏆',
    items: [
      { title: 'Most Grand Slam Titles (Men\'s Singles)', holder: 'Novak Djokovic', value: '24', slug: 'novak-djokovic', detail: 'Australian Open (10), Roland Garros (3), Wimbledon (7), US Open (4)' },
      { title: 'Most Grand Slam Titles (Women\'s Singles)', holder: 'Margaret Court', value: '24', slug: null, detail: 'Australian Open (11), Roland Garros (5), Wimbledon (3), US Open (5)' },
      { title: 'Most Grand Slam Titles (Open Era, Women\'s)', holder: 'Serena Williams', value: '23', slug: null, detail: 'Australian Open (7), Roland Garros (3), Wimbledon (7), US Open (6)' },
      { title: 'Most Consecutive Grand Slam Titles', holder: 'Novak Djokovic', value: '4', slug: 'novak-djokovic', detail: '2015-16: Wimbledon, US Open, Australian Open, Roland Garros' },
      { title: 'Youngest Grand Slam Champion (Men\'s)', holder: 'Michael Chang', value: '17y 3m', slug: null, detail: '1989 Roland Garros' },
      { title: 'Youngest Grand Slam Champion (Women\'s)', holder: 'Martina Hingis', value: '16y 3m', slug: null, detail: '1997 Australian Open' },
    ]
  },
  {
    category: 'Ranking Records',
    icon: '📊',
    items: [
      { title: 'Most Weeks at No. 1 (Men\'s)', holder: 'Novak Djokovic', value: '428', slug: 'novak-djokovic', detail: 'Surpassed Roger Federer\'s 310 weeks in March 2023' },
      { title: 'Most Weeks at No. 1 (Women\'s)', holder: 'Steffi Graf', value: '377', slug: null, detail: 'Held the record since 1997' },
      { title: 'Youngest No. 1 (Men\'s)', holder: 'Carlos Alcaraz', value: '19y 4m', slug: 'carlos-alcaraz', detail: 'September 12, 2022 after winning US Open' },
      { title: 'Youngest No. 1 (Women\'s)', holder: 'Martina Hingis', value: '16y 6m', slug: null, detail: 'March 31, 1997' },
      { title: 'Most Year-End No. 1 (Men\'s)', holder: 'Novak Djokovic', value: '8', slug: 'novak-djokovic', detail: '2011, 2012, 2014, 2015, 2018, 2020, 2021, 2023' },
      { title: 'Most Year-End No. 1 (Women\'s)', holder: 'Steffi Graf', value: '8', slug: null, detail: '1987, 1988, 1989, 1990, 1993, 1995, 1996' },
    ]
  },
  {
    category: 'Match & Serve Records',
    icon: '⚡',
    items: [
      { title: 'Fastest Serve Ever Recorded', holder: 'Sam Groth', value: '263.4 km/h', slug: null, detail: '2012 Busan Challenger (not ATP-recognized)' },
      { title: 'Fastest Serve (ATP Recognized)', holder: 'John Isner', value: '253.0 km/h', slug: null, detail: '2016 Davis Cup' },
      { title: 'Longest Match in History', holder: 'Isner vs. Mahut', value: '11h 5m', slug: null, detail: '2010 Wimbledon, final score 70-68 in 5th set' },
      { title: 'Most Career Titles (Men\'s Open Era)', holder: 'Novak Djokovic', value: '99', slug: 'novak-djokovic', detail: 'Surpassed Jimmy Connors\' 109 is the all-time target' },
      { title: 'Most Career Titles (Women\'s Open Era)', holder: 'Martina Navratilova', value: '167', slug: null, detail: 'Including 59 Grand Slam titles (singles + doubles)' },
      { title: 'Most Career Prize Money (Men\'s)', holder: 'Novak Djokovic', value: '$185M+', slug: 'novak-djokovic', detail: 'First player to earn over $180 million in prize money' },
    ]
  },
  {
    category: 'Surface Records',
    icon: '🎾',
    items: [
      { title: 'Most Roland Garros Titles (Men\'s)', holder: 'Rafael Nadal', value: '14', slug: null, detail: 'Won between 2005-2022, lost only 4 matches total' },
      { title: 'Most Wimbledon Titles (Men\'s)', holder: 'Roger Federer', value: '8', slug: null, detail: 'Won between 2003-2017, including 5 consecutive (2003-07)' },
      { title: 'Most Australian Open Titles (Men\'s)', holder: 'Novak Djokovic', value: '10', slug: 'novak-djokovic', detail: '2008, 2011, 2012, 2013, 2015, 2016, 2019, 2020, 2023' },
      { title: 'Most US Open Titles (Open Era, Men\'s)', holder: 'Jimmy Connors / Pete Sampras / Roger Federer', value: '5', slug: null, detail: 'Tied record among three legends' },
      { title: 'Longest Winning Streak on Clay', holder: 'Rafael Nadal', value: '81 matches', slug: null, detail: 'April 2005 to May 2007' },
      { title: 'Longest Winning Streak on Grass', holder: 'Roger Federer', value: '65 matches', slug: null, detail: '2003 to 2008' },
    ]
  },
];

// ========== SIDEBAR DATA ==========

// 1. Featured player (Djokovic for records page — the GOAT of records)
let sidebarPlayer: any = null;
try {
  sidebarPlayer = await getPlayerBySlug('novak-djokovic');
} catch {}
if (!sidebarPlayer) {
  sidebarPlayer = fallbackPlayers['novak-djokovic'] || {
    first_name: 'Novak', last_name: 'Djokovic', country_code: 'SRB',
    career_titles: 99, grand_slam_titles: 24, slug: 'novak-djokovic', image_url: '',
  };
}

// News and videos are loaded client-side via dynamic-content.js

// 4. Explore articles — 4 random from players and vs categories
let sidebarArticles: any[] = [];
try {
  const [playersArts, vsArts] = await Promise.all([
    getArticles({ category: 'players', limit: 6 }),
    getArticles({ category: 'vs', limit: 6 }),
  ]);
  const combined = [...playersArts, ...vsArts].filter(a => a.title);
  // Shuffle
  for (let i = combined.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [combined[i], combined[j]] = [combined[j], combined[i]];
  }
  sidebarArticles = combined.slice(0, 4);
} catch {}

// Article URL helpers
const categoryUrl: Record<string, string> = {
  players: '/players/', records: '/records/', gear: '/gear/',
  lifestyle: '/lifestyle/', tournaments: '/tournaments/', vs: '/vs/',
};
function articleUrl(art: { category: string; slug: string }): string {
  if (art.category === 'players') {
    if (art.slug.endsWith('-racket')) return `/players/${art.slug.replace(/-racket$/, '')}/racket/`;
    if (art.slug.endsWith('-net-worth')) return `/players/${art.slug.replace(/-net-worth$/, '')}/net-worth/`;
    return `/players/${art.slug}/`;
  }
  return `${categoryUrl[art.category] || '/'}${art.slug}/`;
}
const sbCatColors: Record<string, string> = {
  players: '#4CAF50', records: '#FF9800', gear: '#2196F3',
  lifestyle: '#E91E63', tournaments: '#00BCD4', vs: '#FF5722',
};
const sbCatLabels: Record<string, string> = {
  players: 'Players', records: 'Records', gear: 'Gear',
  lifestyle: 'Lifestyle', tournaments: 'Tournaments', vs: 'H2H',
};

// News category colors
const newsCatColors: Record<string, string> = {
  buzz: '#16a34a', scandal: '#dc2626', business: '#d4a017',
  fashion: '#ec4899', funny: '#f97316', wellness: '#0891b2',
};
const newsCatLabels: Record<string, string> = {
  buzz: 'Buzz', scandal: 'Scandal', business: 'Business',
  fashion: 'Fashion', funny: 'LOL', wellness: 'Wellness',
};
---

<BaseLayout
  title="Tennis Records — All-Time Stats & Achievements"
  description="Complete list of tennis records. Grand Slam records, ranking milestones, serve speed records, and all-time achievements in men's and women's tennis."
  ogImage="/og/records.png"
>
  <div class="records-page">
    <div class="container">
      <nav class="breadcrumbs"><a href="/">Home</a> <span class="sep">/</span> <span class="current">Records</span></nav>
      <section class="page-hero">
        <h1>Tennis Records</h1>
        <p class="subtitle">The greatest achievements and milestones in tennis history</p>
      </section>

      <!-- Records Hero Banner -->
      <div class="records-hero">
        <img src="/images/records/tennis-trophy-gold.jpg" alt="Tennis championship trophy" class="records-hero-img" loading="eager" decoding="async" width="1200" height="400" onerror="this.parentElement.style.display='none'" />
        <div class="records-hero-overlay">
          <div class="records-hero-stat">
            <span class="hero-stat-value">24</span>
            <span class="hero-stat-label">Grand Slam titles — the men's all-time record held by Novak Djokovic</span>
          </div>
        </div>
      </div>

      <!-- TWO-COLUMN LAYOUT -->
      <div class="records-layout">

        <!-- ========== MAIN CONTENT ========== -->
        <main class="records-main">

          <!-- Quick Nav -->
          <nav class="category-nav">
            {records.map(cat => (
              <a href={`#${cat.category.toLowerCase().replace(/\s+/g, '-')}`} class="cat-link">
                <span class="cat-icon">{cat.icon}</span>
                {cat.category}
              </a>
            ))}
            {mostTitlesATP.length > 0 && (
              <a href="#career-titles-leaderboard" class="cat-link live-data">
                <span class="cat-icon">👑</span>
                Titles Leaderboard
              </a>
            )}
            {mostGrandSlams.length > 0 && (
              <a href="#grand-slam-leaderboard" class="cat-link live-data">
                <span class="cat-icon">🏆</span>
                GS Leaders
              </a>
            )}
            {highestWinPct.length > 0 && (
              <a href="#win-percentage-leaderboard" class="cat-link live-data">
                <span class="cat-icon">📈</span>
                Win %
              </a>
            )}
          </nav>

          <!-- Records Sections (with photo banners between them) -->
          {records.map((cat, catIdx) => (
            <>
              {catIdx > 0 && sectionPhotos[catIdx - 1] && (
                <div class="section-photo-break">
                  <img src={sectionPhotos[catIdx - 1].image} alt={sectionPhotos[catIdx - 1].caption} loading="lazy" decoding="async" width="800" height="300" />
                  <div class="section-photo-caption">{sectionPhotos[catIdx - 1].caption}</div>
                </div>
              )}
              <section class="records-section" id={cat.category.toLowerCase().replace(/\s+/g, '-')}>
                <h2>
                  <span class="section-icon">{cat.icon}</span>
                  {cat.category}
                </h2>

                <div class="records-list">
                  {cat.items.map((rec, i) => (
                    <div class="record-card">
                      <div class="record-rank">#{i + 1}</div>
                      <div class="record-content">
                        <h3>{rec.title}</h3>
                        <div class="record-holder">
                          {rec.slug ? (
                            <a href={`/players/${rec.slug}/`} class="holder-link">{rec.holder}</a>
                          ) : (
                            <span class="holder-name">{rec.holder}</span>
                          )}
                        </div>
                        <p class="record-detail">{rec.detail}</p>
                      </div>
                      <div class="record-value">{rec.value}</div>
                    </div>
                  ))}
                </div>
              </section>
            </>
          ))}

          <!-- Dynamic Leaderboards from Real Data -->
          {mostTitlesATP.length > 0 && (
            <section class="records-section leaderboard-section" id="career-titles-leaderboard">
              <h2>
                <span class="section-icon">👑</span>
                Career Titles Leaderboard
              </h2>

              <div class="leaderboard-grid">
                <!-- ATP Most Titles -->
                <div class="leaderboard-table">
                  <h3 class="lb-title">ATP — Most Career Titles</h3>
                  <table>
                    <thead>
                      <tr>
                        <th>#</th>
                        <th>Player</th>
                        <th>Titles</th>
                        <th>GS</th>
                        <th>W-L</th>
                      </tr>
                    </thead>
                    <tbody>
                      {mostTitlesATP.map((p: any, i: number) => (
                        <tr class={i < 3 ? 'top-3' : ''}>
                          <td class="lb-rank">{i + 1}</td>
                          <td class="lb-player">
                            <a href={`/players/${p.slug}/`}>
                              {p.image_url ? (<img src={p.image_url} alt={`${p.first_name} ${p.last_name}`} class="lb-avatar" width="28" height="28" loading="lazy" decoding="async" onerror="this.style.display='none'" />) : null}
                              {getFlagUrl(p.country_code || '') ? (<img src={getFlagUrl(p.country_code || '', 20)} alt={p.country_code || ''} class="lb-flag-img" width="20" height="15" loading="lazy" decoding="async" />) : (<span class="lb-flag">{countryFlags[p.country_code || ''] || ''}</span>)}
                              {p.first_name} <strong>{p.last_name}</strong>
                            </a>
                          </td>
                          <td class="lb-value">{p.career_titles}</td>
                          <td class="lb-gs">{p.grand_slam_titles || 0}</td>
                          <td class="lb-wl">{p.career_win}-{p.career_loss}</td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </div>

                <!-- WTA Most Titles -->
                <div class="leaderboard-table">
                  <h3 class="lb-title">WTA — Most Career Titles</h3>
                  <table>
                    <thead>
                      <tr>
                        <th>#</th>
                        <th>Player</th>
                        <th>Titles</th>
                        <th>GS</th>
                        <th>W-L</th>
                      </tr>
                    </thead>
                    <tbody>
                      {mostTitlesWTA.map((p: any, i: number) => (
                        <tr class={i < 3 ? 'top-3' : ''}>
                          <td class="lb-rank">{i + 1}</td>
                          <td class="lb-player">
                            <a href={`/players/${p.slug}/`}>
                              {p.image_url ? (<img src={p.image_url} alt={`${p.first_name} ${p.last_name}`} class="lb-avatar" width="28" height="28" loading="lazy" decoding="async" onerror="this.style.display='none'" />) : null}
                              {getFlagUrl(p.country_code || '') ? (<img src={getFlagUrl(p.country_code || '', 20)} alt={p.country_code || ''} class="lb-flag-img" width="20" height="15" loading="lazy" decoding="async" />) : (<span class="lb-flag">{countryFlags[p.country_code || ''] || ''}</span>)}
                              {p.first_name} <strong>{p.last_name}</strong>
                            </a>
                          </td>
                          <td class="lb-value">{p.career_titles}</td>
                          <td class="lb-gs">{p.grand_slam_titles || 0}</td>
                          <td class="lb-wl">{p.career_win}-{p.career_loss}</td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </div>
              </div>
            </section>
          )}

          {mostGrandSlams.length > 0 && (
            <section class="records-section leaderboard-section" id="grand-slam-leaderboard">
              <h2>
                <span class="section-icon">🏆</span>
                Grand Slam Titles — All-Time Leaders
              </h2>

              <div class="leaderboard-single">
                <table>
                  <thead>
                    <tr>
                      <th>#</th>
                      <th>Player</th>
                      <th>Tour</th>
                      <th>Grand Slams</th>
                      <th>Total Titles</th>
                      <th>W-L</th>
                    </tr>
                  </thead>
                  <tbody>
                    {mostGrandSlams.map((p: any, i: number) => (
                      <tr class={i < 3 ? 'top-3' : ''}>
                        <td class="lb-rank">{i + 1}</td>
                        <td class="lb-player">
                          <a href={`/players/${p.slug}/`}>
                            {getFlagUrl(p.country_code || '') ? (<img src={getFlagUrl(p.country_code || '', 20)} alt={p.country_code || ''} class="lb-flag-img" width="20" height="15" loading="lazy" decoding="async" />) : (<span class="lb-flag">{countryFlags[p.country_code || ''] || ''}</span>)}
                            {p.first_name} <strong>{p.last_name}</strong>
                          </a>
                        </td>
                        <td><span class={`tour-mini ${p.tour}`}>{p.tour?.toUpperCase()}</span></td>
                        <td class="lb-value gs-val">{p.grand_slam_titles}</td>
                        <td>{p.career_titles}</td>
                        <td class="lb-wl">{p.career_win}-{p.career_loss}</td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            </section>
          )}

          {highestWinPct.length > 0 && (
            <section class="records-section leaderboard-section" id="win-percentage-leaderboard">
              <h2>
                <span class="section-icon">📈</span>
                Highest Career Win Percentage (200+ matches)
              </h2>

              <div class="leaderboard-single">
                <table>
                  <thead>
                    <tr>
                      <th>#</th>
                      <th>Player</th>
                      <th>Tour</th>
                      <th>Win %</th>
                      <th>W-L</th>
                      <th>Titles</th>
                    </tr>
                  </thead>
                  <tbody>
                    {highestWinPct.map((p: any, i: number) => (
                      <tr class={i < 3 ? 'top-3' : ''}>
                        <td class="lb-rank">{i + 1}</td>
                        <td class="lb-player">
                          <a href={`/players/${p.slug}/`}>
                            {getFlagUrl(p.country_code || '') ? (<img src={getFlagUrl(p.country_code || '', 20)} alt={p.country_code || ''} class="lb-flag-img" width="20" height="15" loading="lazy" decoding="async" />) : (<span class="lb-flag">{countryFlags[p.country_code || ''] || ''}</span>)}
                            {p.first_name} <strong>{p.last_name}</strong>
                          </a>
                        </td>
                        <td><span class={`tour-mini ${p.tour}`}>{p.tour?.toUpperCase()}</span></td>
                        <td class="lb-value">{p.win_pct}%</td>
                        <td class="lb-wl">{p.career_win}-{p.career_loss}</td>
                        <td>{p.career_titles}</td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            </section>
          )}

          <!-- Deep Dive Articles -->
          {recordArticles.length > 0 && (
            <section class="records-section" id="deep-dive">
              <div class="articles-header">
                <h2>
                  <span class="section-icon">📖</span>
                  Deep Dive Articles
                </h2>
                <div class="search-box">
                  <input
                    type="text"
                    id="recordSearch"
                    placeholder="Search articles..."
                    value={searchQuery}
                    class="search-input"
                  />
                </div>
              </div>

              <div class="articles-list">
                {displayedRecordArticles.map((art: any) => (
                  <a href={`/records/${art.slug}/`} class="article-card-link">
                    <div class="article-card-content">
                      <h3>{art.title}</h3>
                      <p>{stripMarkdown(art.excerpt || '')}</p>
                    </div>
                    <span class="article-arrow">&rarr;</span>
                  </a>
                ))}
              </div>

              {remainingCount > 0 && (
                <button
                  class="load-more-btn"
                  id="recordsLoadMoreBtn"
                  data-offset="12"
                  data-total={filteredRecordArticles.length}
                >
                  Load more articles ({remainingCount} remaining)
                </button>
              )}
            </section>
          )}

          <!-- Related Content -->
          <section class="related-content">
            <h2>Explore More</h2>
            <div class="explore-grid">
              <a href="/players/" class="explore-card">
                <span class="explore-icon">&#128101;</span>
                <h3>Player Profiles</h3>
                <p>Career stats, bios, and rankings for top ATP & WTA players</p>
              </a>
              <a href="/rankings/" class="explore-card">
                <span class="explore-icon">&#128200;</span>
                <h3>Live Rankings</h3>
                <p>Current ATP and WTA rankings updated weekly</p>
              </a>
              <a href="/gear/" class="explore-card">
                <span class="explore-icon">&#127934;</span>
                <h3>Player Gear</h3>
                <p>Rackets, shoes, and equipment used by the pros</p>
              </a>
            </div>
          </section>

        </main>

        <!-- ========== SIDEBAR ========== -->
        <aside class="sb">

          <!-- 1. FEATURED PLAYER -->
          <div class="sb-profile">
            <div class="sb-profile__header">
              <span class="sb-profile__label">Featured Player</span>
              <a href="/players/" class="sb-link">View all &rarr;</a>
            </div>
            <a href={`/players/${sidebarPlayer.slug}/`} class="sb-profile__card">
              <div class="sb-profile__img">
                {sidebarPlayer.image_url && (
                  <img src={sidebarPlayer.image_url} alt={`${sidebarPlayer.first_name} ${sidebarPlayer.last_name}`} loading="lazy" decoding="async" width="320" height="160" />
                )}
                <div class="sb-profile__name">
                  {getFlagUrl(sidebarPlayer.country_code) ? (
                    <img src={getFlagUrl(sidebarPlayer.country_code, 40)} alt={sidebarPlayer.country_code} class="sb-flag" width="20" height="15" loading="lazy" decoding="async" />
                  ) : null}
                  {sidebarPlayer.first_name} {sidebarPlayer.last_name}
                </div>
              </div>
              <div class="sb-profile__stats">
                <div class="sb-profile__row"><span>Grand Slams</span><span>{sidebarPlayer.grand_slam_titles || 0}</span></div>
                <div class="sb-profile__row"><span>Career Titles</span><span>{sidebarPlayer.career_titles || 0}</span></div>
              </div>
            </a>
          </div>

          <!-- WATCH TENNIS — loaded client-side -->
          <div class="sb-block" data-dynamic="sidebar-videos" data-slots="2,3"></div>

          <!-- NEWS — loaded client-side -->
          <div class="sb-block" data-dynamic="sidebar-news" data-limit="2"></div>

          <!-- 4. EXPLORE ARTICLES -->
          {sidebarArticles.length > 0 && (
            <div class="sb-articles">
              <div class="sb-articles__header">
                <span class="sb-articles__label">Explore</span>
              </div>
              <div class="sb-articles__list">
                {sidebarArticles.map((art: any) => (
