<script>
  // Search functionality
  const searchInput = document.getElementById('recordSearch');
  if (searchInput) {
    searchInput.addEventListener('keyup', (e) => {
      if (e.key === 'Enter') {
        const query = searchInput.value.trim();
        const url = new URL(window.location);
        if (query) {
          url.searchParams.set('q', query);
        } else {
          url.searchParams.delete('q');
        }
        window.history.replaceState({}, '', url);
        window.location.href = url.toString();
      }
    });
  }

  // ----- Filter Tabs (client-side) -----
  // Classify article based on data-category, hide cards that don't match
  function classifyText(text) {
    const t = text.toLowerCase();
    if (/grand-slam|slam|wimbledon|roland|french-open|australian-open|us-open/.test(t)) return 'slams';
    if (/ranking|no-1|number-one|year-end|weeks-at|world-no/.test(t)) return 'rankings';
    if (/serve|ace|fastest|longest-match|tiebreak/.test(t)) return 'serves';
    if (/streak|consecutive|winning|undefeated|surface/.test(t)) return 'streaks';
    return 'career';
  }

  let activeFilter = 'all';
  const filterTabs = document.querySelectorAll('.filter-tab');
  const articlesGrid = document.getElementById('articlesGrid');

  function applyFilter() {
    if (!articlesGrid) return;
    let visibleCount = 0;
    articlesGrid.querySelectorAll('.article-card').forEach(card => {
      const cat = card.dataset.category || 'career';
      if (activeFilter === 'all' || cat === activeFilter) {
        card.classList.remove('is-hidden');
        visibleCount++;
      } else {
        card.classList.add('is-hidden');
      }
    });
    // Show empty state if no matches
    let empty = articlesGrid.querySelector('.articles-empty');
    if (visibleCount === 0) {
      if (!empty) {
        empty = document.createElement('div');
        empty.className = 'articles-empty';
        empty.textContent = 'No articles in this category yet. Try another filter.';
        articlesGrid.appendChild(empty);
      }
    } else if (empty) {
      empty.remove();
    }
  }

  filterTabs.forEach(tab => {
    tab.addEventListener('click', () => {
      filterTabs.forEach(t => {
        t.classList.remove('active');
        t.setAttribute('aria-selected', 'false');
      });
      tab.classList.add('active');
      tab.setAttribute('aria-selected', 'true');
      activeFilter = tab.dataset.filter || 'all';
      applyFilter();
    });
  });

  // ----- Load More -----
  const loadMoreBtn = document.getElementById('recordsLoadMoreBtn');
  if (loadMoreBtn) {
    loadMoreBtn.addEventListener('click', async () => {
      const offset = parseInt(loadMoreBtn.dataset.offset || '12');
      const total = parseInt(loadMoreBtn.dataset.total || '0');
      const query = searchInput?.value || '';

      try {
        const params = new URLSearchParams();
        params.set('offset', offset.toString());
        if (query) params.set('q', query);

        const response = await fetch(`/api/records-articles?${params}`);
        const articles = await response.json();

        if (Array.isArray(articles) && articles.length > 0 && articlesGrid) {
          const subcatLabels = {
            slams: { icon: '🏆', label: 'Grand Slams' },
            rankings: { icon: '📊', label: 'Rankings' },
            serves: { icon: '⚡', label: 'Serves & Match' },
            streaks: { icon: '🔥', label: 'Streaks' },
            career: { icon: '👑', label: 'Career' },
          };
          // Same image diversifier as server-side: avoid 27x tennis-court-aerial duplicates
          const IMG_POOL = {
            slams: ['/images/records/tennis-trophy-gold.webp', '/images/records/tennis-court-aerial.webp', '/images/records/titles-single-year.webp', '/images/records/bagels-dominant.webp'],
            rankings: ['/images/records/tennis-court-aerial.webp', '/images/records/tennis-trophy-gold.webp', '/images/records/titles-single-year.webp'],
            serves: ['/images/records/fastest-serve.webp', '/images/records/fastest-serves.webp', '/images/records/most-aces.webp', '/images/records/tennis-aces.webp', '/images/records/double-faults.webp', '/images/records/longest-match.webp', '/images/records/longest-matches.webp'],
            streaks: ['/images/records/tennis-court-aerial.webp', '/images/records/tennis-trophy-gold.webp', '/images/records/titles-single-year.webp', '/images/records/bagels-record.webp'],
            career: ['/images/records/tennis-trophy-gold.webp', '/images/records/prize-money-record.webp', '/images/records/prize-money-check.webp', '/images/records/titles-single-year.webp', '/images/records/bagels-record.webp', '/images/records/tennis-court-aerial.webp'],
          };
          const GENERIC_IMGS = new Set(['/images/records/tennis-court-aerial.webp', '/images/records/tennis-trophy-gold.webp']);
          function hashStr(s) {
            let h = 0;
            for (let i = 0; i < s.length; i++) h = ((h << 5) - h + s.charCodeAt(i)) | 0;
            return Math.abs(h);
          }
          function diversifyImage(art, subcat) {
            if (art.image_url && !GENERIC_IMGS.has(art.image_url)) return art.image_url;
            const pool = IMG_POOL[subcat] || IMG_POOL.career;
            return pool[hashStr(art.slug) % pool.length];
          }

          articles.forEach(article => {
            const subcategory = classifyText(article.title + ' ' + article.slug);
            const meta = subcatLabels[subcategory] || subcatLabels.career;
            const img = diversifyImage(article, subcategory);
            const link = document.createElement('a');
            link.href = `/records/${article.slug}/`;
            link.className = 'article-card';
            link.dataset.category = subcategory;
            if (activeFilter !== 'all' && activeFilter !== subcategory) {
              link.classList.add('is-hidden');
            }
            link.innerHTML = `
              <div class="article-card__img">
                <img src="${img}" alt="${article.title}" loading="lazy" decoding="async" width="400" height="225" onerror="this.src='/images/records/tennis-trophy-gold.webp'" />
                <span class="article-card__badge">${meta.icon} ${meta.label}</span>
              </div>
              <div class="article-card__body">
                <h3>${article.title}</h3>
                <p>${article.excerpt || ''}</p>
                <span class="article-card__cta">Read more &rarr;</span>
              </div>
            `;
            articlesGrid.appendChild(link);
          });

          const newOffset = offset + articles.length;
          const newRemaining = total - newOffset;

          if (newRemaining <= 0) {
            loadMoreBtn.style.display = 'none';
          } else {
            loadMoreBtn.dataset.offset = newOffset.toString();
            loadMoreBtn.textContent = `Load more articles (${newRemaining} remaining)`;
          }
        }
      } catch (error) {
        console.error('Error loading more articles:', error);
      }
    });
  }
</script>

