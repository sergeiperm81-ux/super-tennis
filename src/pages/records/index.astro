// ========== ARTICLE SUBCATEGORY FILTERING ==========
// Auto-classify articles into 5 subgroups based on title/slug keywords
function classifyArticle(art: { title: string; slug: string }): string {
  const text = (art.title + ' ' + art.slug).toLowerCase();
  if (/grand-slam|slam|wimbledon|roland|french-open|australian-open|us-open/.test(text)) return 'slams';
  if (/ranking|no-1|number-one|year-end|weeks-at|world-no/.test(text)) return 'rankings';
  if (/serve|ace|fastest|longest-match|tiebreak/.test(text)) return 'serves';
  if (/streak|consecutive|winning|undefeated|surface/.test(text)) return 'streaks';
  return 'career'; // default: career titles, prize money, longevity, etc.
}

const articleFilterTabs = [
  { id: 'all', label: 'All', icon: '📚' },
  { id: 'slams', label: 'Grand Slams', icon: '🏆' },
  { id: 'rankings', label: 'Rankings', icon: '📊' },
  { id: 'serves', label: 'Serves & Match', icon: '⚡' },
  { id: 'streaks', label: 'Streaks', icon: '🔥' },
  { id: 'career', label: 'Career', icon: '👑' },
];

// Build article slug set for cross-linking record cards to deep-dive articles
const articleSlugSet = new Set(recordArticles.map((a: any) => a.slug));
function findRecordArticle(record: { articleSlug?: string }): string | null {
  if (record.articleSlug && articleSlugSet.has(record.articleSlug)) {
    return `/records/${record.articleSlug}/`;
  }
  return null;
}

// ========== IMAGE DIVERSIFIER ==========
// Most articles in DB use one of two generic images (court-aerial 27x, trophy-gold 17x).
// We override those with deterministic slug-hashed picks from a per-subcategory pool
// so the grid doesn't show 30+ identical thumbnails.
const RECORD_IMAGE_POOL: Record<string, string[]> = {
  slams: [
    '/images/records/tennis-trophy-gold.webp',
    '/images/records/tennis-court-aerial.webp',
    '/images/records/titles-single-year.webp',
    '/images/records/bagels-dominant.webp',
  ],
  rankings: [
    '/images/records/tennis-court-aerial.webp',
    '/images/records/tennis-trophy-gold.webp',
    '/images/records/titles-single-year.webp',
  ],
  serves: [
    '/images/records/fastest-serve.webp',
    '/images/records/fastest-serves.webp',
    '/images/records/most-aces.webp',
    '/images/records/tennis-aces.webp',
    '/images/records/double-faults.webp',
    '/images/records/longest-match.webp',
    '/images/records/longest-matches.webp',
  ],
  streaks: [
    '/images/records/tennis-court-aerial.webp',
    '/images/records/tennis-trophy-gold.webp',
    '/images/records/titles-single-year.webp',
    '/images/records/bagels-record.webp',
  ],
  career: [
    '/images/records/tennis-trophy-gold.webp',
    '/images/records/prize-money-record.webp',
    '/images/records/prize-money-check.webp',
    '/images/records/titles-single-year.webp',
    '/images/records/bagels-record.webp',
    '/images/records/tennis-court-aerial.webp',
  ],
};

const GENERIC_IMAGES = new Set([
  '/images/records/tennis-court-aerial.webp',
  '/images/records/tennis-trophy-gold.webp',
]);

function hashSlug(slug: string): number {
  let h = 0;
  for (let i = 0; i < slug.length; i++) {
    h = ((h << 5) - h + slug.charCodeAt(i)) | 0;
  }
  return Math.abs(h);
}

function pickRecordImage(article: { slug: string; image_url?: string }, subcategory: string): string {
  // If DB has a specific (non-generic) image, keep it
  if (article.image_url && !GENERIC_IMAGES.has(article.image_url)) {
    return article.image_url;
  }
  // Otherwise diversify using hash-based pick from the subcategory pool
  const pool = RECORD_IMAGE_POOL[subcategory] || RECORD_IMAGE_POOL.career;
  return pool[hashSlug(article.slug) % pool.length];
}
---

<BaseLayout
  title="Tennis Records — All-Time Stats & Achievements"
  description="Complete list of tennis records. Grand Slam records, ranking milestones, serve speed records, and all-time achievements in men's and women's tennis."
  ogImage="/og/records.png"
  dynamicContent={true}
>
  <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />

  <div class="records-page">
    <div class="container">
      <nav class="breadcrumbs"><a href="/">Home</a> <span class="sep">/</span> <span class="current">Records</span></nav>
      <section class="page-hero">
        <h1>Tennis Records</h1>
        <p class="subtitle">The greatest achievements and milestones in tennis history</p>
      </section>

      <!-- Records Hero Banner -->
      <div class="records-hero">
        <img src="/images/records/tennis-trophy-gold.webp" alt="Tennis championship trophy" class="records-hero-img" loading="eager" decoding="async" width="1200" height="400" onerror="this.parentElement.style.display='none'" />
        <div class="records-hero-overlay">
          <div class="records-hero-stat">
            <span class="hero-stat-value">24</span>
            <span class="hero-stat-label">Grand Slam titles — the men's all-time record held by Novak Djokovic</span>
          </div>
        </div>
      </div>

      <!-- TWO-COLUMN LAYOUT -->
      <div class="records-layout">

        <!-- ========== MAIN CONTENT ========== -->
        <main class="records-main">

          <!-- Quick Nav -->
          <nav class="category-nav">
            {records.map(cat => (
              <a href={`#${cat.category.toLowerCase().replace(/\s+/g, '-')}`} class="cat-link">
                <span class="cat-icon">{cat.icon}</span>
                {cat.category}
              </a>
            ))}
            {mostTitlesATP.length > 0 && (
              <a href="#career-titles-leaderboard" class="cat-link live-data">
                <span class="cat-icon">👑</span>
                Titles Leaderboard
              </a>
            )}
            {mostGrandSlams.length > 0 && (
              <a href="#grand-slam-leaderboard" class="cat-link live-data">
                <span class="cat-icon">🏆</span>
                GS Leaders
              </a>
            )}
            {highestWinPct.length > 0 && (
              <a href="#win-percentage-leaderboard" class="cat-link live-data">
                <span class="cat-icon">📈</span>
                Win %
              </a>
            )}
          </nav>

          <!-- Records Sections (with photo banners between them) -->
          {records.map((cat, catIdx) => (
            <>
              {catIdx > 0 && sectionPhotos[catIdx - 1] && (
                <div class="section-photo-break">
                  <img src={sectionPhotos[catIdx - 1].image} alt={sectionPhotos[catIdx - 1].caption} loading="lazy" decoding="async" width="800" height="300" />
                  <div class="section-photo-caption">{sectionPhotos[catIdx - 1].caption}</div>
                </div>
              )}
              <section class="records-section" id={cat.category.toLowerCase().replace(/\s+/g, '-')}>
                <h2>
                  <span class="section-icon">{cat.icon}</span>
                  {cat.category}
                </h2>

                <div class="records-list">
                  {cat.items.map((rec, i) => {
                    const recArticleUrl = findRecordArticle(rec);
                    return (
                      <div class="record-card">
                        <div class="record-rank">#{i + 1}</div>
                        <div class="record-content">
                          <h3>
                            {recArticleUrl ? (
                              <a href={recArticleUrl} class="record-title-link">{rec.title} <span class="record-arrow">&rarr;</span></a>
                            ) : (
                              rec.title
                            )}
                          </h3>
                          <div class="record-holder">
                            {rec.slug ? (
                              <a href={`/players/${rec.slug}/`} class="holder-link">{rec.holder}</a>
                            ) : (
                              <span class="holder-name">{rec.holder}</span>
                            )}
                          </div>
                          <p class="record-detail">{rec.detail}</p>
                        </div>
                        <div class="record-value">{rec.value}</div>
                      </div>
                    );
                  })}
                </div>
              </section>
            </>
          ))}

          <!-- Deep Dive Articles — moved above leaderboards for visibility -->
          {recordArticles.length > 0 && (
            <section class="records-section" id="deep-dive">
              <div class="articles-header">
                <h2>
                  <span class="section-icon">📖</span>
                  Deep Dive Articles
                  <span class="articles-count">({filteredRecordArticles.length})</span>
                </h2>
                <div class="search-box">
                  <input
                    type="text"
                    id="recordSearch"
                    placeholder="Search articles..."
                    value={searchQuery}
                    class="search-input"
                  />
                </div>
              </div>

              <!-- Filter Tabs -->
              <div class="article-filters" role="tablist" aria-label="Filter articles by topic">
                {articleFilterTabs.map(tab => (
                  <button
                    type="button"
                    class={`filter-tab ${tab.id === 'all' ? 'active' : ''}`}
                    data-filter={tab.id}
                    role="tab"
                    aria-selected={tab.id === 'all' ? 'true' : 'false'}
                  >
                    <span class="filter-icon">{tab.icon}</span>
                    {tab.label}
                  </button>
                ))}
              </div>

              <!-- Article Grid -->
              <div class="articles-grid" id="articlesGrid">
                {displayedRecordArticles.map((art: any) => {
                  const subcategory = classifyArticle(art);
                  const img = pickRecordImage(art, subcategory);
                  return (
                    <a
                      href={`/records/${art.slug}/`}
                      class="article-card"
                      data-category={subcategory}
                    >
