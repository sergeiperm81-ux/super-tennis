---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LiteYouTube from '../../components/LiteYouTube.astro';
import { getLeaderboard, getArticles, getPlayerBySlug } from '../../lib/supabase';
import { countryFlags, fallbackPlayers, getFlagUrl, stripMarkdown } from '../../lib/fallback-data';

// Dynamic leaderboards from Supabase
let mostTitlesATP: any[] = [];
let mostTitlesWTA: any[] = [];
let mostGrandSlams: any[] = [];
let highestWinPct: any[] = [];

try {
  [mostTitlesATP, mostTitlesWTA, mostGrandSlams] = await Promise.all([
    getLeaderboard('career_titles', 'atp', 10),
    getLeaderboard('career_titles', 'wta', 10),
    getLeaderboard('grand_slam_titles', null, 10),
  ]);

  // For win percentage, we need to compute it client-side from the titles leaders
  const allPlayers = await getLeaderboard('career_win', null, 50);
  highestWinPct = allPlayers
    .filter((p: any) => (p.career_win + p.career_loss) >= 200) // Minimum 200 matches
    .map((p: any) => ({
      ...p,
      win_pct: ((p.career_win / (p.career_win + p.career_loss)) * 100).toFixed(1),
    }))
    .sort((a: any, b: any) => parseFloat(b.win_pct) - parseFloat(a.win_pct))
    .slice(0, 10);
} catch (e) {
  console.warn('Records: Supabase unavailable, using static data only');
}

// Fetch record articles from Supabase
let recordArticles: any[] = [];
try {
  recordArticles = await getArticles({ category: 'records', limit: 100 });
} catch (e) {}

// Filter record articles by search query and subcategory
const url = new URL(Astro.request.url);
const searchQuery = url.searchParams.get('q') || '';
let filteredRecordArticles = recordArticles;

if (searchQuery) {
  const query = searchQuery.toLowerCase();
  filteredRecordArticles = filteredRecordArticles.filter(a =>
    a.title.toLowerCase().includes(query) ||
    (a.excerpt || '').toLowerCase().includes(query)
  );
}

// Display first 12 articles, rest loaded via Load More
const displayedRecordArticles = filteredRecordArticles.slice(0, 12);
const remainingCount = filteredRecordArticles.length - 12;

// Section break photos (between record categories)
const sectionPhotos: { image: string; caption: string; credit: string }[] = [
  { image: '/images/tournaments/wimbledon.webp', caption: 'The All England Club — where history is made', credit: '' },
  { image: '/images/records/tennis-court-aerial.webp', caption: 'The path to No. 1 starts here', credit: '' },
  { image: '/images/tournaments/roland-garros.webp', caption: 'Roland Garros — the ultimate test of endurance', credit: '' },
];

// Curated records data (editorial, not in database).
// articleSlug links the card to a deep-dive article in the records category.
// If the article doesn't exist in Supabase, the link is silently dropped.
const records = [
  {
    category: 'Grand Slam Records',
    icon: '🏆',
    items: [
      { title: 'Most Grand Slam Titles (Men\'s Singles)', holder: 'Novak Djokovic', value: '24', slug: 'novak-djokovic', detail: 'Australian Open (10), Roland Garros (3), Wimbledon (7), US Open (4)', articleSlug: 'most-grand-slam-titles-mens' },
      { title: 'Most Grand Slam Titles (Women\'s Singles)', holder: 'Margaret Court', value: '24', slug: null, detail: 'Australian Open (11), Roland Garros (5), Wimbledon (3), US Open (5)', articleSlug: 'most-grand-slam-titles-womens' },
      { title: 'Most Grand Slam Titles (Open Era, Women\'s)', holder: 'Serena Williams', value: '23', slug: null, detail: 'Australian Open (7), Roland Garros (3), Wimbledon (7), US Open (6)', articleSlug: 'serena-williams-grand-slam-record' },
      { title: 'Most Consecutive Grand Slam Titles', holder: 'Novak Djokovic', value: '4', slug: 'novak-djokovic', detail: '2015-16: Wimbledon, US Open, Australian Open, Roland Garros', articleSlug: 'most-consecutive-grand-slam-titles' },
      { title: 'Youngest Grand Slam Champion (Men\'s)', holder: 'Michael Chang', value: '17y 3m', slug: null, detail: '1989 Roland Garros', articleSlug: 'youngest-grand-slam-champions' },
      { title: 'Youngest Grand Slam Champion (Women\'s)', holder: 'Martina Hingis', value: '16y 3m', slug: null, detail: '1997 Australian Open', articleSlug: 'youngest-grand-slam-champions' },
    ]
  },
  {
    category: 'Ranking Records',
    icon: '📊',
    items: [
      { title: 'Most Weeks at No. 1 (Men\'s)', holder: 'Novak Djokovic', value: '428', slug: 'novak-djokovic', detail: 'Surpassed Roger Federer\'s 310 weeks in March 2023', articleSlug: 'most-weeks-at-number-one' },
      { title: 'Most Weeks at No. 1 (Women\'s)', holder: 'Steffi Graf', value: '377', slug: null, detail: 'Held the record since 1997', articleSlug: 'most-weeks-at-number-one' },
      { title: 'Youngest No. 1 (Men\'s)', holder: 'Carlos Alcaraz', value: '19y 4m', slug: 'carlos-alcaraz', detail: 'September 12, 2022 after winning US Open', articleSlug: 'youngest-world-number-one' },
      { title: 'Youngest No. 1 (Women\'s)', holder: 'Martina Hingis', value: '16y 6m', slug: null, detail: 'March 31, 1997', articleSlug: 'youngest-world-number-one' },
      { title: 'Most Year-End No. 1 (Men\'s)', holder: 'Novak Djokovic', value: '8', slug: 'novak-djokovic', detail: '2011, 2012, 2014, 2015, 2018, 2020, 2021, 2023', articleSlug: 'year-end-number-one-records' },
      { title: 'Most Year-End No. 1 (Women\'s)', holder: 'Steffi Graf', value: '8', slug: null, detail: '1987, 1988, 1989, 1990, 1993, 1995, 1996', articleSlug: 'year-end-number-one-records' },
    ]
  },
  {
    category: 'Match & Serve Records',
    icon: '⚡',
    items: [
      { title: 'Fastest Serve Ever Recorded', holder: 'Sam Groth', value: '263.4 km/h', slug: null, detail: '2012 Busan Challenger (not ATP-recognized)', articleSlug: 'fastest-tennis-serves-ever' },
      { title: 'Fastest Serve (ATP Recognized)', holder: 'John Isner', value: '253.0 km/h', slug: null, detail: '2016 Davis Cup', articleSlug: 'fastest-tennis-serves-ever' },
      { title: 'Longest Match in History', holder: 'Isner vs. Mahut', value: '11h 5m', slug: null, detail: '2010 Wimbledon, final score 70-68 in 5th set', articleSlug: 'longest-tennis-match-in-history' },
      { title: 'Most Career Titles (Men\'s Open Era)', holder: 'Jimmy Connors', value: '109', slug: null, detail: 'All-time men\'s record. Roger Federer (103) and Novak Djokovic (99+) follow', articleSlug: 'most-career-titles-mens' },
      { title: 'Most Career Titles (Women\'s Open Era)', holder: 'Martina Navratilova', value: '167', slug: null, detail: 'Including 59 Grand Slam titles (singles + doubles)', articleSlug: 'most-career-titles-womens' },
      { title: 'Most Career Prize Money (Men\'s)', holder: 'Novak Djokovic', value: '$185M+', slug: 'novak-djokovic', detail: 'First player to earn over $180 million in prize money', articleSlug: 'highest-tennis-prize-money-earners' },
    ]
  },
  {
    category: 'Surface Records',
    icon: '🎾',
    items: [
      { title: 'Most Roland Garros Titles (Men\'s)', holder: 'Rafael Nadal', value: '14', slug: null, detail: 'Won between 2005-2022, lost only 4 matches total', articleSlug: 'rafael-nadal-roland-garros-record' },
      { title: 'Most Wimbledon Titles (Men\'s)', holder: 'Roger Federer', value: '8', slug: null, detail: 'Won between 2003-2017, including 5 consecutive (2003-07)', articleSlug: 'most-wimbledon-titles-mens' },
      { title: 'Most Australian Open Titles (Men\'s)', holder: 'Novak Djokovic', value: '10', slug: 'novak-djokovic', detail: '2008, 2011, 2012, 2013, 2015, 2016, 2019, 2020, 2023', articleSlug: 'most-australian-open-titles' },
      { title: 'Most US Open Titles (Open Era, Men\'s)', holder: 'Jimmy Connors / Pete Sampras / Roger Federer', value: '5', slug: null, detail: 'Tied record among three legends', articleSlug: 'most-us-open-titles-mens' },
      { title: 'Longest Winning Streak on Clay', holder: 'Rafael Nadal', value: '81 matches', slug: null, detail: 'April 2005 to May 2007', articleSlug: 'longest-winning-streaks-tennis' },
      { title: 'Longest Winning Streak on Grass', holder: 'Roger Federer', value: '65 matches', slug: null, detail: '2003 to 2008', articleSlug: 'longest-winning-streaks-tennis' },
    ]
  },
];

// ========== SIDEBAR DATA ==========

// 1. Featured player (Djokovic for records page — the GOAT of records)
let sidebarPlayer: any = null;
try {
  sidebarPlayer = await getPlayerBySlug('novak-djokovic');
} catch {}
if (!sidebarPlayer) {
  sidebarPlayer = fallbackPlayers['novak-djokovic'] || {
    first_name: 'Novak', last_name: 'Djokovic', country_code: 'SRB',
    career_titles: 99, grand_slam_titles: 24, slug: 'novak-djokovic', image_url: '',
  };
}

// News and videos are loaded client-side via dynamic-content.js

// 4. Explore articles — 4 random from players and vs categories
let sidebarArticles: any[] = [];
try {
  const [playersArts, vsArts] = await Promise.all([
    getArticles({ category: 'players', limit: 6 }),
    getArticles({ category: 'vs', limit: 6 }),
  ]);
  const combined = [...playersArts, ...vsArts].filter(a => a.title);
  // Shuffle
  for (let i = combined.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [combined[i], combined[j]] = [combined[j], combined[i]];
  }
  sidebarArticles = combined.slice(0, 4);
} catch {}

// Article URL helpers
const categoryUrl: Record<string, string> = {
  players: '/players/', records: '/records/', gear: '/gear/',
  lifestyle: '/lifestyle/', tournaments: '/tournaments/', vs: '/vs/',
};
function articleUrl(art: { category: string; slug: string }): string {
  if (art.category === 'players') {
    const subPageSuffixes = ['-racket', '-net-worth', '-stats', '-grand-slams', '-career-timeline', '-partner', '-age'];
    const baseSlug = subPageSuffixes.reduce((s, sfx) => s.endsWith(sfx) ? s.slice(0, -sfx.length) : s, art.slug);
    return `/players/${baseSlug}/`;
  }
  return `${categoryUrl[art.category] || '/'}${art.slug}/`;
}
const sbCatColors: Record<string, string> = {
  players: '#4CAF50', records: '#FF9800', gear: '#2196F3',
  lifestyle: '#E91E63', tournaments: '#00BCD4', vs: '#FF5722',
};
const sbCatLabels: Record<string, string> = {
  players: 'Players', records: 'Records', gear: 'Gear',
  lifestyle: 'Lifestyle', tournaments: 'Tournaments', vs: 'H2H',
};

// News category colors
const newsCatColors: Record<string, string> = {
  buzz: '#16a34a', scandal: '#dc2626', business: '#d4a017',
  fashion: '#ec4899', funny: '#f97316', wellness: '#0891b2',
};
const newsCatLabels: Record<string, string> = {
  buzz: 'Buzz', scandal: 'Scandal', business: 'Business',
  fashion: 'Fashion', funny: 'LOL', wellness: 'Wellness',
};

// ========== FAQ SCHEMA — for Google "People Also Ask" + AI citations ==========
const faqJsonLd = {
