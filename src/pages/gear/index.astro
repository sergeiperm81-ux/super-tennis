---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getArticles } from '../../lib/supabase';
import { stripMarkdown } from '../../lib/fallback-data';
import { getArticlePhotosForCategory } from '../../lib/player-photos';

// Get URL search params
const url = new URL(Astro.request.url);
const filterSubcat = url.searchParams.get('type') || 'all';
const searchQuery = url.searchParams.get('q') || '';

// Fetch real gear articles from Supabase
let gearArticles: any[] = [];
try {
  gearArticles = await getArticles({ category: 'gear', limit: 100 });
} catch (e) {
  console.warn('Gear index: Supabase unavailable');
}

// Filter by subcategory
let filteredArticles = gearArticles;
if (filterSubcat !== 'all') {
  filteredArticles = gearArticles.filter(a => (a.subcategory || 'guides') === filterSubcat);
}

// Filter by search
if (searchQuery) {
  const query = searchQuery.toLowerCase();
  filteredArticles = filteredArticles.filter(a =>
    a.title.toLowerCase().includes(query) ||
    (a.excerpt || '').toLowerCase().includes(query)
  );
}

// Batch-fetch all article photos (player photos + local)
const articlePhotos = await getArticlePhotosForCategory(filteredArticles, 'gear');

// Pagination: first 12 in grid
const gridArticles = filteredArticles.slice(0, 12);
const totalArticles = filteredArticles.length;
const hasMore = totalArticles > 12;

// Category grouping
function getCategory(slug: string): string {
  if (slug.includes('racket') || slug.includes('head-vs-wilson') || slug.includes('junior')) return 'Rackets';
  if (slug.includes('string') || slug.includes('gut') || slug.includes('tension')) return 'Strings';
  if (slug.includes('shoe') || slug.includes('apparel')) return 'Clothing & Shoes';
  if (slug.includes('ball-machine')) return 'Equipment';
  if (slug.includes('court') || slug.includes('surface')) return 'Courts';
  return 'Accessories';
}

function getCategoryColor(slug: string): string {
  const cat = getCategory(slug);
  if (cat === 'Rackets') return '#16a34a';
  if (cat === 'Strings') return '#2563eb';
  if (cat === 'Clothing & Shoes') return '#d97706';
  if (cat === 'Equipment') return '#dc2626';
  if (cat === 'Courts') return '#059669';
  return '#7c3aed';
}

// Icon mapping
const iconMap: Record<string, string> = {
  'best-tennis-rackets-2026': '🎾',
  'best-tennis-strings-guide': '🔧',
  'best-tennis-shoes-2026': '👟',
  'best-tennis-bags-2026': '🎒',
  'best-tennis-overgrips': '🤲',
  'head-vs-wilson-vs-babolat': '⚔️',
  'best-tennis-balls-2026': '🟡',
  'best-tennis-dampeners': '🔇',
  'tennis-racket-weight-guide': '⚖️',
  'best-tennis-sunglasses': '🕶️',
  'tennis-court-surfaces-equipment': '🏟️',
  'best-tennis-gadgets-tech': '📱',
  'best-junior-tennis-rackets': '👶',
  'natural-gut-vs-synthetic-strings': '🧵',
  'tennis-apparel-brands-2026': '👕',
};

// ItemList JSON-LD for first 10 articles
const itemListJsonLd = gearArticles.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  itemListElement: gearArticles.slice(0, 10).map((article, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: article.title,
    url: `https://super.tennis/gear/${article.slug}/`,
  })),
} : null;

// FAQ data for gear page
const gearFaqItems = [
  {
    q: 'What tennis racket should a beginner use?',
    a: 'Beginners should look for a lightweight racket weighing 260-280 grams (9.2-9.9 oz) with a large head size of 100-110 square inches. A larger head provides a bigger sweet spot, making it more forgiving on off-center hits. Pre-strung rackets from brands like Wilson, Head, or Babolat in the $50-$120 range are excellent starting points.',
  },
  {
    q: 'How often should you restring a tennis racket?',
    a: 'As a general rule, you should restring your racket every 40-50 hours of play, or at least twice a year even if you play infrequently. Strings lose tension and elasticity over time, which reduces control and power. Frequent players (3+ times per week) may need to restring monthly. A common guideline is to restring as many times per year as you play per week.',
  },
  {
    q: 'What are the best tennis shoes for clay courts?',
    a: 'The best clay court tennis shoes feature a herringbone outsole pattern, which provides excellent traction on the loose surface while still allowing controlled sliding. Look for shoes with durable outsoles designed to resist the abrasive clay surface. Top options include models from Nike, Asics, and Adidas specifically designed for clay, often labeled with "Clay" or "CLY" in the model name.',
  },
];

const gearFaqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: gearFaqItems.map(item => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.a,
    },
  })),
};
---

<BaseLayout
  title="Tennis Gear — Rackets, Shoes & Equipment Reviews"
  description="Expert tennis gear reviews and guides. Find the best rackets, shoes, strings, and equipment for your game. Pro player setups and recommendations."
  ogImage="/og/gear.png"
>
  {itemListJsonLd && <script type="application/ld+json" set:html={JSON.stringify(itemListJsonLd)} />}
  <script type="application/ld+json" set:html={JSON.stringify(gearFaqJsonLd)} />
  <div class="gear-page">
    <div class="container">
      <nav class="breadcrumbs"><a href="/">Home</a> <span class="sep">/</span> <span class="current">Gear</span></nav>
      <section class="page-hero">
        <h1>Tennis Gear</h1>
        <p class="subtitle">Expert reviews, pro player setups, and buying guides for every level{gearArticles.length > 0 && ` — ${gearArticles.length} guides`}</p>
      </section>

      {/* Hero Banner */}
      <div class="gear-hero">
        <img src="/images/gear/tennis-rackets.jpg" alt="Tennis rackets and equipment" loading="eager" decoding="async" width="1200" height="400" onerror="this.parentElement.style.display='none'" />
        <div class="gear-hero-overlay">
          <h2>Find Your Perfect Setup</h2>
          <p>Rackets, strings, shoes, and accessories — reviewed by tennis experts</p>
        </div>
      </div>

      {/* Search & Filter Section */}
      <div class="filter-section">
        <input
          type="text"
          class="search-input"
          id="search-input"
          placeholder="🔍 Search gear guides..."
          value={searchQuery}
        />
      </div>

      {/* Category filters */}
      <div class="cat-filters" id="cat-filters">
        <a href="?type=all" class={`cat-btn ${filterSubcat === 'all' ? 'active' : ''}`} data-subcat="all">All</a>
        <a href="?type=rackets" class={`cat-btn ${filterSubcat === 'rackets' ? 'active' : ''}`} data-subcat="rackets" style="--cat-color: #dc2626">Rackets</a>
        <a href="?type=strings" class={`cat-btn ${filterSubcat === 'strings' ? 'active' : ''}`} data-subcat="strings" style="--cat-color: #2563eb">Strings</a>
        <a href="?type=shoes" class={`cat-btn ${filterSubcat === 'shoes' ? 'active' : ''}`} data-subcat="shoes" style="--cat-color: #059669">Shoes</a>
        <a href="?type=accessories" class={`cat-btn ${filterSubcat === 'accessories' ? 'active' : ''}`} data-subcat="accessories" style="--cat-color: #f97316">Accessories</a>
        <a href="?type=guides" class={`cat-btn ${filterSubcat === 'guides' ? 'active' : ''}`} data-subcat="guides" style="--cat-color: #7c3aed">Guides</a>
      </div>

      {filteredArticles.length === 0 ? (
        <div class="empty-state">
          <p>No guides found{searchQuery ? ` for "${searchQuery}"` : ''}{filterSubcat !== 'all' ? ` in this category` : ''}. Try a different search or category.</p>
        </div>
      ) : null}

      {gridArticles.length > 0 && (
        <div class="articles-grid" id="articles-grid">
          {gridArticles.map((article) => (
            <a href={`/gear/${article.slug}/`} class="gear-card">
              {articlePhotos.get(article.slug) ? (
                <div class="gear-card-img">
                  <img src={articlePhotos.get(article.slug)!} alt={article.title} loading="lazy" decoding="async" width="400" height="267" onerror="this.parentElement.classList.add('no-img')" />
                </div>
              ) : (
                <div class="gear-card-icon">🎾</div>
              )}
              <div class="card-content">
                <span class="card-category">{article.subcategory || 'Guides'}</span>
                <h2>{article.title}</h2>
                <p>{stripMarkdown(article.excerpt || article.meta_description || '')}</p>
                <span class="read-more">Read Guide →</span>
              </div>
            </a>
          ))}
        </div>
      )}

      {hasMore && (
        <div class="load-more-section">
          <button class="load-more-btn" id="load-more-btn">
            Load More ({totalArticles - 12} more)
          </button>
        </div>
      )}

      <!-- FAQ Section -->
      <section class="faq-section">
        <h2>Frequently Asked Questions</h2>
        <div class="faq-list">
          {gearFaqItems.map(item => (
            <details class="faq-item">
              <summary class="faq-question">{item.q}</summary>
              <p class="faq-answer">{item.a}</p>
            </details>
          ))}
        </div>
      </section>

      <section class="related-section">
        <h2>Pro Player Equipment</h2>
        <p>See what rackets, strings, and shoes your favorite pros use</p>
        <div class="cta-links">
          <a href="/players/">Browse Players →</a>
          <a href="/rankings/">View Rankings →</a>
          <a href="/records/">Tennis Records →</a>
        </div>
      </section>
    </div>
  </div>

  <script is:inline>
    // Search functionality
    const searchInput = document.getElementById('search-input');
    if (searchInput) {
      searchInput.addEventListener('keyup', function(e) {
        if (e.key === 'Enter') {
          const query = this.value.trim();
          const type = new URLSearchParams(window.location.search).get('type') || 'all';
          if (query) {
            window.location.href = `?type=${type}&q=${encodeURIComponent(query)}`;
          } else {
            window.location.href = `?type=${type}`;
          }
        }
      });
    }

    // Load More functionality
    const loadMoreBtn = document.getElementById('load-more-btn');
    if (loadMoreBtn) {
      loadMoreBtn.addEventListener('click', async function() {
        const currentType = new URLSearchParams(window.location.search).get('type') || 'all';
        const currentQ = new URLSearchParams(window.location.search).get('q') || '';

        try {
          const response = await fetch(`/api/gear-articles?type=${currentType}${currentQ ? `&q=${encodeURIComponent(currentQ)}` : ''}`);
          const articles = await response.json();

          const articlesGrid = document.getElementById('articles-grid');
          const currentCount = articlesGrid.querySelectorAll('.gear-card').length;

          // Append next 12 articles
          articles.slice(currentCount, currentCount + 12).forEach(article => {
            const card = createGearCard(article);
            articlesGrid.appendChild(card);
          });

          // Hide Load More if no more articles
          if (currentCount + 12 >= articles.length) {
            loadMoreBtn.parentElement.style.display = 'none';
          } else {
            loadMoreBtn.textContent = `Load More (${articles.length - currentCount - 12} more)`;
          }
        } catch (error) {
          console.error('Failed to load more guides:', error);
        }
      });
    }

    function createGearCard(article) {
      const a = document.createElement('a');
      a.href = `/gear/${article.slug}/`;
      a.className = 'gear-card';
      a.innerHTML = `
        <div class="gear-card-img">
          ${article.photo ? `<img src="${article.photo}" alt="${article.title}" loading="lazy" />` : '<div class="gear-card-icon">🎾</div>'}
        </div>
        <div class="card-content">
          <span class="card-category">${article.subcategory || 'Guides'}</span>
          <h2>${article.title}</h2>
          <p>${article.excerpt || ''}</p>
          <span class="read-more">Read Guide →</span>
        </div>
      `;
      return a;
    }
  </script>
</BaseLayout>

<style>
  .filter-section {
    margin-bottom: 24px;
  }

  .search-input {
    width: 100%;
    padding: 12px 16px;
    font-size: 0.95rem;
    border: 1px solid #d1d5db;
    border-radius: var(--radius);
    background: white;
    color: #111827;
    transition: all 0.2s;
  }
  .search-input:focus {
    outline: none;
    border-color: var(--court-green);
    box-shadow: 0 0 0 3px rgba(34, 197, 94, 0.1);
  }
  .search-input::placeholder {
    color: #9ca3af;
  }

  .cat-filters {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin-bottom: 28px;
    padding-bottom: 16px;
    border-bottom: 1px solid #e5e7eb;
  }
  .cat-btn {
    display: inline-block;
    padding: 6px 16px;
    border-radius: 20px;
    text-decoration: none;
    border: 1px solid #d1d5db;
    background: transparent;
    font-size: 0.85rem;
    font-weight: 600;
    cursor: pointer;
    color: #374151;
    transition: all 0.2s;
  }
  .cat-btn:hover {
    border-color: var(--cat-color, #6b7280);
    color: var(--cat-color, #6b7280);
  }
  .cat-btn.active {
    background: var(--cat-color, #111827);
    color: #fff;
    border-color: var(--cat-color, #111827);
  }
  .gear-page {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px 60px;
  }

  .page-hero {
    padding: 48px 0 32px;
    border-bottom: 3px solid var(--court-green);
    margin-bottom: 32px;
  }
  .page-hero h1 {
    font-family: var(--font-heading);
    font-size: 2.8rem;
    text-transform: uppercase;
    color: var(--gray-900);
    margin: 0;
  }
  .subtitle {
    color: var(--gray-600);
    font-size: 1.1rem;
    margin: 8px 0 0;
  }

  /* Gear Hero Banner */
  .gear-hero {
    position: relative;
    border-radius: var(--radius);
    overflow: hidden;
    margin-bottom: 32px;
    height: 180px;
  }
  .gear-hero img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .gear-hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(0,0,0,0.65) 0%, rgba(0,0,0,0.2) 100%);
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: center;
    padding: 32px;
  }
  .gear-hero-overlay h2 {
    color: white;
    font-family: var(--font-heading);
    font-size: 1.6rem;
    text-transform: uppercase;
    margin: 0 0 8px;
  }
  .gear-hero-overlay p {
    color: rgba(255,255,255,0.85);
    font-size: 0.95rem;
    margin: 0;
  }

  /* Articles Grid */
  .articles-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-bottom: 48px;
  }

  .gear-card {
    text-decoration: none;
    color: inherit;
    background: white;
    border: 1px solid var(--gray-200);
    border-radius: var(--radius);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: all 0.2s;
  }
  .gear-card:hover {
    border-color: var(--court-green);
    box-shadow: var(--shadow);
    transform: translateY(-2px);
  }

  /* Featured first card spans 2 columns */
  .gear-card.featured {
    grid-column: span 2;
  }
  .gear-card.featured .gear-card-img {
    aspect-ratio: 16 / 9;
  }
  .gear-card.featured h2 {
    font-size: 1.2rem;
  }

  .gear-card-img {
    aspect-ratio: 1 / 1;
    overflow: hidden;
    border-radius: var(--radius);
  }
  .gear-card-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
    border-radius: var(--radius);
    display: block;
  }
  .gear-card-img.no-img {
    display: none;
  }

  .gear-card-icon {
    aspect-ratio: 1 / 1;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 3rem;
    background: var(--gray-50);
  }
  .gear-card.featured .gear-card-icon {
    aspect-ratio: 16 / 9;
    font-size: 4rem;
  }

  .card-content {
    padding: 16px 20px 20px;
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .card-category {
    font-family: var(--font-heading);
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 6px;
    display: block;
  }

  .card-content h2 {
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 700;
    margin: 0 0 8px;
    line-height: 1.35;
  }
  .card-content p {
    color: var(--gray-600);
    font-size: 0.82rem;
    line-height: 1.6;
    margin: 0;
    flex: 1;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .read-more {
    color: var(--court-green);
    font-weight: 600;
    font-size: 0.85rem;
    margin-top: 14px;
  }

  .empty-state {
    text-align: center;
    padding: 60px 24px;
    color: var(--gray-500);
    background: var(--gray-50);
    border-radius: var(--radius);
    margin-bottom: 48px;
  }

  /* Load More */
  .load-more-section {
    display: flex;
    justify-content: center;
    margin: 48px 0;
  }
  .load-more-btn {
    padding: 12px 32px;
    font-size: 0.95rem;
    font-weight: 600;
    color: white;
    background: var(--court-green);
    border: none;
    border-radius: var(--radius);
    cursor: pointer;
    transition: all 0.2s;
  }
  .load-more-btn:hover {
    background: #16a34a;
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(34, 197, 94, 0.3);
  }
  .load-more-btn:active {
    transform: translateY(0);
  }

  /* FAQ Section */
  .faq-section {
    margin-bottom: 48px;
    padding-top: 16px;
  }
  .faq-section h2 {
    font-family: var(--font-heading);
    font-size: 1.6rem;
    text-transform: uppercase;
    color: var(--gray-900);
    margin: 0 0 24px;
  }
  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .faq-item {
    border: 1px solid var(--gray-200);
    border-radius: var(--radius);
    overflow: hidden;
  }
  .faq-question {
    padding: 16px 20px;
    font-weight: 600;
    font-size: 0.95rem;
    cursor: pointer;
    list-style: none;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    background: var(--gray-50);
    transition: background 0.15s;
  }
  .faq-question::-webkit-details-marker { display: none; }
  .faq-question::after {
    content: '+';
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--gray-400);
    flex-shrink: 0;
  }
  .faq-item[open] .faq-question::after { content: '-'; }
  .faq-question:hover { background: var(--gray-100); }
  .faq-answer {
    padding: 16px 20px;
    margin: 0;
    font-size: 0.9rem;
    line-height: 1.7;
    color: var(--gray-600);
    border-top: 1px solid var(--gray-200);
  }

  .related-section {
    text-align: center;
    padding: 40px;
    background: var(--gray-50);
    border-radius: var(--radius);
  }
  .related-section h2 {
    font-family: var(--font-heading);
    font-size: 1.4rem;
    text-transform: uppercase;
    margin: 0 0 8px;
  }
  .related-section p {
    color: var(--gray-600);
    margin: 0 0 20px;
  }
  .cta-links {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
  }
  .cta-links a {
    color: var(--court-green);
    font-weight: 600;
    font-size: 0.95rem;
  }
  .cta-links a:hover { text-decoration: underline; }

  @media (max-width: 1024px) {
    .articles-grid { grid-template-columns: repeat(2, 1fr); }
    .gear-card.featured { grid-column: span 2; }
  }
  @media (max-width: 768px) {
    .articles-grid { grid-template-columns: 1fr; }
    .gear-card.featured { grid-column: span 1; }
    .page-hero h1 { font-size: 2rem; }
  }
</style>
