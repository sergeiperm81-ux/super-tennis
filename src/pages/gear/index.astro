---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getArticles } from '../../lib/supabase';

// Fetch real gear articles from Supabase
let gearArticles: any[] = [];
try {
  gearArticles = await getArticles({ category: 'gear', limit: 30 });
} catch (e) {
  console.warn('Gear index: Supabase unavailable');
}

// Icon mapping for gear article slugs
const iconMap: Record<string, string> = {
  'best-tennis-rackets-2026': '🎾',
  'best-tennis-strings-guide': '🔧',
  'best-tennis-shoes-2026': '👟',
  'best-tennis-bags-2026': '🎒',
  'best-tennis-overgrips': '🤲',
  'head-vs-wilson-vs-babolat': '⚔️',
  'best-tennis-balls-2026': '🟡',
  'best-tennis-dampeners': '🔇',
  'tennis-racket-weight-guide': '⚖️',
  'best-tennis-sunglasses': '🕶️',
  'tennis-court-surfaces-equipment': '🏟️',
  'best-tennis-gadgets-tech': '📱',
  'best-junior-tennis-rackets': '👶',
  'natural-gut-vs-synthetic-strings': '🧵',
  'tennis-apparel-brands-2026': '👕',
};

// Category grouping for articles
function getCategory(slug: string): string {
  if (slug.includes('racket') || slug.includes('head-vs-wilson') || slug.includes('junior')) return 'Rackets';
  if (slug.includes('string') || slug.includes('gut')) return 'Strings';
  if (slug.includes('shoe') || slug.includes('apparel')) return 'Clothing & Shoes';
  return 'Accessories';
}
---

<BaseLayout
  title="Tennis Gear — Rackets, Shoes & Equipment Reviews"
  description="Expert tennis gear reviews and guides. Find the best rackets, shoes, strings, and equipment for your game. Pro player setups and recommendations."
>
  <div class="gear-page">
    <div class="container">
      <section class="page-hero">
        <h1>Tennis Gear</h1>
        <p class="subtitle">Expert reviews, pro player setups, and buying guides for every level</p>
      </section>

      {gearArticles.length > 0 ? (
        <div class="articles-grid">
          {gearArticles.map(article => (
            <a href={`/gear/${article.slug}/`} class="gear-card">
              <div class="gear-icon">{iconMap[article.slug] || '🎾'}</div>
              <div class="card-content">
                <span class="card-category">{getCategory(article.slug)}</span>
                <h2>{article.title}</h2>
                <p>{article.excerpt || article.meta_description || ''}</p>
              </div>
              <span class="read-more">Read Guide →</span>
            </a>
          ))}
        </div>
      ) : (
        <div class="empty-state">
          <p>Gear guides are coming soon. Check back shortly!</p>
        </div>
      )}

      <section class="related-section">
        <h2>Pro Player Equipment</h2>
        <p>See what rackets, strings, and shoes your favorite pros use</p>
        <div class="cta-links">
          <a href="/players/">Browse Players →</a>
          <a href="/rankings/">View Rankings →</a>
          <a href="/records/">Tennis Records →</a>
        </div>
      </section>
    </div>
  </div>
</BaseLayout>

<style>
  .gear-page {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px 60px;
  }

  .page-hero {
    padding: 48px 0 32px;
    border-bottom: 3px solid var(--court-green);
    margin-bottom: 40px;
  }
  .page-hero h1 {
    font-family: var(--font-heading);
    font-size: 2.8rem;
    text-transform: uppercase;
    color: var(--gray-900);
    margin: 0;
  }
  .subtitle {
    color: var(--gray-600);
    font-size: 1.1rem;
    margin: 8px 0 0;
  }

  .articles-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-bottom: 48px;
  }

  .gear-card {
    text-decoration: none;
    color: inherit;
    background: white;
    border: 1px solid var(--gray-200);
    border-radius: var(--radius);
    padding: 24px;
    display: flex;
    flex-direction: column;
    transition: all 0.2s;
  }
  .gear-card:hover {
    border-color: var(--court-green);
    box-shadow: var(--shadow);
    transform: translateY(-2px);
  }

  .gear-icon {
    font-size: 2.2rem;
    margin-bottom: 12px;
  }

  .card-content {
    flex: 1;
  }

  .card-category {
    font-family: var(--font-heading);
    font-size: 0.65rem;
    text-transform: uppercase;
    color: var(--court-green);
    letter-spacing: 0.05em;
    margin-bottom: 6px;
    display: block;
  }

  .card-content h2 {
    font-family: var(--font-body);
    font-size: 1.05rem;
    font-weight: 700;
    margin: 0 0 8px;
    line-height: 1.35;
  }
  .card-content p {
    color: var(--gray-600);
    font-size: 0.85rem;
    line-height: 1.6;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .read-more {
    color: var(--court-green);
    font-weight: 600;
    font-size: 0.85rem;
    margin-top: 16px;
  }

  .empty-state {
    text-align: center;
    padding: 60px 24px;
    color: var(--gray-500);
    background: var(--gray-50);
    border-radius: var(--radius);
    margin-bottom: 48px;
  }

  .related-section {
    text-align: center;
    padding: 40px;
    background: var(--gray-50);
    border-radius: var(--radius);
  }
  .related-section h2 {
    font-family: var(--font-heading);
    font-size: 1.4rem;
    text-transform: uppercase;
    margin: 0 0 8px;
  }
  .related-section p {
    color: var(--gray-600);
    margin: 0 0 20px;
  }
  .cta-links {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
  }
  .cta-links a {
    color: var(--court-green);
    font-weight: 600;
    font-size: 0.95rem;
  }
  .cta-links a:hover { text-decoration: underline; }

  @media (max-width: 1024px) {
    .articles-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 768px) {
    .articles-grid { grid-template-columns: 1fr; }
    .page-hero h1 { font-size: 2rem; }
  }
</style>
