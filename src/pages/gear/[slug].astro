---
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import ArticleFooter from '../../components/ArticleFooter.astro';
import RelatedArticles from '../../components/RelatedArticles.astro';
import { getArticleBySlug, getArticleSlugs } from '../../lib/supabase';
import { addInterlinks } from '../../lib/interlinks';
import { getArticlePhotoUrl } from '../../lib/player-photos';
import { buildHowToSchema } from '../../lib/howto-schema';
import { marked } from 'marked';
import { getArticleAlternates } from '../../lib/i18n';

export async function getStaticPaths() {
  let slugs: string[] = [];
  try {
    slugs = await getArticleSlugs('gear');
  } catch (e) {
    console.warn('gear getStaticPaths: Supabase unavailable');
  }

  if (slugs.length === 0) {
    slugs = [
      'best-tennis-rackets-2026', 'best-tennis-shoes-2026', 'best-tennis-strings-guide',
      'best-tennis-bags-guide', 'tennis-overgrip-comparison', 'head-vs-wilson-vs-babolat',
      'best-tennis-balls-comparison', 'tennis-accessories-essentials', 'junior-tennis-racket-guide',
      'best-clay-court-shoes', 'tennis-racket-weight-guide', 'best-tennis-sunglasses',
      'best-tennis-dampeners-guide', 'tennis-elbow-prevention-gear', 'used-tennis-rackets-buying-guide',
    ];
  }

  return slugs.map(slug => ({ params: { slug } }));
}

const { slug } = Astro.params;

let article: any = null;
try {
  article = await getArticleBySlug(slug as string);
} catch (e) {
  console.warn(`Gear article not found: ${slug}`);
}

if (!article) {
  return Astro.redirect('/gear/');
}

const heroImage = await getArticlePhotoUrl(slug as string, 'gear') || article.image_url || null;
const alternates = await getArticleAlternates(article.id, `/gear/${slug}/`);

const rawHtml = article.body ? marked.parse(article.body) : '';
const bodyHtml = rawHtml ? await addInterlinks(rawHtml as string, `/gear/${slug}/`) : '';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: article.title,
  description: article.meta_description || article.excerpt,
  url: `https://super.tennis/gear/${slug}/`,
  ...(article.created_at && { datePublished: article.created_at }),
  ...(article.updated_at && { dateModified: article.updated_at }),
  author: {
    '@type': 'Organization',
    '@id': 'https://super.tennis/#organization',
    name: 'SUPER.TENNIS Editorial',
    url: 'https://super.tennis/about/',
  },
  publisher: {
    '@type': 'Organization',
    name: 'SUPER.TENNIS',
    url: 'https://super.tennis',
    logo: { '@type': 'ImageObject', url: 'https://super.tennis/og/default.png' },
  },
  ...(heroImage && { image: heroImage }),
};

// HowTo JSON-LD for how-to-* gear articles (Codex SEO audit 2026-05-17)
const howToJsonLd = buildHowToSchema(
  slug as string,
  article.title,
  article.meta_description || article.excerpt || '',
  bodyHtml,
  'gear',
);

// Product ItemList JSON-LD (2026-06-17 GEO audit).
// Gear roundups list each product as an <h2> section ("Best Overall: Wilson
// Clash 100 v2") containing an Amazon affiliate link. We extract those into an
// ItemList of Product nodes so AI/Google parse the page as a product roundup.
// We do NOT fabricate prices or ratings (we don't have per-product data) — only
// the name and the real affiliate offer URL, which is honest and valid.
function extractGearProducts(html: string): { name: string; url: string }[] {
  if (!html) return [];
  const out: { name: string; url: string }[] = [];
  const seen = new Set<string>();
  const sections = html.split(/<h2[^>]*>/i).slice(1);
  for (const sec of sections) {
    const hMatch = sec.match(/^([\s\S]*?)<\/h2>/i);
    if (!hMatch) continue;
    const heading = hMatch[1].replace(/<[^>]+>/g, '').replace(/&amp;/g, '&').trim();
    // Only "Best X: Product Name" roundup headings are products. Requiring the
    // colon-prefix excludes generic sections ("Where to Buy", "Weight
    // Categories") that also contain affiliate links but aren't products —
    // those would otherwise become junk Product nodes.
    const ci = heading.indexOf(': ');
    if (ci === -1) continue;
    const name = heading.slice(ci + 2).trim();
    if (!name || name.length < 3 || name.length > 90) continue;
    if (!/[A-Za-z]/.test(name)) continue;
    const az = sec.match(/href="(https:\/\/www\.amazon\.com\/[^"]*tag=supertennis0b-20[^"]*)"/i);
    if (!az) continue; // only sections with a real affiliate link count as products
    if (seen.has(name)) continue;
    seen.add(name);
    out.push({ name, url: az[1].replace(/&amp;/g, '&') });
  }
  return out;
}
const gearProducts = extractGearProducts(bodyHtml as string);
const itemListJsonLd = gearProducts.length >= 2 ? {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: article.title,
  itemListElement: gearProducts.map((p, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    item: {
      '@type': 'Product',
      name: p.name,
      offers: { '@type': 'Offer', url: p.url, availability: 'https://schema.org/InStock' },
    },
  })),
} : null;
---

<ArticleLayout
  title={article.meta_title || article.title}
  description={article.meta_description || article.excerpt || `${article.title} — Tennis gear guide on SUPER.TENNIS.`}
  breadcrumbs={[
    { label: 'Home', href: '/' },
    { label: 'Gear', href: '/gear/' },
    { label: article.title },
  ]}
  image={heroImage || undefined}
  publishedDate={article.created_at || undefined}
  updatedDate={article.updated_at || undefined}
  category="gear"
  categoryLabel="Gear Guide"
  categoryHref="/gear/"
  alternates={alternates}
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  {howToJsonLd && <script type="application/ld+json" set:html={JSON.stringify(howToJsonLd)} />}
  {itemListJsonLd && <script type="application/ld+json" set:html={JSON.stringify(itemListJsonLd)} />}

  <div set:html={bodyHtml} />

  <RelatedArticles category="gear" currentSlug={slug as string} />

  <ArticleFooter backLabel="All Gear Guides" backHref="/gear/" />
</ArticleLayout>
