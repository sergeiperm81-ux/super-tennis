---
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import ArticleFooter from '../../components/ArticleFooter.astro';
import RelatedArticles from '../../components/RelatedArticles.astro';
import { getArticleBySlug, getArticleSlugs } from '../../lib/supabase';
import { addInterlinks } from '../../lib/interlinks';
import { getArticlePhotoUrl } from '../../lib/player-photos';
import { marked } from 'marked';

export async function getStaticPaths() {
  let slugs: string[] = [];
  try {
    slugs = await getArticleSlugs('gear');
  } catch (e) {
    console.warn('gear getStaticPaths: Supabase unavailable');
  }

  if (slugs.length === 0) {
    slugs = [
      'best-tennis-rackets-2026', 'best-tennis-shoes-2026', 'best-tennis-strings-guide',
      'tennis-bag-guide', 'tennis-overgrip-guide', 'head-vs-wilson-vs-babolat',
      'best-tennis-balls-2026', 'tennis-accessories-essentials', 'junior-tennis-racket-guide',
      'best-clay-court-shoes', 'tennis-racket-weight-guide', 'tennis-sunglasses-guide',
      'best-tennis-dampeners', 'tennis-elbow-prevention-gear', 'used-tennis-rackets-buying-guide',
    ];
  }

  return slugs.map(slug => ({ params: { slug } }));
}

const { slug } = Astro.params;

let article: any = null;
try {
  article = await getArticleBySlug(slug as string);
} catch (e) {
  console.warn(`Gear article not found: ${slug}`);
}

if (!article) {
  return Astro.redirect('/gear/');
}

const heroImage = await getArticlePhotoUrl(slug as string, 'gear');

const rawHtml = article.body ? marked.parse(article.body) : '';
const bodyHtml = rawHtml ? await addInterlinks(rawHtml as string, `/gear/${slug}/`) : '';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: article.title,
  description: article.meta_description || article.excerpt,
  url: `https://super.tennis/gear/${slug}/`,
  ...(article.created_at && { datePublished: article.created_at }),
  ...(article.updated_at && { dateModified: article.updated_at }),
  author: { '@type': 'Organization', name: 'SUPER.TENNIS', url: 'https://super.tennis' },
  publisher: {
    '@type': 'Organization',
    name: 'SUPER.TENNIS',
    url: 'https://super.tennis',
    logo: { '@type': 'ImageObject', url: 'https://super.tennis/og-image.png' },
  },
  ...(heroImage && { image: heroImage }),
  about: {
    '@type': 'Product',
    name: 'Tennis Equipment',
  },
};
---

<ArticleLayout
  title={article.meta_title || article.title}
  description={article.meta_description || article.excerpt || `${article.title} — Tennis gear guide on SUPER.TENNIS.`}
  breadcrumbs={[
    { label: 'Home', href: '/' },
    { label: 'Gear', href: '/gear/' },
    { label: article.title },
  ]}
  image={heroImage || undefined}
  category="gear"
  categoryLabel="Gear Guide"
  categoryHref="/gear/"
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <div set:html={bodyHtml} />

  <RelatedArticles category="gear" currentSlug={slug as string} />

  <ArticleFooter backLabel="All Gear Guides" backHref="/gear/" />
</ArticleLayout>
