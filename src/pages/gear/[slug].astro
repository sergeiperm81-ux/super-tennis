---
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import { getArticleBySlug, getArticleSlugs } from '../../lib/supabase';
import { marked } from 'marked';

export async function getStaticPaths() {
  let slugs: string[] = [];
  try {
    slugs = await getArticleSlugs('gear');
  } catch (e) {
    console.warn('gear getStaticPaths: Supabase unavailable');
  }

  if (slugs.length === 0) {
    slugs = [
      'best-tennis-rackets-2026', 'best-tennis-shoes-2026', 'best-tennis-strings-guide',
      'tennis-bag-guide', 'tennis-overgrip-guide', 'head-vs-wilson-vs-babolat',
      'best-tennis-balls-2026', 'tennis-accessories-essentials', 'junior-tennis-racket-guide',
      'best-clay-court-shoes', 'tennis-racket-weight-guide', 'tennis-sunglasses-guide',
      'best-tennis-dampeners', 'tennis-elbow-prevention-gear', 'used-tennis-rackets-buying-guide',
    ];
  }

  return slugs.map(slug => ({ params: { slug } }));
}

const { slug } = Astro.params;

let article: any = null;
try {
  article = await getArticleBySlug(slug as string);
} catch (e) {
  console.warn(`Gear article not found: ${slug}`);
}

if (!article) {
  return Astro.redirect('/gear/');
}

const bodyHtml = article.body ? marked.parse(article.body) : '';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: article.title,
  description: article.meta_description || article.excerpt,
  url: `https://super.tennis/gear/${slug}/`,
  publisher: {
    '@type': 'Organization',
    name: 'SUPER.TENNIS',
    url: 'https://super.tennis',
  },
  about: {
    '@type': 'Thing',
    name: 'Tennis Equipment',
  },
};
---

<ArticleLayout
  title={article.meta_title || article.title}
  description={article.meta_description || article.excerpt || `${article.title} — Tennis gear guide on SUPER.TENNIS.`}
  breadcrumbs={[
    { label: 'Home', href: '/' },
    { label: 'Gear', href: '/gear/' },
    { label: article.title },
  ]}
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <div set:html={bodyHtml} />

  <div class="article-nav">
    <a href="/gear/" class="nav-back">← All Gear Guides</a>
    <div class="nav-related">
      <a href="/players/">👥 Player Profiles</a>
      <a href="/records/">🏆 Records</a>
    </div>
  </div>
</ArticleLayout>

<style>
  .article-nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 16px;
    margin-top: 40px;
    padding-top: 24px;
    border-top: 2px solid var(--gray-200);
  }
  .nav-back {
    color: var(--court-green);
    font-weight: 600;
    font-size: 0.95rem;
  }
  .nav-back:hover { text-decoration: underline; }
  .nav-related { display: flex; gap: 16px; }
  .nav-related a {
    color: var(--gray-600);
    font-size: 0.9rem;
    font-weight: 500;
    transition: color 0.2s;
  }
  .nav-related a:hover { color: var(--court-green); }
</style>
