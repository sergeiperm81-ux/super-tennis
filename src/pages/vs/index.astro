    border-radius: 4px;
    letter-spacing: 0.05em;
    align-self: flex-start;
    margin-bottom: 10px;
  }
  .h2h-grid .h2h-card .era-badge.big-three { background: #fef3c7; color: #92400e; }
  .h2h-grid .h2h-card .era-badge.current { background: #dcfce7; color: #166534; }
  .h2h-grid .h2h-card .era-badge.wta { background: #f3e8ff; color: #6d28d9; }
  .h2h-grid .h2h-card .era-badge.classic { background: #f3f4f6; color: #374151; }
  .h2h-grid .h2h-card h2 {
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 700;
    margin: 0 0 8px;
    line-height: 1.35;
  }
  .h2h-grid .h2h-card p {
    color: var(--gray-600);
    font-size: 0.82rem;
    line-height: 1.6;
    margin: 0;
    flex: 1;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .h2h-grid .h2h-card .read-more {
    color: var(--court-green);
    font-weight: 600;
    font-size: 0.85rem;
    margin-top: 14px;
  }
</style>

<script is:inline>
  // Search functionality
  const searchInput = document.getElementById('search-input');
  if (searchInput) {
    searchInput.addEventListener('keyup', function(e) {
      if (e.key === 'Enter') {
        const query = this.value.trim();
        const era = new URLSearchParams(window.location.search).get('era') || 'all';
        if (query) {
          window.location.href = `?era=${era}&q=${encodeURIComponent(query)}`;
        } else {
          window.location.href = `?era=${era}`;
        }
      }
    });
  }

  // Load More functionality
  const loadMoreBtn = document.getElementById('load-more-btn');
  if (loadMoreBtn) {
    loadMoreBtn.addEventListener('click', async function() {
      const currentEra = new URLSearchParams(window.location.search).get('era') || 'all';
      const currentQ = new URLSearchParams(window.location.search).get('q') || '';

      try {
        const response = await fetch(`/api/vs-articles?era=${currentEra}${currentQ ? `&q=${encodeURIComponent(currentQ)}` : ''}`);
        const articles = await response.json();

        const h2hGrid = document.getElementById('h2h-grid');
        const currentCount = h2hGrid.querySelectorAll('.h2h-card').length;

        // Append next 12 articles
        articles.slice(currentCount + 1, currentCount + 13).forEach(article => {
          const card = createRivalryCard(article);
          h2hGrid.appendChild(card);
        });

        // Hide Load More if no more articles
        if (currentCount + 13 >= articles.length) {
          loadMoreBtn.parentElement.style.display = 'none';
        } else {
          loadMoreBtn.textContent = `Load More (${articles.length - currentCount - 13} more)`;
        }
      } catch (error) {
        console.error('Failed to load more rivalries:', error);
      }
    });
  }

  function createRivalryCard(article) {
    const a = document.createElement('a');
    a.href = `/vs/${article.slug}/`;
    a.className = `h2h-card ${article.era_class}`;
    a.innerHTML = `
      <div class="card-player-duo">
        <div class="duo-player">
          ${article.p1 ? `<img src="${article.p1}" alt="${article.name1}" class="duo-avatar" loading="lazy" />` : ''}
          <div class="duo-placeholder">${article.name1.charAt(0)}</div>
          <span class="duo-name">${article.name1.split(' ').pop()}</span>
        </div>
        <span class="duo-vs">vs</span>
        <div class="duo-player">
          ${article.p2 ? `<img src="${article.p2}" alt="${article.name2}" class="duo-avatar" loading="lazy" />` : ''}
          <div class="duo-placeholder">${article.name2.charAt(0)}</div>
          <span class="duo-name">${article.name2.split(' ').pop()}</span>
        </div>
      </div>
      <span class="era-badge ${article.era_class}">${article.era}</span>
      <h2>${article.title}</h2>
      <p>${article.excerpt || ''}</p>
      <span class="read-more">Read Analysis →</span>
    `;
    return a;
  }
</script>
