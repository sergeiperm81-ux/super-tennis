---
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import ArticleFooter from '../../components/ArticleFooter.astro';
import RelatedArticles from '../../components/RelatedArticles.astro';
import { getArticleBySlug, getArticleSlugs, getPlayerBySlug, getH2H } from '../../lib/supabase';
import type { H2HData, Player } from '../../lib/supabase';
import { addInterlinks } from '../../lib/interlinks';
import { getVsPhotos, vsPlayerSlugs, slugToName } from '../../lib/player-photos';
import { marked } from 'marked';

export async function getStaticPaths() {
  let slugs: string[] = [];
  try {
    slugs = await getArticleSlugs('vs');
  } catch (e) {
    console.warn('vs getStaticPaths: Supabase unavailable');
  }

  if (slugs.length === 0) {
    slugs = [
      'djokovic-vs-nadal', 'federer-vs-nadal', 'djokovic-vs-federer',
      'alcaraz-vs-sinner', 'djokovic-vs-alcaraz', 'evert-vs-navratilova',
      'williams-vs-williams', 'djokovic-vs-murray', 'nadal-vs-federer-clay',
      'swiatek-vs-sabalenka', 'sampras-vs-agassi', 'borg-vs-mcenroe',
      'graf-vs-seles', 'federer-vs-djokovic-wimbledon', 'nadal-vs-djokovic-french-open',
      'big-three-comparison', 'medvedev-vs-sinner', 'zverev-vs-alcaraz',
      'gauff-vs-swiatek', 'connors-vs-lendl', 'henin-vs-clijsters',
      'sharapova-vs-williams', 'federer-vs-murray', 'tsitsipas-vs-medvedev',
      'kyrgios-vs-djokovic',
    ];
  }

  return slugs.map(slug => ({ params: { slug } }));
}

const { slug } = Astro.params;

let article: any = null;
try {
  article = await getArticleBySlug(slug as string);
} catch (e) {
  console.warn(`H2H article not found: ${slug}`);
}

if (!article) {
  return Astro.redirect('/vs/');
}

// Get both player photos for the split-screen hero
const [photo1, photo2] = await getVsPhotos(slug as string);
const pair = vsPlayerSlugs[slug as string];
const name1 = pair ? slugToName(pair[0]) : '';
const name2 = pair ? slugToName(pair[1]) : '';

const rawHtml = article.body ? marked.parse(article.body) : '';
const bodyHtml = rawHtml ? await addInterlinks(rawHtml as string, `/vs/${slug}/`) : '';

// Fetch H2H data from database
let h2h: H2HData | null = null;
let p1: Player | null = null;
let p2: Player | null = null;
if (pair) {
  [p1, p2] = await Promise.all([
    getPlayerBySlug(pair[0]),
    getPlayerBySlug(pair[1]),
  ]);
  if (p1 && p2) {
    h2h = await getH2H(p1.player_id, p2.player_id);
    // Ensure correct orientation: h2h.player1_id is the smaller sorted ID
    if (h2h && p1.player_id > p2.player_id) {
      // Swap display — h2h data is stored with sorted IDs
      h2h = {
        ...h2h,
        player1_wins: h2h.player2_wins,
        player2_wins: h2h.player1_wins,
        surface_hard_p1: h2h.surface_hard_p2,
        surface_hard_p2: h2h.surface_hard_p1,
        surface_clay_p1: h2h.surface_clay_p2,
        surface_clay_p2: h2h.surface_clay_p1,
        surface_grass_p1: h2h.surface_grass_p2,
        surface_grass_p2: h2h.surface_grass_p1,
      };
    }
  }
}

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: article.title,
  description: article.meta_description || article.excerpt,
  url: `https://super.tennis/vs/${slug}/`,
  publisher: {
    '@type': 'Organization',
    name: 'SUPER.TENNIS',
    url: 'https://super.tennis',
  },
  about: {
    '@type': 'Thing',
    name: 'Tennis Head to Head',
  },
};
---

<ArticleLayout
  title={article.meta_title || article.title}
  description={article.meta_description || article.excerpt || `${article.title} — Head to head rivalry analysis on SUPER.TENNIS.`}
  breadcrumbs={[
    { label: 'Home', href: '/' },
    { label: 'Head to Head', href: '/vs/' },
    { label: article.title },
  ]}
  category="vs"
  categoryLabel="Head to Head"
  categoryHref="/vs/"
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  {(photo1 || photo2) && (
    <div class="vs-hero">
      <div class="vs-side">
        {photo1 ? (
          <img src={photo1} alt={name1} class="vs-photo" loading="eager" decoding="async" width="400" height="400" onerror="this.style.display='none'" />
        ) : (
          <div class="vs-placeholder"></div>
        )}
        <div class="vs-name-overlay">
          <span class="vs-player-name">{name1}</span>
        </div>
      </div>
      <div class="vs-badge">VS</div>
      <div class="vs-side">
        {photo2 ? (
          <img src={photo2} alt={name2} class="vs-photo" loading="eager" decoding="async" width="400" height="400" onerror="this.style.display='none'" />
        ) : (
          <div class="vs-placeholder"></div>
        )}
        <div class="vs-name-overlay">
          <span class="vs-player-name">{name2}</span>
        </div>
      </div>
    </div>
  )}

  {h2h && (h2h.player1_wins > 0 || h2h.player2_wins > 0) && (
    <div class="h2h-card">
      <h2 class="h2h-title">Head to Head Record</h2>
      <div class="h2h-score">
        <div class="h2h-side">
          <span class="h2h-name">{name1}</span>
          <span class="h2h-wins">{h2h.player1_wins}</span>
        </div>
        <span class="h2h-divider">-</span>
        <div class="h2h-side">
          <span class="h2h-wins">{h2h.player2_wins}</span>
          <span class="h2h-name">{name2}</span>
        </div>
      </div>

      {(h2h.surface_hard_p1 > 0 || h2h.surface_hard_p2 > 0 || h2h.surface_clay_p1 > 0 || h2h.surface_clay_p2 > 0 || h2h.surface_grass_p1 > 0 || h2h.surface_grass_p2 > 0) && (
        <div class="h2h-surfaces">
          {(h2h.surface_hard_p1 > 0 || h2h.surface_hard_p2 > 0) && (
            <div class="h2h-surface">
              <span class="surface-label">Hard</span>
              <span class="surface-score">{h2h.surface_hard_p1} - {h2h.surface_hard_p2}</span>
            </div>
          )}
          {(h2h.surface_clay_p1 > 0 || h2h.surface_clay_p2 > 0) && (
            <div class="h2h-surface">
              <span class="surface-label">Clay</span>
              <span class="surface-score">{h2h.surface_clay_p1} - {h2h.surface_clay_p2}</span>
            </div>
          )}
          {(h2h.surface_grass_p1 > 0 || h2h.surface_grass_p2 > 0) && (
            <div class="h2h-surface">
              <span class="surface-label">Grass</span>
              <span class="surface-score">{h2h.surface_grass_p1} - {h2h.surface_grass_p2}</span>
            </div>
          )}
        </div>
      )}

      {h2h.last_match_tournament && (
        <div class="h2h-last">
          Last match: {h2h.last_match_tournament}
          {h2h.last_match_score && ` — ${h2h.last_match_score}`}
          {h2h.last_match_date && ` (${new Date(h2h.last_match_date).toLocaleDateString('en-US', { month: 'short', year: 'numeric' })})`}
        </div>
      )}
    </div>
  )}

  <div set:html={bodyHtml} />

  <RelatedArticles category="vs" currentSlug={slug as string} />

  <ArticleFooter backLabel="All Rivalries" backHref="/vs/" />
</ArticleLayout>

<style>
  .vs-hero {
    display: grid;
    grid-template-columns: 1fr 1fr;
    position: relative;
    margin: 0 -24px 32px;
    height: 400px;
    border-radius: var(--radius);
    overflow: hidden;
  }

  .vs-side {
    position: relative;
    overflow: hidden;
    background: var(--gray-200);
  }

  .vs-photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top;
    transition: transform 0.4s ease;
  }
  .vs-side:hover .vs-photo {
    transform: scale(1.04);
  }

  .vs-placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, var(--gray-200), var(--gray-300));
  }

  .vs-name-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 32px 16px 16px;
    background: linear-gradient(to top, rgba(0,0,0,0.75), transparent);
    text-align: center;
  }

  .vs-player-name {
    font-family: var(--font-heading);
    font-size: 1.15rem;
    font-weight: 700;
    color: white;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    text-shadow: 0 1px 4px rgba(0,0,0,0.5);
  }

  .vs-badge {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    z-index: 10;
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: #d4a017;
    color: white;
    font-family: var(--font-heading);
    font-size: 1.2rem;
    font-weight: 800;
    display: flex;
    align-items: center;
    justify-content: center;
    letter-spacing: 0.05em;
    box-shadow: 0 4px 16px rgba(0,0,0,0.3);
    border: 3px solid white;
  }

  @media (max-width: 768px) {
    .vs-hero {
      height: 280px;
    }
    .vs-player-name {
      font-size: 0.9rem;
    }
    .vs-badge {
      width: 48px;
      height: 48px;
      font-size: 0.95rem;
    }
  }

  @media (max-width: 480px) {
    .vs-hero {
      height: 220px;
      margin: 0 -24px 24px;
    }
    .vs-player-name {
      font-size: 0.78rem;
    }
  }

  /* H2H Data Card */
  .h2h-card {
    margin: 0 0 2rem;
    padding: 1.5rem;
    background: linear-gradient(135deg, #1a1a2e, #16213e);
    border-radius: 16px;
    color: #fff;
    text-align: center;
  }
  .h2h-title {
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #94a3b8;
    margin: 0 0 1rem;
  }
  .h2h-score {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    margin-bottom: 1rem;
  }
  .h2h-side {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .h2h-name {
    font-size: 0.95rem;
    font-weight: 500;
    color: #cbd5e1;
  }
  .h2h-wins {
    font-size: 2.5rem;
    font-weight: 800;
    color: #d4a017;
    line-height: 1;
  }
  .h2h-divider {
    font-size: 2rem;
    color: #475569;
    font-weight: 300;
  }
  .h2h-surfaces {
    display: flex;
    justify-content: center;
    gap: 1.5rem;
    margin: 0.75rem 0;
    padding-top: 0.75rem;
    border-top: 1px solid rgba(255,255,255,0.1);
  }
  .h2h-surface {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
  }
  .surface-label {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #64748b;
  }
  .surface-score {
    font-size: 1.1rem;
    font-weight: 700;
    color: #e2e8f0;
  }
  .h2h-last {
    margin-top: 0.75rem;
    font-size: 0.8rem;
    color: #64748b;
    font-style: italic;
  }
</style>
