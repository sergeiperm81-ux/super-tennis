---
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import ArticleFooter from '../../components/ArticleFooter.astro';
import { getArticleBySlug, getArticleSlugs } from '../../lib/supabase';
import { addInterlinks } from '../../lib/interlinks';
import { getVsPhotos, vsPlayerSlugs, slugToName } from '../../lib/player-photos';
import { marked } from 'marked';

export async function getStaticPaths() {
  let slugs: string[] = [];
  try {
    slugs = await getArticleSlugs('vs');
  } catch (e) {
    console.warn('vs getStaticPaths: Supabase unavailable');
  }

  if (slugs.length === 0) {
    slugs = [
      'djokovic-vs-nadal', 'federer-vs-nadal', 'djokovic-vs-federer',
      'alcaraz-vs-sinner', 'djokovic-vs-alcaraz', 'evert-vs-navratilova',
      'williams-vs-williams', 'djokovic-vs-murray', 'nadal-vs-federer-clay',
      'swiatek-vs-sabalenka', 'sampras-vs-agassi', 'borg-vs-mcenroe',
      'graf-vs-seles', 'federer-vs-djokovic-wimbledon', 'nadal-vs-djokovic-french-open',
      'big-three-comparison', 'medvedev-vs-sinner', 'zverev-vs-alcaraz',
      'gauff-vs-swiatek', 'connors-vs-lendl', 'henin-vs-clijsters',
      'sharapova-vs-williams', 'federer-vs-murray', 'tsitsipas-vs-medvedev',
      'kyrgios-vs-djokovic',
    ];
  }

  return slugs.map(slug => ({ params: { slug } }));
}

const { slug } = Astro.params;

let article: any = null;
try {
  article = await getArticleBySlug(slug as string);
} catch (e) {
  console.warn(`H2H article not found: ${slug}`);
}

if (!article) {
  return Astro.redirect('/vs/');
}

// Get both player photos for the split-screen hero
const [photo1, photo2] = await getVsPhotos(slug as string);
const pair = vsPlayerSlugs[slug as string];
const name1 = pair ? slugToName(pair[0]) : '';
const name2 = pair ? slugToName(pair[1]) : '';

const rawHtml = article.body ? marked.parse(article.body) : '';
const bodyHtml = rawHtml ? await addInterlinks(rawHtml as string, `/vs/${slug}/`) : '';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: article.title,
  description: article.meta_description || article.excerpt,
  url: `https://super.tennis/vs/${slug}/`,
  publisher: {
    '@type': 'Organization',
    name: 'SUPER.TENNIS',
    url: 'https://super.tennis',
  },
  about: {
    '@type': 'Thing',
    name: 'Tennis Head to Head',
  },
};
---

<ArticleLayout
  title={article.meta_title || article.title}
  description={article.meta_description || article.excerpt || `${article.title} — Head to head rivalry analysis on SUPER.TENNIS.`}
  breadcrumbs={[
    { label: 'Home', href: '/' },
    { label: 'Head to Head', href: '/vs/' },
    { label: article.title },
  ]}
  category="vs"
  categoryLabel="Head to Head"
  categoryHref="/vs/"
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  {(photo1 || photo2) && (
    <div class="vs-hero">
      <div class="vs-side">
        {photo1 ? (
          <img src={photo1} alt={name1} class="vs-photo" loading="eager" onerror="this.style.display='none'" />
        ) : (
          <div class="vs-placeholder"></div>
        )}
        <div class="vs-name-overlay">
          <span class="vs-player-name">{name1}</span>
        </div>
      </div>
      <div class="vs-badge">VS</div>
      <div class="vs-side">
        {photo2 ? (
          <img src={photo2} alt={name2} class="vs-photo" loading="eager" onerror="this.style.display='none'" />
        ) : (
          <div class="vs-placeholder"></div>
        )}
        <div class="vs-name-overlay">
          <span class="vs-player-name">{name2}</span>
        </div>
      </div>
    </div>
  )}

  <div set:html={bodyHtml} />

  <ArticleFooter backLabel="All Rivalries" backHref="/vs/" />
</ArticleLayout>

<style>
  .vs-hero {
    display: grid;
    grid-template-columns: 1fr 1fr;
    position: relative;
    margin: 0 -24px 32px;
    height: 400px;
    border-radius: var(--radius);
    overflow: hidden;
  }

  .vs-side {
    position: relative;
    overflow: hidden;
    background: var(--gray-200);
  }

  .vs-photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top;
    transition: transform 0.4s ease;
  }
  .vs-side:hover .vs-photo {
    transform: scale(1.04);
  }

  .vs-placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, var(--gray-200), var(--gray-300));
  }

  .vs-name-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 32px 16px 16px;
    background: linear-gradient(to top, rgba(0,0,0,0.75), transparent);
    text-align: center;
  }

  .vs-player-name {
    font-family: var(--font-heading);
    font-size: 1.15rem;
    font-weight: 700;
    color: white;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    text-shadow: 0 1px 4px rgba(0,0,0,0.5);
  }

  .vs-badge {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    z-index: 10;
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: #d4a017;
    color: white;
    font-family: var(--font-heading);
    font-size: 1.2rem;
    font-weight: 800;
    display: flex;
    align-items: center;
    justify-content: center;
    letter-spacing: 0.05em;
    box-shadow: 0 4px 16px rgba(0,0,0,0.3);
    border: 3px solid white;
  }

  @media (max-width: 768px) {
    .vs-hero {
      height: 280px;
    }
    .vs-player-name {
      font-size: 0.9rem;
    }
    .vs-badge {
      width: 48px;
      height: 48px;
      font-size: 0.95rem;
    }
  }

  @media (max-width: 480px) {
    .vs-hero {
      height: 220px;
      margin: 0 -24px 24px;
    }
    .vs-player-name {
      font-size: 0.78rem;
    }
  }
</style>
