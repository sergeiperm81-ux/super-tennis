---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Roland Garros 2026 Winner Prediction — Who Will Win?"
  description="Pick who you think will win Roland Garros 2026. ATP & WTA top contenders — one tap, shareable card. Make your prediction!"
  ogImage="/images/rg-card-template.png"
>

<style is:global>
  .rg-section {
    background: var(--gray-50, #f8f9fa);
    padding: 3rem 1rem 5rem;
  }
  .rg-wrap {
    max-width: 720px;
    margin: 0 auto;
  }

  /* ── Header ── */
  .rg-header {
    text-align: center;
    margin-bottom: 2rem;
  }
  .clay-badge {
    background: #c85a20;
    border-radius: 4px;
    color: #fff;
    display: inline-block;
    font-family: var(--font-heading, 'Oswald', sans-serif);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 1.5px;
    margin-bottom: 1rem;
    padding: 0.3rem 0.9rem;
    text-transform: uppercase;
  }
  .rg-header h1 {
    font-family: var(--font-heading, 'Oswald', sans-serif);
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 700;
    color: var(--gray-900, #212529);
    margin-bottom: 0.4rem;
    text-transform: uppercase;
    letter-spacing: 1px;
  }
  .rg-header p {
    color: var(--gray-600, #868e96);
    font-size: 0.95rem;
  }

  /* ── Tabs ── */
  .tour-tabs {
    display: flex;
    background: var(--gray-200, #e9ecef);
    border-radius: 10px;
    margin-bottom: 1.5rem;
    padding: 4px;
    gap: 4px;
  }
  .tour-tab {
    background: none;
    border: none;
    border-radius: 7px;
    color: var(--gray-600, #868e96);
    cursor: pointer;
    flex: 1;
    font-family: var(--font-heading, 'Oswald', sans-serif);
    font-size: 0.95rem;
    font-weight: 500;
    letter-spacing: 0.5px;
    padding: 0.65rem;
    transition: all 0.18s;
    text-transform: uppercase;
  }
  .tour-tab.active {
    background: #fff;
    color: var(--court-green, #2d8c3c);
    box-shadow: 0 1px 4px rgba(0,0,0,0.1);
    font-weight: 700;
  }
  .tour-tab:hover:not(.active) {
    color: var(--gray-800, #343a40);
  }

  /* ── Player grid ── */
  .players-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.75rem;
  }
  @media (min-width: 500px) {
    .players-grid { grid-template-columns: repeat(4, 1fr); }
  }

  .player-tile {
    background: #fff;
    border: 2px solid #dee2e6;
    border-radius: 14px;
    cursor: pointer;
    padding: 1.25rem 0.75rem 1.1rem;
    text-align: center;
    transition: all 0.18s ease;
    position: relative;
    box-shadow: 0 2px 8px rgba(0,0,0,0.08);
    user-select: none;
    -webkit-user-select: none;
  }
  .player-tile:hover {
    border-color: #2d8c3c;
    box-shadow: 0 6px 20px rgba(45,140,60,0.18);
    transform: translateY(-3px);
    background: #f6fff7;
  }
  .player-tile.selected {
    border-color: #2d8c3c;
    border-width: 2px;
    background: #eaf7ec;
    box-shadow: 0 0 0 2px #2d8c3c, 0 6px 20px rgba(45,140,60,0.18);
    transform: translateY(-2px);
  }
  .player-tile.dimmed {
    opacity: 0.28;
    transform: none !important;
    box-shadow: 0 2px 8px rgba(0,0,0,0.08) !important;
    border-color: #dee2e6 !important;
    background: #fff !important;
  }

  .tile-check {
    position: absolute;
    top: 8px;
    right: 8px;
    background: #2d8c3c;
    color: #fff;
    width: 20px;
    height: 20px;
    border-radius: 50%;
    font-size: 0.65rem;
    font-weight: 900;
    display: none;
    align-items: center;
    justify-content: center;
    line-height: 1;
  }
  .player-tile.selected .tile-check { display: flex; }

  .tile-flag-img {
    display: block;
    margin: 0 auto 0.65rem;
    border-radius: 3px;
    box-shadow: 0 1px 4px rgba(0,0,0,0.15);
    width: 40px;
    height: 27px;
    object-fit: cover;
  }
  .tile-name {
    font-family: 'Oswald', var(--font-heading, sans-serif);
    font-size: 0.85rem;
    font-weight: 600;
    color: #212529;
    line-height: 1.2;
    margin-bottom: 0.3rem;
    text-transform: uppercase;
    letter-spacing: 0.3px;
  }
  .tile-label {
    font-size: 0.63rem;
    color: #868e96;
    line-height: 1.3;
  }
  .player-tile.selected .tile-name { color: #1e6b2b; }
  .player-tile.selected .tile-label { color: #2d8c3c; }

  /* ── Result card ── */
  #result-box {
    display: none;
    margin-top: 2rem;
  }
  #result-card {
    background: url('/images/rg-card-template.png') center/cover no-repeat;
    border-radius: 16px;
    aspect-ratio: 16/9;
    width: 100%;
    position: relative;
    overflow: hidden;
    margin-bottom: 1rem;
    box-shadow: 0 4px 20px rgba(0,0,0,0.15);
  }
  .rc-player-overlay {
    position: absolute;
    top: 35%;
    left: 9.9%;
    max-width: 48%;
  }
  .rc-flag-img {
    display: block;
    width: 44px;
    height: 30px;
    object-fit: cover;
    border-radius: 3px;
    box-shadow: 0 1px 4px rgba(0,0,0,0.3);
    margin-bottom: 0.5rem;
  }
  .rc-player-name {
    font-family: 'Oswald', sans-serif;
    font-size: clamp(1.1rem, 3.5vw, 2rem);
    font-weight: 700;
    color: #000;
    line-height: 1.05;
    margin-bottom: 0.25rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  .rc-player-note {
    font-size: clamp(0.6rem, 1.5vw, 0.8rem);
    color: #333;
    font-weight: 500;
  }

  /* ── Action buttons ── */
  .result-actions {
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }
  .share-row {
    display: flex;
    gap: 0.5rem;
  }
  .btn-share {
    flex: 1;
    border-radius: 10px;
    color: #fff;
    font-size: 0.9rem;
    font-weight: 700;
    padding: 0.85rem;
    text-align: center;
    text-decoration: none;
    display: block;
    transition: opacity 0.2s;
  }
  .btn-share:hover { opacity: 0.85; color: #fff; }
  .btn-fb { background: #1877f2; }
  .btn-li { background: #0a66c2; }
  .btn-download {
    background: var(--court-green, #2d8c3c);
    border-radius: 10px;
    color: #fff;
    cursor: pointer;
    font-size: 0.9rem;
    font-weight: 700;
    padding: 0.85rem;
    transition: background 0.2s;
    border: none;
  }
  .btn-download:hover { background: var(--court-green-dark, #1e6b2b); }
  .btn-change {
    background: transparent;
    border: none;
    color: var(--gray-500, #adb5bd);
    cursor: pointer;
    font-size: 0.82rem;
    padding: 0.5rem;
    transition: color 0.2s;
  }
  .btn-change:hover { color: var(--gray-700, #495057); }
  .share-hint {
    text-align: center;
    font-size: 0.82rem;
    color: #868e96;
    margin-top: 0.25rem;
  }
</style>

<div class="rg-section">
  <div class="rg-wrap">
    <div class="rg-header">
      <span class="clay-badge">Roland Garros 2026 · May 25 – June 8</span>
      <h1>Who Will Win?</h1>
      <p>Pick your champion — one tap, shareable card</p>
    </div>

    <div class="tour-tabs">
      <button class="tour-tab active" onclick="switchTour('atp', this)">Men's ATP</button>
      <button class="tour-tab" onclick="switchTour('wta', this)">Women's WTA</button>
    </div>

    <div id="grid-atp" class="players-grid"></div>
    <div id="grid-wta" class="players-grid" style="display:none"></div>

    <div id="result-box">
      <div id="result-card">
        <div class="rc-player-overlay">
          <img class="rc-flag-img" id="rc-flag-img" src="" alt="" width="44" height="30">
          <div class="rc-player-name" id="rc-name"></div>
          <div class="rc-player-note" id="rc-note"></div>
        </div>
      </div>
      <div class="result-actions">
        <button class="btn-download" onclick="downloadCard()">💾 Save as Image</button>
        <div class="share-row">
          <a class="btn-share btn-fb" id="btn-fb" href="https://www.facebook.com/sharer/sharer.php?u=https%3A%2F%2Fsuper.tennis%2Froland-garros-bracket" target="_blank" rel="noopener">f Share</a>
          <a class="btn-share btn-li" id="btn-li" href="https://www.linkedin.com/sharing/share-offsite/?url=https%3A%2F%2Fsuper.tennis%2Froland-garros-bracket" target="_blank" rel="noopener">in Share</a>
        </div>
        <button class="btn-change" onclick="changePick()">↺ Change my pick</button>
      </div>
      <p class="share-hint">💡 Save the card and post it on Instagram or attach it to any post</p>
    </div>
  </div>
</div>

<script is:inline>
const PLAYERS = {
  atp: [
    { cc: 'es', name: 'Carlos Alcaraz',    note: 'Defending Champion' },
    { cc: 'it', name: 'Jannik Sinner',     note: 'World No. 1' },
    { cc: 'de', name: 'Alexander Zverev',  note: '3× finalist' },
    { cc: 'rs', name: 'Novak Djokovic',    note: 'Won RG 2023' },
    { cc: 'no', name: 'Casper Ruud',       note: '3× finalist' },
    { cc: 'gr', name: 'Stefanos Tsitsipas',note: 'Finalist 2021' },
    { cc: 'dk', name: 'Holger Rune',       note: 'Clay specialist' },
    { cc: 'ru', name: 'Andrey Rublev',     note: 'Top 10 clay' },
  ],
  wta: [
    { cc: 'pl', name: 'Iga Swiatek',       note: '4× champion' },
    { cc: 'by', name: 'Aryna Sabalenka',   note: 'World No. 2' },
    { cc: 'us', name: 'Coco Gauff',        note: 'US Open champion' },
    { cc: 'kz', name: 'Elena Rybakina',    note: 'Wimbledon champion' },
    { cc: 'it', name: 'Jasmine Paolini',   note: 'Finalist 2024' },
    { cc: 'ru', name: 'Mirra Andreeva',    note: 'Rising star' },
    { cc: 'cz', name: 'Karolína Muchová',  note: 'Finalist 2023' },
    { cc: 'ru', name: 'Daria Kasatkina',   note: 'Clay specialist' },
  ],
};

let activeTour = 'atp';
let currentPick = null;

function renderGrid(tour) {
  const grid = document.getElementById(`grid-${tour}`);
  grid.innerHTML = PLAYERS[tour].map((p, i) => `
    <div class="player-tile" id="tile-${tour}-${i}" onclick="pickPlayer('${tour}', ${i})">
      <div class="tile-check">✓</div>
      <img class="tile-flag-img" src="https://flagcdn.com/w40/${p.cc}.png" width="36" height="24" alt="${p.name}" loading="lazy">
      <div class="tile-name">${p.name}</div>
      <div class="tile-label">${p.note}</div>
    </div>
  `).join('');
}

function pickPlayer(tour, idx) {
  const player = PLAYERS[tour][idx];
  currentPick = { tour, idx, player };

  document.querySelectorAll(`#grid-${tour} .player-tile`).forEach((t, i) => {
    t.classList.toggle('selected', i === idx);
    t.classList.toggle('dimmed', i !== idx);
  });

  const flagEl = document.getElementById('rc-flag-img');
  flagEl.src = `https://flagcdn.com/w40/${player.cc}.png`;
  flagEl.alt = player.name;
  document.getElementById('rc-name').textContent = player.name;
  document.getElementById('rc-note').textContent = player.note;

  document.getElementById('result-box').style.display = 'block';
  document.getElementById('result-box').scrollIntoView({ behavior: 'smooth', block: 'nearest' });
}

function switchTour(tour, el) {
  activeTour = tour;
  currentPick = null;
  document.querySelectorAll('.tour-tab').forEach(t => t.classList.remove('active'));
  el.classList.add('active');
  document.getElementById('grid-atp').style.display = tour === 'atp' ? 'grid' : 'none';
  document.getElementById('grid-wta').style.display = tour === 'wta' ? 'grid' : 'none';
  document.getElementById('result-box').style.display = 'none';
}

function changePick() {
  if (!currentPick) return;
  document.querySelectorAll(`#grid-${currentPick.tour} .player-tile`).forEach(t => {
    t.classList.remove('selected', 'dimmed');
  });
  document.getElementById('result-box').style.display = 'none';
  currentPick = null;
}

function downloadCard() {
  if (!currentPick) return;
  const { player, tour } = currentPick;

  const canvas = document.createElement('canvas');
  canvas.width = 1600;
  canvas.height = 900;
  const ctx = canvas.getContext('2d');

  const img = new Image();
  img.crossOrigin = 'anonymous';
  img.onload = () => {
    ctx.drawImage(img, 0, 0, 1600, 900);

    // Flag image overlay
    const flagImg = new Image();
    flagImg.crossOrigin = 'anonymous';

    function drawNameAndSave(flagDrawn) {
      if (flagDrawn) {
        ctx.drawImage(flagImg, 158, 320, 72, 48);
      } else {
        // fallback: text country code
        ctx.font = 'bold 40px Arial';
        ctx.fillStyle = '#333';
        ctx.fillText(player.cc.toUpperCase(), 158, 322);
      }
      ctx.textBaseline = 'top';
      ctx.fillStyle = '#000000';
      const nameUpper = player.name.toUpperCase();
      let fontSize = 100;
      do {
        ctx.font = `900 ${fontSize}px Arial, sans-serif`;
        fontSize -= 4;
      } while (ctx.measureText(nameUpper).width > 620 && fontSize > 40);
      ctx.fillText(nameUpper, 158, 390);
      ctx.font = '500 32px Arial, sans-serif';
      ctx.fillStyle = '#333333';
      ctx.fillText(player.note, 160, 390 + fontSize + 14);
      const tourLabel = tour === 'atp' ? 'ATP' : 'WTA';
      ctx.font = 'bold 26px Arial, sans-serif';
      ctx.fillStyle = '#555555';
      ctx.fillText(tourLabel, 160, 390 + fontSize + 58);
      try {
        const link = document.createElement('a');
        link.download = `rg2026-${player.name.replace(/\s+/g, '-').toLowerCase()}.png`;
        link.href = canvas.toDataURL('image/png');
        link.click();
      } catch(e) {
        alert('Не удалось сохранить: ' + e.message);
      }
    }

    flagImg.onload = () => drawNameAndSave(true);
    flagImg.onerror = () => drawNameAndSave(false);
    flagImg.src = `https://flagcdn.com/w40/${player.cc}.png`;
  };
  img.src = '/images/rg-card-template.png';
}

renderGrid('atp');
renderGrid('wta');
</script>

</BaseLayout>
