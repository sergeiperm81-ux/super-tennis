---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Roland Garros 2026 Winner Prediction — Who Will Win?"
  description="Pick who you think will win Roland Garros 2026. ATP & WTA top contenders — one tap, shareable card. Make your prediction!"
>

<style>
  .rg-wrap {
    max-width: 680px;
    margin: 0 auto;
    padding: 2rem 1rem 4rem;
  }

  .rg-header {
    text-align: center;
    margin-bottom: 1.75rem;
  }
  .clay-badge {
    background: rgba(180,80,30,0.2);
    border: 1px solid rgba(180,80,30,0.4);
    border-radius: 20px;
    color: #e8845a;
    display: inline-block;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 1px;
    margin-bottom: 0.75rem;
    padding: 0.3rem 0.9rem;
    text-transform: uppercase;
  }
  .rg-header h1 {
    font-size: clamp(1.5rem, 4vw, 2.1rem);
    font-weight: 800;
    color: var(--text-primary, #fff);
    margin-bottom: 0.4rem;
  }
  .rg-header p {
    color: var(--text-secondary, #aaa);
    font-size: 0.95rem;
  }

  /* Tabs */
  .tour-tabs {
    display: flex;
    background: rgba(255,255,255,0.05);
    border-radius: 12px;
    margin-bottom: 1.75rem;
    padding: 4px;
    gap: 4px;
  }
  .tour-tab {
    background: none;
    border: none;
    border-radius: 9px;
    color: rgba(255,255,255,0.45);
    cursor: pointer;
    flex: 1;
    font-size: 0.9rem;
    font-weight: 700;
    padding: 0.65rem;
    transition: all 0.2s;
  }
  .tour-tab.active {
    background: rgba(255,255,255,0.1);
    color: #e8c547;
  }

  /* Player grid */
  .players-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.75rem;
  }
  @media (min-width: 480px) {
    .players-grid { grid-template-columns: repeat(4, 1fr); }
  }

  .player-tile {
    background: rgba(255,255,255,0.04);
    border: 2px solid rgba(255,255,255,0.08);
    border-radius: 16px;
    cursor: pointer;
    padding: 1rem 0.5rem;
    text-align: center;
    transition: all 0.18s;
    position: relative;
    overflow: hidden;
  }
  .player-tile:hover {
    background: rgba(232,197,71,0.08);
    border-color: rgba(232,197,71,0.4);
    transform: translateY(-2px);
  }
  .player-tile.selected {
    background: rgba(232,197,71,0.15);
    border-color: #e8c547;
  }
  .player-tile.dimmed {
    opacity: 0.3;
    transform: none;
  }
  .tile-flag {
    font-size: 1.6rem;
    display: block;
    margin-bottom: 0.3rem;
  }
  .tile-name {
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--text-primary, #fff);
    line-height: 1.2;
    margin-bottom: 0.3rem;
  }
  .tile-label {
    font-size: 0.65rem;
    color: rgba(255,255,255,0.4);
    line-height: 1.3;
  }
  .player-tile.selected .tile-label { color: #e8c547; }
  .tile-check {
    position: absolute;
    top: 6px;
    right: 8px;
    color: #e8c547;
    font-size: 0.9rem;
    display: none;
  }
  .player-tile.selected .tile-check { display: block; }

  /* Result card */
  #result-box {
    display: none;
    margin-top: 1.75rem;
  }
  #result-card {
    background: #a9e040;
    border-radius: 20px;
    padding: 1.75rem 1.5rem 1.5rem;
    margin-bottom: 1rem;
    position: relative;
    overflow: hidden;
    min-height: 160px;
  }
  .rc-event {
    font-size: 0.78rem;
    font-weight: 800;
    color: #1a1a1a;
    letter-spacing: 1px;
    text-transform: uppercase;
    margin-bottom: 0.4rem;
  }
  .rc-pick-label {
    font-size: 0.72rem;
    font-weight: 700;
    color: #333;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 0.35rem;
  }
  .rc-player-flag { font-size: 1.6rem; display: block; margin-bottom: 0.15rem; }
  .rc-player-name {
    font-size: clamp(1.4rem, 5vw, 2rem);
    font-weight: 900;
    color: #000;
    line-height: 1.1;
    margin-bottom: 0.2rem;
    text-transform: uppercase;
  }
  .rc-player-note {
    font-size: 0.75rem;
    color: #333;
    margin-bottom: 0;
  }
  .rc-site {
    position: absolute;
    bottom: 1rem;
    left: 1.5rem;
    font-size: 0.65rem;
    font-weight: 800;
    letter-spacing: 1.5px;
    color: #1a1a1a;
    text-transform: uppercase;
  }

  /* Action buttons */
  .result-actions {
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }
  .btn-twitter {
    background: #000;
    border: 1px solid rgba(255,255,255,0.2);
    border-radius: 12px;
    color: #fff;
    cursor: pointer;
    font-size: 0.95rem;
    font-weight: 700;
    padding: 0.9rem;
    text-align: center;
    text-decoration: none;
    display: block;
    transition: background 0.2s;
  }
  .btn-twitter:hover { background: #111; }
  .btn-download {
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 12px;
    color: rgba(255,255,255,0.8);
    cursor: pointer;
    font-size: 0.9rem;
    font-weight: 600;
    padding: 0.85rem;
    transition: background 0.2s;
  }
  .btn-download:hover { background: rgba(255,255,255,0.1); }
  .btn-change {
    background: transparent;
    border: none;
    color: rgba(255,255,255,0.35);
    cursor: pointer;
    font-size: 0.82rem;
    padding: 0.5rem;
    transition: color 0.2s;
  }
  .btn-change:hover { color: rgba(255,255,255,0.7); }
</style>

<div class="rg-wrap">
  <div class="rg-header">
    <span class="clay-badge">🏺 Roland Garros 2026 · May 25 – June 8</span>
    <h1>Who Will Win?</h1>
    <p>Pick your champion — one tap, shareable card</p>
  </div>

  <div class="tour-tabs">
    <button class="tour-tab active" onclick="switchTour('atp', this)">🎾 Men's ATP</button>
    <button class="tour-tab" onclick="switchTour('wta', this)">🎾 Women's WTA</button>
  </div>

  <div id="grid-atp" class="players-grid"></div>
  <div id="grid-wta" class="players-grid" style="display:none"></div>

  <div id="result-box">
    <div id="result-card">
      <div class="rc-event">ROLAND GARROS 2026</div>
      <div class="rc-pick-label">My pick to win</div>
      <span class="rc-player-flag" id="rc-flag"></span>
      <div class="rc-player-name" id="rc-name"></div>
      <div class="rc-player-note" id="rc-note"></div>
      <div class="rc-site">SUPER.TENNIS</div>
    </div>
    <div class="result-actions">
      <a id="btn-twitter" class="btn-twitter" href="#" target="_blank" rel="noopener">
        𝕏 Share on Twitter / X
      </a>
      <button class="btn-download" onclick="downloadCard()">💾 Save as Image</button>
      <button class="btn-change" onclick="changePick()">↺ Change my pick</button>
    </div>
  </div>
</div>

<script is:inline>
const PLAYERS = {
  atp: [
    { flag: '🇪🇸', name: 'Carlos Alcaraz',    note: 'Defending Champion' },
    { flag: '🇮🇹', name: 'Jannik Sinner',     note: 'World No. 1' },
    { flag: '🇩🇪', name: 'Alexander Zverev',  note: '3× finalist' },
    { flag: '🇷🇸', name: 'Novak Djokovic',    note: 'Won RG 2023' },
    { flag: '🇳🇴', name: 'Casper Ruud',       note: '3× finalist' },
    { flag: '🇬🇷', name: 'Stefanos Tsitsipas',note: 'Finalist 2021' },
    { flag: '🇩🇰', name: 'Holger Rune',       note: 'Clay specialist' },
    { flag: '🇷🇺', name: 'Andrey Rublev',     note: 'Top 10 clay' },
  ],
  wta: [
    { flag: '🇵🇱', name: 'Iga Swiatek',       note: '4× champion' },
    { flag: '🇧🇾', name: 'Aryna Sabalenka',   note: 'World No. 2' },
    { flag: '🇺🇸', name: 'Coco Gauff',        note: 'US Open champion' },
    { flag: '🇰🇿', name: 'Elena Rybakina',    note: 'Wimbledon champion' },
    { flag: '🇮🇹', name: 'Jasmine Paolini',   note: 'Finalist 2024' },
    { flag: '🇷🇺', name: 'Mirra Andreeva',    note: 'Rising star' },
    { flag: '🇨🇿', name: 'Karolína Muchová',  note: 'Finalist 2023' },
    { flag: '🇷🇺', name: 'Daria Kasatkina',   note: 'Clay specialist' },
  ],
};

let activeTour = 'atp';
let currentPick = null;

function renderGrid(tour) {
  const grid = document.getElementById(`grid-${tour}`);
  grid.innerHTML = PLAYERS[tour].map((p, i) => `
    <div class="player-tile" id="tile-${tour}-${i}" onclick="pickPlayer('${tour}', ${i})">
      <span class="tile-check">✓</span>
      <span class="tile-flag">${p.flag}</span>
      <div class="tile-name">${p.name}</div>
      <div class="tile-label">${p.note}</div>
    </div>
  `).join('');
}

function pickPlayer(tour, idx) {
  const player = PLAYERS[tour][idx];
  currentPick = { tour, idx, player };

  // Update tile states
  document.querySelectorAll(`#grid-${tour} .player-tile`).forEach((t, i) => {
    t.classList.toggle('selected', i === idx);
    t.classList.toggle('dimmed', i !== idx);
  });

  // Fill result card
  document.getElementById('rc-flag').textContent = player.flag;
  document.getElementById('rc-name').textContent = player.name;
  document.getElementById('rc-note').textContent = player.note;

  // Twitter link
  const tourLabel = tour === 'atp' ? 'ATP' : 'WTA';
  const tweet = `My Roland Garros 2026 ${tourLabel} pick: ${player.flag} ${player.name} 🏆\n\nWho's your pick? 👇\nsuper.tennis/roland-garros-bracket`;
  document.getElementById('btn-twitter').href = `https://twitter.com/intent/tweet?text=${encodeURIComponent(tweet)}`;

  // Show result
  document.getElementById('result-box').style.display = 'block';
  document.getElementById('result-box').scrollIntoView({ behavior: 'smooth', block: 'nearest' });
}

function switchTour(tour, el) {
  activeTour = tour;
  currentPick = null;
  document.querySelectorAll('.tour-tab').forEach(t => t.classList.remove('active'));
  el.classList.add('active');
  document.getElementById('grid-atp').style.display = tour === 'atp' ? 'grid' : 'none';
  document.getElementById('grid-wta').style.display = tour === 'wta' ? 'grid' : 'none';
  document.getElementById('result-box').style.display = 'none';
}

function changePick() {
  if (!currentPick) return;
  document.querySelectorAll(`#grid-${currentPick.tour} .player-tile`).forEach(t => {
    t.classList.remove('selected', 'dimmed');
  });
  document.getElementById('result-box').style.display = 'none';
  currentPick = null;
}

function downloadCard() {
  if (!currentPick) return;
  const { player, tour } = currentPick;

  const canvas = document.createElement('canvas');
  canvas.width = 1600;
  canvas.height = 900;
  const ctx = canvas.getContext('2d');

  const img = new Image();
  img.onload = () => {
    // 1. Draw Canva template (lime green bg + tennis player photo + ROLAND GARROS + SUPER.TENNIS)
    ctx.drawImage(img, 0, 0, 1600, 900);

    // 2. Flag emoji — left column, below "MY PICK TO WIN" label
    ctx.font = '72px serif';
    ctx.textBaseline = 'top';
    ctx.fillText(player.flag, 158, 320);

    // 3. Player name — bold, black, uppercase
    ctx.textBaseline = 'top';
    ctx.fillStyle = '#000000';
    const nameUpper = player.name.toUpperCase();
    // Fit text within ~620px (left content area)
    let fontSize = 100;
    do {
      ctx.font = `900 ${fontSize}px Arial, sans-serif`;
      fontSize -= 4;
    } while (ctx.measureText(nameUpper).width > 620 && fontSize > 40);
    ctx.fillText(nameUpper, 158, 415);

    // 4. Note / subtitle
    ctx.font = '500 32px Arial, sans-serif';
    ctx.fillStyle = '#333333';
    ctx.fillText(player.note, 160, 415 + fontSize + 12);

    // 5. Tour badge (ATP / WTA)
    const tourLabel = tour === 'atp' ? 'ATP' : 'WTA';
    ctx.font = 'bold 26px Arial, sans-serif';
    ctx.fillStyle = '#555555';
    ctx.fillText(tourLabel, 160, 415 + fontSize + 56);

    // 6. Download
    const link = document.createElement('a');
    link.download = `rg2026-${player.name.replace(/\s+/g, '-').toLowerCase()}.png`;
    link.href = canvas.toDataURL('image/png');
    link.click();
  };
  img.src = '/images/rg-card-template.png';
}

// Init
renderGrid('atp');
renderGrid('wta');
</script>

</BaseLayout>
