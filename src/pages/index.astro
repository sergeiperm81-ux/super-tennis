<script>
  // News category filter
  const nfBtns = document.querySelectorAll('.nf-btn');
  const newsItems = document.querySelectorAll<HTMLElement>('.news-item');

  nfBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      nfBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      const cat = (btn as HTMLElement).dataset.cat || 'all';
      newsItems.forEach(item => {
        if (cat === 'all' || item.dataset.cat === cat) {
          item.style.display = '';
        } else {
          item.style.display = 'none';
        }
      });
    });
  });
</script>
<script src="/js/dynamic-content.js" defer></script>
