---
import BaseLayout from '../layouts/BaseLayout.astro';
import LiteYouTube from '../components/LiteYouTube.astro';
import { getLatestRankings, getPlayerBySlug, getArticles } from '../lib/supabase';
import { countryFlags, fallbackPlayers, getFlagUrl } from '../lib/fallback-data';

// Helper to get player photo by slug
async function getPlayerPhoto(slug: string): Promise<string> {
  try {
    const p = await getPlayerBySlug(slug);
    if (p?.image_url) return p.image_url;
  } catch {}
  return fallbackPlayers[slug]?.image_url || '';
}

// Fetch real sidebar data from Supabase
let atpTop5: any[] = [];
let sidebarPlayer: any = null;
try {
  const rankings = await getLatestRankings('atp', 5);
  atpTop5 = rankings.map((r: any) => ({
    rank: r.ranking,
    name: `${r.players?.first_name} ${r.players?.last_name}`,
    slug: r.players?.slug,
    country: r.players?.country_code || '',
    points: r.points?.toLocaleString() || '0',
  }));
  sidebarPlayer = await getPlayerBySlug('jannik-sinner');
} catch (e) {
  console.warn('Homepage: Supabase unavailable for sidebar');
}

// Fallback sidebar data
if (atpTop5.length === 0) {
  atpTop5 = [
    { rank: 1, name: 'Jannik Sinner', slug: 'jannik-sinner', country: 'ITA', points: '11,830' },
    { rank: 2, name: 'Alexander Zverev', slug: 'alexander-zverev', country: 'GER', points: '9,855' },
    { rank: 3, name: 'Carlos Alcaraz', slug: 'carlos-alcaraz', country: 'ESP', points: '7,190' },
    { rank: 4, name: 'Novak Djokovic', slug: 'novak-djokovic', country: 'SRB', points: '6,875' },
    { rank: 5, name: 'Daniil Medvedev', slug: 'daniil-medvedev', country: 'RUS', points: '6,445' },
  ];
}

if (!sidebarPlayer) {
  sidebarPlayer = fallbackPlayers['jannik-sinner'] || {
    first_name: 'Jannik', last_name: 'Sinner', country_code: 'ITA',
    career_titles: 19, grand_slam_titles: 3, slug: 'jannik-sinner',
    image_url: '',
  };
}

// Fetch real player photos for homepage cards
const [sinnerPhoto, djokovicPhoto, swiatekPhoto, alcarazPhoto, federerPhoto,
       nadalPhoto, serenaPhoto, zverevPhoto, sabalenkaPhoto, gauffPhoto] = await Promise.all([
  getPlayerPhoto('jannik-sinner'),
  getPlayerPhoto('novak-djokovic'),
  getPlayerPhoto('iga-swiatek'),
  getPlayerPhoto('carlos-alcaraz'),
  getPlayerPhoto('roger-federer'),
  getPlayerPhoto('rafael-nadal'),
  getPlayerPhoto('serena-williams'),
  getPlayerPhoto('alexander-zverev'),
  getPlayerPhoto('aryna-sabalenka'),
  getPlayerPhoto('coco-gauff'),
]);

// Homepage JSON-LD
const homepageJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'SUPER.TENNIS',
  url: 'https://super.tennis',
  description: 'Tennis for everyone. Players, records, gear, lifestyle — the world of tennis beyond the court.',
  publisher: {
    '@type': 'Organization',
    name: 'SUPER.TENNIS',
    url: 'https://super.tennis',
  },
};

// Badge colors
const badgeColors: Record<string, string> = {
  PLAYERS: '#4CAF50',
  RECORDS: '#FF9800',
  GEAR: '#2196F3',
  LIFESTYLE: '#E91E63',
  MONEY: '#FFD700',
  RANKINGS: '#9C27B0',
  TOURNAMENTS: '#00BCD4',
  H2H: '#FF5722',
};

// 2. Row of 3 vertical cards
const row3a = [
  {
    title: "Iga Swiatek Returns to World No. 1 After Miami Open Victory",
    badge: "PLAYERS",
    image: swiatekPhoto,
    href: "/players/iga-swiatek/",
  },
  {
    title: "Most Grand Slam Titles of All Time — Men's & Women's",
    badge: "RECORDS",
    image: nadalPhoto,
    href: "/records/most-grand-slam-titles/",
  },
  {
    title: "Best Tennis Rackets for Beginners in 2026",
    badge: "GEAR",
    image: gauffPhoto,
    href: "/gear/best-tennis-rackets-beginners/",
  },
];

// 3. Full-width heroes
const hero2 = {
  title: "Boris Becker Sold His 1989 US Open Trophy for $357,000 — Here Is Why",
  badge: "LIFESTYLE",
  image: 'https://upload.wikimedia.org/wikipedia/commons/c/cb/Boris_Becker_-_240422_174721_%28cropped%29.jpg',
  href: "/lifestyle/boris-becker-sells-1989-us-open-trophy/",
  desc: "A six-time Grand Slam champion parted with the one piece of silverware a tennis player is supposed to keep forever. The story behind the sale — and what it says about life after the tour.",
  imagePosition: 'center 25%',
};
const hero3 = {
  title: "Tennis in Movies & TV Shows — The Greatest Tennis Scenes in Cinema",
  badge: "LIFESTYLE",
  image: 'https://upload.wikimedia.org/wikipedia/commons/9/91/Cast_of_Challengers_2024.jpg',
  href: "/lifestyle/tennis-in-movies-tv-shows/",
  desc: "From Hitchcock's Strangers on a Train to Challengers — the most iconic tennis scenes in film history.",
};
const hero5 = {
  title: "Your Complete Guide to Wimbledon",
  badge: "TOURNAMENTS",
  image: '/images/tournaments/wimbledon.webp',
  href: "/tournaments/wimbledon-guide/",
  desc: "Everything you need to know about the world's most prestigious tennis tournament.",
};

// 4. Row of 2 vertical cards
const row2 = [
  {
    title: "How Novak Djokovic Built a $250 Million Empire",
    badge: "MONEY",
    image: djokovicPhoto,
    href: "/players/novak-djokovic/",
  },
  {
    title: "Roger Federer's Net Worth — $550 Million Tennis Empire",
    badge: "MONEY",
    image: federerPhoto,
    href: "/players/roger-federer/",
  },
];

// 5. Compact horizontal cards
const compactCards = [
  {
    title: "Fastest Serves in Tennis History — Updated Rankings",
    badge: "RECORDS",
    image: zverevPhoto,
    href: "/records/fastest-serve-tennis/",
  },
  {
    title: "Tennis Rules Explained — A Complete Beginner's Guide",
    badge: "LIFESTYLE",
    image: alcarazPhoto,
    href: "/lifestyle/tennis-rules-explained/",
  },
];

// 6. Horizontal feature card
const featureCard = {
  title: "Tennis Fashion Through the Decades — From Victorian Corsets to Nike Collabs",
  badge: "LIFESTYLE",
  image: '/images/tennis-fashion-cover.webp',
  href: "/lifestyle/tennis-fashion-through-decades/",
  desc: "A visual journey through 140 years of tennis fashion — from ankle-length skirts to Serena's catsuits.",
};

// 7. Hero 4
const hero4 = {
  title: "The Match That Changed Tennis: A New Documentary Revisits Djokovic vs Nadal, 2012 Australian Open",
  badge: "LIFESTYLE",
  image: '/images/tournaments/melbourne-park.webp',
  href: "/lifestyle/the-match-that-changed-tennis-2012-australian-open-documentary/",
  desc: "Five hours and fifty-three minutes. One trophy ceremony where both finalists had to sit down. A fresh Discovery+ documentary now asks what that night actually was.",
};

// 8. Second row of 3 vertical cards
const row3b = [
  {
    title: "What Racket Does Rafael Nadal Use?",
    badge: "GEAR",
    image: nadalPhoto,
    href: "/players/rafael-nadal/",
  },
  {
    title: "Aryna Sabalenka — Dominating Women's Tennis",
    badge: "PLAYERS",
    image: sabalenkaPhoto,
    href: "/players/aryna-sabalenka/",
  },
  {
    title: "The GOAT Debate — Who Is the Greatest Tennis Player?",
    badge: "RECORDS",
    image: djokovicPhoto,
    href: "/records/tennis-goat-debate/",
  },
];

// Fetch articles from each category to ensure representation in More Stories
let latestArticles: any[] = [];
try {
  const editorialSlugs = new Set([
    'most-grand-slam-titles', 'fastest-serve-tennis', 'most-weeks-number-one',
    'tennis-goat-debate', 'best-tennis-rackets-beginners', 'tennis-rules-explained',
  ]);
  const cats = ['players', 'vs', 'records', 'gear', 'lifestyle', 'tournaments'];
  const perCat = await Promise.all(
    cats.map(c => getArticles({ category: c, limit: 5 }))
  );
  // Take 2 from each category, then fill remaining slots
  const picked = new Set<string>();
  const result: any[] = [];
  for (const articles of perCat) {
    let count = 0;
    for (const a of articles) {
      if (count >= 2) break;
      if (!editorialSlugs.has(a.slug) && a.title && a.category && !picked.has(a.slug)) {
        result.push(a);
        picked.add(a.slug);
        count++;
      }
    }
  }
  // Fill remaining slots up to 18 total (round-robin from leftovers)
  for (const articles of perCat) {
    for (const a of articles) {
      if (result.length >= 18) break;
      if (!editorialSlugs.has(a.slug) && a.title && a.category && !picked.has(a.slug)) {
        result.push(a);
        picked.add(a.slug);
      }
    }
  }
  latestArticles = result;
} catch (e) {
  console.warn('Homepage: Failed to fetch articles for news section');
}

// News and videos are now loaded client-side via dynamic-content.js
// No SSG fetch needed — data comes from Worker API at runtime

// Map category to URL prefix
const categoryUrl: Record<string, string> = {
  players: '/players/',
  records: '/records/',
  gear: '/gear/',
  lifestyle: '/lifestyle/',
  tournaments: '/tournaments/',
  vs: '/vs/',
};

// Build correct URL for an article (handles player sub-pages)
function articleUrl(art: { category: string; slug: string }): string {
  if (art.category === 'players') {
    // All player content is now on the main profile page (sub-pages consolidated 2026-04-02)
    // Extract base player slug from slugs like "coco-gauff-racket" or "djokovic-net-worth"
    const subPageSuffixes = ['-racket', '-net-worth', '-stats', '-grand-slams', '-career-timeline', '-partner', '-age'];
    const baseSlugs = subPageSuffixes.reduce((slug, suffix) => slug.endsWith(suffix) ? slug.slice(0, -suffix.length) : slug, art.slug);
    return `/players/${baseSlugs}/`;
  }
  return `${categoryUrl[art.category] || '/'}${art.slug}/`;
}

// Category display labels & colors
const categoryLabels: Record<string, string> = {
  players: 'Players',
  records: 'Records',
  gear: 'Gear',
  lifestyle: 'Lifestyle',
  tournaments: 'Tournaments',
  vs: 'H2H',
};
const categoryColors: Record<string, string> = {
  players: '#4CAF50',
  records: '#FF9800',
  gear: '#2196F3',
  lifestyle: '#E91E63',
  tournaments: '#00BCD4',
  vs: '#FF5722',
};

// Sidebar data
const recentScores = [
  { p1: 'J. Sinner', p2: 'C. Alcaraz', score: '6-4  3-6  7-6', tournament: 'Indian Wells Masters', round: 'Final', winner: 1 },
  { p1: 'A. Sabalenka', p2: 'I. Swiatek', score: '7-5  6-3', tournament: 'Dubai Open', round: 'Final', winner: 1 },
  { p1: 'N. Djokovic', p2: 'D. Medvedev', score: '6-7  6-4  6-2', tournament: 'Australian Open', round: 'SF', winner: 1 },
];

// Build sidebar player profile from real data
const profilePlayer = sidebarPlayer || fallbackPlayers['jannik-sinner'];
const playerProfile = profilePlayer ? {
  name: `${profilePlayer.first_name} ${profilePlayer.last_name}`,
  country: profilePlayer.country_code || '',
  flag: countryFlags[profilePlayer.country_code || ''] || '',
  ranking: 1,
  titles: profilePlayer.career_titles || 0,
  grandSlams: profilePlayer.grand_slam_titles || 0,
  image: profilePlayer.image_url || sinnerPhoto,
  href: `/players/${profilePlayer.slug}/`,
  wl: `${profilePlayer.career_win || 0}-${profilePlayer.career_loss || 0}`,
} : {
  name: 'Jannik Sinner', country: 'ITA', flag: '', ranking: 1, titles: 19, grandSlams: 3,
  image: sinnerPhoto,
  href: '/players/jannik-sinner/', wl: '0-0',
};
---

<BaseLayout title="Home" jsonLd={homepageJsonLd} dynamicContent={true}>
  <!-- TRENDING NOW ticker bar -->
  <div class="trending-bar" id="trending-bar">
    <div class="trending-bar__label">TRENDING</div>
    <div class="trending-bar__track">
      <div class="trending-bar__scroll" id="trending-scroll">
        <!-- Populated by JS from latest news -->
      </div>
    </div>
  </div>

  <div class="news-page">
    <div class="container">
      <div class="news-layout">
        <!-- ========== MAIN CONTENT COLUMN ========== -->
        <main class="news-main">

          <!-- TENNIS BUZZ — Daily News (loaded client-side) -->
          <section class="buzz-section">
            <div class="buzz-header">
              <div class="buzz-header__left">
                <span class="buzz-dot"></span>
                <h2 class="buzz-title">What's Hot</h2>
              </div>
              <a href="/news/" class="buzz-all">All news &rarr;</a>
            </div>
            <div class="buzz-grid" data-dynamic="news" data-limit="6">
              <div class="buzz-card skeleton"></div>
              <div class="buzz-card skeleton"></div>
              <div class="buzz-card skeleton"></div>
              <div class="buzz-card skeleton"></div>
              <div class="buzz-card skeleton"></div>
              <div class="buzz-card skeleton"></div>
            </div>
          </section>

          <!-- FOLLOW US — After News -->
          <div class="social-strip">
            <span class="social-strip__label">Follow us</span>
            <a href="https://www.youtube.com/@SuperTennisNews" target="_blank" rel="noopener noreferrer" class="social-strip__link social-strip__link--yt" aria-label="YouTube">
              <svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
              YouTube
            </a>
            <a href="https://bsky.app/profile/supertennisnews.bsky.social" target="_blank" rel="noopener noreferrer" class="social-strip__link social-strip__link--bs" aria-label="Bluesky">
              <svg viewBox="0 0 568 501" fill="currentColor" width="16" height="16"><path d="M123.121 33.664C188.241 82.553 258.281 181.68 284 234.873c25.719-53.192 95.759-152.32 160.879-201.21C491.866-1.611 568-28.906 568 49.851c0 17.346-9.945 145.713-15.778 166.555-20.275 72.453-94.155 90.933-159.875 79.748C507.222 316.236 568 349.292 568 397.083c0 67.503-77.226 116.879-120.53 83.847C381.222 431.328 317.486 311.377 284 273.703c-33.486 37.674-97.222 157.625-163.47 207.227C77.226 513.962 0 464.586 0 397.083c0-47.791 60.778-80.847 175.653-100.929C109.933 307.334 36.053 288.859 15.778 216.406 9.945 195.564 0 67.197 0 49.851 0-28.906 76.134-1.611 123.121 33.664z"/></svg>
              Bluesky
            </a>
          </div>

          <!-- WATCH TENNIS — Video Pair 1 (loaded client-side) -->
          <section class="videos-section">
            <div class="videos-header">
              <h2 class="videos-title">Watch Tennis</h2>
              <a href="/video/" class="videos-all">All channels &rarr;</a>
            </div>
            <div class="video-pair" data-dynamic="videos" data-slots="0,1"></div>
          </section>

          <!-- 2. THREE COMPACT CARDS -->
          <div class="row-3-compact">
            {row3a.map(card => (
              <a href={card.href} class="compact-card">
                <div class="compact-card__img">
                  <img src={card.image} alt={card.title} loading="lazy" decoding="async" width="400" height="267" />
                </div>
                <div class="compact-card__body">
                  <span class="badge" style={`background: ${badgeColors[card.badge]}; color: #000;`}>{card.badge}</span>
                  <h3 class="compact-card__title">{card.title}</h3>
                </div>
              </a>
            ))}
          </div>

          <!-- 3. FULL-WIDTH HERO -->
          <a href={hero2.href} class="card-hero">
            <img src={hero2.image} alt={hero2.title} loading="lazy" decoding="async" width="800" height="400" style={hero2.imagePosition ? `object-position: ${hero2.imagePosition}` : undefined} />
            <div class="card-hero__overlay"></div>
            <div class="card-hero__content">
              <span class="badge" style={`background: ${badgeColors[hero2.badge]}; color: #000;`}>{hero2.badge}</span>
              <h3 class="card-hero__title">{hero2.title}</h3>
              <p class="card-hero__desc">{hero2.desc}</p>
            </div>
          </a>

          <!-- 4. FULL-WIDTH HERO -->
          <a href={hero3.href} class="card-hero">
            <img src={hero3.image} alt={hero3.title} loading="lazy" decoding="async" width="800" height="400" />
            <div class="card-hero__overlay"></div>
            <div class="card-hero__content">
              <span class="badge" style={`background: ${badgeColors[hero3.badge]}; color: #000;`}>{hero3.badge}</span>
              <h3 class="card-hero__title">{hero3.title}</h3>
              <p class="card-hero__desc">{hero3.desc}</p>
            </div>
          </a>

          <!-- VIDEO PAIR 2 (loaded client-side) -->
          <div class="video-pair" data-dynamic="videos" data-slots="2,3"></div>

          <!-- 5. TWO VERTICAL CARDS -->
          <div class="row-2">
            {row2.map(card => (
              <a href={card.href} class="vcard">
                <div class="vcard__img">
                  <img src={card.image} alt={card.title} loading="lazy" decoding="async" width="400" height="267" />
                </div>
                <h3 class="vcard__title">{card.title}</h3>
              </a>
            ))}
          </div>

          <!-- 6. TWO COMPACT HORIZONTAL CARDS -->
          <div class="row-2">
            {compactCards.map(card => (
              <a href={card.href} class="hcard">
                <div class="hcard__img">
                  <img src={card.image} alt={card.title} loading="lazy" decoding="async" width="400" height="267" />
                </div>
                <div class="hcard__body">
                  <h3 class="hcard__title">{card.title}</h3>
                </div>
              </a>
            ))}
          </div>

          <!-- 7. HORIZONTAL FEATURE CARD (big photo left + text right) -->
          <a href={featureCard.href} class="feature-card">
            <div class="feature-card__img">
              <img src={featureCard.image} alt={featureCard.title} loading="lazy" decoding="async" width="600" height="400" />
            </div>
            <div class="feature-card__body">
              <span class="badge" style={`background: ${badgeColors[featureCard.badge]}; color: #000;`}>{featureCard.badge}</span>
              <h3 class="feature-card__title">{featureCard.title}</h3>
              <p class="feature-card__desc">{featureCard.desc}</p>
            </div>
          </a>

          <!-- 8. FULL-WIDTH HERO -->
          <a href={hero4.href} class="card-hero">
            <img src={hero4.image} alt={hero4.title} loading="lazy" decoding="async" width="800" height="400" />
            <div class="card-hero__overlay"></div>
            <div class="card-hero__content">
              <span class="badge" style={`background: ${badgeColors[hero4.badge]}; color: #000;`}>{hero4.badge}</span>
              <h3 class="card-hero__title">{hero4.title}</h3>
              <p class="card-hero__desc">{hero4.desc}</p>
            </div>
          </a>

          <!-- 9. THREE VERTICAL CARDS -->
          <div class="row-3">
            {row3b.map(card => (
              <a href={card.href} class="vcard">
                <div class="vcard__img">
                  <img src={card.image} alt={card.title} loading="lazy" decoding="async" width="400" height="267" />
                </div>
                <h3 class="vcard__title">{card.title}</h3>
              </a>
            ))}
          </div>

          <!-- VIDEO PAIR 3 (loaded client-side) -->
          <div class="video-pair" data-dynamic="videos" data-slots="4,5"></div>

          <!-- STYLE QUIZ BANNER -->
          <a href="/tennis-playing-style" class="inline-banner-link">
            <img src="/images/style-banner.png" alt="What's Your Tennis Style? — Take the Quiz" class="inline-banner-img" width="1600" height="900" loading="lazy" decoding="async" />
          </a>

          <!-- FOLLOW US — Compact Social Strip -->
          <div class="social-strip">
            <span class="social-strip__label">Follow us</span>
            <a href="https://www.youtube.com/@SuperTennisNews" target="_blank" rel="noopener noreferrer" class="social-strip__link social-strip__link--yt" aria-label="YouTube">
              <svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
              YouTube
            </a>
            <a href="https://bsky.app/profile/supertennisnews.bsky.social" target="_blank" rel="noopener noreferrer" class="social-strip__link social-strip__link--bs" aria-label="Bluesky">
              <svg viewBox="0 0 568 501" fill="currentColor" width="16" height="16"><path d="M123.121 33.664C188.241 82.553 258.281 181.68 284 234.873c25.719-53.192 95.759-152.32 160.879-201.21C491.866-1.611 568-28.906 568 49.851c0 17.346-9.945 145.713-15.778 166.555-20.275 72.453-94.155 90.933-159.875 79.748C507.222 316.236 568 349.292 568 397.083c0 67.503-77.226 116.879-120.53 83.847C381.222 431.328 317.486 311.377 284 273.703c-33.486 37.674-97.222 157.625-163.47 207.227C77.226 513.962 0 464.586 0 397.083c0-47.791 60.778-80.847 175.653-100.929C109.933 307.334 36.053 288.859 15.778 216.406 9.945 195.564 0 67.197 0 49.851 0-28.906 76.134-1.611 123.121 33.664z"/></svg>
              Bluesky
            </a>
          </div>

          <!-- 10. LATEST ARTICLES FROM DATABASE -->
          {latestArticles.length > 0 && (
            <section class="news-section">
              <div class="news-section__header">
                <h2 class="news-section__title">More Stories</h2>
                <div class="news-section__filters">
                  <button class="nf-btn active" data-cat="all">All</button>
                  <button class="nf-btn" data-cat="players">Players</button>
                  <button class="nf-btn" data-cat="records">Records</button>
                  <button class="nf-btn" data-cat="gear">Gear</button>
                  <button class="nf-btn" data-cat="lifestyle">Lifestyle</button>
                  <button class="nf-btn" data-cat="vs">H2H</button>
                </div>
              </div>
              <div class="news-list" id="news-list">
                {latestArticles.map((art: any) => (
                  <a href={articleUrl(art)} class="news-item" data-cat={art.category}>
                    <span class="news-cat" style={`background: ${categoryColors[art.category] || '#666'}`}>
                      {categoryLabels[art.category] || art.category}
                    </span>
