<script>
  // Category filters — uses event delegation since items are loaded dynamically
  document.getElementById('np-filters')?.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('.np-filter');
    if (!btn) return;
    const cat = btn.getAttribute('data-cat');
    document.querySelectorAll('.np-filter').forEach(f => f.classList.remove('active'));
    btn.classList.add('active');
    document.querySelectorAll('.np-item').forEach(item => {
      if (cat === 'all' || item.getAttribute('data-cat') === cat) {
        (item as HTMLElement).classList.remove('hidden');
      } else {
        (item as HTMLElement).classList.add('hidden');
      }
    });
  });

  // Hash navigation is handled by dynamic-content.js after items load
</script>
<script src="/js/dynamic-content.js" defer></script>
