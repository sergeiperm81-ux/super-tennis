---
/**
 * PlayerGearBlock — compact Amazon-affiliate card for a player's racket.
 *
 * Data source: src/lib/player-gear.ts (playerGearMap, 44 ATP/WTA players,
 * tag supertennis0b-20). Renders NOTHING when the player isn't in the map,
 * so it's safe to drop onto any page unconditionally.
 *
 * Added 2026-06-12 after the monetization audit: player pages were the
 * largest unmonetized traffic segment (~267 views/30d in the top-30 alone)
 * even though the racket data already existed in code (used only on /vs/).
 *
 * Compliance: rel="sponsored" per Google guidelines; the Amazon Associates
 * operating agreement requires the earnings disclosure shown inline below.
 */
import { playerGearMap } from '../lib/player-gear';

interface Props {
  playerSlug?: string;
  playerName?: string;
  heading?: string;
  /**
   * When true and no gear matches, render a generic internal CTA to the
   * (fully monetized) /gear/ hub instead of nothing. Gives every article
   * a monetization path without forcing irrelevant Amazon links.
   */
  fallback?: boolean;
}

const { playerSlug = '', playerName = '', heading = '🎾 Racket Spotlight', fallback = false } = Astro.props;
const gear = playerSlug ? playerGearMap[playerSlug] : undefined;
---

{gear ? (
  <div class="pgear">
    <h3 class="pgear__title">{heading}</h3>
    <a href={gear.amazonUrl} class="pgear__card" target="_blank" rel="noopener sponsored">
      <span class="pgear__brand">{gear.brand}</span>
      <span class="pgear__racket">{gear.racket}</span>
      <span class="pgear__player">{playerName}'s racket of choice</span>
      <span class="pgear__cta">View on Amazon →</span>
    </a>
    <div class="pgear__links">
      {gear.gearPageUrl && (
        <a href={gear.gearPageUrl} class="pgear__more">🎾 Compare rackets →</a>
      )}
      {/* Shoes added 2026-06-12: shoes are the #1 gear-traffic category and
          convert better than rackets ($70 avg order ≈ shoes, not $200 rackets).
          Links to our monetized shoes guide rather than a fabricated
          per-player shoe model. */}
      <a href="/gear/best-tennis-shoes-2026/" class="pgear__more">👟 Court shoes →</a>
    </div>
    <p class="pgear__disclaimer">As an Amazon Associate, SUPER.TENNIS earns from qualifying purchases.</p>
  </div>
) : fallback && (
  <div class="pgear pgear--fallback">
    <h3 class="pgear__title">🎾 Play Like the Pros</h3>
    <a href="/gear/" class="pgear__card pgear__card--internal">
      <span class="pgear__racket">Rackets, shoes, strings & more</span>
      <span class="pgear__player">Hand-tested guides for every level and budget</span>
      <span class="pgear__cta">Browse gear guides →</span>
    </a>
  </div>
)}

<style>
  .pgear {
    margin: 24px 0;
    padding: 16px 18px;
    background: #fffbeb;
    border: 1px solid #fde68a;
    border-radius: var(--radius, 8px);
  }
  .pgear__title {
    font-family: var(--font-heading);
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #92400e;
    margin: 0 0 10px;
  }
  .pgear__card {
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding: 12px 14px;
    background: white;
    border: 1px solid #fcd34d;
    border-radius: 8px;
    text-decoration: none;
    transition: box-shadow 0.2s, transform 0.2s;
  }
  .pgear__card:hover {
    box-shadow: 0 4px 12px rgba(245, 158, 11, 0.25);
    transform: translateY(-1px);
  }
  .pgear__brand {
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #78350f;
    font-weight: 700;
  }
  .pgear__racket {
    font-size: 0.98rem;
    font-weight: 700;
    color: #1e293b;
    line-height: 1.3;
  }
  .pgear__player {
    font-size: 0.78rem;
    color: #64748b;
  }
  .pgear__cta {
    margin-top: 6px;
    font-size: 0.8rem;
    color: #d97706;
    font-weight: 600;
  }
  .pgear__links {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    margin-top: 10px;
  }
  .pgear__more {
    font-size: 0.78rem;
    color: var(--court-green, #16a34a);
    text-decoration: none;
    font-weight: 600;
  }
  .pgear__more:hover { text-decoration: underline; }
  .pgear__disclaimer {
    margin: 8px 0 0;
    font-size: 0.68rem;
    color: #92400e;
    opacity: 0.7;
    line-height: 1.4;
  }
  /* Fallback (internal /gear/ CTA) — green accent instead of Amazon amber
     so readers can tell editorial guides from sponsored product links. */
  .pgear--fallback {
    background: #f0fdf4;
    border-color: #bbf7d0;
  }
  .pgear--fallback .pgear__title { color: #166534; }
  .pgear__card--internal { border-color: #86efac; }
  .pgear__card--internal:hover { box-shadow: 0 4px 12px rgba(22, 163, 74, 0.2); }
  .pgear--fallback .pgear__cta { color: var(--court-green, #16a34a); }
</style>
