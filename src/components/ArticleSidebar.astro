---
import { getFlagUrl, countryFlags } from '../lib/fallback-data';

interface Props {
  category: string;
  accentColor: string;
}

const { category, accentColor } = Astro.props;

const atpTop5 = [
  { rank: 1, name: 'Jannik Sinner',    slug: 'jannik-sinner',    country: 'ITA', points: '11,830' },
  { rank: 2, name: 'Alexander Zverev', slug: 'alexander-zverev', country: 'GER', points: '9,855' },
  { rank: 3, name: 'Carlos Alcaraz',   slug: 'carlos-alcaraz',   country: 'ESP', points: '7,190' },
  { rank: 4, name: 'Novak Djokovic',   slug: 'novak-djokovic',   country: 'SRB', points: '6,875' },
  { rank: 5, name: 'Daniil Medvedev',  slug: 'daniil-medvedev',  country: 'RUS', points: '6,445' },
];

const exploreLinks = [
  { label: 'Records',      href: '/records/',     cat: 'records',     color: '#dc2626' },
  { label: 'Head to Head', href: '/vs/',           cat: 'vs',          color: '#d4a017' },
  { label: 'Gear',         href: '/gear/',          cat: 'gear',        color: '#2563eb' },
  { label: 'Lifestyle',    href: '/lifestyle/',     cat: 'lifestyle',   color: '#7c3aed' },
  { label: 'Tournaments',  href: '/tournaments/',   cat: 'tournaments', color: '#059669' },
  { label: 'News',         href: '/news/',           cat: 'news',        color: '#16a34a' },
  { label: 'Players',      href: '/players/',        cat: 'players',     color: '#0ea5e9' },
  { label: 'Rankings',     href: '/rankings/',       cat: 'rankings',    color: '#f97316' },
].filter(l => l.cat !== category).slice(0, 6);

const featuredPlayer = {
  name: 'Jannik Sinner',
  slug: 'jannik-sinner',
  country: 'ITA',
  grandSlams: 3,
  careerTitles: 23,
  image: 'https://upload.wikimedia.org/wikipedia/commons/thumb/2/2c/Jannik_Sinner_Roland_Garros_2024.jpg/480px-Jannik_Sinner_Roland_Garros_2024.jpg',
};

const flagUrl = getFlagUrl(featuredPlayer.country, 20);
---

<aside class="as">

  <!-- LATEST NEWS -->
  <div class="as-block">
    <div class="as-block__header">
      <span class="as-block__label">Latest News</span>
      <a href="/news/" class="as-link">All news →</a>
    </div>
    <div id="as-news-list" class="as-news-list">
      {Array.from({length: 5}).map(() => (
        <div class="as-news-skeleton"></div>
      ))}
    </div>
  </div>

  <!-- FEATURED PLAYER -->
  <div class="as-block as-profile-block">
    <div class="as-block__header">
      <span class="as-block__label">Featured Player</span>
      <a href="/players/" class="as-link">All players →</a>
    </div>
    <a href={`/players/${featuredPlayer.slug}/`} class="as-profile__card">
      <div class="as-profile__img">
        <img
          src={featuredPlayer.image}
          alt={featuredPlayer.name}
          loading="lazy"
          decoding="async"
          width="320"
          height="160"
          onerror="this.parentElement.style.background='#1f2937'"
        />
        <div class="as-profile__overlay">
          {flagUrl && <img src={flagUrl} alt={featuredPlayer.country} class="as-flag" width="20" height="14" />}
          <span class="as-profile__name">{featuredPlayer.name}</span>
        </div>
      </div>
      <div class="as-profile__stats">
        <div class="as-profile__row"><span>Grand Slams</span><span>{featuredPlayer.grandSlams}</span></div>
        <div class="as-profile__row"><span>Career Titles</span><span>{featuredPlayer.careerTitles}</span></div>
        <div class="as-profile__row"><span>Ranking</span><span class="as-rank-badge">ATP #1</span></div>
      </div>
    </a>
  </div>

  <!-- ATP RANKINGS -->
  <div class="as-block">
    <div class="as-block__header">
      <span class="as-block__label">ATP Rankings</span>
      <a href="/rankings/" class="as-link">Full table →</a>
    </div>
    <table class="as-rankings__table">
      <tbody>
        {atpTop5.map(r => (
          <tr>
            <td class="as-rank">{r.rank}</td>
            <td class="as-player">
              <a href={`/players/${r.slug}/`}>
                {getFlagUrl(r.country, 20) ? (
                  <img src={getFlagUrl(r.country, 20)} alt={r.country} class="as-flag" width="20" height="14" loading="lazy" />
                ) : (
                  <span>{countryFlags[r.country] || ''}</span>
                )}
                {r.name}
              </a>
            </td>
            <td class="as-pts">{r.points}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>

  <!-- EXPLORE -->
  <div class="as-block">
    <div class="as-block__header">
      <span class="as-block__label">Explore</span>
    </div>
    <div class="as-explore">
      {exploreLinks.map(l => (
        <a href={l.href} class="as-explore__item">
          <span class="as-explore__cat" style={`background:${l.color}`}>{l.label}</span>
          <span class="as-explore__arrow">→</span>
        </a>
      ))}
    </div>
  </div>

  <!-- QUIZ CTA -->
  <div class="as-block as-cta" style={`border-top: 3px solid ${accentColor}`}>
    <div class="as-cta__inner">
      <div class="as-cta__emoji">🎾</div>
      <p class="as-cta__title">What's Your Tennis Style?</p>
      <p class="as-cta__desc">Find out which pro plays like you.</p>
      <a href="/tennis-playing-style/" class="as-cta__btn" style={`background:${accentColor}`}>Take the Quiz</a>
    </div>
  </div>

</aside>

<script>
  async function loadSidebarNews() {
    const list = document.getElementById('as-news-list');
    if (!list) return;
    try {
      const res = await fetch('https://supertennis-cron.sfedoroff.workers.dev/api/news?limit=6');
      if (!res.ok) return;
      const items = await res.json();
      if (!Array.isArray(items) || !items.length) return;

      const catColors: Record<string, string> = {
        scandal: '#dc2626', love: '#e11d7e', money: '#d4a017',
        fashion: '#9333ea', viral: '#f97316', buzz: '#16a34a',
      };

      function esc(s: string): string {
        return String(s || '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
      }

      list.innerHTML = items.slice(0, 6).map((item: any) => {
        const slug = (item.slug || item.title || '')
          .toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '').substring(0, 80);
        const cat = esc(item.category || 'buzz');
        const color = catColors[item.category] || '#16a34a';
        const catLabel = esc((item.category || 'buzz').charAt(0).toUpperCase() + (item.category || 'buzz').slice(1));
        // Inline styles — bypasses Astro scoped CSS limitation on dynamic elements
        return `<a href="/news/${esc(slug)}/" style="display:flex;align-items:flex-start;gap:8px;padding:10px 14px;border-bottom:1px solid #f3f4f6;text-decoration:none;transition:background 0.15s;" onmouseover="this.style.background='#f9fafb'" onmouseout="this.style.background=''">
          <span style="display:inline-block;padding:2px 7px;border-radius:3px;font-size:0.6rem;font-weight:700;text-transform:uppercase;letter-spacing:0.5px;color:#fff;white-space:nowrap;flex-shrink:0;margin-top:3px;background:${color}">${catLabel}</span>
          <span style="font-size:0.82rem;font-weight:600;line-height:1.35;color:#1f2937;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden">${esc(item.title)}</span>
        </a>`;
      }).join('');
    } catch {}
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', loadSidebarNews);
  } else {
    loadSidebarNews();
  }
</script>

<style>
  .as {
    position: sticky;
    top: calc(var(--header-height) + 8px);
    display: flex;
    flex-direction: column;
    gap: 20px;
    max-height: calc(100vh - var(--header-height) - 24px);
    overflow-y: auto;
    scrollbar-width: none;
  }
  .as::-webkit-scrollbar { display: none; }

  /* Block base — NO overflow:hidden here, it clips table rows */
  .as-block {
    background: var(--white);
    border-radius: var(--radius);
    border: 1px solid var(--gray-200);
  }

  /* Only the profile card needs overflow:hidden (for the image crop) */
  .as-profile-block {
    overflow: hidden;
  }

  .as-block__header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 12px 16px;
    background: var(--gray-900);
    border-radius: var(--radius) var(--radius) 0 0;
  }

  .as-block__label {
    font-family: var(--font-heading);
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: #fff;
  }

  .as-link {
    font-size: 0.7rem;
    color: var(--court-green);
    font-weight: 600;
    text-decoration: none;
  }
  .as-link:hover { text-decoration: underline; }

  /* News skeletons */
  .as-news-list { display: flex; flex-direction: column; }
  .as-news-skeleton {
    height: 52px;
    margin: 6px 10px;
    border-radius: 4px;
    background: linear-gradient(90deg, var(--gray-100) 25%, var(--gray-50) 50%, var(--gray-100) 75%);
    background-size: 200% 100%;
    animation: as-shimmer 1.4s infinite;
  }
  @keyframes as-shimmer {
    0%   { background-position: 200% 0; }
    100% { background-position: -200% 0; }
  }

  /* Featured Player */
  .as-profile__card {
    display: block;
    text-decoration: none;
  }
  .as-profile__img {
    position: relative;
    height: 160px;
    overflow: hidden;
    background: var(--gray-200);
  }
  .as-profile__img > img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
  }
  .as-profile__overlay {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    padding: 28px 14px 12px;
    background: linear-gradient(transparent, rgba(0,0,0,0.85));
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .as-flag {
    width: 20px;
    height: 14px;
    object-fit: cover;
    border-radius: 2px;
    flex-shrink: 0;
    vertical-align: middle;
  }
  .as-profile__name {
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 700;
    color: #fff;
    text-transform: uppercase;
    letter-spacing: 1px;
    line-height: 1.2;
  }
  .as-profile__stats { padding: 2px 0; }
  .as-profile__row {
    display: flex;
    justify-content: space-between;
    padding: 9px 16px;
    border-bottom: 1px solid var(--gray-100);
    font-size: 0.8rem;
  }
  .as-profile__row:last-child { border-bottom: none; }
  .as-profile__row > span:first-child { color: var(--gray-500); }
  .as-profile__row > span:last-child { font-weight: 700; color: var(--gray-900); }
  .as-rank-badge { color: var(--court-green) !important; }

  /* Rankings table */
  .as-rankings__table {
    width: 100%;
    border-collapse: collapse;
  }
  .as-rankings__table tr { border-bottom: 1px solid var(--gray-100); }
  .as-rankings__table tr:last-child { border-bottom: none; }
  .as-rankings__table tr:hover td { background: var(--gray-50); }

  .as-rank {
    padding: 10px 12px;
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 0.9rem;
    color: var(--court-green);
    width: 28px;
  }
  .as-player {
    padding: 10px 6px;
    font-size: 0.8rem;
  }
  .as-player a {
    color: var(--gray-900);
    text-decoration: none;
    font-weight: 600;
    display: flex;
    align-items: center;
    gap: 6px;
    transition: color 0.15s;
  }
  .as-player a:hover { color: var(--court-green); }
  .as-pts {
    padding: 10px 14px;
    text-align: right;
    font-family: var(--font-heading);
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--gray-400);
  }

  /* Explore */
  .as-explore { display: flex; flex-direction: column; }
  .as-explore__item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 10px 16px;
    border-bottom: 1px solid var(--gray-100);
    text-decoration: none;
    transition: background 0.15s;
  }
  .as-explore__item:last-child { border-bottom: none; }
  .as-explore__item:hover { background: var(--gray-50); }
  .as-explore__cat {
    display: inline-block;
    padding: 3px 10px;
    border-radius: 4px;
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: #fff;
  }
  .as-explore__arrow {
    font-size: 0.85rem;
    color: var(--gray-400);
  }
  .as-explore__item:hover .as-explore__arrow { color: var(--court-green); }

  /* Quiz CTA */
  .as-cta { text-align: center; padding: 24px 20px; }
  .as-cta__inner { display: flex; flex-direction: column; align-items: center; gap: 6px; }
  .as-cta__emoji { font-size: 2rem; }
  .as-cta__title {
    font-family: var(--font-heading);
    font-size: 0.95rem;
    font-weight: 700;
    text-transform: uppercase;
    color: var(--gray-900);
    margin: 4px 0 0;
  }
  .as-cta__desc {
    font-size: 0.8rem;
    color: var(--gray-500);
    line-height: 1.5;
    margin: 0 0 10px;
  }
  .as-cta__btn {
    display: inline-block;
    padding: 9px 22px;
    border-radius: 6px;
    color: #fff;
    font-size: 0.82rem;
    font-weight: 700;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    transition: opacity 0.2s;
  }
  .as-cta__btn:hover { opacity: 0.85; }
</style>
