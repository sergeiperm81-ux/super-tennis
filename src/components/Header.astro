---
import { localizedPath, type Locale } from '../lib/i18n';

interface Props {
  locale?: Locale;
}
const { locale = 'en' } = Astro.props as Props;

// `localized` marks sections that have a published /es/ (etc.) version. News/Videos are not
// localized yet → they keep their English URL even on localized pages (label still translates).
const NAV = [
  { key: 'video', href: '/video/', localized: false },
  { key: 'news', href: '/news/', localized: false },
  { key: 'players', href: '/players/', localized: true },
  { key: 'rankings', href: '/rankings/', localized: true },
  { key: 'vs', href: '/vs/', localized: true },
  { key: 'records', href: '/records/', localized: true },
  { key: 'tournaments', href: '/tournaments/', localized: true },
  { key: 'calendar', href: '/calendar/', localized: true },
  { key: 'gear', href: '/gear/', localized: true },
  { key: 'lifestyle', href: '/lifestyle/', localized: true },
];

const LABELS: Record<string, Record<string, string>> = {
  en: { video: 'Videos', news: 'News', players: 'Players', rankings: 'Rankings', vs: 'H2H', records: 'Records', tournaments: 'Tournaments', calendar: 'Calendar', gear: 'Gear', lifestyle: 'Lifestyle' },
  es: { video: 'Vídeos', news: 'Noticias', players: 'Jugadores', rankings: 'Ranking', vs: 'H2H', records: 'Récords', tournaments: 'Torneos', calendar: 'Calendario', gear: 'Equipamiento', lifestyle: 'Estilo de vida' },
  fr: { video: 'Vidéos', news: 'Actualités', players: 'Joueurs', rankings: 'Classement', vs: 'H2H', records: 'Records', tournaments: 'Tournois', calendar: 'Calendrier', gear: 'Équipement', lifestyle: 'Style de vie' },
  zh: { video: '视频', news: '新闻', players: '球员', rankings: '排名', vs: 'H2H', records: '纪录', tournaments: '赛事', calendar: '赛程', gear: '装备', lifestyle: '生活方式' },
};
const labels = LABELS[locale] ?? LABELS.en;

const navLinks = NAV.map((n) => ({
  href: n.localized ? localizedPath(locale, n.href) : n.href,
  label: labels[n.key] ?? n.key,
}));
const homeHref = localizedPath(locale, '/');

// Determine which nav link is active based on current URL
const currentPath = Astro.url.pathname;
function isActive(href: string): boolean {
  if (href === '/' || href === '/es/' || href === '/fr/' || href === '/zh/') return currentPath === href;
  return currentPath.startsWith(href);
}
---

<header class="header" id="header">
  <div class="container header__inner">
    <a href={homeHref} class="logo">
      <span class="logo__text">
        SUPER
        <svg class="logo__ball" width="18" height="18" viewBox="0 0 64 64" aria-hidden="true">
          <circle cx="32" cy="32" r="30" fill="#ccff00" stroke="#8B9A2B" stroke-width="2"/>
          <path d="M10 32 C20 20, 44 20, 54 32" fill="none" stroke="#fff" stroke-width="3"/>
          <path d="M10 32 C20 44, 44 44, 54 32" fill="none" stroke="#fff" stroke-width="3"/>
        </svg>
        TENNIS
      </span>
    </a>

    <nav class="nav" id="nav">
      {navLinks.map(link => (
        <a href={link.href} class={`nav__link ${isActive(link.href) ? 'nav__link--active' : ''}`}>{link.label}</a>
      ))}
    </nav>

    <a href="/search/" class="search-btn" aria-label="Search">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
    </a>

    <button class="burger" id="burger" aria-label="Toggle menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>

<style>
  .header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    background: rgba(255,255,255,0.95);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--gray-200);
    transition: var(--transition);
  }
  .header.scrolled {
    box-shadow: var(--shadow);
  }
  .header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: var(--header-height);
  }
  .logo {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 700;
    letter-spacing: 1px;
  }
  .logo__text {
    color: var(--gray-900);
    display: flex;
    align-items: center;
    gap: 2px;
  }
  .logo__ball { vertical-align: middle; margin: 0 1px; }

  .nav {
    display: flex;
    gap: 22px;
  }
  .nav__link {
    font-weight: 500;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: var(--gray-700);
    padding: 4px 0;
    position: relative;
    transition: var(--transition);
  }
  .nav__link:hover {
    color: var(--court-green);
  }
  .nav__link::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 0;
    height: 2px;
    background: var(--court-green);
    transition: var(--transition);
  }
  .nav__link:hover::after {
    width: 100%;
  }
  .nav__link--active {
    color: var(--court-green);
  }
  .nav__link--active::after {
    width: 100%;
  }

  .search-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--gray-400);
    padding: 6px;
    border-radius: 50%;
    transition: color 0.2s, background 0.2s;
  }
  .search-btn:hover {
    color: white;
    background: rgba(255,255,255,0.1);
  }

  .burger {
    display: none;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 5px;
    padding: 4px;
    min-width: 44px;
    min-height: 44px;
  }
  .burger span {
    display: block;
    width: 24px;
    height: 2px;
    background: var(--gray-800);
    transition: var(--transition);
  }

  @media (max-width: 1024px) {
    .burger { display: flex; }
    .nav {
      display: none;
      position: absolute;
      top: var(--header-height);
      left: 0;
      right: 0;
      background: var(--white);
      flex-direction: column;
      padding: 16px 24px;
      gap: 4px;
      border-bottom: 1px solid var(--gray-200);
      box-shadow: var(--shadow-md);
    }
    .nav.open { display: flex; }
    .nav__link {
      padding: 12px 0;
    }
  }
</style>

<script>
  // Header scroll effect
  const header = document.getElementById('header');
  if (header) {
    window.addEventListener('scroll', () => {
      header.classList.toggle('scrolled', window.scrollY > 10);
    }, { passive: true });
  }

  // Mobile burger toggle
  const burger = document.getElementById('burger');
  const nav = document.getElementById('nav');
  if (burger && nav) {
    burger.addEventListener('click', () => {
      const isOpen = nav.classList.toggle('open');
      burger.setAttribute('aria-expanded', String(isOpen));
    });

    // Close menu on nav link click
    nav.querySelectorAll('.nav__link').forEach(link => {
      link.addEventListener('click', () => {
        nav.classList.remove('open');
        burger.setAttribute('aria-expanded', 'false');
      });
    });

    // Close menu on outside click
    document.addEventListener('click', (e) => {
      if (!header?.contains(e.target as Node) && nav.classList.contains('open')) {
        nav.classList.remove('open');
        burger.setAttribute('aria-expanded', 'false');
      }
    });

    // Close menu on Escape key
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && nav.classList.contains('open')) {
        nav.classList.remove('open');
        burger.setAttribute('aria-expanded', 'false');
      }
    });
  }
</script>
