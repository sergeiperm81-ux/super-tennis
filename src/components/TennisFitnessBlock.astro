---
/**
 * TennisFitnessBlock — affiliate CTA for the Tennis Fitness training program.
 *
 * Why a dedicated component (2026-06-12 monetization audit): Tennis Fitness
 * pays 50% commission (coupon SERGEI) vs Amazon's ~3% on gear. On a single
 * sale it earns roughly what 15 racket sales would. It is the highest-ROI
 * affiliate we have, and it maps perfectly to health/fitness content — yet
 * it was only present in 5 of 13 health lifestyle articles. This block puts
 * it on the rest.
 *
 * No earnings disclosure inline: ArticleLayout already renders the affiliate
 * disclosure banner on lifestyle articles, and duplicating it was flagged as
 * a past mistake. rel="sponsored" per Google guidelines.
 *
 * Link + coupon are the live affiliate values pulled from existing articles.
 */
const TF_URL = 'http://www.memberstennisfitness.com/a/2147833367/Fq9Sy7S5';
const COUPON = 'SERGEI';
---

<div class="tffit">
  <h3 class="tffit__title">💪 Get Match-Fit at Home</h3>
  <p class="tffit__pitch">
    Tennis-specific strength, mobility and conditioning — structured pro-level
    training you can do anywhere, built for every level from club player to
    competitor.
  </p>
  <a href={TF_URL} class="tffit__cta" target="_blank" rel="noopener sponsored">
    Start the Tennis Fitness program →
  </a>
  <p class="tffit__coupon">
    Use code <strong>{COUPON}</strong> for <strong>50% off</strong>
  </p>
</div>

<style>
  .tffit {
    margin: 24px 0;
    padding: 18px 20px;
    background: linear-gradient(135deg, #ecfdf5 0%, #f0fdfa 100%);
    border: 1px solid #6ee7b7;
    border-radius: var(--radius, 8px);
  }
  .tffit__title {
    font-family: var(--font-heading);
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: #065f46;
    margin: 0 0 8px;
  }
  .tffit__pitch {
    margin: 0 0 14px;
    font-size: 0.92rem;
    line-height: 1.55;
    color: #134e4a;
  }
  .tffit__cta {
    display: inline-block;
    padding: 10px 20px;
    background: var(--court-green, #16a34a);
    color: white;
    border-radius: 6px;
    font-size: 0.92rem;
    font-weight: 700;
    text-decoration: none;
    transition: filter 0.2s, transform 0.2s;
  }
  .tffit__cta:hover {
    filter: brightness(1.08);
    transform: translateY(-1px);
  }
  .tffit__coupon {
    margin: 10px 0 0;
    font-size: 0.85rem;
    color: #047857;
  }
  .tffit__coupon strong { color: #065f46; }
</style>
