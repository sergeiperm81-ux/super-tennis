---
import Newsletter from './Newsletter.astro';
const currentYear = new Date().getFullYear();

const sections = [
  {
    title: 'Explore',
    links: [
      { href: '/players/', label: 'Players' },
      { href: '/records/', label: 'Records' },
      { href: '/tournaments/', label: 'Tournaments' },
      { href: '/gear/', label: 'Gear' },
      { href: '/lifestyle/', label: 'Lifestyle' },
      { href: '/video/', label: 'Videos' },
    ],
  },
  {
    title: 'Tools',
    links: [
      { href: '/rankings/', label: 'Rankings' },
      { href: '/calendar/', label: 'Calendar' },
      { href: '/vs/', label: 'Head to Head' },
      { href: '/stats/', label: 'Site Stats' },
      { href: '/about/', label: 'About' },
      { href: '/contact/', label: 'Contact' },
    ],
  },
  {
    title: 'Popular Players',
    links: [
      { href: '/players/novak-djokovic/', label: 'Novak Djokovic' },
      { href: '/players/carlos-alcaraz/', label: 'Carlos Alcaraz' },
      { href: '/players/jannik-sinner/', label: 'Jannik Sinner' },
      { href: '/players/iga-swiatek/', label: 'Iga Swiatek' },
      { href: '/players/aryna-sabalenka/', label: 'Aryna Sabalenka' },
      { href: '/players/coco-gauff/', label: 'Coco Gauff' },
    ],
  },
];
---

<footer class="footer">
  <div class="container footer__inner">
    <div class="footer__brand">
      <a href="/" class="footer__logo">
        SUPER
        <svg class="footer__ball" width="14" height="14" viewBox="0 0 64 64" aria-hidden="true">
          <circle cx="32" cy="32" r="30" fill="#ccff00" stroke="#8B9A2B" stroke-width="2"/>
          <path d="M10 32 C20 20, 44 20, 54 32" fill="none" stroke="#fff" stroke-width="3"/>
          <path d="M10 32 C20 44, 44 44, 54 32" fill="none" stroke="#fff" stroke-width="3"/>
        </svg>
        TENNIS
      </a>
      <p class="footer__tagline">Tennis for everyone. The world of tennis beyond the court.</p>
      <div class="footer__social">
        <a href="https://www.youtube.com/@SuperTennisNews" target="_blank" rel="noopener noreferrer" class="footer__social-link" aria-label="YouTube">
          <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
        </a>
        <a href="https://www.tiktok.com/@supertennisnews" target="_blank" rel="noopener noreferrer" class="footer__social-link" aria-label="TikTok">
          <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20"><path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/></svg>
        </a>
        <!-- Instagram — hidden until account is created -->
      </div>
    </div>
    <div class="footer__newsletter">
      <Newsletter />
    </div>
    <div class="footer__nav">
      {sections.map(section => (
        <div class="footer__section">
          <h4 class="footer__heading">{section.title}</h4>
          <ul class="footer__list">
            {section.links.map(link => (
              <li><a href={link.href} class="footer__link">{link.label}</a></li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
  <div class="footer__bottom">
    <div class="container footer__bottom-inner">
      <p>&copy; {currentYear} SUPER.TENNIS. All rights reserved.</p>
      <nav class="footer__legal">
        <a href="/privacy/" class="footer__legal-link">Privacy Policy</a>
        <a href="/terms/" class="footer__legal-link">Terms of Service</a>
      </nav>
      <p class="footer__disclaimer">Player stats sourced from public records. Not affiliated with ATP, WTA, or ITF.</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--gray-900);
    color: var(--gray-400);
    margin-top: 80px;
  }
  .footer__inner {
    display: flex;
    justify-content: space-between;
    gap: 48px;
    padding: 48px 24px;
  }
  .footer__brand {
    max-width: 240px;
    flex-shrink: 0;
  }
  .footer__newsletter {
    flex: 0 0 280px;
    display: flex;
    align-items: flex-start;
    padding-top: 4px;
  }
  .footer__logo {
    font-family: var(--font-heading);
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--white);
    letter-spacing: 1px;
    display: flex;
    align-items: center;
    gap: 2px;
    text-decoration: none;
  }
  .footer__ball { vertical-align: middle; margin: 0 1px; }
  .footer__tagline {
    margin-top: 10px;
    font-size: 0.88rem;
    line-height: 1.5;
  }
  .footer__social {
    display: flex;
    gap: 12px;
    margin-top: 16px;
  }
  .footer__social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    border-radius: 50%;
    background: var(--gray-800, #222);
    color: var(--gray-400, #999);
    transition: var(--transition);
  }
  .footer__social-link:hover {
    background: var(--ball-yellow, #e6d14c);
    color: var(--gray-900, #111);
    transform: translateY(-2px);
  }
  .footer__nav {
    display: flex;
    gap: 56px;
  }
  .footer__heading {
    font-family: var(--font-heading);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: var(--white);
    margin-bottom: 14px;
  }
  .footer__list {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .footer__link {
    font-size: 0.88rem;
    transition: var(--transition);
  }
  .footer__link:hover {
    color: var(--ball-yellow);
  }
  .footer__bottom {
    border-top: 1px solid var(--gray-800);
    padding: 16px 24px;
    font-size: 0.78rem;
    text-align: center;
  }
  .footer__bottom-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .footer__legal {
    display: flex;
    gap: 16px;
  }
  .footer__legal-link {
    color: var(--gray-400);
    font-size: 0.78rem;
    text-decoration: none;
    transition: var(--transition);
  }
  .footer__legal-link:hover {
    color: var(--ball-yellow);
  }
  .footer__disclaimer {
    color: var(--gray-600);
    font-size: 0.72rem;
  }

  @media (max-width: 768px) {
    .footer__inner {
      flex-direction: column;
      gap: 32px;
    }
    .footer__newsletter {
      flex: unset;
    }
    .footer__nav {
      gap: 32px;
      flex-wrap: wrap;
    }
    .footer__bottom-inner {
      flex-direction: column;
      gap: 8px;
    }
  }
</style>
