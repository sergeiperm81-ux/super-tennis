---
const currentYear = new Date().getFullYear();

const sections = [
  {
    title: 'Explore',
    links: [
      { href: '/players/', label: 'Players' },
      { href: '/records/', label: 'Records' },
      { href: '/tournaments/', label: 'Tournaments' },
      { href: '/gear/', label: 'Gear' },
      { href: '/lifestyle/', label: 'Lifestyle' },
      { href: '/video/', label: 'Videos' },
    ],
  },
  {
    title: 'Tools',
    links: [
      { href: '/rankings/', label: 'Rankings' },
      { href: '/calendar/', label: 'Calendar' },
      { href: '/vs/', label: 'Head to Head' },
      { href: '/stats/', label: 'Site Stats' },
    ],
  },
  {
    title: 'Popular Players',
    links: [
      { href: '/players/novak-djokovic/', label: 'Novak Djokovic' },
      { href: '/players/carlos-alcaraz/', label: 'Carlos Alcaraz' },
      { href: '/players/jannik-sinner/', label: 'Jannik Sinner' },
      { href: '/players/iga-swiatek/', label: 'Iga Swiatek' },
      { href: '/players/aryna-sabalenka/', label: 'Aryna Sabalenka' },
      { href: '/players/coco-gauff/', label: 'Coco Gauff' },
    ],
  },
];
---

<footer class="footer">
  <div class="container footer__inner">
    <div class="footer__brand">
      <a href="/" class="footer__logo">
        SUPER
        <svg class="footer__ball" width="14" height="14" viewBox="0 0 64 64" aria-hidden="true">
          <circle cx="32" cy="32" r="30" fill="#ccff00" stroke="#8B9A2B" stroke-width="2"/>
          <path d="M10 32 C20 20, 44 20, 54 32" fill="none" stroke="#fff" stroke-width="3"/>
          <path d="M10 32 C20 44, 44 44, 54 32" fill="none" stroke="#fff" stroke-width="3"/>
        </svg>
        TENNIS
      </a>
      <p class="footer__tagline">Tennis for everyone. The world of tennis beyond the court.</p>
    </div>
    <div class="footer__nav">
      {sections.map(section => (
        <div class="footer__section">
          <h4 class="footer__heading">{section.title}</h4>
          <ul class="footer__list">
            {section.links.map(link => (
              <li><a href={link.href} class="footer__link">{link.label}</a></li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
  <div class="footer__bottom">
    <div class="container footer__bottom-inner">
      <p>&copy; {currentYear} SUPER.TENNIS. All rights reserved.</p>
      <p class="footer__disclaimer">Player stats sourced from public records. Not affiliated with ATP, WTA, or ITF.</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--gray-900);
    color: var(--gray-400);
    margin-top: 80px;
  }
  .footer__inner {
    display: flex;
    justify-content: space-between;
    gap: 48px;
    padding: 48px 24px;
  }
  .footer__brand {
    max-width: 280px;
  }
  .footer__logo {
    font-family: var(--font-heading);
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--white);
    letter-spacing: 1px;
    display: flex;
    align-items: center;
    gap: 2px;
    text-decoration: none;
  }
  .footer__ball { vertical-align: middle; margin: 0 1px; }
  .footer__tagline {
    margin-top: 10px;
    font-size: 0.88rem;
    line-height: 1.5;
  }
  .footer__nav {
    display: flex;
    gap: 56px;
  }
  .footer__heading {
    font-family: var(--font-heading);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: var(--white);
    margin-bottom: 14px;
  }
  .footer__list {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .footer__link {
    font-size: 0.88rem;
    transition: var(--transition);
  }
  .footer__link:hover {
    color: var(--ball-yellow);
  }
  .footer__bottom {
    border-top: 1px solid var(--gray-800);
    padding: 16px 24px;
    font-size: 0.78rem;
    text-align: center;
  }
  .footer__bottom-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .footer__disclaimer {
    color: var(--gray-600);
    font-size: 0.72rem;
  }

  @media (max-width: 768px) {
    .footer__inner {
      flex-direction: column;
      gap: 32px;
    }
    .footer__nav {
      gap: 32px;
      flex-wrap: wrap;
    }
    .footer__bottom-inner {
      flex-direction: column;
      gap: 8px;
    }
  }
</style>
