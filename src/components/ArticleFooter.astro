---
/**
 * ArticleFooter — Bottom navigation for article pages
 * Shows share buttons, back link + related section links
 */
interface Props {
  backLabel: string;
  backHref: string;
  relatedLinks?: { label: string; href: string }[];
  shareTitle?: string;
}

const { backLabel, backHref, relatedLinks = [], shareTitle } = Astro.props;

// Default related links if none provided
const defaultLinks = [
  { label: 'Player Profiles', href: '/players/' },
  { label: 'Tennis Records', href: '/records/' },
  { label: 'Rankings', href: '/rankings/' },
  { label: 'Gear Guides', href: '/gear/' },
  { label: 'Tournaments', href: '/tournaments/' },
  { label: 'Head to Head', href: '/vs/' },
];

const links = relatedLinks.length > 0 ? relatedLinks : defaultLinks.filter(l => l.href !== backHref).slice(0, 4);
---

<footer class="article-footer">
  <!-- Share row -->
  <div class="share-row">
    <span class="share-label">Share:</span>
    <button class="share-btn share-x" data-share="x" title="Share on X" aria-label="Share on X">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
    </button>
    <button class="share-btn share-fb" data-share="fb" title="Share on Facebook" aria-label="Share on Facebook">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
    </button>
    <button class="share-btn share-copy" data-share="copy" title="Copy link" aria-label="Copy link">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
    </button>
    <span class="copy-toast" id="copy-toast">Copied!</span>
  </div>

  <!-- Navigation -->
  <div class="nav-row">
    <a href={backHref} class="back-link">{backLabel}</a>
    <div class="footer-links">
      <span class="footer-label">Explore:</span>
      {links.map(link => (
        <a href={link.href} class="footer-link">{link.label}</a>
      ))}
    </div>
  </div>
</footer>

<script>
  const footer = document.querySelector('.article-footer');
  if (footer) {
    const title = document.querySelector('h1')?.textContent || document.title;
    const url = window.location.href;

    footer.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest('[data-share]') as HTMLElement;
      if (!btn) return;
      const type = btn.dataset.share;
      if (type === 'x') {
        window.open(`https://x.com/intent/tweet?text=${encodeURIComponent(title)}&url=${encodeURIComponent(url)}`, '_blank', 'width=550,height=420');
      } else if (type === 'fb') {
        window.open(`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(url)}`, '_blank', 'width=550,height=420');
      } else if (type === 'copy') {
        navigator.clipboard.writeText(url).then(() => {
          const toast = document.getElementById('copy-toast');
          if (toast) {
            toast.classList.add('show');
            setTimeout(() => toast.classList.remove('show'), 1500);
          }
        });
      }
    });
  }
</script>

<style>
  .article-footer {
    margin-top: 48px;
    padding-top: 24px;
    border-top: 2px solid var(--gray-200);
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  /* Share row */
  .share-row {
    display: flex;
    align-items: center;
    gap: 8px;
    position: relative;
  }
  .share-label {
    font-size: 0.82rem;
    color: var(--gray-500);
    font-weight: 500;
    margin-right: 4px;
  }
  .share-btn {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--gray-600);
    background: var(--gray-50);
    border: 1px solid var(--gray-200);
    transition: all 0.2s;
  }
  .share-btn:hover {
    border-color: var(--gray-400);
    color: var(--gray-900);
    background: white;
  }
  .share-x:hover { color: #000; }
  .share-fb:hover { color: #1877F2; }
  .share-copy:hover { color: var(--court-green); }

  .copy-toast {
    position: absolute;
    left: 170px;
    background: var(--gray-900);
    color: white;
    font-size: 0.75rem;
    padding: 4px 10px;
    border-radius: 4px;
    opacity: 0;
    transform: translateY(4px);
    transition: opacity 0.2s, transform 0.2s;
    pointer-events: none;
  }
  .copy-toast.show {
    opacity: 1;
    transform: translateY(0);
  }

  /* Navigation row */
  .nav-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 16px;
  }

  .back-link {
    color: var(--court-green);
    font-weight: 600;
    font-size: 0.92rem;
    display: flex;
    align-items: center;
    gap: 6px;
    transition: color 0.2s;
  }
  .back-link::before {
    content: '←';
  }
  .back-link:hover { text-decoration: underline; }

  .footer-links {
    display: flex;
    gap: 16px;
    align-items: center;
    flex-wrap: wrap;
  }

  .footer-label {
    font-size: 0.82rem;
    color: var(--gray-500);
    font-weight: 500;
  }

  .footer-link {
    color: var(--gray-600);
    font-size: 0.88rem;
    font-weight: 500;
    transition: color 0.2s;
    padding: 4px 12px;
    border-radius: 20px;
    background: var(--gray-50);
    border: 1px solid var(--gray-200);
  }
  .footer-link:hover {
    color: var(--court-green);
    border-color: var(--court-green);
    background: white;
  }

  @media (max-width: 768px) {
    .nav-row { flex-direction: column; align-items: flex-start; }
    .footer-links { gap: 8px; }
    .footer-link { font-size: 0.82rem; padding: 3px 10px; }
  }
</style>
