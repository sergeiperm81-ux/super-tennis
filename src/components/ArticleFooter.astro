---
/**
 * ArticleFooter — Bottom navigation for article pages
 * Shows share buttons, back link + related section links
 */
interface Props {
  backLabel: string;
  backHref: string;
  relatedLinks?: { label: string; href: string }[];
  shareTitle?: string;
}

const { backLabel, backHref, relatedLinks = [], shareTitle } = Astro.props;

// Default related links if none provided
const defaultLinks = [
  { label: 'Player Profiles', href: '/players/' },
  { label: 'Tennis Records', href: '/records/' },
  { label: 'Rankings', href: '/rankings/' },
  { label: 'Gear Guides', href: '/gear/' },
  { label: 'Tournaments', href: '/tournaments/' },
  { label: 'Head to Head', href: '/vs/' },
];

const links = relatedLinks.length > 0 ? relatedLinks : defaultLinks.filter(l => l.href !== backHref).slice(0, 4);
---

<footer class="article-footer">
  <!-- Share row -->
  <div class="share-row">
    <span class="share-label">Share:</span>
    <button class="share-btn share-x" data-share="x" title="Share on X" aria-label="Share on X">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
    </button>
    <button class="share-btn share-fb" data-share="fb" title="Share on Facebook" aria-label="Share on Facebook">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
    </button>
    <button class="share-btn share-wa" data-share="wa" title="Share on WhatsApp" aria-label="Share on WhatsApp">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
    </button>
    <button class="share-btn share-tg" data-share="tg" title="Share on Telegram" aria-label="Share on Telegram">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M11.944 0A12 12 0 000 12a12 12 0 0012 12 12 12 0 0012-12A12 12 0 0012 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 01.171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.479.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg>
    </button>
    <button class="share-btn share-rd" data-share="rd" title="Share on Reddit" aria-label="Share on Reddit">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm5.943 13.29a1.47 1.47 0 01-.018.221c-.36 2.197-2.792 3.87-5.925 3.87-3.133 0-5.565-1.673-5.925-3.87a1.56 1.56 0 01-.018-.221 1.474 1.474 0 011.186-1.445 5.5 5.5 0 01-.126-.715c0-1.655 2.181-2.998 4.883-2.998s4.883 1.343 4.883 2.998c0 .25-.044.49-.126.715A1.474 1.474 0 0117.943 13.29zM9.5 12.5a1 1 0 100 2 1 1 0 000-2zm5 0a1 1 0 100 2 1 1 0 000-2zm-4.293 3.207a.5.5 0 01.707 0 2.11 2.11 0 001.586.707 2.11 2.11 0 001.586-.707.5.5 0 01.707.707A3.11 3.11 0 0112 17.414a3.11 3.11 0 01-1.793-1 .5.5 0 010-.707zM20 10a1.5 1.5 0 10-2.676.933 7.5 7.5 0 00-3.324-1.708l1.286-3.214 2.928.585a1 1 0 10.078-.996l-3.2-.64a.5.5 0 00-.578.289l-1.5 3.75a7.6 7.6 0 00-1.028.002l-1.5-3.752a.5.5 0 00-.578-.289l-3.2.64a1 1 0 10.078.996l2.928-.585 1.286 3.214A7.5 7.5 0 006.676 10.933 1.5 1.5 0 104 10a1.5 1.5 0 001.125 1.453C5.046 11.637 5 11.815 5 12c0 2.761 3.134 5 7 5s7-2.239 7-5c0-.185-.046-.363-.125-.547A1.5 1.5 0 0020 10z"/></svg>
    </button>
    <button class="share-btn share-li" data-share="li" title="Share on LinkedIn" aria-label="Share on LinkedIn">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
    </button>
    <button class="share-btn share-copy" data-share="copy" title="Copy link" aria-label="Copy link">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
    </button>
    <span class="copy-toast" id="copy-toast">Copied!</span>
  </div>

  <!-- Navigation -->
  <div class="nav-row">
    <a href={backHref} class="back-link">{backLabel}</a>
    <div class="footer-links">
      <span class="footer-label">Explore:</span>
      {links.map(link => (
        <a href={link.href} class="footer-link">{link.label}</a>
      ))}
    </div>
  </div>
</footer>

<script>
  const footer = document.querySelector('.article-footer');
  if (footer) {
    const title = document.querySelector('h1')?.textContent || document.title;
    const url = window.location.href;

    footer.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest('[data-share]') as HTMLElement;
      if (!btn) return;
      const type = btn.dataset.share;
      if (type === 'x') {
        window.open(`https://x.com/intent/tweet?text=${encodeURIComponent(title)}&url=${encodeURIComponent(url)}`, '_blank', 'width=550,height=420');
      } else if (type === 'fb') {
        window.open(`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(url)}`, '_blank', 'width=550,height=420');
      } else if (type === 'wa') {
        window.open(`https://wa.me/?text=${encodeURIComponent(title + ' ' + url)}`, '_blank');
      } else if (type === 'tg') {
        window.open(`https://t.me/share/url?url=${encodeURIComponent(url)}&text=${encodeURIComponent(title)}`, '_blank', 'width=550,height=420');
      } else if (type === 'rd') {
        window.open(`https://www.reddit.com/submit?url=${encodeURIComponent(url)}&title=${encodeURIComponent(title)}`, '_blank', 'width=550,height=420');
      } else if (type === 'li') {
        window.open(`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(url)}`, '_blank', 'width=550,height=420');
      } else if (type === 'copy') {
        navigator.clipboard.writeText(url).then(() => {
          const toast = document.getElementById('copy-toast');
          if (toast) {
            toast.classList.add('show');
            setTimeout(() => toast.classList.remove('show'), 1500);
          }
        });
      }
    });
  }
</script>

<style>
  .article-footer {
    margin-top: 48px;
    padding-top: 24px;
    border-top: 2px solid var(--gray-200);
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  /* Share row */
  .share-row {
    display: flex;
    align-items: center;
    gap: 8px;
    position: relative;
  }
  .share-label {
    font-size: 0.82rem;
    color: var(--gray-500);
    font-weight: 500;
    margin-right: 4px;
  }
  .share-btn {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--gray-600);
    background: var(--gray-50);
    border: 1px solid var(--gray-200);
    transition: all 0.2s;
  }
  .share-btn:hover {
    border-color: var(--gray-400);
    color: var(--gray-900);
    background: white;
  }
  .share-x:hover { color: #000; }
  .share-fb:hover { color: #1877F2; }
  .share-wa:hover { color: #25d366; }
  .share-tg:hover { color: #0088cc; }
  .share-rd:hover { color: #ff4500; }
  .share-li:hover { color: #0077b5; }
  .share-copy:hover { color: var(--court-green); }

  .copy-toast {
    position: absolute;
    left: 170px;
    background: var(--gray-900);
    color: white;
    font-size: 0.75rem;
    padding: 4px 10px;
    border-radius: 4px;
    opacity: 0;
    transform: translateY(4px);
    transition: opacity 0.2s, transform 0.2s;
    pointer-events: none;
  }
  .copy-toast.show {
    opacity: 1;
    transform: translateY(0);
  }

  /* Navigation row */
  .nav-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 16px;
  }

  .back-link {
    color: var(--court-green);
    font-weight: 600;
    font-size: 0.92rem;
    display: flex;
    align-items: center;
    gap: 6px;
    transition: color 0.2s;
  }
  .back-link::before {
    content: '←';
  }
  .back-link:hover { text-decoration: underline; }

  .footer-links {
    display: flex;
    gap: 16px;
    align-items: center;
    flex-wrap: wrap;
  }

  .footer-label {
    font-size: 0.82rem;
    color: var(--gray-500);
    font-weight: 500;
  }

  .footer-link {
    color: var(--gray-600);
    font-size: 0.88rem;
    font-weight: 500;
    transition: color 0.2s;
    padding: 4px 12px;
    border-radius: 20px;
    background: var(--gray-50);
    border: 1px solid var(--gray-200);
  }
  .footer-link:hover {
    color: var(--court-green);
    border-color: var(--court-green);
    background: white;
  }

  @media (max-width: 768px) {
    .nav-row { flex-direction: column; align-items: flex-start; }
    .footer-links { gap: 8px; }
    .footer-link { font-size: 0.82rem; padding: 3px 10px; }
  }
</style>
