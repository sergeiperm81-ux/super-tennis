# --- Edge caching (added 2026-04-16 after audit: cf-cache-status was DYNAMIC for all static HTML/images) ---
# Content assets — long-lived, safe to cache a year. Images only change via
# new filenames (filename collision protection via validate-photos.mjs),
# so we can treat them as effectively immutable.
/images/*
  Cache-Control: public, max-age=31536000, immutable

# Fonts
/fonts/*
  Cache-Control: public, max-age=31536000, immutable

# Open-Graph social preview images
/og/*
  Cache-Control: public, max-age=604800

# HTML: use shared (CDN) cache for 1h with stale-while-revalidate for 24h.
# The site is SSG and deploy triggers a full rebuild, which invalidates
# Cloudflare Pages cache on push, so users on old HTML see new content
# within 1h even without manual purge. Browser cache stays weak.
/*.html
  Cache-Control: public, max-age=0, s-maxage=3600, stale-while-revalidate=86400
